\ ******************************************************************************
\ ******************************************************************************
\ * Landscape / terrain system
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: landscape_draw
\ * Description: Redraws the cave walls on every other pixel row using a
\ *              delta-XOR scheme — only the columns whose wall position
\ *              changed since last frame are touched.
\ *
\ * Cave structure: each visible scanline has a "left wall" (right edge of the
\ * solid fill on the left side of the screen) and a "right wall" (left edge
\ * of the solid fill on the right). Those edges move a little each frame as
\ * the world scrolls horizontally.
\ *
\ * Wall arrays (indexed by Y-scanline, updated by update_window_and_terrain_tables):
\ *     terrain_left_wall[Y]  = left-wall world X for scanline Y
\ *     terrain_right_wall[Y] = right-wall world X for scanline Y
\ *
\ * Cached last-frame screen positions (one byte per visible scanline):
\ *     terrain_draw_table_2[t] = left-wall screen X drawn on last frame
\ *     terrain_draw_table_4[t] = right-wall screen X drawn on last frame
\ *
\ * Per-scanline algorithm for each wall:
\ *   1. Fetch wall[Y] and convert to screen-X by subtracting window_xpos.
\ *      (Done via the self-mod SBC trick described below.)
\ *   2. Clamp the screen-X to [0, SCREEN_WIDTH_CHARS].
\ *   3. delta = new_screen_X - cached_screen_X.
\ *         delta > 0 (wall moved right): XOR-fill delta columns starting
\ *                                       from the OLD cached position, which
\ *                                       flips previously-filled cells off.
\ *         delta < 0 (wall moved left) : XOR-fill |delta| columns starting
\ *                                       from the NEW position, which flips
\ *                                       newly-needed cells on.
\ *         delta = 0 (unchanged)       : nothing to draw.
\ *   4. Update the cache with the new screen-X for next frame.
\ *
\ * draw_terrain (line 1281) does the actual EOR row draw. It requires carry
\ * clear on entry — every path reaching it arrives with C=0.
\ *
\ * Self-mod SBC trick (sbc_window_xpos_{1,2}): the immediate operand is
\ * patched to (window_xpos_INT - 1) at setup. The loop enters the first SBC
\ * with carry clear (explicit CLC before the loop), so:
\ *     A - (window_xpos-1) - (1 - 0)   =   A - window_xpos
\ * This saves a SEC per iteration. The second SBC relies on draw_terrain and
\ * the intervening code leaving C=0 — which they do on every reachable path.
\ *
\ * Scanline stepping: terrain_draw_addr_LO advances by 2 every iteration
\ * (every other pixel row). When that crosses a character-cell boundary
\ * (low nibble == 0 mod 8), add SCREEN_CHAR_ROW_BYTES-8 to jump down a char
\ * row. Loop exits when terrain_draw_addr_HI goes negative (past screen end).
\ ******************************************************************************

.landscape_draw
\\ {

\ --- Setup: clear cache cursor, seed wall/screen cursors, patch SBC operand ---
        LDA     #$00
        STA     terrain_draw_table_index            ; cursor into cached-X tables (per scanline)

        LDA     #$49                                ; $49 = 73 visible half-res scanlines
        CLC
        ADC     terrain_window_y_index
        STA     terrain_draw_wall_index             ; cursor into wall arrays (starts at top of window)

        LDA     #$02                                ; begin at screen pixel row 2
        STA     terrain_draw_addr_LO

        LDA     #HI(SCREEN_START_ADDR)
        STA     terrain_draw_addr_HI

        LDX     window_xpos_INT                     ; patch SBC operand = window_xpos - 1
        DEX                                         ;   so SBC with C=0 performs A - window_xpos
        STX     window_xpos_2                        ; **MODIFIES CODE**
        STX     window_xpos_1                        ; **MODIFIES CODE**

        CLC                                         ; prime carry for first SBC below

    .landscape_draw_loop

\ --- LEFT WALL: fetch, convert world X -> screen X, clamp ---
        LDY     terrain_draw_wall_index
        LDA     terrain_left_wall,Y

    .sbc_window_xpos_1
        SBC     #$00                                ; **SELF-MODIFIED** operand = window_xpos-1
        window_xpos_1   = sbc_window_xpos_1+1       ; with C=0 on entry: A = wall - window_xpos
        BCS     terrain_xpos_1_greater_than_zero    ; borrow (wall left of window) → clamp to 0

        LDA     #$00
        JMP     terrain_xpos_1_less_than_screen_width

    .terrain_xpos_1_greater_than_zero
        CMP     #SCREEN_WIDTH_CHARS
        BCC     terrain_xpos_1_less_than_screen_width

        LDA     #SCREEN_WIDTH_CHARS                 ; clamp to right edge of playfield

    .terrain_xpos_1_less_than_screen_width
        STA     terrain_xpos_1_clipped

\ --- LEFT WALL: delta vs cached last-frame screen X ---
        LDY     terrain_draw_table_index
        SEC
        SBC     terrain_draw_table_2,Y              ; A = new_screen_X - cached_screen_X
        BCS     terrain_width_1_greater_than_zero   ; C=1 → new >= cached (moved right / same)

\ --- LEFT WALL: delta < 0, wall moved LEFT — XOR-fill |delta| cols from NEW pos ---
        EOR     #$FF                                ; negate two's complement: A = |delta| - 1
        TAX
        INX                                         ; X = |delta|  (column count)

        LDA     terrain_xpos_1_clipped
        STA     terrain_draw_table_2,Y              ; update cache with new screen X
        TAY                                         ; Y = new screen X (draw start column)

        JMP     draw_terrain_xpos_1                 ; C=0 preserved from BCC above

    .terrain_width_1_greater_than_zero
        CLC                                         ; prepare C=0 for draw_terrain / next SBC
        BEQ     landscape_draw_part_2               ; delta == 0 → nothing to do

\ --- LEFT WALL: delta > 0, wall moved RIGHT — XOR-fill delta cols from OLD pos ---
        TAX                                         ; X = delta (column count)
        LDA     terrain_draw_table_2,Y
        STA     terrain_draw_start_x                ; old screen X (draw start column)
        LDA     terrain_xpos_1_clipped
        STA     terrain_draw_table_2,Y              ; update cache with new screen X
        LDY     terrain_draw_start_x

    .draw_terrain_xpos_1
        JSR     draw_terrain                        ; XOR X columns starting at col Y on this scanline

\ --- RIGHT WALL: fetch, convert world X -> screen X, clamp ---
    .landscape_draw_part_2
        LDY     terrain_draw_wall_index
        LDA     terrain_right_wall,Y

    .sbc_window_xpos_2
        SBC     #$00                                ; **SELF-MODIFIED** (same operand as above)
        window_xpos_2   = sbc_window_xpos_2+1       ; C=0 guaranteed by all reaching paths
        BCS     terrain_xpos_2_greater_than_zero

        LDA     #$00
        JMP     terrain_xpos_2_less_than_screen_width

    .terrain_xpos_2_greater_than_zero
        CMP     #SCREEN_WIDTH_CHARS
        BCC     terrain_xpos_2_less_than_screen_width

        LDA     #SCREEN_WIDTH_CHARS

    .terrain_xpos_2_less_than_screen_width
        STA     terrain_xpos_2_clipped

\ --- RIGHT WALL: delta vs cached last-frame screen X ---
        LDY     terrain_draw_table_index
        SEC
        SBC     terrain_draw_table_4,Y
        BCS     terrain_width_2_greater_than_zero

\ --- RIGHT WALL: delta < 0, wall moved LEFT — XOR-fill |delta| cols from NEW pos ---
        EOR     #$FF
        TAX
        INX

        LDA     terrain_xpos_2_clipped
        STA     terrain_draw_table_4,Y
        TAY

        JMP     draw_terrain_xpos_2

    .terrain_width_2_greater_than_zero
        CLC
        BEQ     landscape_increment_index           ; delta == 0 → nothing to do

\ --- RIGHT WALL: delta > 0, wall moved RIGHT — XOR-fill delta cols from OLD pos ---
        TAX
        LDA     terrain_draw_table_4,Y
        STA     terrain_draw_start_x
        LDA     terrain_xpos_2_clipped
        STA     terrain_draw_table_4,Y
        LDY     terrain_draw_start_x

    .draw_terrain_xpos_2
        JSR     draw_terrain

\ --- Advance per-scanline cursors ---
    .landscape_increment_index
        INC     terrain_draw_wall_index
        INC     terrain_draw_table_index

\ --- Advance screen address: +2 pixel rows, wrap into next char row every 8 ---
.landscape_increment_draw_addr
        LDA     terrain_draw_addr_LO
        ADC     #$02                                ; two pixel rows (we draw every other row)
        STA     terrain_draw_addr_LO
        AND     #$07                                ; crossed char-cell boundary?
        BEQ     landscape_draw_next_character_row

        JMP     landscape_draw_loop

    .landscape_draw_next_character_row
        LDA     terrain_draw_addr_LO
        ADC     #LO(SCREEN_CHAR_ROW_BYTES - 8)
        STA     terrain_draw_addr_LO
        LDA     terrain_draw_addr_HI
        ADC     #HI(SCREEN_CHAR_ROW_BYTES - 8)      ; jump down one character row
        STA     terrain_draw_addr_HI
        BMI     landscape_draw_return               ; wrapped past top of memory → done

        JMP     landscape_draw_loop

    .landscape_draw_return
        RTS
\\ }

\ ******************************************************************************
\ * Function: initialise_landscape
\ * Description: Initialises landscape wall state and processes terrain to current Y position 
\ ******************************************************************************
        
.initialise_landscape
{
        LDX     #$01
        STX     terrain_left_wall_2_index
        STX     terrain_right_wall_2_index
        DEX
        STX     terrain_window_y_index
        STX     terrain_left_wall_1_xpos
        STX     terrain_left_wall_2_xpos
        STX     terrain_left_wall_1_index
        STX     terrain_right_wall_1_index
        DEX
        STX     terrain_left_wall_1_counter
        STX     terrain_right_wall_1_counter
        STX     terrain_right_wall_1_xpos
        STX     terrain_right_wall_2_xpos
        STX     terrain_left_wall_2_counter
        STX     terrain_right_wall_2_counter

        LDA     window_ypos_INT
        STA     terrain_y_count_inner
        LDA     window_ypos_EXT
        STA     terrain_y_count_outer
        INC     terrain_y_count_inner
        INC     terrain_y_count_outer
        INC     terrain_y_count_outer
        BNE     terrain_y_count_outer_not_zero

    .initialise_landscape_loop        ; $C37
        JSR     terrain_process_accumulate_xpos    

    .terrain_y_count_outer_not_zero
        DEC     terrain_y_count_inner
        BNE     initialise_landscape_loop

        DEC     terrain_y_count_outer
        BNE     initialise_landscape_loop

        RTS
}

\ ******************************************************************************
\ * Functions: terrain_process_subtract_xpos, terrain_process_accumulate_xpos
\ * Description: updates all triples, terrain_left_wall & terrain_right_wall
\ ******************************************************************************

.terrain_call_process_fn
        JMP     terrain_call_process_fn_JMP_LO                    ; **SELF-MODIFIED CODE **
        terrain_call_process_fn_JMP_LO   = terrain_call_process_fn+1
        terrain_call_process_fn_JMP_HI   = terrain_call_process_fn+2

.terrain_process_subtract_xpos
{
        LDA     #LO(terrain_subtract_xpos_fn)
        STA     terrain_call_process_fn_JMP_LO                    ; **MODIFIES CODE**
        LDA     #HI(terrain_subtract_xpos_fn)
        STA     terrain_call_process_fn_JMP_HI                    ; **MODIFIES CODE**
        DEC     terrain_window_y_index
        JSR     terrain_process
        RTS
}

.terrain_process_accumulate_xpos
{
        LDA     #LO(terrain_accumulate_xpos_fn)
        STA     terrain_call_process_fn_JMP_LO                    ; **MODIFIES CODE**
        LDA     #HI(terrain_accumulate_xpos_fn)
        STA     terrain_call_process_fn_JMP_HI                    ; **MODIFIES CODE**
        INC     terrain_window_y_index
}
\\ Fall through!

.terrain_process
{
\\ Set pointers to data tables A & B
        LDA     terrain_left_wall_counter_LO
        STA     terrain_data_count_ptr
        LDA     terrain_left_wall_counter_HI
        STA     terrain_data_count_ptr+1
        LDA     terrain_left_wall_increment_LO
        STA     terrain_data_x_increment_ptr
        LDA     terrain_left_wall_increment_HI
        STA     terrain_data_x_increment_ptr+1

\\ Load first triple
        LDA     terrain_left_wall_1_xpos
        LDX     terrain_left_wall_1_counter
        LDY     terrain_left_wall_1_index
\\ Process triple
        JSR     terrain_call_process_fn
\\ Store returned values
        STY     terrain_left_wall_1_index
        STX     terrain_left_wall_1_counter

        LDY     terrain_window_y_index
        STA     terrain_left_wall,Y
        STA     terrain_left_wall_1_xpos

\\ Load second triple
        LDA     terrain_left_wall_2_xpos
        LDX     terrain_left_wall_2_counter
        LDY     terrain_left_wall_2_index
\\ Process triple
        JSR     terrain_call_process_fn
\\ Store returned values
        STY     terrain_left_wall_2_index
        STX     terrain_left_wall_2_counter

        LDY     terrain_window_y_index
        DEY
        STA     terrain_left_wall,Y
        STA     terrain_left_wall_2_xpos

\\ Set pointers to data tables C & D
        LDA     terrain_right_wall_counter_LO
        STA     terrain_data_count_ptr
        LDA     terrain_right_wall_counter_HI
        STA     terrain_data_count_ptr+1
        LDA     terrain_right_wall_increment_LO
        STA     terrain_data_x_increment_ptr
        LDA     terrain_right_wall_increment_HI
        STA     terrain_data_x_increment_ptr+1

\\ Load third triple
        LDA     terrain_right_wall_1_xpos
        LDX     terrain_right_wall_1_counter
        LDY     terrain_right_wall_1_index
\\ Process triple
        JSR     terrain_call_process_fn
\\ Store returned values
        STY     terrain_right_wall_1_index
        STX     terrain_right_wall_1_counter
        LDY     terrain_window_y_index
        STA     terrain_right_wall,Y
        STA     terrain_right_wall_1_xpos

\\ Load fourth triple
        LDA     terrain_right_wall_2_xpos
        LDX     terrain_right_wall_2_counter
        LDY     terrain_right_wall_2_index
\\ Process triple
        JSR     terrain_call_process_fn
\\ Store returned values
        STY     terrain_right_wall_2_index
        STX     terrain_right_wall_2_counter
        LDY     terrain_window_y_index
        DEY
        STA     terrain_right_wall,Y
        STA     terrain_right_wall_2_xpos
        RTS
}

\ ******************************************************************************
\ * Terrain variables
\ ******************************************************************************

.terrain_window_y_index            ; $CfB
        EQUB    $00

.terrain_left_wall_1_xpos
        EQUB    $00

.terrain_left_wall_1_counter
        EQUB    $00

.terrain_left_wall_1_index
        EQUB    $00

.terrain_left_wall_2_xpos
        EQUB    $00

.terrain_left_wall_2_counter
        EQUB    $00

.terrain_left_wall_2_index
        EQUB    $00

.terrain_right_wall_1_xpos
        EQUB    $00

.terrain_right_wall_1_counter
        EQUB    $00

.terrain_right_wall_1_index
        EQUB    $00

.terrain_right_wall_2_xpos
        EQUB    $00

.terrain_right_wall_2_counter
        EQUB    $00

.terrain_right_wall_2_index
        EQUB    $00

.terrain_left_wall_counter_LO
        EQUB    $00

.terrain_left_wall_counter_HI
        EQUB    $00

.terrain_left_wall_increment_LO
        EQUB    $00

.terrain_left_wall_increment_HI
        EQUB    $00

.terrain_right_wall_counter_LO
        EQUB    $00

.terrain_right_wall_counter_HI
        EQUB    $00

.terrain_right_wall_increment_LO
        EQUB    $00

.terrain_right_wall_increment_HI
        EQUB    $00

\ ******************************************************************************
\ * Functions: terrain_accumulate_xpos_fn, terrain_subtract_xpos_fn
\ * Params: X = counter, Y = index into terrain data, A = accumulated x position
\ * Returns: X = updated counter, A = accumulated x position
\ * Description: Accumulates/subtracts terrain X offset using counted run-length data 
\ ******************************************************************************
        
.terrain_accumulate_xpos_fn
{
        CPX        #$00
        BNE        terrain_accumulate_xpos_fn_counter_not_zero
        INY                                            ; incremenet index into table
        PHA                                            ; keep accumlator
        LDA        (terrain_data_count_ptr),Y            ; read new count value from table
        TAX                                            ; store new counter
        PLA                                            ; restore accumulated x
        
    .terrain_accumulate_xpos_fn_counter_not_zero
        CLC
        ADC        (terrain_data_x_increment_ptr),Y    ; add x increment to accumulated x from table
        DEX                                            ; decrement counter
        RTS
}
        
.terrain_subtract_xpos_fn
{
        INX
        SEC
        SBC        (terrain_data_x_increment_ptr),Y
        PHA
        LDA        (terrain_data_count_ptr),Y
        STA        terrain_y_count_inner
        CPX        terrain_y_count_inner
        BNE        terrain_subtract_xpos_fn_counter_not_zero
        DEY
        LDX        #$00
        
    .terrain_subtract_xpos_fn_counter_not_zero
        PLA
        RTS
}

\ ******************************************************************************
\ * Function: draw_terrain
\ * Params: Y = start column, X = width to draw in columns
\ * Returns: none
\ * Description: Draws a horizontal terrain line across columns using EOR plotting 
\ ******************************************************************************

IF _UNROLL_TERRAIN==FALSE
.draw_terrain
{
        LDA     mult_by_8_LO,Y
        STA     terrain_draw_ptr

        LDA     mult_by_8_HI,Y
        ADC     terrain_draw_addr_HI
        STA     terrain_draw_ptr+1
        
        LDY     terrain_draw_addr_LO
        LDA     #LANDSCAPE_COLOUR_BYTE                        ; solid line colour 2
        EOR     (terrain_draw_ptr),Y
        STA     (terrain_draw_ptr),Y
        DEX
        BEQ     draw_terrain_return

    .draw_terrain_loop
        TYA
        ADC     #$08                        ; next column
        TAY
        BCC     inc_terrain_draw_ptr_no_carry

        CLC
        INC     terrain_draw_ptr+1
        
    .inc_terrain_draw_ptr_no_carry
        LDA     #LANDSCAPE_COLOUR_BYTE                        ; solid line colour 2
        EOR     (terrain_draw_ptr),Y
        STA     (terrain_draw_ptr),Y
        DEX
        BNE     draw_terrain_loop

    .draw_terrain_return
        RTS
}
ENDIF

\ ******************************************************************************
\ ******************************************************************************
\ * Level object system
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Object tables per object type
\ ******************************************************************************

.obj_tractor_counter    ; indexed by current_object, initialised to 0 at start of level, counts up when tractor beam active
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00,$00
IF _SWRAM_BUILD
        \ extend to LEVEL_MAX_OBJECTS+1 entries so a fuel object at any
        \ level slot can safely INC obj_tractor_counter,X without overrun
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
ENDIF

.obj_type_width
        EQUB    $05,$05,$05,$05,$04,$05,$05,$02,$02
IF _TIMED_LASER
        EQUB    $05,$05,$05,$05                  ; [9..C] laser_turret orientations
ENDIF
IF _GRAVITY_WELL
        EQUB    $04                              ; [D] gravity_well (small AABB; non-collidable)
ENDIF
IF _BOBBING_MINES
        EQUB    $03                              ; [E] bobbing_mine (12 px wide)
        EQUB    $03                              ; [F] bobbing_mine_horizontal
ENDIF
IF _TELEPORTER
        EQUB    $03                              ; [10] teleporter (placeholder)
ENDIF

.obj_type_height
        EQUB    $08,$08,$08,$08,$0A,$08,$0A,$08,$08
IF _TIMED_LASER
        EQUB    $08,$08,$08,$08                  ; [9..C] laser_turret orientations
ENDIF
IF _GRAVITY_WELL
        EQUB    $04                              ; [D] gravity_well
ENDIF
IF _BOBBING_MINES
        EQUB    $0C                              ; [E] bobbing_mine (12 rows tall)
        EQUB    $0C                              ; [F] bobbing_mine_horizontal
ENDIF
IF _TELEPORTER
        EQUB    $08                              ; [10] teleporter (placeholder)
ENDIF

.obj_type_explosion_particle
        EQUB    $02,$02,$02,$02,$01                ; only guns and fuel can be destroyed
IF _TIMED_LASER
        EQUB    $00,$00,$00,$00                  ; pad [5..8] (not destructible)
        EQUB    $02,$02,$02,$02                  ; [9..C] laser_turret orientations
ENDIF
IF _GRAVITY_WELL
        EQUB    $00                              ; [D] gravity_well (not destructible)
ENDIF
IF _BOBBING_MINES
        EQUB    $02                              ; [E] bobbing_mine (destructible by bullets)
        EQUB    $02                              ; [F] bobbing_mine_horizontal
ENDIF
IF _TELEPORTER
        EQUB    $00                              ; [10] teleporter (not destructible)
ENDIF

.obj_type_score_value                            ; only guns and fuel can be destroyed
        EQUB    $75,$75,$75,$75,$15
IF _TIMED_LASER
        EQUB    $00,$00,$00,$00                  ; pad [5..8]
        EQUB    $A0,$A0,$A0,$A0                  ; [9..C] laser_turret orientations
ENDIF
IF _GRAVITY_WELL
        EQUB    $00                              ; [D] gravity_well
ENDIF
IF _BOBBING_MINES
        EQUB    $50                              ; [E] bobbing_mine
        EQUB    $50                              ; [F] bobbing_mine_horizontal
ENDIF
IF _TELEPORTER
        EQUB    $00                              ; [10] teleporter
ENDIF

\ ******************************************************************************
\ * Function: end_of_objects_function
\ * Description: Processing that happens once all objects have been updated
\ ******************************************************************************

.end_of_objects_function
{
IF _TIMED_LASER
        JSR     update_all_laser_beams              ; erase / re-draw timed laser beams
ENDIF
IF _TELEPORTER
        JSR     teleporter_dispatch_pending         ; consume any latched warp request
ENDIF
        LDA     score_accumulation
        BEQ     skip_add_score

        JSR     add_A_to_score

    .skip_add_score
        JSR     update_pod_tractor_beam

        LDA     level_tick_counter
        AND     #$01
        BNE     skip_dec_generator

        LDA     generator_recharge_counter
        BEQ     skip_dec_generator

        DEC     generator_recharge_counter

    .skip_dec_generator
        DEC     countdown_timer_ticks
        BPL     return

        LDA     #$20
        STA     countdown_timer_ticks
        
        LDA     planet_countdown_timer
        BMI     return

        BEQ     skip_countdown_sound

        \\ Planet countdown timer sound
        
        DEC     planet_countdown_timer
        LDX     #LO(sound_params_collect_1)
        JSR     make_sound

    .skip_countdown_sound
    
        \\ Plot countdown timer on screen
    
        LDA     #$FF
        STA     font_byte_mask
        LDA     planet_countdown_timer
        CLC
        ADC     #ASCII_0                    ; ASCII '0'
        JSR     write_countdown_timer

        LDA     #$0F
        STA     font_byte_mask
        LDA     planet_countdown_timer
        BNE     return

        LDA     #$01
        STA     plot_ship_collision_detected
        LDA     #$FF
        STA     pod_lifted_flag
    
    .return
        RTS
}

.end_of_obj_type_table
{
        JMP     end_of_objects_function
}

\ ******************************************************************************
\ * Function: write_countdown_timer
\ * Params: A = ASCII of number to plot
\ * Returns: none
\ * Description: Writes a countdown timer digit to two screen locations
\ ******************************************************************************

.write_countdown_timer
{
        LDX     #$69
        LDY     #$3F
        JSR     plot_char_set_scr_addr_XY
        JSR     plot_char_A

        LDX     #$39
        LDY     #$40
        JSR     plot_char_set_scr_addr_XY
        JSR     plot_char_A

        RTS
}

\ ******************************************************************************
\ * Function: accumulate_score_A
\ * Params: A = score value
\ * Returns: A = accumulated score
\ * Description: Adds score value in A to the running score accumulator
\ ******************************************************************************

.accumulate_score_A
{
        CLC
        ADC     score_accumulation
        STA     score_accumulation
        RTS
}

\ ******************************************************************************
\ * Function: update_and_draw_all_objects
\ * Description: Per-frame tick + redraw for every object in the current level.
\ *
\ * Object types (see OBJECT_* constants near thrust.6502:102):
\ *     $00..$03  gun_up_right / up_left / down_right / down_left  (hostile guns)
\ *     $04       fuel            (shield-tractor pickup)
\ *     $05       pod_stand       (pod holder; touching ends the level)
\ *     $06       generator       (shield-tractor destroyable; starts planet timer)
\ *     $07..$08  door_switch_right / door_switch_left
\ *     $09..$0C  laser_turret  (SWRAM build only — timed beam emitter, 4 orientations)
\ *
\ * Per-object loop, repeated until level_N_obj_type[X] == $FF:
\ *   1. Unpack gun_aim byte into base angle + spread mask.
\ *   2. Pod_stand / generator per-frame ALIVE-flag updates (pod-lifted clears
\ *      ALIVE; generator blinks while the planet countdown runs).
\ *   3. Select sprite for this type; run visibility cull; if the on-screen
\ *      position is unchanged from last frame and the object is still alive,
\ *      skip redraw entirely (dirty-rect optimisation).
\ *   4. Erase old sprite at previous on-screen position for moved objects.
\ *   5. If not ALIVE any more, advance to next object.
\ *   6. Pod_stand vs player collision + planet-countdown-expired trigger.
\ *   7. Test all 4 player bullets against this object's hitbox. Per-type hit
\ *      dispatch: door_switches latch open, generator recharges/destroys and
\ *      arms the planet timer, guns / fuel / laser_turret are destroyed
\ *      outright, pod_stand and anything above are inert to bullets.
\ *   8. Shield-tractor fuel pickup (fuel type only, when shield pressed).
\ *   9. Hostile gun fire (gun types $00..$03).
\ *  10. Generator debris particle emission (every 8 ticks, generator only).
\ *  11. Plot sprite at new on-screen position and cache it for next frame.
\ *
\ * Flags on level_obj_flags,X (see banner above .level_obj_flags for layout):
\ *     OBJ_flag_drawn (bit 0): sprite was XOR-plotted last frame (needs erase)
\ *     OBJ_flag_alive (bit 1): clear → skip draw + collisions + behaviour
\ ******************************************************************************

.update_and_draw_all_objects
\\ {
        LDX     #$00
        STX     collecting_fuel_flag
        STX     score_accumulation

    .update_objects_loop
        STX     current_object

    .load_object_type
        LDA     level_0_obj_type,X                    ; **SELF-MODIFIED CODE**
        level_obj_type_addr_LO   = load_object_type+1
        level_obj_type_addr_HI   = load_object_type+2

        CMP     #$FF
        BEQ     end_of_obj_type_table

        STA     object_type

\ --- 1. Unpack gun_aim byte: bits 2..4 = base angle (shifted), bits 0..1 = spread ---
    .load_gun_aim
        LDA     level_0_obj_data_0,X                 ; **SELF-MODIFIED CODE** (slot 0 = gun_aim)
        level_gun_aim_addr_LO   = load_gun_aim+1
        level_gun_aim_addr_HI   = load_gun_aim+2
{
IF _GRAVITY_WELL
        \\ Gravity wells are invisible field objects: no sprite, no collision,
        \\ no per-object dispatch. The pull on the ship is computed in
        \\ apply_gravity_wells_to_force; visualisation is by debris particles
        \\ spawned elsewhere. Skip the entire update body.
        LDY     object_type
        CPY     #OBJECT_gravity_well
        BNE     not_gravity_well
        JMP     next_object
    .not_gravity_well
ENDIF
IF _BOBBING_MINES
        \\ Mines: animate Y (or X for the horizontal variant) by writing the
        \\ new displayed position into level_obj_pos_* before
        \\ object_visibility_test loads it. obj_data slot 2 carries the
        \\ previous frame's signed offset so each frame can apply
        \\ (new_offset - prev_offset) as a delta.
        LDY     object_type
        CPY     #OBJECT_bobbing_mine
        BNE     not_bobbing_mine
        JSR     update_bobbing_mine
        JMP     mine_update_done
    .not_bobbing_mine
        CPY     #OBJECT_bobbing_mine_horizontal
        BNE     mine_update_done
        JSR     update_bobbing_mine_horizontal
    .mine_update_done
ENDIF
IF _TELEPORTER
        \\ Teleporter pads: no sprite plot (placeholder pixels would trigger
        \\ ship-vs-pixel collisions). emit_debris populates well_obj_*_save with
        \\ the pad's world position; the ship-contact AABB then reads from
        \\ those slots. Latched pending warps fire at end of frame.
        LDY     object_type
        CPY     #OBJECT_teleporter
        BNE     not_teleporter
        JSR     teleporter_emit_debris
        JSR     teleporter_check_ship_contact
        JMP     next_object
    .not_teleporter
ENDIF
IF _SWITCHES
        \\ Doors carve terrain in their own per-frame tick (tick_doors).
        \\ Skip the main update body so the door isn't sprite-plotted (no
        \\ visible sprite) and isn't bullet-collidable (can't be shot).
        LDY     object_type
        CPY     #OBJECT_door
        BNE     not_door
        JMP     next_object
    .not_door
ENDIF
        PHA
        AND     #$1C
        STA     gun_base_angle
        PLA
        AND     #$03
        TAY
        LDA     gun_spread_mask_table,Y
        STA     gun_angle_spread_mask
        LDY     object_type

\ --- 2a. pod_stand: set ALIVE while on the stand; clear once pod has been lifted ---
        CPY     #OBJECT_pod_stand
        BNE     check_generator_blink

        LDA     level_obj_flags,X
        ORA     #OBJ_flag_alive
        STA     level_obj_flags,X
        LDA     pod_lifted_flag
        BEQ     check_generator_blink

        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X

\ --- 2b. generator: blink ALIVE bit on/off while planet countdown is active ---
    .check_generator_blink
        CPY     #OBJECT_generator
        BNE     load_sprite_pointers

        LDA     planet_countdown_timer
        BMI     load_sprite_pointers            ; countdown not armed yet ($FF)

        BEQ     load_sprite_pointers            ; countdown expired

        LDA     countdown_timer_ticks
        AND     #$04
        BNE     generator_blink_off

        LDA     level_obj_flags,X               ; on-phase: set ALIVE
        ORA     #OBJ_flag_alive
        STA     level_obj_flags,X
        JMP     load_sprite_pointers

    .generator_blink_off
        LDA     level_obj_flags,X               ; off-phase: clear ALIVE
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X

\ --- 3. Load this type's sprite A/B pointers via self-mod inside plot_static_sprite ---
    .load_sprite_pointers
        LDA     obj_sprite_data_A_table_LO,Y
        STA     sprite_data_A_ptr_LO                ; **MODIFIES CODE**
        LDA     obj_sprite_data_A_table_HI,Y
        STA     sprite_data_A_ptr_HI                ; **MODIFIES CODE**
        LDA     obj_sprite_data_B_table_LO,Y
        STA     sprite_data_B_ptr_LO                ; **MODIFIES CODE**
        LDA     obj_sprite_data_B_table_HI,Y
        STA     sprite_data_B_ptr_HI                ; **MODIFIES CODE**
        LDA     #$00
        STA     update_objects_flag
        STA     obj_plot_sprite_at_ptr+1
        LDA     level_obj_flags,X
        ROR     A                                   ; shift OBJ_flag_drawn (bit 0) into C
        BCC     test_alive_flag                     ; not drawn last frame → nothing to erase

        JSR     object_visibility_test              ; was drawn: recompute new plot pos

\ --- Dirty-rect check: if new plot ptr == cached ptr AND still alive, skip redraw ---
        LDX     current_object
        LDA     obj_plot_sprite_at_ptr+1
        BEQ     erase_old_sprite                    ; culled this frame → erase old

        CMP     level_obj_plot_at_ptr_HI,X
        BNE     erase_old_sprite                    ; moved cell → erase old

        LDA     obj_plot_sprite_at_ptr
        CMP     level_obj_plot_at_ptr_LO,X
        BNE     erase_old_sprite

        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BEQ     erase_old_sprite                    ; died → erase old

        LDA     #$FF                                ; unchanged → mark "no redraw"
        STA     update_objects_flag
        JMP     check_planet_explode_trigger

\ --- 4. Erase sprite at previous on-screen position and clear moved-bit ---
    .erase_old_sprite
        LDA     level_obj_plot_at_ptr_HI,X
        STA     plot_sprite_at_ptr+1
        LDA     level_obj_plot_at_ptr_LO,X
        STA     plot_sprite_at_ptr
        JSR     plot_static_sprite                  ; XOR-erase at old cell

        LDX     current_object
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_drawn)           ; no longer on screen after XOR-erase
        STA     level_obj_flags,X

\ --- 5. If ALIVE bit is clear, skip the rest of the per-object work ---
    .test_alive_flag
        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BNE     compute_visibility_if_needed

        JMP     next_object

    .compute_visibility_if_needed
        LDA     obj_plot_sprite_at_ptr+1
        BNE     check_planet_explode_trigger

        JSR     object_visibility_test              ; alive but not yet culled

\ --- 6. Planet-explode trigger: fires when countdown hits zero for any non-pod object ---
    .check_planet_explode_trigger
IF _BOBBING_MINES
\ Mine ship-contact: if the ship is inside the mine's bounding box, destroy
\ both the mine and the ship. We force the ship's destruction by setting
\ plot_ship_collision_detected here rather than relying on the per-frame
\ pixel collision (which the bounding-box overlap can outpace by a frame).
\ Sits in front of the planet-explode trigger so every visible mine gets
\ the test (the trigger's BNE/BEQ paths skip everything below).
        LDA     object_type
        CMP     #OBJECT_bobbing_mine
        BEQ     do_mine_ship_contact_test
        CMP     #OBJECT_bobbing_mine_horizontal
        BNE     not_mine_ship_contact
    .do_mine_ship_contact_test
IF _SWITCHES
        \\ Disabled mines are inert — fly past them. The destruction path
        \\ via bullets still works (destroy_object doesn't read this bit).
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BNE     not_mine_ship_contact
ENDIF

        SEC                                          ; 16-bit dy = mine_y - player_y
        LDA     current_obj_ypos_INT
        SBC     player_ypos_INT
        TAY                                          ; Y = dy_lo (signed)
        LDA     current_obj_ypos_EXT
        SBC     player_ypos_INT_HI
        BMI     mine_dy_neg
        BNE     not_mine_ship_contact                ; dy_hi > 0: too far below
        CPY     #$0B                                 ; |dy| < 11 px
        BCS     not_mine_ship_contact                ; (mine 12 px tall + ship ~10 px,
        JMP     mine_test_dx                         ;  half-sum = 11 ≈ overlap range)
    .mine_dy_neg
        CMP     #$FF
        BNE     not_mine_ship_contact                ; dy_hi < -1: too far above
        TYA
        EOR     #$FF
        CLC
        ADC     #$01                                 ; A = |dy_lo|
        CMP     #$0B
        BCS     not_mine_ship_contact

    .mine_test_dx
        SEC                                          ; 8-bit dx = mine_x - player_x
        LDA     current_obj_xpos_INT                 ; (X is in CHARS, 4 BBC px each)
        SBC     player_xpos_INT
        BPL     mine_dx_pos
        EOR     #$FF
        CLC
        ADC     #$01                                 ; A = |dx|
    .mine_dx_pos
        CMP     #$05                                 ; |dx| < 5 chars (mine 3 chars
        BCS     not_mine_ship_contact                ;  + ship 2 chars = overlap range)

        \\ Geometric overlap → kill the ship and explode the mine.
        LDA     #$FF
        STA     plot_ship_collision_detected
        JMP     destroy_object
    .not_mine_ship_contact
ENDIF
        LDA     object_type
        CMP     #OBJECT_pod_stand
        BEQ     bullet_test_object                  ; pod_stand is inert to the trigger

        LDA     planet_countdown_timer
        BNE     bullet_test_object                  ; $01..$7F → still counting

        LDA     planet_explode_anim
        BNE     init_planet_explode_timer

        LDA     #$0F                                ; kick off explosion animation
        STA     planet_explode_anim
    .init_planet_explode_timer
        LDA     #POD_DESTROY_TIMER_INIT
        STA     pod_destroying_player_timer
        LDA     #$01
        STA     explosion_particle_type
        LDA     #$00
        STA     score_value
        JMP     destroy_object                      ; treat ship as destroyed

\ --- 7. Bullet collision: load per-type hitbox / score / explosion, scan 4 bullets ---
    .bullet_test_object
        LDX     object_type
        LDA     obj_type_width,X
        STA     current_object_width
        LDA     obj_type_height,X
        STA     current_object_height
        LDA     obj_type_explosion_particle,X
        STA     explosion_particle_type
        LDA     obj_type_score_value,X
        STA     score_value
        LDX     #$03                                ; X = bullet index 3..0

    .bullet_test_loop
        LDA     particles_lifetime,X
        BEQ     bullet_miss                         ; slot empty

        LDA     particles_type,X
        BNE     bullet_miss                         ; not a player bullet

        SEC                                         ; AABB test: dx = bullet.x - obj.x
        LDA     particles_xpos_INT,X
        SBC     current_obj_xpos_INT
        BCC     bullet_miss                         ; left of obj

        CMP     current_object_width
        BCS     bullet_miss                         ; right of obj

        SEC                                         ; AABB test: dy = bullet.y - obj.y
        LDA     particles_ypos_INT,X
        SBC     current_obj_ypos_INT
        TAY
        LDA     particles_ypos_INT_HI,X
        SBC     current_obj_ypos_EXT
        BNE     bullet_miss                         ; different Y high-byte

        CPY     current_object_height
        BCS     bullet_miss                         ; below obj

        LDA     particles_lifetime,X                ; hit: kill bullet lifetime
        AND     #PARTICLE_flag
        STA     particles_lifetime,X

\ --- Hit dispatch by object type ---
        LDA     object_type
        CMP     #OBJECT_door_switch_right
        BEQ     handle_door_switch

        CMP     #OBJECT_door_switch_left
        BEQ     handle_door_switch

        JMP     handle_generator                    ; everything else: test generator, else generic

    .handle_door_switch
IF _SWITCHES
        \\ Try wiring dispatch first. If the switch is in this level's
        \\ wiring table, the dispatcher fires its action and returns
        \\ carry CLEAR (suppress legacy). If unwired, returns carry SET
        \\ and we fall through to the original counter latch — that
        \\ keeps levels 3/4/5 doors working with zero migration.
        JSR     try_dispatch_switch_action
        BCC     handle_door_switch_consumed
ENDIF
        LDA     #$FF                                ; latch door-switch state
        STA     door_switch_counter_A
IF _SWITCHES
    .handle_door_switch_consumed
ENDIF
        JSR     spawn_hit_debris

    .handle_generator
        LDA     object_type
        CMP     #OBJECT_generator
        BNE     check_generic_destructible

        JSR     spawn_hit_debris

        JSR     rnd                                 ; generator is destroyable only when
        AND     #$1F                                ; accumulated recharge+random overflows
        ADC     generator_recharge_increase         ; → otherwise damage is absorbed as recharge
        STA     generator_recharge_counter
        STA     generator_recharge_increase
        BCC     delete_object                       ; no overflow → just bumped recharge

        LDA     planet_countdown_timer
        BPL     delete_object                       ; countdown already armed → no re-arm

        LDA     #$FF                                ; generator truly destroyed: arm countdown
        STA     generator_recharge_counter
        LDA     #PLANET_COUNTDOWN_SECONDS
        STA     planet_countdown_timer
        LDA     #$01
        STA     countdown_timer_ticks
        JMP     delete_object

\ --- Bullet didn't hit this object (or generator absorbed it) — try next bullet ---
    .bullet_miss
        JMP     try_next_bullet

\ --- Helper: spawn random-debris explosion at bullet X's particle position ---
    .spawn_hit_debris
        LDA     particles_xpos_INT,X
        STA     explosion_xpos_INT
        LDA     particles_ypos_INT_HI,X
        STA     explosion_ypos_INT_HI
        LDA     particles_ypos_INT,X
        STA     explosion_ypos_INT
        LDA     #PARTICLE_type_random_debris                        ; random debris
        STA     explosion_particle_type
        JMP     create_explosion

\ --- delete_object: generator recharge path — bullet consumed, no destruction ---
    .delete_object
        JMP     object_bullet_test_done

\ --- Generic destructibility gate: types < pod_stand are destroyed; others are inert ---
    .check_generic_destructible
        LDA     object_type
IF _TIMED_LASER
        CMP     #OBJECT_laser_turret_up_right       ; $09
        BCC     check_pod_stand                     ; < $09: fall through to normal check
        CMP     #(OBJECT_laser_turret_down_left+1)  ; $0D
        BCC     destroy_object                      ; $09..$0C: laser turret → destroy
    .check_pod_stand
ENDIF
IF _BOBBING_MINES
        CMP     #OBJECT_bobbing_mine                ; $0E
        BEQ     destroy_object                      ; mine is destructible by bullets
        CMP     #OBJECT_bobbing_mine_horizontal     ; $0F
        BEQ     destroy_object
ENDIF
        CMP     #OBJECT_pod_stand
        BCS     try_next_bullet                     ; pod_stand and above are inert

\ --- Destroy: clear ALIVE bit, spawn explosion, award score ---
    .destroy_object
        LDX     current_object
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X
        LDA     current_obj_xpos_INT
        ADC     #$02
        STA     explosion_xpos_INT
        LDA     current_obj_ypos_INT
        ADC     #$04
        STA     explosion_ypos_INT
        LDA     current_obj_ypos_EXT
        ADC     #$00
        STA     explosion_ypos_INT_HI
        LDA     score_value
        JSR     accumulate_score_A

        JSR     create_explosion

        JMP     object_bullet_test_done

    .try_next_bullet
        DEX
        BMI     object_bullet_test_done             ; all 4 bullets tested

        JMP     bullet_test_loop

\ --- Post-bullet tail: fuel tractor → gun fire → generator debris → plot ---
    .object_bullet_test_done
        LDA     pod_destroying_player_timer         ; $FF (idle/armed) → run tractor
        BMI     try_tractor_fuel_pickup             ; positive → pod killing player, skip

    .skip_tractor_check
        JMP     try_gun_fire

\ --- 8. Shield-tractor fuel pickup: fuel type only, player must be near + shield pressed ---
    .try_tractor_fuel_pickup
        LDA     pod_tethered_flag
        BNE     skip_tractor_check                  ; pod on ship → no fuel pickup

        LDA     object_type
        CMP     #OBJECT_fuel
        BNE     skip_tractor_check

        CMP     #OBJECT_generator                   ; (unreachable after fuel-eq check —
        BEQ     skip_tractor_check                  ;  kept because the original does it)

        LDA     shield_tractor_pressed
        BEQ     skip_tractor_check

        LDA     current_obj_xpos_INT                ; player proximity: |dx| < 6
        SEC
        SBC     player_xpos_INT
        BEQ     skip_tractor_check

        CMP     #$06
        BCS     skip_tractor_check

        LDA     current_obj_ypos_INT                ; and |dy| < $1C, same Y high byte
        SBC     player_ypos_INT
        TAX
        LDA     current_obj_ypos_EXT
        SBC     player_ypos_INT_HI
        BNE     skip_tractor_check

        CPX     #$1C
        BCS     skip_tractor_check

        LDA     #$01                                ; engaged: count tractor frames
        STA     collecting_fuel_flag
        LDX     current_object
        LDY     obj_tractor_counter,X
        INY
        TYA
        STA     obj_tractor_counter,X
        CMP     #$1A                                ; ~26 frames to fully tractor fuel
        BCC     try_gun_fire

        LDA     level_obj_flags,X                   ; fuel collected: clear ALIVE, score, sfx
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X
        LDA     #$30
        JSR     accumulate_score_A

        JSR     collect_pod_fuel_sound

\ --- 9. Hostile gun fire: guns ($00-$03) ---
    .try_gun_fire
        LDA     object_type
        CMP     #OBJECT_fuel
        BCS     generator_debris_tick
IF _SWITCHES
        \\ Disabled guns stay drawn but stop firing.
        LDX     current_object
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BNE     generator_debris_tick
ENDIF

        LDA     generator_recharge_counter          ; guns are silenced while generator
        BNE     generator_debris_tick               ; is recharging (or already destroyed)

        LDA     planet_countdown_timer              ; and once the planet countdown is armed
        BPL     generator_debris_tick

        LDA     current_obj_visible_flag            ; don't shoot from off-screen
        BEQ     generator_debris_tick

        JSR     rnd                                 ; per-frame fire probability

        CMP     hostile_gun_shoot_probability
        BCS     generator_debris_tick

        JSR     hostile_gun_sound

        JSR     particle_return_free_slot_in_Y

        TYA                                         ; pick shot angle:
        TAX                                         ;   base + rnd(spread_mask) + rnd(0..3)
        JSR     rnd

        AND     #$03
        STA     rnd_AND_3
        LDA     rnd_B
        AND     gun_angle_spread_mask
        ADC     gun_base_angle
        ADC     rnd_AND_3
        AND     #ANGLE_MASK
        TAY
        JSR     angle_to_bullet_dx_dy

        LDA     #PARTICLE_type_hostile_bullet
        STA     particles_type,X
        STA     particles_xpos_FRAC,X
        LDA     particles_lifetime,X
        AND     #PARTICLE_flag
        ORA     #PARTICLE_lifetime_bullet
        STA     particles_lifetime,X
        LDY     object_type
        LDA     current_obj_xpos_INT                ; bullet spawn pos = obj + per-gun offset
        CLC
        ADC     gun_bullet_x_offset,Y
        STA     particles_xpos_INT,X
        LDA     current_obj_ypos_INT
        ADC     gun_bullet_y_offset,Y
        STA     particles_ypos_INT,X
        LDA     current_obj_ypos_EXT
        ADC     #$00
        STA     particles_ypos_INT_HI,X

\ --- 10. Generator debris emitter: every 8 ticks, generator only, before planet trigger ---
    .generator_debris_tick
        LDA     level_tick_counter
        AND     #$07
        BNE     plot_current_sprite

        LDA     object_type
        CMP     #OBJECT_generator
        BNE     plot_current_sprite

        LDA     generator_recharge_counter
        BNE     plot_current_sprite                 ; generator recharging/destroyed

        LDA     planet_countdown_timer
        BPL     plot_current_sprite                 ; countdown already armed

        JSR     particle_return_free_slot_in_Y

        LDA     current_obj_xpos_INT                ; spawn a debris puff drifting upward
        CLC
        ADC     #$04
        STA     particles_xpos_INT,Y
        LDA     #$00
        STA     particles_xpos_FRAC,Y
        STA     particles_dx_FRAC,Y
        STA     particles_dx_INT,Y
        LDA     current_obj_ypos_INT
        STA     particles_ypos_INT,Y
        LDA     current_obj_ypos_EXT
        STA     particles_ypos_INT_HI,Y
        LDA     #$8E                                ; dy = negative (upward)
        STA     particles_dy_FRAC,Y
        LDA     #$FF
        STA     particles_dy_INT,Y
        LDA     #PARTICLE_type_debris
        STA     particles_type,Y
        LDA     particles_lifetime,Y
        AND     #PARTICLE_flag
        ORA     #PARTICLE_lifetime_generator
        STA     particles_lifetime,Y

\ --- 11. Plot sprite at new on-screen position and cache for next-frame dirty-rect check ---
    .plot_current_sprite
        LDA     update_objects_flag                 ; set by dirty-rect → skip redraw
        BNE     next_object

        LDA     obj_plot_sprite_at_ptr
        STA     plot_sprite_at_ptr
        LDA     obj_plot_sprite_at_ptr+1
        STA     plot_sprite_at_ptr+1
        BEQ     next_object                         ; culled off-screen

        LDX     current_object
        LDA     plot_sprite_at_ptr
        STA     level_obj_plot_at_ptr_LO,X
        LDA     plot_sprite_at_ptr+1
        STA     level_obj_plot_at_ptr_HI,X
        JSR     plot_static_sprite

    .next_object
        LDX     current_object
        INX
        JMP     update_objects_loop
}

\ ******************************************************************************
\ * Gun bullet data
\ ******************************************************************************

.gun_bullet_x_offset
        EQUB    $04,$04,$01,$01

.gun_bullet_y_offset
        EQUB    $00,$08,$00,$08

.gun_spread_mask_table                        ; not sure what this is used for?
        EQUB    $01,$03,$07,$0F

\ ******************************************************************************
\ * Function: object_visibility_test
\ * Description: Checks if object is within visible screen area and culls if off-screen
\ ******************************************************************************

.object_visibility_test
\\ {
        LDA     level_0_obj_pos_X,X                ; **SELF-MODIFIED CODE**
        level_obj_pos_X_addr_LO     = object_visibility_test+1
        level_obj_pos_X_addr_HI     = object_visibility_test+2
        STA     current_obj_xpos_INT

    .L10E8
        LDA     level_0_obj_pos_Y,X                ; **SELF-MODIFIED CODE**
        level_obj_pos_Y_addr_LO   = L10E8+1
        level_obj_pos_Y_addr_HI   = L10E8+2
        STA     current_obj_ypos_INT

    .L10ED
        LDA     level_0_obj_pos_Y_EXT,X            ; **SELF-MODIFIED CODE**
        level_obj_pos_Y_EXT_addr_LO   = L10ED+1
        level_obj_pos_Y_EXT_addr_HI   = L10ED+2
        STA     current_obj_ypos_EXT

        LDA     #$00
        STA     current_obj_visible_flag
        SEC
        LDA     current_obj_ypos_INT
        SBC     window_ypos_INT
        STA     obj_screen_y
        LDA     current_obj_ypos_EXT
        SBC     window_ypos_EXT
        STA     obj_screen_y_hi
        BNE     L1126

        LDA     #$01
        STA     current_obj_visible_flag
        SEC
        LDA     obj_screen_y
        SBC     #SCREEN_ADDR_HI_OFFSET
        STA     obj_screen_y
        CMP     #$11
        BCC     L1126

        CMP     #$7E
        BCS     L1126

        LDY     object_type
        SEC
        LDA     current_obj_xpos_INT
        SBC     window_xpos_INT
        STA     obj_screen_x
        CMP     object_type_cull_size_table,Y
        BCC     calculate_object_plot_addr

    .L1126
        RTS
\\ }

\ ******************************************************************************
\ * Object cull sizes (I think)
\ ******************************************************************************

.object_type_cull_size_table
        EQUB    $44,$44,$44,$44,$45,$45,$44,$47,$47
IF _TIMED_LASER
        EQUB    $44,$44,$44,$44                  ; [9..C] laser_turret orientations (5 chars wide like guns)
ENDIF
IF _GRAVITY_WELL
        EQUB    $44                              ; [D] gravity_well (no sprite yet; cull width borrowed from guns)
ENDIF
IF _BOBBING_MINES
        EQUB    $44                              ; [E] bobbing_mine
        EQUB    $44                              ; [F] bobbing_mine_horizontal
ENDIF
IF _TELEPORTER
        EQUB    $44                              ; [10] teleporter
ENDIF

\ ******************************************************************************
\ * Function: calculate_object_plot_addr
\ * Params: current_object
\ * Returns: none
\ * Description: Calculates screen memory address for plotting an object sprite
\ ******************************************************************************

.calculate_object_plot_addr
{
        LDA     current_object
        BNE     L1160

        LDA     obj_screen_y
        SEC
        SBC     window_scroll_y
        ROL     A
        SEC
        SBC     #$05
        STA     pod_window_ypos_INT
        SEC
        LDA     obj_screen_x
        SBC     #$02
        SEC
        SBC     window_scroll_x
        STA     pod_window_xpos_INT
        LDA     #$40
        STA     pod_window_xpos_FRAC
        LDA     #$00
        STA     nearest_obj_xpos_FRAC
        LDA     current_obj_xpos_INT
        SEC
        SBC     #$02
        STA     nearest_obj_xpos_INT
        LDA     current_obj_ypos_EXT
        STA     nearest_obj_ypos_INT_HI
        LDA     current_obj_ypos_INT
        STA     nearest_obj_ypos_INT

    .L1160
        CLC
        ROL     obj_screen_y
        LDY     #$00
        STY     obj_scraddr_y_lo
        STY     obj_scraddr_x_hi
        LDA     obj_screen_y
        AND     #$07
        STA     obj_pixel_row
        LDA     obj_screen_y
        LSR     A
        LSR     A
        AND     #$FE
        STA     obj_scraddr_y_hi
        LSR     A
        LSR     A
        ROR     obj_scraddr_y_lo
        LSR     A
        ROR     obj_scraddr_y_lo
        ADC     obj_scraddr_y_hi
        ADC     #SCREEN_ADDR_HI_OFFSET
        TAX
        LDA     obj_screen_x
        ASL     A
        ASL     A
        ROL     obj_scraddr_x_hi
        ASL     A
        ROL     obj_scraddr_x_hi
        AND     #$F8
        ADC     obj_pixel_row
        ADC     obj_scraddr_y_lo
        STA     obj_plot_sprite_at_ptr
        TXA
        ADC     obj_scraddr_x_hi
        STA     obj_plot_sprite_at_ptr+1
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Sprite routines and data
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: plot_static_sprite
\ * Params: L0070, L0071 contain screen address to plot sprite at
\ * Returns: none
\ * Description: Plots a static sprite to screen using XOR drawing with row wrapping
\ ******************************************************************************
        
.plot_static_sprite
\\ {
        LDX     current_object
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_drawn
        STA     level_obj_flags,X
        LDA     plot_sprite_at_ptr
        AND     #$07
        EOR     #$07
        STA     sprite_rows_to_boundary
        INC     sprite_rows_to_boundary
        LDX     #$00
        JMP     L11DB

    .L11B3
        INC     plot_sprite_at_ptr
        TYA
        AND     #$7F
        TAY
        DEC     sprite_rows_to_boundary
        BNE     L11D3

        DEC     plot_sprite_at_ptr
        LDA     plot_sprite_at_ptr
        ADC     #$39
        STA     plot_sprite_at_ptr
        LDA     plot_sprite_at_ptr+1
        ADC     #$02
        STA     plot_sprite_at_ptr+1
        LDA     #$08
        STA     sprite_rows_to_boundary
        TYA
        AND     #$7F
        TAY
        
    .L11D3
        LDA     obj_sprite_data_B_gun_down_left,X                    ; **SELF-MODIFIED CODE**
        sprite_data_B_ptr_LO   = L11D3+1
        sprite_data_B_ptr_HI   = L11D3+2
        EOR     (plot_sprite_at_ptr),Y
        STA     (plot_sprite_at_ptr),Y
        INX
        
    .L11DB
        LDY     obj_sprite_data_A_gun_down_left,X                    ; **SELF-MODIFIED CODE**
        sprite_data_A_ptr_LO   = L11DB+1
        sprite_data_A_ptr_HI   = L11DB+2
        BPL     L11D3

        CPY     #$FF
        BNE     L11B3

        RTS
\\ }

