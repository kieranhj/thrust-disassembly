\ *****************************************************************************
\ *****************************************************************************
\ * Thrust
\ * By Jeremey C. Smith
\ *
\ * Source disassembly & documentation by Kieran HJ Connell, February 2016
\ * Initial disassembly created using BeebDis by Phill Harvey-Smith
\ * Verified to compile using BeebAsm by Rich Talbot-Watkins
\ * With thanks to jms2 for his original Thrust disassembly notes and
\ * Matt Godbolt for his encouragement for me to get this released!
\ *
\ * Notes:
\ * Original $.THRUST3 executable had to first be decrypted -> (Thrust4)
\ * Relocated from load address $1A00 to executation address $A60 -> (Thrust5)
\ * Relocation code modified slightly as no longer encrypted -> (Thrust6)
\ * Source documented and annotated for first release --> (Thrust7)
\ * Subsequent corrections & documentation --> (Thrust8)
\ *
\ * _LO & _HI used to identify low byte & high byte of 16-bit values & pointers
\ *
\ * Most calculations are in Q7.8 fixed-point arithmetic although y values are
\ * stored in Q10.8 as each world can be several screens deep. Some physics
\ * calculations are performed Q7.16  in x to provide additional precision.
\ * _FRAC & _INT are used to identify the fraction and integer components of a
\ * fixed-point variable. _FRAC_LO is used to signify an additional byte of
\ * precision at the low end whilst _INT_HI is used for additional upper bits.
\ *****************************************************************************
\ *****************************************************************************

_SWRAM_BUILD         = TRUE

_DEBUG_RASTERS       = (_SWRAM_BUILD AND FALSE)   ; Raster timing
_DEBUG_FRAME_TIME    = (_SWRAM_BUILD AND TRUE)    ; Show frame time in status bar
_UNROLL_TERRAIN      = (_SWRAM_BUILD AND TRUE)    ; Faster terrain plotting
_FRIENDLY_KEYS       = (_SWRAM_BUILD AND TRUE)    ; Emulator friendly key map
_THRUST_PARTICLES    = (_SWRAM_BUILD AND TRUE)    ; Generate thrust particles
_FAST_SPRITES        = (_SWRAM_BUILD AND FALSE)   ; Pre-baked two-stream ship sprites
_NO_WRAP_UNDERGROUND = (_SWRAM_BUILD AND TRUE)    ; Skip X wrap when below surface
_TIMED_LASER         = (_SWRAM_BUILD AND TRUE)    ; Timed laser turret enemy ($09)
_GRAVITY_WELL        = (_SWRAM_BUILD AND TRUE)    ; Gravity well object ($0D)
_Y_BANDS             = (_SWRAM_BUILD AND TRUE)    ; Y-banded per-level parameter overrides (gravity)
_BOBBING_MINES       = (_SWRAM_BUILD AND TRUE)    ; Bobbing mine hazard object ($0E)
_TELEPORTER          = (_SWRAM_BUILD AND TRUE)    ; One-way teleporter pad object ($10)
_LAST_USED_CHECKPOINT = (_SWRAM_BUILD AND TRUE)   ; Track active checkpoint across deaths
_SWITCHES            = (_SWRAM_BUILD AND TRUE)    ; Editor-driven switches & triggers (wiring table)

\ ******************************************************************************
\ ******************************************************************************
\ * Useful game defines.
\ ******************************************************************************
\ ******************************************************************************

INITIAL_LEVEL                       = $01       ; staring level
INITIAL_LIVES                       = $04       ; starting number of lives
INITIAL_FUEL                        = $10       ; starting fuel value (BCD 1000)

\ ******************************************************************************
\ ******************************************************************************
\ * Constants
\ ******************************************************************************
\ ******************************************************************************

SCREEN_BASE_ADDR                    = $3C80     ; MODE 1 screen memory base
SCREEN_WIDTH_CHARS                  = 72        ; screen width in character columns
SCREEN_HEIGHT_ROWS                  = 30        ; total screen height in rows
SCREEN_STATUS_ROWS                  = 2         ; first two rows are status bar

SCREEN_CHAR_ROW_BYTES               = (SCREEN_WIDTH_CHARS * 8) ; bytes per character row
SCREEN_PLAY_HEIGHT                  = SCREEN_HEIGHT_ROWS-SCREEN_STATUS_ROWS
SCREEN_START_ADDR                   = SCREEN_BASE_ADDR + SCREEN_CHAR_ROW_BYTES * SCREEN_STATUS_ROWS

ASCII_beep                          = $07       ; BEL character
ASCII_space                         = $20       ; space character
ASCII_escape                        = $1B       ; escape character
ASCII_0                             = $30       ; digit 0
ASCII_9                             = $39       ; digit 9
ASCII_a                             = $61       ; lowercase a
ASCII_z                             = $7A       ; lowercase z
ASCII_delete                        = $7F       ; delete character

INKEY_spacebar                      = $9D       ; negative INKEY value for spacebar
INKEY_ctrl                          = $FE       ; negative INKEY value for CTRL
INKEY_capslock                      = $BF       ; negative INKEY value for CAPS LOCK
INKEY_shift                         = $FF       ; negative INKEY value for SHIFT
INKEY_return                        = $B6       ; negative INKEY value for RETURN
INKEY_escape                        = $8F       ; negative INKEY value for ESCAPE
INKEY_copy                          = $96       ; negative INKEY value for COPY
INKEY_Q                             = $EF       ; negative INKEY value for Q
INKEY_S                             = $AE       ; negative INKEY value for S
INKEY_Z                             = $9E       ; negative INKEY value for Z
INKEY_X                             = $BD       ; negative INKEY value for X
INKEY_P                             = $C8       ; negative INKEY value for P

IF _FRIENDLY_KEYS
KEY_ROTATE_left                     = INKEY_Z
KEY_ROTATE_right                    = INKEY_X
KEY_PAUSE                           = INKEY_P
KEY_UNPAUSE                         = $4F       ; ASCII_O
ELSE
KEY_ROTATE_left                     = INKEY_capslock
KEY_ROTATE_right                    = INKEY_ctrl
KEY_PAUSE                           = INKEY_copy
KEY_UNPAUSE                         = ASCII_delete
ENDIF

KEY_FIRE                            = INKEY_return
KEY_THRUST                          = INKEY_shift
KEY_SHIELD                          = INKEY_spacebar

OBJECT_gun_up_right                 = $0        ; gun emplacement facing up-right
OBJECT_gun_down_right               = $1        ; gun emplacement facing down-right
OBJECT_gun_up_left                  = $2        ; gun emplacement facing up-left
OBJECT_gun_down_left                = $3        ; gun emplacement facing down-left
OBJECT_fuel                         = $4        ; fuel pickup
OBJECT_pod_stand                    = $5        ; pod on its stand
OBJECT_generator                    = $6        ; reactor/generator
OBJECT_door_switch_right            = $7        ; door switch (right side)
OBJECT_door_switch_left             = $8        ; door switch (left side)
IF _TIMED_LASER
OBJECT_laser_turret_up_right        = $9        ; laser turret facing up-right (SWRAM only)
OBJECT_laser_turret_down_right      = $A        ; laser turret facing down-right (SWRAM only)
OBJECT_laser_turret_up_left         = $B        ; laser turret facing up-left (SWRAM only)
OBJECT_laser_turret_down_left       = $C        ; laser turret facing down-left (SWRAM only)
ENDIF
IF _GRAVITY_WELL
OBJECT_gravity_well                 = $D        ; gravity well: radial pull on ship inside radius (SWRAM only)
ENDIF
IF _BOBBING_MINES
OBJECT_bobbing_mine                 = $E        ; bobbing mine: vertical sine-wave hazard, destroyed by bullets (SWRAM only)
OBJECT_bobbing_mine_horizontal      = $F        ; bobbing mine: horizontal sine-wave hazard (SWRAM only)
ENDIF
IF _TELEPORTER
OBJECT_teleporter                   = $10       ; teleporter pad: warps player to a checkpoint (SWRAM only)
ENDIF
IF _SWITCHES
OBJECT_door                         = $11       ; door: carves a hole into terrain when pulsed by a wired switch (SWRAM only)
ENDIF

OBJ_flag_drawn                      = $01       ; level_obj_flags bit 0: sprite was XOR-plotted (needs erase before redraw)
OBJ_flag_alive                      = $02       ; level_obj_flags bit 1: object is active (update + draw + collide)
OBJ_flag_laser_beam_drawn           = $04       ; level_obj_flags bit 2: laser_turret beam was XOR-plotted (needs erase before re-evaluation)
OBJ_flag_laser_redraw_pending       = $08       ; level_obj_flags bit 3: laser geometry changed (set_param/xor_param) -- skip update_one_laser_beam fast path so the cached pixels get erased and redrawn at the new endpoint
OBJ_flag_disabled                   = $10       ; level_obj_flags bit 4: per-type behaviour suspended (gun fire / laser beam / mine motion+contact / well force / teleporter warp). Sprite still plots; bullet collision still works -- the object is visually present but inert.

PARTICLE_flag                       = $80       ; particle can be replaced
PARTICLE_lifetime_bullet            = $28       ; bullet lifetime in ticks
PARTICLE_lifetime_generator         = $0A       ; generator debris lifetime
PARTICLE_lifetime_star              = $1E       ; star lifetime in ticks
PARTICLE_lifetime_thrust            = $09       ; thrust lifetime in ticks
PARTICLE_table_max                  = $1F       ; max index into particle table (32 slots)
PARTICLE_type_player_bullet         = $00       ; player bullet particle type
PARTICLE_type_debris                = $01       ; shoot generator
PARTICLE_type_star                  = $02       ; background star particle type
PARTICLE_type_hostile_bullet        = $03       ; enemy bullet particle type
PARTICLE_type_random_debris         = $04       ; random debris explosion particle type

NUM_ANGLES                          = 32        ; number of discrete ship/tether angles
ANGLE_MASK                          = NUM_ANGLES - 1 ; bitmask for angle wrapping (0-31)
ANGLE_DOWN                          = $10       ; ship angle pointing straight down

PIXEL_COLUMN_MASK                   = $03       ; pixel column mask (4 pixels per MODE 5 byte)
SCREEN_ADDR_HI_OFFSET               = $38       ; high byte offset for screen address calculation
LANDSCAPE_COLOUR_BYTE               = $F0       ; pixel byte for terrain lines (colour 2)
OBJECT_COLOUR_BYTE                  = $FF       ; pixel byte for object colour (logical 3)

PLAYER_CENTRE_X_OFFSET              = $04       ; X offset to centre of player sprite
PLAYER_CENTRE_Y_OFFSET              = $05       ; Y offset to centre of player sprite
SHIELD_SPRITE_INDEX                 = $11       ; sprite index for shield (after 17 rotation frames)
LEVEL_MAX_OBJECTS                   = $1F       ; max object index per level (32 objects)
PLANET_COUNTDOWN_SECONDS            = $0A       ; planet countdown timer in seconds
POD_DESTROY_TIMER_INIT              = $3C       ; pod destroying player timer initial value (60 ticks)
TRACTOR_BEAM_ACTIVATE_DIST          = $75       ; distance threshold to activate tractor beam
TRACTOR_BEAM_ATTACH_DIST            = $84       ; distance threshold to attach pod
WORLD_X_WRAP_THRESHOLD              = (256 - SCREEN_WIDTH_CHARS)           ; $B8 - X position wrap point
WORLD_X_WRAP_FORWARD                = (SCREEN_WIDTH_CHARS + 1)             ; $49 - forward wrap delta
WORLD_X_WRAP_BACKWARD               = (0 - SCREEN_WIDTH_CHARS - 1) AND $FF ; $B7 - backward wrap delta

