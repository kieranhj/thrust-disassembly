\ ******************************************************************************
\ ******************************************************************************
\ * Character plot routines
\ ******************************************************************************
\ ******************************************************************************
        
\ ******************************************************************************
\ * Function: char_write_ptr_next_column
\ * Description: Advances the character write pointer to the next screen column (+8 bytes)
\ ******************************************************************************

.char_write_ptr_next_column
{
        CLC
        LDA     char_write_ptr_LO
        ADC     #$08
        STA     char_write_ptr_LO
        BCC     return

        INC     char_write_ptr_HI
    .return
        RTS
}

\ ******************************************************************************
\ * Function: char_clear_cursor_backspace
\ * Description: Clears cursor pixels at current position and moves back one char
\ ******************************************************************************

.char_clear_cursor_backspace
{
        LDA     #$00
        LDY     #$04
        STA     (char_write_ptr_LO),Y
        LDY     #$0C
        STA     (char_write_ptr_LO),Y
        SEC
        LDA     char_write_ptr_LO
        SBC     #$10
        STA     char_write_ptr_LO
        BCS     return

        DEC     char_write_ptr_HI
    .return
        RTS
}

\ ******************************************************************************
\ * Function: char_plot_cursor
\ * Description: Draws a blinking text cursor at the current write position
\ ******************************************************************************

.char_plot_cursor
{
        LDA     char_flag_cursor
        BEQ     skip_cursor

        LDA     #$0F
        LDY     #$04
        STA     (char_write_ptr_LO),Y
        LDY     #$0C
        STA     (char_write_ptr_LO),Y

    .skip_cursor
        PLA
        TAY
        PLA
        TAX
        PLA
        CLC
        RTS
}

\ ******************************************************************************
\ * Function: plot_char_A
\ * Params: A = ASCII character to plot
\ * Returns: none
\ * Description: Dispatches ASCII char in A to appropriate plot routine by type
\ ******************************************************************************

.plot_char_A
{
        STA     char_to_plot
        PHA
        TXA
        PHA
        TYA
        PHA
        LDA     char_to_plot
        CMP     #ASCII_beep
        BEQ     plot_char_beep

        CMP     #ASCII_space
        BCC     char_plot_cursor

        BEQ     plot_char_space

        CMP     #ASCII_delete
        BEQ     plot_char_delete

        CMP     #ASCII_0
        BCC     not_a_number

        CMP     #ASCII_9+1
        BCC     plot_ascii_number

    .not_a_number
        ORA     #$20
        CMP     #ASCII_a
        BCC     not_a_letter

        CMP     #ASCII_z+1
        BCC     plot_ascii_lower_case_letter

    .not_a_letter
        LDA     #$00
        JMP     plot_font_A

    .plot_char_space
        JSR     char_erase
        JMP     char_plot_cursor

    .plot_char_beep
        JSR     jmp_wrchv
        JMP     char_plot_cursor
}

\ ******************************************************************************
\ * Function: char_erase
\ * Description: Erases a character cell by zeroing two columns of 5 pixel rows
\ ******************************************************************************

.char_erase
{
        LDX     #$02

    .col_loop
        LDY     #$04
        LDA     #$00

    .row_loop
        STA     (char_write_ptr_LO),Y
        DEY
        BPL     row_loop

        JSR     char_write_ptr_next_column

        DEX
        BNE     col_loop
        RTS
}

\ ******************************************************************************
\ * Function: plot_char_delete
\ * Description: Handles delete key: backspace, erase char, backspace, show cursor
\ ******************************************************************************

.plot_char_delete
{
        JSR     char_clear_cursor_backspace
        JSR     char_erase
        JSR     char_clear_cursor_backspace
        JMP     char_plot_cursor
}

\ ******************************************************************************
\ * Function: plot_ascii_lower_case_letter
\ * Params: A = ASCII character to plot (A-Z)
\ * Returns: none
\ * Description: Converts ASCII lowercase letter (a-z) to font index and plots it
\ ******************************************************************************

.plot_ascii_lower_case_letter
{
        SEC
        SBC     #$60
        JMP     plot_font_A
}

\ ******************************************************************************
\ * Function: plot_ascii_number
\ * Params: A = ASCII character to plot (0-9)
\ * Returns: none
\ * Description: Converts ASCII digit (0-9) to font index and plots it
\ ******************************************************************************

.plot_ascii_number
{
        SEC
        SBC     #$15
        JMP     plot_font_A
}

\ ******************************************************************************
\ * Function: plot_font_A
\ * Params: A = font character to plot
\ * Returns: none
\ * Description: Plots a font character from 5-line font data as two nibble columns
\ ******************************************************************************

.plot_font_A
{
        TAX
        LDY     #$00
        LDA     font_data_line_0,X
        JSR     plot_font_top_nibble

        LDA     font_data_line_1,X
        JSR     plot_font_top_nibble

        LDA     font_data_line_2,X
        JSR     plot_font_top_nibble

        LDA     font_data_line_3,X
        JSR     plot_font_top_nibble

        LDA     font_data_line_4,X
        JSR     plot_font_top_nibble

        JSR     char_write_ptr_next_column

        LDY     #$00
        LDA     font_data_line_0,X
        JSR     plot_font_bottom_nibble

        LDA     font_data_line_1,X
        JSR     plot_font_bottom_nibble

        LDA     font_data_line_2,X
        JSR     plot_font_bottom_nibble

        LDA     font_data_line_3,X
        JSR     plot_font_bottom_nibble

        LDA     font_data_line_4,X
        JSR     plot_font_bottom_nibble

        JSR     char_write_ptr_next_column
        JMP     char_plot_cursor
}

\ ******************************************************************************
\ * Character variables
\ ******************************************************************************

.char_to_plot
        EQUB    $00

.char_flag_cursor
        EQUB    $00

\ ******************************************************************************
\ * Functions: plot_font_top_nibble, plot_font_bottom_nibble
\ * Params: A = font character to plot
\ * Returns: none
\ * Description: Splits font byte into top/bottom nibbles for screen pixel output
\ ******************************************************************************

.plot_font_top_nibble
\\ {
        PHA
        AND     #$F0
        STA     char_to_plot
        PLA
        ROR     A
        ROR     A
        ROR     A
        ROR     A
        AND     #$0F
        ORA     char_to_plot

.plot_font_byte
        AND     font_byte_mask
        STA     (char_write_ptr_LO),Y
        INY
        RTS
\\ }

.plot_font_bottom_nibble
{
        PHA
        AND     #$0F
        STA     char_to_plot
        PLA
        ROL     A
        ROL     A
        ROL     A
        ROL     A
        AND     #$F0
        ORA     char_to_plot
        JMP     plot_font_byte
}

\ ******************************************************************************
\ ******************************************************************************
\ * Game routines
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: multiply_signed_8x8
\ * Params: A = signed 8-bit multiplicand (stored into multiply_operand_b);
\ *         multiply_operand_a = signed 8-bit multiplier (pre-set by caller)
\ * Returns: multiply_result_hi:multiply_result_lo = signed 16-bit product
\ * Corrupts: A, X, multiply_operand_a, multiply_operand_b, multiply_sign_ext
\ * Description: Signed 8x8 -> 16 multiply using a standard shift-and-add loop.
\ *   If multiply_operand_a is negative, both operands are two's-complement
\ *   negated up-front, so the result's sign comes out correct without a final
\ *   fix-up. multiply_sign_ext holds the sign extension of operand_b and is
\ *   added (instead of 0) on each shift so the high byte accumulates signed.
\ ******************************************************************************

.multiply_signed_8x8
{
        STA     multiply_operand_b
        LDA     #$00
        STA     multiply_result_lo
        STA     multiply_result_hi
        STA     multiply_sign_ext
        LDA     multiply_operand_a
        BPL     L16F2

        EOR     #$FF
        STA     multiply_operand_a
        INC     multiply_operand_a
        LDA     multiply_operand_b
        EOR     #$FF
        STA     multiply_operand_b
        INC     multiply_operand_b

    .L16F2
        LDA     multiply_operand_b
        BPL     L16FA

        LDA     #$FF
        STA     multiply_sign_ext

    .L16FA
        LDX     #$08

    .L16FC
        ROR     multiply_operand_a
        BCC     L170D

        LDA     multiply_operand_b
        CLC
        ADC     multiply_result_lo
        STA     multiply_result_lo
        LDA     multiply_sign_ext
        ADC     multiply_result_hi
        STA     multiply_result_hi

    .L170D
        CLC
        ROL     multiply_operand_b
        ROL     multiply_sign_ext
        DEX
        BNE     L16FC

        RTS
}

\ ******************************************************************************
\ * Function: update_window_and_terrain_tables
\ * Description: Per-frame viewport advance. Drives four tightly coupled
\ *              pieces of state:
\ *
\ *   1. Apply last frame's scroll delta to window_xpos / window_ypos. For Y,
\ *      also walk the terrain RLE replay (terrain_process_{accumulate,
\ *      subtract}_xpos) forward or backward by that many rows so that
\ *      terrain_left_wall[] and terrain_right_wall[] stay in sync with the
\ *      visible window.
\ *   2. Tick door-switch timers (tick_door_logic).
\ *   3. Recompute the player's distance from the window origin on both axes
\ *      and from that decide next frame's window_scroll_{x,y} — a damped
\ *      follow that snaps toward force_vector when the player leaves a
\ *      central deadzone and decelerates by 1 per frame when the player
\ *      returns toward centre. A separate clamp zeroes scroll if the
\ *      window would overshoot past the player.
\ *   4. If window_xpos just crossed a world X-wrap boundary, shift
\ *      window_xpos / midpoint_xpos / player_xpos / old_player_xpos and
\ *      every particle's xpos by WORLD_X_WRAP_FORWARD or _BACKWARD, then
\ *      fix up the cached wall-X tables so the delta-XOR draw doesn't see
\ *      a spurious jump.
\ *
\ * _NO_WRAP_UNDERGROUND build flag: when player Y is below the per-level
\ * threshold, skip the X-wrap check entirely and instead just clamp
\ * window_scroll_x to zero when window_xpos drops below 3. Prevents the
\ * left-hand wall lookup going wrong underground. See docs/ideas.md.
\ ******************************************************************************

.update_window_and_terrain_tables
{

\ --- 1a. Apply accumulated X and Y scroll to window position ---
        CLC
        LDA     window_scroll_x
        ADC     window_xpos_INT
        STA     window_xpos_INT

        CLC
        LDA     window_scroll_y
        BMI     y_scroll_up                            ; negative → walk terrain backwards
        BEQ     after_y_scroll                         ; zero → skip terrain walk

\ --- 1b. Y scrolling DOWN: extend window_ypos and replay terrain forward N rows ---
        ADC     window_ypos_INT
        STA     window_ypos_INT
        BCC     y_down_no_ext_carry
        INC     window_ypos_EXT                        ; 16-bit overflow of window_ypos

    .y_down_no_ext_carry
        LDA     window_scroll_y                        ; A = scroll_y = iteration count

    .y_down_expand_terrain_loop
        PHA
        JSR     terrain_process_accumulate_xpos        ; advances terrain_window_y_index by 1

        PLA
        SEC
        SBC     #$01
        BNE     y_down_expand_terrain_loop

        JMP     after_y_scroll

\ --- 1c. Y scrolling UP: retract window_ypos and replay terrain backward |scroll_y| rows ---
    .y_scroll_up
        ADC     window_ypos_INT
        STA     window_ypos_INT
        BCS     y_up_no_ext_borrow
        DEC     window_ypos_EXT                        ; 16-bit borrow of window_ypos

    .y_up_no_ext_borrow
        LDA     window_scroll_y                        ; A = scroll_y (negative) = -iteration count

    .y_up_contract_terrain_loop
        PHA
        JSR     terrain_process_subtract_xpos          ; retreats terrain_window_y_index by 1

        PLA
        CLC
        ADC     #$01                                   ; add 1 (count up toward zero)
        BNE     y_up_contract_terrain_loop

\ --- 2. Tick door-switch timers (decoupled from scroll but always advances) ---
    .after_y_scroll
        JSR     tick_door_logic
IF _SWITCHES
        JSR     tick_switch_logic                      ; per-switch refractory decrement
ENDIF

\ --- 3a. Y scroll speed: compute player_ydist_in_window (larger = lower on screen) ---
        SEC
        LDA     midpoint_ypos_INT
        SBC     window_ypos_INT
        SEC
        SBC     #SCREEN_ADDR_HI_OFFSET
        STA     player_ydist_in_window_INT
        SEC                                            ; (carry-prep; dead here, CMP resets C anyway)
        LDA     force_vectory_INT
        BMI     player_heading_up

\ --- 3b. Player moving DOWN: decelerate if central, else snap scroll to force+1 ---
        LDA     player_ydist_in_window_INT
        CMP     #$5D
        BCS     player_below_lower_y_bound             ; past lower deadzone → snap to force

        ; Player inside lower deadzone — maybe decelerate existing downward scroll.

        LDA     window_scroll_y
        BMI     done_y_down_speed
        BEQ     done_y_down_speed                      ; scroll already <= 0, nothing to do

        ; Window scrolling down — check whether scroll is outrunning the player.

        LDX     force_vectory_INT
        INX
        CPX     window_scroll_y
        BCS     done_y_down_speed                      ; force+1 >= scroll → leave scroll alone

        ; Scroll is outrunning the player; decelerate by 1 (but never settle on 0 mid-scroll).

        DEC     window_scroll_y
        BNE     done_y_down_speed

        INC     window_scroll_y                        ; undo if DEC landed on zero

    .done_y_down_speed
        JMP     clamp_y_scroll_at_edge

    .player_below_lower_y_bound
        ; Player past bottom of deadzone → snap scroll_y = force_y + 1 to chase.

        LDX     force_vectory_INT
        INX
        STX     window_scroll_y

        JMP     clamp_y_scroll_at_edge

\ --- 3c. Player moving UP: decelerate if central, else snap scroll to force-1 ---
    .player_heading_up
        LDA     player_ydist_in_window_INT
        CMP     #$2F
        BCC     player_above_upper_y_bound             ; past upper deadzone → snap to force

        ; Player inside upper deadzone — maybe decelerate existing upward scroll.

        LDA     window_scroll_y
        BPL     done_y_up_speed                        ; scroll is >= 0 (not scrolling up)

        ; Window scrolling up — check whether scroll is outrunning the player.

        LDA     window_scroll_y
        CMP     force_vectory_INT
        BCS     done_y_up_speed                        ; scroll >= force (less negative) → leave it

        ; Scroll is outrunning the player upward; decelerate by 1 (never settle on 0 mid-scroll).

        INC     window_scroll_y
        BNE     done_y_up_speed

        DEC     window_scroll_y                        ; undo if INC landed on zero

    .done_y_up_speed
        JMP     clamp_y_scroll_at_edge

    .player_above_upper_y_bound
        ; Player past top of deadzone → snap scroll_y = force_y - 1 to chase.

        LDX     force_vectory_INT
        DEX
        STX     window_scroll_y

\ --- 3d. Clamp Y scroll to zero if player has drifted to the OPPOSITE edge ---
    .clamp_y_scroll_at_edge
        LDA     window_scroll_y
        BEQ     compute_x_scroll_speed                 ; no Y scroll → jump to X scroll
        BMI     clamp_up_scroll_near_bottom

        ; Window scrolling DOWN — zero scroll if player has drifted up to near top of screen.

        LDA     player_ydist_in_window_INT
        CMP     #$3C
        BCS     compute_x_scroll_speed                 ; player still below top zone → keep scroll

        ; Player pulled away from bottom-track of scroll → stop scrolling down.

        LDA     #$00
        STA     window_scroll_y

        JMP     compute_x_scroll_speed

    .clamp_up_scroll_near_bottom
        ; Window scrolling UP — zero scroll if player has drifted down to near bottom of screen.

        LDA     player_ydist_in_window_INT
        CMP     #$50
        BCC     compute_x_scroll_speed                 ; player still above bottom zone → keep scroll

        ; Player pulled away from top-track of scroll → stop scrolling up.

        LDA     #$00
        STA     window_scroll_y

\ --- 4a. X scroll speed: compute player_xdist_in_window; snap scroll if outside deadzone ---
    .compute_x_scroll_speed
        SEC
        LDA     midpoint_xpos_INT
        SBC     window_xpos_INT
        STA     player_xdist_in_window_INT             ; player X offset inside the window
        SEC
        SBC     #$10
        BCS     x_dist_ge_16

        ; Player X dist < $10 — player has pushed past the left deadzone edge.
        ; A now holds (xdist - $10), which is negative → use as -ve scroll.

        STA     window_scroll_x                        ; scroll left at (xdist - $10)
        JMP     decelerate_x_scroll

    .x_dist_ge_16
        ; Player X dist >= $10. Test against the right deadzone edge.

        LDA     player_xdist_in_window_INT
        SEC
        SBC     #$30
        BEQ     decelerate_x_scroll                    ; exactly on right edge → no snap
        BCC     decelerate_x_scroll                    ; still inside deadzone

        ; Player X dist >= $30 — player has pushed past the right deadzone edge.
        ; A now holds (xdist - $30), positive → use as +ve scroll.

        STA     window_scroll_x                        ; scroll right at (xdist - $30)

\ --- 4b. X scroll deceleration when player is back inside deadzone ---
    .decelerate_x_scroll
        LDA     window_scroll_x
        BEQ     check_x_wrap                           ; no X scroll → jump to wrap check
        BMI     x_scrolling_left

        ; Window scrolling RIGHT — check whether player has drifted back toward centre.

        LDA     player_xdist_in_window_INT
        CMP     #$1D
        BCS     x_right_not_central

        ; Player back inside the right-scroll bound — stop scrolling right.

        LDA     #$00
        STA     window_scroll_x

        JMP     check_x_wrap

    .x_right_not_central
        CMP     #$30
        BCS     check_x_wrap                           ; player still past right edge → keep speed

        ; Player inside the right-hand deadzone window → decelerate by 1 (not through 0).

        DEC     window_scroll_x
        BNE     check_x_wrap

        INC     window_scroll_x                        ; undo if DEC landed on zero
        JMP     check_x_wrap

    .x_scrolling_left
        ; Window scrolling LEFT — check whether player has drifted back toward centre.

        LDA     player_xdist_in_window_INT
        CMP     #$23
        BCC     x_left_not_central

        ; Player back inside the left-scroll bound — stop scrolling left.

        LDA     #$00
        STA     window_scroll_x
        JMP     check_x_wrap

    .x_left_not_central
        CMP     #$10
        BCC     check_x_wrap                           ; player still past left edge → keep speed

        ; Player inside the left-hand deadzone window → decelerate by 1 (not through 0).

        INC     window_scroll_x
        BNE     check_x_wrap

        DEC     window_scroll_x                        ; undo if INC landed on zero

\ --- 4c. World X-wrap check: wrap everything in world-X by ±WORLD_X_WRAP_* if needed ---
    .check_x_wrap
IF _NO_WRAP_UNDERGROUND
        \ Skip X wrap when player Y is below the no-wrap threshold.
        \ Left-hand wall lookup breaks down at small window_xpos underground,
        \ so we disable the wrap and instead clamp scroll_x so the window
        \ can't drift below xpos=3. See docs/ideas.md for context.
        LDA     player_ypos_INT_HI
        CMP     no_wrap_y_INT_HI
        BCC     do_wrap_check           ; player HI < threshold HI: above, do wrap
        BNE     do_left_hand_clamp      ; player HI > threshold HI: below, skip wrap
        LDA     player_ypos_INT
        CMP     no_wrap_y_INT
        BCC     do_wrap_check           ; player LO < threshold LO: above, do wrap
    .do_left_hand_clamp
        LDA     window_xpos_INT
        CMP     #$3
        BCS     no_lh_clamp
        LDA     #0
        STA     window_scroll_x                        ; clamp: don't scroll below xpos=3
    .no_lh_clamp
        JMP     return

    .do_wrap_check
ENDIF
        LDA     window_xpos_INT
        BEQ     wrap_x_backward                        ; xpos == 0 → wrap backward
                                                       ;   (treat $00 as "about to underflow")
        CMP     #$DC
        BCC     check_wrap_x_forward                   ; $01..$DB → no backward wrap, try forward

    .wrap_x_backward
        LDA     #WORLD_X_WRAP_BACKWARD                 ; xpos was $00 or $DC..$FF → shift backward
        BNE     apply_x_wrap                           ; always taken (constant non-zero)

    .check_wrap_x_forward
        CMP     #WORLD_X_WRAP_THRESHOLD
        BCC     return                                 ; below threshold → no wrap needed

        LDA     #WORLD_X_WRAP_FORWARD                  ; shift forward

\ --- 4d. Apply the X-wrap delta to window, midpoint, player, old-player, and particles ---
    .apply_x_wrap
        STA     window_deltax_INT
        LDA     window_xpos_INT
        CLC
        ADC     window_deltax_INT
        STA     window_xpos_INT
        LDA     midpoint_xpos_INT
        CLC
        ADC     window_deltax_INT
        STA     midpoint_xpos_INT
        LDA     player_xpos_INT
        CLC
        ADC     window_deltax_INT
        STA     player_xpos_INT
        LDA     old_player_xpos_INT
        CLC
        ADC     window_deltax_INT
        STA     old_player_xpos_INT
        LDX     #PARTICLE_table_max

    .shift_particles_x_loop
        LDA     particles_xpos_INT,X
        CLC
        ADC     window_deltax_INT
        STA     particles_xpos_INT,X
        DEX
        BPL     shift_particles_x_loop

\ --- 4e. Sync cached wall-X tables across the wrap so the delta-XOR doesn't flash ---
\ --- Walks all scanline cache entries (via terrain_draw_table_1,X / _3,X with X=17..127,
\ --- covering table_2 and table_4 too). Entries with both walls pinned at the same edge
\ --- get flipped to the opposite edge, matching the world-X shift.
        LDX     #$11
    .wrap_fix_cache_loop
        LDA     terrain_draw_table_3,X
        BNE     check_both_at_right_edge

        ; table_3 == 0 (right wall at left edge) — if table_1 is also 0, flip both to SCREEN_WIDTH.

        LDA     terrain_draw_table_1,X
        BNE     next_cache_entry

        LDA     #SCREEN_WIDTH_CHARS
        STA     terrain_draw_table_1,X
        STA     terrain_draw_table_3,X
        JMP     next_cache_entry

    .check_both_at_right_edge
        CMP     #SCREEN_WIDTH_CHARS
        BNE     next_cache_entry                       ; table_3 non-zero and not at right edge

        LDA     terrain_draw_table_1,X
        CMP     #SCREEN_WIDTH_CHARS
        BNE     next_cache_entry

        ; Both walls pinned at SCREEN_WIDTH — flip both to 0.

        LDA     #$00
        STA     terrain_draw_table_3,X
        STA     terrain_draw_table_1,X

    .next_cache_entry
        INX
        BPL     wrap_fix_cache_loop                    ; walk X = 17..127

    .return
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Level logic for doors
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: tick_door_logic
\ * Description: Decrements door switch counter and dispatches door logic by level
\ ******************************************************************************

.tick_door_logic
{
IF _SWITCHES
        \\ Wiring system replaces the legacy level_3/4/5 door dispatch.
        \\ tick_doors walks all OBJECT_door instances and runs their per-
        \\ door state machine + wall carve. Hardcoded routines below stay
        \\ assembled but go unreachable here (they remain reachable under
        \\ _SWITCHES = FALSE, anchoring the non-SWRAM CRC).
        \\
        \\ Counter A is still drained for any wired switch that fell through
        \\ to the legacy latch (none, in practice — switches with no wiring
        \\ entry write $FF here and then the legacy routines used to fire
        \\ off it). Keeps state from accumulating if mixed wiring lands
        \\ later.
        LDA     door_switch_counter_A
        BEQ     tick_doors_dispatch
        DEC     door_switch_counter_A
.tick_doors_dispatch
        JMP     tick_doors
ELSE
        LDA     door_switch_counter_A
        BEQ     door_switch_zero

        DEC     door_switch_counter_A

    .door_switch_zero
        LDA     level_number
        CMP     #$03
        BEQ     level_3_door_logic

        CMP     #$05
        BEQ     level_5_door_logic

        CMP     #$04
        BEQ     level_4_door_logic

        RTS
ENDIF
}

.level_5_door_logic
{
        JMP     do_level_5_door_logic
}

.level_4_door_logic
{
        JMP     do_level_4_door_logic
}

\ ******************************************************************************
\ * Function: level_3_door_logic
\ * Description: Calculates door position and opens/closes level 3 door in terrain
\ ******************************************************************************

.level_3_door_logic
{
        SEC
        LDA     #$69
        SBC     window_ypos_INT
        STA     door_screen_ypos
        LDA     #$02
        SBC     window_ypos_EXT
        BNE     return

        LDA     door_screen_ypos
        CMP     #$F1
        BCC     L18AF

    .return
        RTS

    .L18AF
        LDA     door_switch_counter_A
        CMP     #$10
        BCS     L18BA

        STA     door_switch_counter_B
        JMP     L18C2

    .L18BA
        LDA     door_switch_counter_B
        CMP     #$10
        BCS     L18C2

        INC     door_switch_counter_B
        
    .L18C2
        SEC
        LDA     #$AE
        SBC     door_switch_counter_B
        PHA
        LDA     door_screen_ypos
        CLC
        ADC     terrain_window_y_index
        TAY
        PLA
        LDX     #$0D
        
    .L18D2
        STA     terrain_left_wall,Y
        INY
        DEX
        BNE     L18D2

        RTS
}

\ ******************************************************************************
\ * Function: do_level_4_door_logic
\ * Description: Calculates door position and opens/closes level 4 door in terrain
\ ******************************************************************************

.do_level_4_door_logic
{
        SEC
        LDA     #$43
        SBC     window_ypos_INT
        STA     door_screen_ypos
        LDA     #$03
        SBC     window_ypos_EXT
        BNE     return

        LDA     door_screen_ypos
        CMP     #$E9
        BCC     L18EE

    .return
        RTS
    
    .L18EE
        LDA     door_switch_counter_A
        CMP     #$15
        BCS     L18F9

        STA     door_switch_counter_B
        JMP     L1901

    .L18F9
        LDA     door_switch_counter_B
        CMP     #$15
        BCS     L1901

        INC     door_switch_counter_B
        
    .L1901
        LDA     door_screen_ypos
        CLC
        ADC     terrain_window_y_index
        CLC
        ADC     #$15
        TAX
        LDA     #$A6
        LDY     #$15
        
    .L190F
        CPY     door_switch_counter_B
        BNE     L1915

        LDA     #$98
        
    .L1915
        STA     terrain_left_wall,X
        DEX
        DEY
        BNE     L190F

        RTS
}

\ ******************************************************************************
\ * Function: do_level_5_door_logic
\ * Description: Calculates door position and draws level 5 diamond-shaped door
\ ******************************************************************************

.do_level_5_door_logic
{
        SEC
        LDA     #$70
        SBC     window_ypos_INT
        STA     door_screen_ypos
        LDA     #$03
        SBC     window_ypos_EXT
        BNE     return

        LDA     door_screen_ypos
        CMP     #$EF
        BCC     L1931

    .return
        RTS

    .L1931
        LDA     door_switch_counter_A
        CMP     #$12
        BCS     L193C

        STA     door_switch_counter_B
        JMP     L1944

    .L193C
        LDA     door_switch_counter_B
        CMP     #$12
        BCS     L1944

        INC     door_switch_counter_B
        
    .L1944
        SEC
        LDA     #$C0
        SBC     door_switch_counter_B
        PHA
        LDA     door_screen_ypos
        CLC
        ADC     terrain_window_y_index
        TAY
        PLA
        CLC
        LDX     #$07
        
    .L1955
        STA     terrain_left_wall,Y
        ADC     #$01
        INY
        DEX
        BNE     L1955

        SEC
        LDX     #$08
        
    .L1961
        STA     terrain_left_wall,Y
        SBC     #$01
        INY
        DEX
        BNE     L1961

        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Player lives, score & fuel logic
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: lose_a_life
\ * Description: Decrements lives using BCD and returns $FF in X if none left
\ ******************************************************************************

.lose_a_life
{
        LDA     lives
        SEC
        SED
        SBC     #$01
        STA     lives
        CLD
        BPL     write_num_lives

        LDX     #$FF
        RTS
}

\ ******************************************************************************
\ * Function: extra_life
\ * Description: Increments the player's life count by one using BCD
\ ******************************************************************************

.extra_life
{
        LDA     lives
        CLC
        SED
        ADC     #$01
        STA     lives
        CLD
}

\ ******************************************************************************
\ * Function: write_num_lives
\ * Description: Displays the current number of lives on screen
\ ******************************************************************************

.write_num_lives
{
        PHA
        LDX     #$C1
        LDY     #$3F
        JSR     plot_char_set_scr_addr_XY

        PLA
        BEQ     zero_lives

        DEY
        LDX     #$00
        LDY     #$00
        JMP     plot_score_ext
}

\ ******************************************************************************
\ * Function: zero_lives
\ * Description: Displays '0' for lives when player has zero lives remaining
\ ******************************************************************************

.zero_lives
{
        LDA     #ASCII_space
        JSR     plot_char_A

        LDA     #$30                    ; ASCII '0'
        JMP     plot_char_A
}
    
.add_score_return
{
        RTS
}

\ ******************************************************************************
\ * Function: add_A_to_score
\ * Params: A = value to add to player score
\ * Returns: none
\ * Description: Adds A to 3-byte BCD score, awards extra life every 1000 pts
\ ******************************************************************************

.add_A_to_score
{
        LDX     demo_mode_flag
        BNE     add_score_return

        PHA
        LDA     score_B
        AND     #$F0
        STA     add_score_thousands                    ; number of thousands
        PLA
        SED
        CLC
        ADC     score_A
        STA     score_A
        LDA     #$00
        ADC     score_B
        STA     score_B
        LDA     #$00
        ADC     score_C
        STA     score_C
        CLD
        LDA     score_B
        AND     #$F0
        CMP     add_score_thousands
        BEQ     write_score

        JSR     extra_life
        JSR     countdown_sound

    .write_score
        LDA     #LO(score_A)
        STA     plot_string_ptr
        LDA     #HI(score_A)
        STA     plot_string_ptr+1
        LDA     #$0F
        LDX     #$61
        LDY     #$40
        JMP     plot_three_byte_BCD_number
}

\ ******************************************************************************
\ * Function: plot_three_byte_BCD_number
\ * Params: screen address in X,Y address of BCD number in L0080, A is pixel mask
\ * Returns: none
\ * Description: Plots a 3-byte BCD number to screen at given address
\ ******************************************************************************

.plot_three_byte_BCD_number            ; 
\\ {
        STA     font_byte_mask
        JSR     plot_char_set_scr_addr_XY

.plot_three_byte_BCD_number_ext
        LDX     #$00
        LDY     #$02
        
    .plot_BCD_loop
        LDA     (plot_string_ptr),Y

.plot_score_ext
        PHA
        ROR     A
        ROR     A
        ROR     A
        ROR     A
        AND     #$0F
        JSR     plot_number_zero_space

        PLA
        AND     #$0F
        JSR     plot_number_zero_space

        DEY
        BPL     plot_BCD_loop

        RTS
\\ }

\ ******************************************************************************
\ * Function: plot_char_set_scr_addr_XY
\ * Params: screen address in X,Y
\ * Returns: none
\ * Description: Sets the character write pointer to screen address X,Y
\ ******************************************************************************

.plot_char_set_scr_addr_XY
{
        STX     char_write_ptr_LO
        STY     char_write_ptr_HI
        RTS
}

\ ******************************************************************************
\ * Function: plot_number_zero_space
\ * Params: A = number to plot (0-9)
\ * Returns: none
\ * Description: Plots digit A as a character, or a space if leading zero
\ ******************************************************************************

.plot_number_zero_space
{
        BNE     plot_a_number

        CPX     #$00
        BNE     plot_a_number

        LDA     #ASCII_space
        JMP     plot_char_A

    .plot_a_number
        CLC
        ADC     #ASCII_0
        TAX
        JMP     plot_char_A
}
        
\ ******************************************************************************
\ * Function: add_fuel
\ * Description: Adds $11 to fuel (skipped in demo mode)
\ ******************************************************************************

.add_fuel
{
        LDA     demo_mode_flag
        BNE     fuel_return

        LDA     #$11
        LDX     #$00
        JMP     add_A_X_to_fuel
}

\ ******************************************************************************
\ * Function: use_fuel
\ * Description: Checks if fuel remains; if empty sets flag, else subtracts
\ ******************************************************************************

.use_fuel
{
        LDA     demo_mode_flag
        BNE     fuel_return

        LDA     #$00
        STA     fuel_just_ran_out_flag
        LDA     fuel_A
        ORA     fuel_B
        ORA     fuel_C
        BNE     subtract_from_fuel
}
\\ Fall through!

\ ******************************************************************************
\ * Function: fuel_is_empty
\ * Description: Sets fuel empty flag and displays '0' for fuel on screen
\ ******************************************************************************

.fuel_is_empty
{
        LDX     #$21
        LDY     #$3F
        JSR     plot_char_set_scr_addr_XY

        LDA     #ASCII_0
        JSR     plot_char_A

        LDA     #$FF
        STA     fuel_empty_flag
        STA     fuel_just_ran_out_flag
        RTS
}

\ ******************************************************************************
\ * Function: subtract_from_fuel
\ * Description: Subtracts 1 from fuel by adding $99,$99 in BCD (decimal -1)
\ ******************************************************************************

.subtract_from_fuel
{
        LDA     #$99
        LDX     #$99
}
\\ Fall through!
        
\ ******************************************************************************
\ * Function: add_A_X_to_fuel
\ * Params: add A to fuel_A, add X to fuel_B & fuel_C
\ * Returns: none
\ * Description: Adds A to fuel_A and X to fuel_B/C using BCD arithmetic
\ ******************************************************************************

.add_A_X_to_fuel                        ; 
{
        SED
        CLC
        ADC     fuel_A
        STA     fuel_A
        TXA
        ADC     fuel_B
        STA     fuel_B
        TXA
        ADC     fuel_C
        STA     fuel_C
        CLD
        ORA     fuel_B
        ORA     fuel_A
        BEQ     fuel_is_empty

        LDA     #$00
        STA     fuel_value_updated_flag
}
\\ Fall through!

.fuel_return
{
        RTS
}

IF _DEBUG_FRAME_TIME
.debug_frame_time_cs EQUB $00

.plot_debug_frame_time
{
        LDX     #$61
        LDY     #$3F
        JSR     plot_char_set_scr_addr_XY

        LDA     debug_frame_time_cs
        JMP     plot_number_zero_space
}
ENDIF

\ ******************************************************************************
\ * Function: plot_fuel_value
\ * Description: Plots the current fuel value to screen as a BCD number
\ ******************************************************************************

.plot_fuel_value
{
        LDA     fuel_value_updated_flag
        BNE     fuel_return

        LDA     fuel_empty_flag
        BMI     fuel_return

        LDA     #LO(fuel_A)
        STA     plot_string_ptr
        LDA     #HI(fuel_A)
        STA     plot_string_ptr+1
        LDA     #$0F
        STA     fuel_value_updated_flag
        LDX     #$D1
        LDY     #$3E
        JMP     plot_three_byte_BCD_number
}

\ ******************************************************************************
\ * Function: plot_high_score_table
\ * Description: Plots the high score table with ranks, scores and names
\ ******************************************************************************

.plot_high_score_table
{
        LDX     #$B0
        LDY     #$4C
        JSR     plot_char_set_scr_addr_XY

        LDY     #$01
        STY     high_score_ptr_A+1
        DEY
        STY     high_score_ptr_A            ; high_score_table at $100
        LDA     #$31
        STA     plot_high_score_number
        
    .L1AA9
        LDA     plot_high_score_number
        JSR     plot_char_A

        LDA     #$2E
        JSR     plot_char_A

        INC     plot_high_score_number
        JSR     plot_three_byte_BCD_number_ext

        LDA     #$30
        JSR     plot_char_A

        LDY     #$03
        
    .L1ABF
        LDA     (high_score_ptr_A),Y
        JSR     plot_char_A

        INY
        CPY     #$10
        BNE     L1ABF

    .L1AC9
        LDA     #$20
        JSR     plot_char_A

        INY
        CPY     #$1E
        BNE     L1AC9

        LDY     #$00
        LDA     high_score_ptr_A
        CLC
        ADC     #$10
        STA     high_score_ptr_A
        BPL     L1AA9

        RTS
}

\ ******************************************************************************
\ * Player variables - fuel & lives
\ ******************************************************************************

\\ Fuel stored in BCD - ones, hundreds, ten-thousands

.fuel_A
        EQUB    $00
.fuel_B
        EQUB    $00
.fuel_C
        EQUB    $00
.fuel_empty_flag
        EQUB    $00
.lives
        EQUB    $00

\ ******************************************************************************
\ ******************************************************************************
\ * String functions
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Functions: write_game_over, write_top_8_thrusters, write_congratulations,
\ * write_enter_name, write_press_spacebar, write_out_of_fuel
\ * Description: Loads string address and writes one of several game messages
\ ******************************************************************************

.write_game_over
        LDX        #LO(string_game_over): EQUB $2C                ; BIT - has the effect of skipping next two bytes
.write_top_8_thrusters
        LDX        #LO(string_top_8_thrusters): EQUB $2C        ; BIT - has the effect of skipping next two bytes
.write_congratulations
        LDX        #LO(string_congratulations): EQUB $2C        ; BIT - has the effect of skipping next two bytes
.write_enter_name
        LDX        #LO(string_enter_name): EQUB $2C            ; BIT - has the effect of skipping next two bytes
.write_press_spacebar
        LDX        #LO(string_press_spacebar): EQUB $2C        ; BIT - has the effect of skipping next two bytes
.write_out_of_fuel
        LDX     #LO(string_out_of_fuel)

\\ They all fall through!
{
        LDA     #HI(in_game_messages)
        STA     plot_string_ptr+1
}
\\ Fall through!

\ ******************************************************************************
\ * Function: write_message, write_message_ext
\ * Params: X = LO byte of ptr to string, Y = HI byte of ptr to string
\ * Returns: none
\ * Description: Reads screen pos and mask from string, then plots characters
\ ******************************************************************************

.write_message
{
        STX     plot_string_ptr
        LDY     #$00
        LDA     (plot_string_ptr),Y
        TAX
        INY
        LDA     (plot_string_ptr),Y
        TAY
        JSR     plot_char_set_scr_addr_XY
}
\\ Fall though!

.write_message_ext
{
        LDY     #$02
        LDA     (plot_string_ptr),Y
        STA     font_byte_mask
        
    .loop
        INY
        LDA     (plot_string_ptr),Y
        BMI     return

        JSR     plot_char_A
        JMP     loop

    .return
        LDA     #$0F
        STA     font_byte_mask
        RTS
}

\ ******************************************************************************
\ * Functions: write_in, write_complete, write_failed
\ * Description: Loads string address for end-of-level messages and plots them
\ ******************************************************************************

.write_in
        LDX     #LO(string_in): EQUB $2C                    ; BIT - has the effect of skipping next two bytes
.write_complete
        LDX     #LO(string_complete): EQUB $2C                ; BIT - has the effect of skipping next two bytes
.write_failed
        LDX        #LO(string_failed)
\\ They all fall through!
{
        STX     plot_string_ptr
        LDA     #HI(end_of_level_messages)
        STA     plot_string_ptr+1
        JMP     write_message_ext
}

\ ******************************************************************************
\ * Functions: write_mission, write_bonus, write_no_bonus,
\ * write_planet_destroyed, write_reverse_gravity, write_invisible_landscape
\ * Description: Loads string address for mission status messages and plots them
\ ******************************************************************************

.write_mission
        LDX     #LO(string_mission): EQUB $2C                ; BIT - has the effect of skipping next two bytes
.write_bonus
        LDX        #LO(string_bonus): EQUB $2C                    ; BIT - has the effect of skipping next two bytes
.write_no_bonus
        LDX        #LO(string_no_bonus): EQUB $2C                ; BIT - has the effect of skipping next two bytes
.write_planet_destroyed
        LDX        #LO(string_planet_destroyed): EQUB $2C        ; BIT - has the effect of skipping next two bytes
.write_reverse_gravity
        LDX        #LO(string_reverse_gravity): EQUB $2C        ; BIT - has the effect of skipping next two bytes
.write_invisible_landscape
        LDX        #LO(string_invisible_landscape)
\\ They all fall through!
{
        LDA     #HI(end_of_level_messages)
        STA     plot_string_ptr+1
        JMP     write_message
}

\ ******************************************************************************
\ ******************************************************************************
\ * Main player functions
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: ship_input_thrust_calculate_force
\ * Description: Zeroes or applies gravity to ship force vector based on state
\ ******************************************************************************

.ship_input_thrust_calculate_force
{
        LDA     pod_destroying_player_timer
        BMI     L1B5F

        LDA     pod_tethered_flag
        BNE     L1B5F

        LDA     player_ship_destroyed_flag
        BNE     L1B5F

        LDA     #$00
        STA     force_vectory_INT
        STA     force_vectory_FRAC
        STA     force_vectorx_INT
        STA     force_vectorx_FRAC
        RTS

    .L1B5F
        LDA     level_tick_counter
        AND     #$0F
        BEQ     add_gravity_to_force_vector

        CMP     #$03
        BEQ     add_gravity_to_force_vector

        CMP     #$05
        BEQ     add_gravity_to_force_vector

        CMP     #$08
        BEQ     add_gravity_to_force_vector

        CMP     #$0B
        BEQ     add_gravity_to_force_vector

        CMP     #$0D
        BEQ     add_gravity_to_force_vector

        RTS

    .add_gravity_to_force_vector
        CLC
        LDA     force_vectory_FRAC
        ADC     gravity_FRAC
        STA     force_vectory_FRAC
        LDA     force_vectory_INT
        ADC     gravity_SIGN
        STA     force_vectory_INT
IF _GRAVITY_WELL
        JSR     apply_gravity_wells_to_force
ENDIF

        LDA     pod_destroying_player_timer
        BPL     no_thrust

        LDA     fuel_just_ran_out_flag
        BNE     no_thrust

        LDX     #KEY_THRUST
        JSR     test_inkey

        BEQ     thrust_was_pressed

    .no_thrust
        JMP     end_of_thrust_force_calculation

    .thrust_was_pressed
        JSR     use_fuel
        JSR     run_engine
        IF _THRUST_PARTICLES
        JSR     create_thrust_particle
        ENDIF

        LDY     #$04
        LDA     pod_tethered_flag
        BEQ     L1BA6

        INY
    .L1BA6
        LDX     ship_angle
        LDA     angle_to_y_FRAC,X
        STA     calc_force_vectory_FRAC
        LDA     angle_to_y_INT,X
        
    .L1BB0
        ROR     A
        ROR     calc_force_vectory_FRAC
        DEY
        BNE     L1BB0

        AND     #$01
        EOR     #$FF
        CLC
        ADC     #$01
        STA     calc_force_vectory_INT
        LDY     #$04
        LDA     pod_tethered_flag
        BEQ     L1BC6
        INY

    .L1BC6
        LDA     angle_to_x_FRAC,X
        STA     calc_force_vectorx_FRAC
        LDA     angle_to_x_INT,X

    .L1BCE
        ROR     A
        ROR     calc_force_vectorx_FRAC
        ROR     calc_force_vectorx_FRAC_LO
        DEY
        BNE     L1BCE

        AND     #$01
        EOR     #$FF
        CLC
        ADC     #$01
        STA     calc_force_vectorx_INT
        CLC
        LDA     force_vectorx_FRAC_LO
        ADC     calc_force_vectorx_FRAC_LO
        STA     force_vectorx_FRAC_LO
        LDA     force_vectorx_FRAC
        ADC     calc_force_vectorx_FRAC
        STA     force_vectorx_FRAC
        LDA     force_vectorx_INT
        ADC     calc_force_vectorx_INT
        STA     force_vectorx_INT

        CLC
        LDA     force_vectory_FRAC
        ADC     calc_force_vectory_FRAC
        STA     force_vectory_FRAC
        LDA     force_vectory_INT
        ADC     calc_force_vectory_INT
        STA     force_vectory_INT
        LDA     level_tick_counter
        AND     #$0F
        CMP     #$03
        BNE     L1C0A

        JMP     end_of_thrust_force_calculation

    .L1C0A
        CMP     #$0B
        BNE     L1C11

        JMP     end_of_thrust_force_calculation

    .L1C11
        LDA     #$00
        STA     thrust_sign_extend
        SEC
        SBC     tether_angle_FRAC
        STA     thrust_angle_sub_frac
        LDA     ship_angle
        SBC     angle_ship_to_pod
        TAY
        LDA     thrust_angle_sub_frac
        CLC
        ADC     #$08
        STA     thrust_angle_sub_frac
        TYA
        ADC     #$00
        AND     #ANGLE_MASK
        TAY
        LDA     angle_to_x_FRAC,Y
        STA     ship_thrust_x_FRAC
        LDA     angle_to_x_INT,Y
        STA     ship_thrust_x_INT
        LDX     #$0E
        
    .L1C38
        LDA     thrust_angle_sub_frac
        AND     #$F0
        CMP     lookup_top_nibble,X
        BNE     L1C46

        INY
        TYA
        AND     #ANGLE_MASK
        TAY

    .L1C46
        CLC
        LDA     angle_to_x_FRAC,Y
        ADC     ship_thrust_x_FRAC
        STA     ship_thrust_x_FRAC
        LDA     angle_to_x_INT,Y
        ADC     ship_thrust_x_INT
        STA     ship_thrust_x_INT
        DEX
        BPL     L1C38

        LDA     ship_thrust_x_INT
        ROL     A
        ROR     ship_thrust_x_INT
        ROR     ship_thrust_x_FRAC

        LDA     ship_thrust_x_INT
        BPL     L1C67
        LDA     #$FF
        STA     thrust_sign_extend
        
    .L1C67
        CLC
        LDA     tether_angular_vel_LO
        STA     prev_tether_vel_LO
        ADC     ship_thrust_x_FRAC
        STA     tether_angular_vel_LO
        LDA     tether_angular_vel_FRAC
        STA     prev_tether_vel_FRAC
        ADC     ship_thrust_x_INT
        STA     tether_angular_vel_FRAC
        LDA     tether_angular_vel_INT
        STA     prev_tether_vel_INT
        ADC     thrust_sign_extend
        STA     tether_angular_vel_INT
        LDA     prev_tether_vel_INT
        LDX     #$06

    .L1C84
        PHA
        ROL     A
        PLA
        ROR     A
        ROR     prev_tether_vel_FRAC
        ROR     prev_tether_vel_LO
        DEX
        BNE     L1C84

        STA     prev_tether_vel_INT

        CLC
        LDA     tether_angular_vel_LO
        SBC     prev_tether_vel_LO
        STA     tether_angular_vel_LO
        LDA     tether_angular_vel_FRAC
        SBC     prev_tether_vel_FRAC
        STA     tether_angular_vel_FRAC
        LDA     tether_angular_vel_INT
        SBC     prev_tether_vel_INT
        STA     tether_angular_vel_INT

    .end_of_thrust_force_calculation
        LDA     force_vectorx_FRAC_LO
        STA     calc_force_vectory_FRAC
        LDA     force_vectorx_FRAC
        STA     calc_force_vectory_INT
        LDA     force_vectorx_INT
        LDX     #$06

    .L1CB0
        PHA
        ROL     A
        PLA
        ROR     A
        ROR     calc_force_vectory_INT
        ROR     calc_force_vectory_FRAC
        DEX
        BNE     L1CB0

        STA     calc_force_vectorx_FRAC
        SEC
        LDA     force_vectorx_FRAC_LO
        SBC     calc_force_vectory_FRAC
        STA     force_vectorx_FRAC_LO
        LDA     force_vectorx_FRAC
        SBC     calc_force_vectory_INT
        STA     force_vectorx_FRAC
        LDA     force_vectorx_INT
        SBC     calc_force_vectorx_FRAC
        STA     force_vectorx_INT
        LDA     #$00
        STA     calc_force_vectorx_INT
        LDA     force_vectory_INT
        BPL     L1CDC

        LDA     #$FF
        STA     calc_force_vectorx_INT

    .L1CDC
        LDA     force_vectory_FRAC
        STA     calc_force_vectory_FRAC
        LDA     force_vectory_INT
        STA     calc_force_vectory_INT
        LDA     calc_force_vectorx_INT
        LDX     #$08

    .L1CE8
        PHA
        ROL     A
        PLA
        ROR     A
        ROR     calc_force_vectory_INT
        ROR     calc_force_vectory_FRAC
        DEX
        BNE     L1CE8

        STA     calc_force_vectorx_FRAC
        SEC
        LDA     force_vectory_FRAC
        SBC     calc_force_vectory_FRAC
        STA     force_vectory_FRAC
        LDA     force_vectory_INT
        SBC     calc_force_vectory_INT
        STA     force_vectory_INT
        LDA     calc_force_vectorx_INT
        SBC     calc_force_vectorx_FRAC
        STA     calc_force_vectorx_INT
        RTS
}

\ ******************************************************************************
\ * Top nibble look up table
\ ******************************************************************************

.lookup_top_nibble
        EQUB    $10,$20,$30,$40,$50,$60,$70,$80,$90,$A0,$B0,$C0,$D0,$E0,$F0

\ ******************************************************************************
\ * Function: test_for_pause
\ * Description: Check for pause/unpause via Copy key, and Q/S for mute/sound toggle
\ ******************************************************************************

.test_for_pause
{
        LDX        #KEY_PAUSE
        JSR        test_inkey
        BNE     not_paused

        LDA     shield_tractor_pressed
        BNE     not_paused

    .pause_loop
        LDA     #$01
        STA     level_tick_state

        LDA     #$0F
        LDX     #$00
        JSR     OSBYTE                    ; *FX 15 - flush all buffers

        JSR     OSRDCH                    ; read character from input stream

        CMP     #KEY_UNPAUSE            ; unpause key
        BNE     pause_loop

        JSR     reset_system_clock

        LDA     #$00
        STA     level_tick_state

    .not_paused
        LDX     #INKEY_Q                ; quiet key
        JSR     test_inkey

        BNE     q_not_pressed
        STX     mute_sound_flag

    .q_not_pressed
        LDX     #INKEY_S                ; sound key
        JSR     test_inkey

        BNE     s_not_pressed

        LDA     #$00
        STA     mute_sound_flag

    .s_not_pressed
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * This code is not called directly - these bytes are used to write over existing code
\ ******************************************************************************
\ ******************************************************************************

.ship_AND_pixel_mask_CODE
        AND     pixel_masks_1,X
IF _FAST_SPRITES=FALSE
.ship_SKIP_pixel_mask_CODE
        JMP     plot_ship_loop
ENDIF

\ ******************************************************************************
\ * Function: update_shield_tractor_draw_ship_and_pod
\ * Description: Handle shield/tractor input, erase old ship sprite, draw new ship and pod
\ ******************************************************************************

.update_shield_tractor_draw_ship_and_pod
{
        JSR     calculate_attached_pod_vector

        LDA     gravity_SIGN
        BPL     L1D61

        ; Reverse gravity.
        JSR     draw_pod_and_collision_test

    .L1D61
        LDA     ship_sprite_plotted_flag
        BNE     ship_input_shield_tractor

        JMP     L1DB3

    .ship_input_shield_tractor
        LDA     #$00
        STA     shield_tractor_pressed
        STA     sheild_tractor_flag

        LDA     pod_destroying_player_timer
        BPL     no_sheild_tractor

        LDA     fuel_just_ran_out_flag
        BNE     no_sheild_tractor

        LDX     #KEY_SHIELD
        JSR     test_inkey

        STX     shield_tractor_pressed
        CPX     #$00
        BEQ     no_sheild_tractor

        LDA     vsync_count
        AND     #$02
        BEQ     no_sheild_tractor

        LDA     #$01
        STA     sheild_tractor_flag

        JSR     use_fuel
        JSR     run_engine_ext

    .no_sheild_tractor
        LDA     #$00
        STA     ship_sprite_plotted_flag

IF _FAST_SPRITES
        SET_RAM_BANK	SPRITE_BANK
ENDIF

        LDX     #$02

    .overwrite_ship_pixel_AND_CODE
IF _FAST_SPRITES
        LDA     ship_ts_AND_CODE,X
        STA     ship_ts_collision_test,X                      ; **MODIFIES CODE**
ELSE
        LDA     ship_AND_pixel_mask_CODE,X
        STA     ship_pixel_mask_test,X                        ; **MODIFIES CODE**
ENDIF
        DEX
        BPL     overwrite_ship_pixel_AND_CODE

IF _FAST_SPRITES
        SET_RAM_BANK    SWRAM_BANK
ENDIF

        LDA     old_plot_ship_at_ptr
        STA     plot_ship_at_ptr
        LDA     old_plot_ship_at_ptr+1
        STA     plot_ship_at_ptr+1
        
        LDA     old_plot_ship_sprite_number
        STA     plot_ship_sprite_number
        LDA     old_plot_ship_pixel_column
        STA     plot_ship_pixel_column
        
IF _FAST_SPRITES
        SET_RAM_BANK	SPRITE_BANK
ENDIF
        JSR     plot_ship_or_shield

    .L1DB3
        LDX     #$02
        
    .overwrite_ship_pixel_SKIP_CODE
IF _FAST_SPRITES
        LDA     ship_ts_SKIP_CODE,X
        STA     ship_ts_collision_test,X                      ; **MODIFIES CODE**
ELSE
        LDA     ship_SKIP_pixel_mask_CODE,X
        STA     ship_pixel_mask_test,X                        ; **MODIFIES CODE**
ENDIF
        DEX
        BPL     overwrite_ship_pixel_SKIP_CODE

IF _FAST_SPRITES
        SET_RAM_BANK    SWRAM_BANK
ENDIF

        LDA     ship_angle
        STA     plot_ship_sprite_number
        STA     old_plot_ship_sprite_number
        LDA     sheild_tractor_flag
        BEQ     L1DCE

    ; Plot shield.

        LDA     #$FF
        STA     plot_ship_sprite_number
        STA     old_plot_ship_sprite_number
        
    .L1DCE
        CLC
        LDA     midpoint_ypos_FRAC
        ADC     midpoint_deltay_FRAC
        STA     ship_window_ypos_FRAC
        LDA     player_ydist_in_window_INT
        ADC     midpoint_deltay_INT
        STA     ship_window_ypos_INT
        LDX     ship_angle
        LDA     plot_ship_sprite_number
        BPL     L1DFB

        LDA     angle_to_y_FRAC,X
        STA     calc_ship_delta_FRAC
        LDA     angle_to_y_INT,X
        STA     calc_ship_delta_INT
        ROL     A
        ROR     calc_ship_delta_INT
        LDA     calc_ship_delta_FRAC
        ROR     A
        ADC     ship_window_ypos_FRAC
        STA     ship_window_ypos_FRAC
        LDA     calc_ship_delta_INT
        ADC     ship_window_ypos_INT
        STA     ship_window_ypos_INT
        
    .L1DFB
        ROL     ship_window_ypos_FRAC
        ROL     ship_window_ypos_INT
        CLC
        LDA     midpoint_xpos_FRAC_LO
        ADC     midpoint_deltax_FRAC_LO
        LDA     midpoint_xpos_FRAC
        ADC     midpoint_deltax_FRAC
        PHA
        STA     ship_window_xpos_FRAC
        LDA     player_xdist_in_window_INT
        ADC     midpoint_deltax_INT
        STA     calc_ship_window_xpos_INT
        STA     ship_window_xpos_INT
        LDA     plot_ship_sprite_number
        BPL     L1E30

        LDA     angle_to_x_FRAC,X
        STA     calc_ship_delta_FRAC
        LDA     angle_to_x_INT,X
        STA     calc_ship_delta_INT
        ROL     A
        ROR     calc_ship_delta_INT
        ROR     calc_ship_delta_FRAC
        PLA
        ADC     calc_ship_delta_FRAC
        PHA
        LDA     calc_ship_window_xpos_INT
        ADC     calc_ship_delta_INT
        STA     calc_ship_window_xpos_INT
        
    .L1E30
        PLA
        ROL     A
        ROL     A
        ROL     A
        AND     #PIXEL_COLUMN_MASK
        STA     plot_ship_pixel_column
        STA     old_plot_ship_pixel_column
        LDA     #$00
        STA     plot_ship_at_ptr
        STA     plot_ship_row_counter
        LDA     ship_window_ypos_INT
        CLC
        AND     #$F8
        ROR     A
        ROR     A
        STA     plot_ship_at_ptr+1
        ROR     A
        ROR     A
        ROR     plot_ship_at_ptr
        ROR     A
        ROR     plot_ship_at_ptr
        ADC     #SCREEN_ADDR_HI_OFFSET
        ADC     plot_ship_at_ptr+1
        STA     plot_ship_at_ptr+1
        LDA     player_ship_destroyed_flag
        BMI     L1E61

        LDA     #$00
        STA     player_ship_destroyed_flag
        JMP     draw_pod_and_collision_test

    .L1E61
        LDA     plot_ship_collision_detected
        BNE     L1E88

        LDA     #$01
        STA     ship_sprite_plotted_flag
        LDY     calc_ship_window_xpos_INT
        LDA     mult_by_8_LO,Y
        ADC     plot_ship_at_ptr
        STA     plot_ship_at_ptr
        LDA     mult_by_8_HI,Y
        ADC     plot_ship_at_ptr+1
        STA     plot_ship_at_ptr+1
        STA     old_plot_ship_at_ptr+1
        LDA     ship_window_ypos_INT
        AND     #$07
        ADC     plot_ship_at_ptr
        STA     plot_ship_at_ptr
        STA     old_plot_ship_at_ptr
IF _FAST_SPRITES
        SET_RAM_BANK	SPRITE_BANK
ENDIF
        JSR     plot_ship_or_shield
IF _FAST_SPRITES
        SET_RAM_BANK    SWRAM_BANK
ENDIF

    .L1E88
        LDA     gravity_SIGN
        BMI     return

    ; Normal gravity.

        JSR     draw_pod_and_collision_test

    .return
        RTS
}

IF _FAST_SPRITES=FALSE
\ ******************************************************************************
\ * Function: plot_ship_or_shield
\ * Params: plot_ship_at_ptr = screen address to plot sprite,
\ * plot_ship_pixel_column, plot_ship_sprite_number = ?
\ * Description: Plot ship or shield sprite at screen address using self-modifying code
\ ******************************************************************************

.plot_ship_or_shield
{
        LDA     #LO(pixel_masks_3)
        STA     ship_pixel_mask_addr_LO                    ; **MODIFIES CODE**
        LDA     #HI(pixel_masks_3)
        STA     ship_pixel_mask_addr_HI                    ; **MODIFIES CODE**
        LDA     #$C9                    ; OPCODE CMP IMMEDIATE
        STA     plot_ship_write_opcode                    ; **MODIFIES CODE**
        LDA     #$FF                    ; OPCODE value
        STA     plot_ship_write_value                    ; **MODIFIES CODE**
        LDA     plot_ship_sprite_number
        BPL     L1EB7

        LDA     #LO(pixel_masks_1)
        STA     ship_pixel_mask_addr_LO                    ; **MODIFIES CODE**
        LDA     #HI(pixel_masks_1)
        STA     ship_pixel_mask_addr_HI                    ; **MODIFIES CODE**

        LDA     #SHIELD_SPRITE_INDEX                    ; sheild sprite?
        JMP     L1ECB

    .L1EB7
        CMP     #SHIELD_SPRITE_INDEX
        BCC     L1ECB

        LDA     #$49                    ; OPCODE EOR IMMEDIATE
        STA     plot_ship_write_opcode                    ; **MODIFIES CODE**
        LDA     #$1F                    ; OPCODE value
        STA     plot_ship_write_value                    ; **MODIFIES CODE**
        LDA     plot_ship_sprite_number
        EOR     #$1F
        ADC     #$00
        
    .L1ECB
        TAY
        LDA     ship_sprite_ptr_table_LO,Y
        STA     ship_sprite_addr_1_LO                    ; **MODIFIES CODE**
        STA     ship_sprite_addr_2_LO                    ; **MODIFIES CODE**
        STA     ship_sprite_addr_3_LO                    ; **MODIFIES CODE**
        LDA     ship_sprite_ptr_table_HI,Y
        STA     ship_sprite_addr_1_HI                    ; **MODIFIES CODE**
        STA     ship_sprite_addr_2_HI                    ; **MODIFIES CODE**
        STA     ship_sprite_addr_3_HI                    ; **MODIFIES CODE**
        LDA     plot_ship_at_ptr
        AND     #$07
        EOR     #$07
        STA     plot_ship_row_counter
        LDX     #$00
        JMP     plot_ship_start
}

\ ******************************************************************************
\ * Function: plot_ship_loop
\ * Description: Inner loop to plot ship sprite pixels to screen with collision detection
\ ******************************************************************************

.plot_ship_loop
\\ {
        LDX     plot_ship_index
        INX
        
.plot_ship_start
        STX     plot_ship_index

    .L1EF6
        LDA     ship_sprite_0_data,X        ; **SELF-MODIFIED CODE**
        ship_sprite_addr_1_LO   = L1EF6+1
        ship_sprite_addr_1_HI   = L1EF6+2
        BMI     L1F1F

    .plot_ship_inner_loop
        SEC
        
.plot_ship_write_opcode
        EOR     #$1F                    ; **SELF-MODIFIED CODE**
        plot_ship_write_value   = plot_ship_write_opcode+1

        ADC     plot_ship_pixel_column
        TAY
        AND     #$3C
        ROL     A
        STA     plot_ship_at_y_offset
        TYA
        AND     #PIXEL_COLUMN_MASK
        TAX

.ship_load_pixel_mask
        LDA     pixel_masks_1,X            ; **SELF-MODIFIED CODE**
        ship_pixel_mask_addr_LO   = ship_load_pixel_mask+1
        ship_pixel_mask_addr_HI   = ship_load_pixel_mask+2

        LDY     plot_ship_at_y_offset
        EOR     (plot_ship_at_ptr),Y
        STA     (plot_ship_at_ptr),Y

.ship_pixel_mask_test
        AND     pixel_masks_1,X            ; **SELF-MODIFIED CODE**
        BEQ     plot_ship_loop

        LDA     #$FF
        STA     plot_ship_collision_detected
        JMP     plot_ship_loop

    .L1F1F
        CMP     #$FF
        BEQ     plot_ship_return

        LDX     plot_ship_index
        DEC     plot_ship_row_counter
        BMI     L1F35

        INC     plot_ship_at_ptr
        
    .L1F2B
        LDA     ship_sprite_4_data,X                ; **SELF-MODIFIED CODE**
        ship_sprite_addr_2_LO   = L1F2B+1
        ship_sprite_addr_2_HI   = L1F2B+2
        CMP     #$80
        BNE     plot_ship_inner_loop

        JMP     plot_ship_loop

    .L1F35
        LDA     #$07
        STA     plot_ship_row_counter
        CLC
        LDA     plot_ship_at_ptr
        ADC     #$39
        STA     plot_ship_at_ptr
        LDA     plot_ship_at_ptr+1
        ADC     #$02
        STA     plot_ship_at_ptr+1                        ; $239 - character row bytes - 7
        
    .L1F46
        LDA     ship_sprite_4_data,X                ; **SELF-MODIFIED CODE**
        ship_sprite_addr_3_LO   = L1F46+1
        ship_sprite_addr_3_HI   = L1F46+2
        CMP     #$80
        BNE     plot_ship_inner_loop

        JMP     plot_ship_loop

    .plot_ship_return
        RTS
\\ }
ENDIF ; _FAST_SPRITES=FALSE

; ******************************************************************************
; Function: calculate_attached_pod_vector
;
; Description:
;   Convert a tether angle (integer + fractional accumulator) into a vector
;   (midpoint_deltax, midpoint_deltay).
;
;   The vector represents the displacement from the CENTRE of the tether
;   to the spaceship; the full tether length is therefore twice this vector.
;
; High‑level equivalent (after final scaling):
;   dx ≈  1.25 * sin(angle) * (tetherIndex + 2) / 4
;   dy ≈ -2.5  * cos(angle) * (tetherIndex + 2) / 4
;
; Note that normally, tetherIndex=14; so the tether length is fixed.
; However when the player's ship is exploding, the tether beam is seen
; to contract.  So in that case tetherIndex is decreased in steps of 2,
; so as to create that animation.
;
; Implementation summary:
;   - Uses 32‑entry fixed‑point SIN/COS lookup tables
;   - Fractional angles are handled via linear interpolation
;   - Interpolation is implemented by repeated accumulation plus a
;     single controlled angle increment inside the loop
; ******************************************************************************

.calculate_attached_pod_vector
{
        LDA     tether_angle_FRAC               ; fractional angle (0–255)
        CLC
        ADC     #$08                            ; bias by +8
        STA     pod_angle_sub_frac              ; store (fraction + 8)
        LDA     angle_ship_to_pod               ; integer angle (0–31)
        ADC     #$00                            ; add carry from frac+8
        AND     #ANGLE_MASK                     ; wrap into 32‑entry table
        TAY                                     ; Y = starting angle index

; ---------------------------------------------------------------------------
; Load first SIN/COS sample into the accumulators.
;
; This contributes the FIRST of (tetherIndex + 2) total samples.
; The remaining (tetherIndex + 1) samples are added in the loop below.
; ---------------------------------------------------------------------------

        LDA     angle_to_x_FRAC,Y
        STA     midpoint_deltax_FRAC
        LDA     angle_to_x_INT,Y
        STA     midpoint_deltax_INT

        LDA     angle_to_y_FRAC,Y
        STA     midpoint_deltay_FRAC
        LDA     angle_to_y_INT,Y
        STA     midpoint_deltay_INT

; ---------------------------------------------------------------------------
; Prepare nibble‑controlled accumulation loop.
;
; top_nibble_index corresponds directly to pod.tetherIndex.
; The loop executes (top_nibble_index + 1) times.
;
; Combined with the initial sample above, this yields exactly
; (tetherIndex + 2) accumulated SIN/COS samples.
; ---------------------------------------------------------------------------

        LDX     top_nibble_index               ; typically initialised to $0E (14)

; ===========================================================================
; NIBBLE‑CONTROLLED ACCUMULATION LOOP
;
; For each iteration:
;   - The top nibble of (fraction + 8) is compared against a lookup table
;     indexed by the loop counter.
;   - When a match occurs, Y is incremented EXACTLY ONCE, switching from
;     angleShipToPod to angleShipToPod + 1.
;   - One SIN and COS table entry is added to the accumulators.
;
; Effect:
;   - First K samples use angleShipToPod
;   - Remaining samples use angleShipToPod + 1
;
; This implements linear interpolation between adjacent table entries.
; ===========================================================================

.L1F75
        LDA     pod_angle_sub_frac            ; (fraction + 8)
        AND     #$F0                          ; extract top nibble
        CMP     lookup_top_nibble,X           ; does angle advance here?
        BNE     L1F83

        INY                                   ; switch to angle + 1
        TYA
        AND     #ANGLE_MASK
        TAY
        
    .L1F83
        CLC
        LDA     angle_to_x_FRAC,Y
        ADC     midpoint_deltax_FRAC
        STA     midpoint_deltax_FRAC
        LDA     angle_to_x_INT,Y
        ADC     midpoint_deltax_INT
        STA     midpoint_deltax_INT

        CLC
        LDA     angle_to_y_FRAC,Y
        ADC     midpoint_deltay_FRAC
        STA     midpoint_deltay_FRAC
        LDA     angle_to_y_INT,Y
        ADC     midpoint_deltay_INT
        STA     midpoint_deltay_INT

        DEX
        BPL     L1F75                         ; loop while X >= 0

; ---------------------------------------------------------------------------
; Final normalisation: arithmetic shift right by 2 (divide by 4).
;
; The accumulated result is intentionally over‑scaled. Dividing by 4
; produces the final tether vector:
;
;   dx ≈  1.25 * sin(angle) * (tetherIndex + 2) / 4
;   dy ≈ -2.5  * cos(angle) * (tetherIndex + 2) / 4
; ---------------------------------------------------------------------------

        LDA     midpoint_deltax_INT
        ROL     A
        ROR     midpoint_deltax_INT
        ROR     midpoint_deltax_FRAC
        ROR     midpoint_deltax_FRAC_LO       ; >> 1
        LDA     midpoint_deltax_INT
        ROL     A
        ROR     midpoint_deltax_INT
        ROR     midpoint_deltax_FRAC
        ROR     midpoint_deltax_FRAC_LO       ; >> 1 again (÷4 total)

        LDA     midpoint_deltay_INT
        ROL     A
        ROR     midpoint_deltay_INT
        ROR     midpoint_deltay_FRAC          ; >> 1
        LDA     midpoint_deltay_INT
        ROL     A
        ROR     midpoint_deltay_INT
        ROR     midpoint_deltay_FRAC          ; >> 1 again (÷4 total)

        RTS
}

\ ******************************************************************************
\ * Function: update_pod_tractor_beam
\ * Description: Check if tractor beam should activate based on pod and button state
\ ******************************************************************************

.update_pod_tractor_beam
{
        LDA     pod_sprite_plotted_flag
        BNE     L1FD3

        LDA     level_obj_flags                ; what's special about first entry in table? -> must be pod!
        AND     #(OBJ_flag_drawn OR OBJ_flag_alive)
        CMP     #(OBJ_flag_drawn OR OBJ_flag_alive)
        BEQ     L1FD3

        RTS

    .L1FD3
        LDA     pod_lifted_flag
        BMI     tractor_beam_return

        LDA     shield_tractor_pressed
        BNE     do_pod_tractor_beam

        STA     tractor_beam_started_flag
        RTS
}

\ ******************************************************************************
\ * Function: do_pod_tractor_beam
\ * Description: Activate tractor beam, check distance to pod, attach pod if close enough
\ ******************************************************************************

.do_pod_tractor_beam
{
        LDA     pod_destroying_player_timer
        BPL     tractor_beam_return

        LDA     tractor_beam_started_flag
        STA     pod_line_exists_flag
        
        JSR     get_distance_ship_to_pod_tractor        ; must return distance?

        CMP     #TRACTOR_BEAM_ACTIVATE_DIST
        BCC     set_flag

        CMP     #TRACTOR_BEAM_ATTACH_DIST                                    ; must be distance of ship from pod stand
        BCS     attach_pod_to_ship

        RTS

    .set_flag
        LDA     #$01
        STA     tractor_beam_started_flag
        STA     pod_line_exists_flag
}
\\ Fall through!

.tractor_beam_return
{
        RTS
}

; ******************************************************************************
; Function: attach_pod_to_ship
;
; Called when the tractor beam successfully attaches a pod to the ship.
;
; This routine transitions the game from “ship only” physics to
; “ship + pod” physics by:
;
;   - Marking the pod as attached and updating level state flags.
;
;   - Computing the exact midpoint between the ship and the pod in
;     fixed‑point world coordinates.  This midpoint becomes the origin
;     of the attached system (the centre of mass).
;
;   - Conserving momentum by halving the ship’s existing linear force
;     vectors so that ship and pod move together as a single body.
;
;   - Computing the target vector from the midpoint to the ship, with
;     intentional asymmetric scaling of X and Y to match the geometry
;     of the tether lookup tables.
;
;   - Performing a 7‑pass coarse‑to‑fine angular search to determine the
;     tether angle (integer angle + fractional accumulator) whose
;     calculated tether vector most closely matches the ship→midpoint
;     direction.  Conceptually, this search is equivalent to solving an
;     atan2‑style operation without using trigonometry.
;
;   - Finalising the attachment by deriving angular impulse and rotational
;     velocity terms based on the chosen tether angle and the current
;     linear forces, enabling the pendulum‑like swinging behaviour of the
;     ship and pod.
;
; On exit, the physics state is fully initialised for an attached pod:
; the midpoint is established, the tether angle is fixed, forces are
; rebalanced, and the angular motion of the combined system is ready to
; evolve on subsequent ticks.
;
; ******************************************************************************
.attach_pod_to_ship
{
        LDA     tractor_beam_started_flag     ; exit if tractor beam inactive
        BEQ     tractor_beam_return

        LDA     #$FF                          ; mark pod as attached
        STA     pod_tethered_flag
        STA     pod_lifted_flag
        STA     level_reset_with_pod_flag

; ---------------------------------------------------------------------------
; Compute midpoint between ship and pod.
;
; This midpoint is the SEARCH TARGET.  We are looking for the tether vector
; from the midpoint to the ship.
;
; X midpoint is computed as a fixed‑point average (INT+FRAC).
; Y midpoint uses extended precision (Q10.8 via INT_HI).
; ---------------------------------------------------------------------------

        CLC
        LDA     player_xpos_FRAC
        ADC     nearest_obj_xpos_FRAC
        STA     midpoint_xpos_FRAC
        LDA     player_xpos_INT
        ADC     nearest_obj_xpos_INT
        ROR     A
        STA     midpoint_xpos_INT
        ROR     midpoint_xpos_FRAC

        CLC
        LDA     player_ypos_FRAC
        ADC     #$80                         ; +0.5 for divide‑by‑2 rounding
        STA     midpoint_ypos_FRAC
        LDA     player_ypos_INT
        ADC     nearest_obj_ypos_INT
        STA     midpoint_ypos_INT
        LDA     player_ypos_INT_HI
        ADC     nearest_obj_ypos_INT_HI
        ROR     A
        STA     midpoint_ypos_INT_HI
        ROR     midpoint_ypos_INT
        ROR     midpoint_ypos_FRAC

; ---------------------------------------------------------------------------
; Halve ship force vectors.
;
; This conserves momentum: after attachment, ship + pod move as one body.
; ---------------------------------------------------------------------------

        LDA     force_vectory_INT
        ROL     A
        ROR     force_vectory_INT
        ROR     force_vectory_FRAC

        LDA     force_vectorx_INT
        ROL     A
        ROR     force_vectorx_INT
        ROR     force_vectorx_FRAC
        ROR     force_vectorx_FRAC_LO        ; X uses extra precision (Q7.16)

; ---------------------------------------------------------------------------
; Compute target vector = ship − midpoint.
;
; Axes are intentionally scaled asymmetrically so they match the scale
; of the tether vectors produced by calculate_attached_pod_vector:
;   - X scaled ×4
;   - Y scaled ×2
;
; This compensates for the different X/Y magnitudes (1.25 vs 2.5).
; ---------------------------------------------------------------------------

        LDA     player_xpos_FRAC
        SBC     midpoint_xpos_FRAC
        STA     attach_pod_delta_x_frac         ; target dX frac
        LDA     player_xpos_INT
        SBC     midpoint_xpos_INT               ; target dX int
        STA     delta_x_shifted
        ROL     attach_pod_delta_x_frac
        ROL     delta_x_shifted
        ROL     attach_pod_delta_x_frac
        ROL     delta_x_shifted                 ; X scaled ×4
        LDA     delta_x_shifted
        STA     delta_x_scaled                  ; store target dX int

        LDA     player_ypos_FRAC
        SBC     midpoint_ypos_FRAC
        STA     delta_y_frac                    ; target dY frac
        LDA     player_ypos_INT
        SBC     midpoint_ypos_INT
        STA     delta_y_shifted                 ; target dY int
        ROL     delta_y_frac
        ROL     delta_y_shifted                 ; Y scaled ×2
        LDA     delta_y_shifted
        STA     attach_pod_delta_y_scaled       ; store target dY int

; ---------------------------------------------------------------------------
; Now perform a search of which angle will produce a tractor beam 
; vector which most closely matches target dX and target dY
; 
; This routine computes the midpoint between the ship and pod, then performs
; a 7‑pass coarse‑to‑fine angular search to determine the tether angle
; (integer + fractional) whose tether vector best matches the ship→pod axis.
;
; Conceptually, the nested loops are performing a single atan2‑like operation:
; The objective of these 2 nested loops is to calculate:
;   angle ≈ atan2(targetDx / 1.25, targetDy / -2.5) * (32 / 2π)
;
; The 6502 implementation avoids trig by:
;   - generating candidate tether vectors
;   - comparing them to the target direction
;   - minimising a Manhattan distance metric
;
; Each pass tests 3 candidate angles and then halves the search step size.
;
; Initialise angular search parameters.
;
; stepHi:stepLo form a Q8.8 angle step.
; Initial step ≈ 32 / 3, dividing the full angular range into thirds.
;
; The search runs for 7 passes, halving the step size each time.
; ---------------------------------------------------------------------------

        LDA     #$0A
        STA     angle_step_int                  ; stepHi
        LDA     #$AB
        STA     angle_step_frac                 ; stepLo
        LDA     #$07
        STA     search_iterations               ; number of passes
        LDA     #$00
        STA     tether_angle_FRAC               ; starting angleFrac
        STA     angle_ship_to_pod               ; starting integer angle
        
; ===========================================================================
; OUTER LOOP: 7‑PASS COARSE‑TO‑FINE ANGLE SEARCH
; ===========================================================================

    .L207E
        LDA     #$FF
        STA     best_distance                   ; best distance this pass
        LDX     #$03
        STX     search_inner_count              ; 3 candidate angles
        
; ---------------------------------------------------------------------------
; INNER LOOP: test 3 candidate angles at current step size
;
; These candidates divide the current angular search window into thirds.
; ---------------------------------------------------------------------------

    .L2086
        JSR     calculate_attached_pod_vector   ; compute candidate tether vector

        ROL     midpoint_deltax_FRAC
        ROL     midpoint_deltax_INT
        ROL     midpoint_deltax_FRAC
        ROL     midpoint_deltax_INT            ; X scaled ×4
        ROL     midpoint_deltay_FRAC
        ROL     midpoint_deltay_INT            ; Y scaled ×2

; Compute |dx − target_dx|

        SEC
        LDA     midpoint_deltax_INT
        SBC     delta_x_shifted
        BPL     L20A0
        EOR     #$FF
        ADC     #$01
        
    .L20A0
        STA     multiply_operand_a              ; |ΔX|

; Compute |dy − target_dy|

        SEC
        LDA     midpoint_deltay_INT
        SBC     delta_y_shifted
        BPL     L20AD
        EOR     #$FF
        ADC     #$01
        
    .L20AD
        STA     multiply_result_lo              ; |ΔY|

; Combine |ΔX| and |ΔY| into a Manhattan distance metric.
;
; X contributes twice the weight of Y implicitly due to scaling above.
; ---------------------------------------------------------------------------

        JSR     get_distance_ship_to_pod_tractor_ext

; Keep the best candidate this pass

        CMP     best_distance
        BCS     L20C0

        STA     best_distance                   ; new best distance
        LDA     tether_angle_FRAC
        STA     prev_tether_vel_LO              ; save best frac
        LDA     angle_ship_to_pod
        STA     temp_angle_ship_to_pod          ; save best int
        
; Advance angle to next candidate: angle += step (Q8.8)
; Carry from fractional addition propagates into integer angle.

    .L20C0
        CLC
        LDA     tether_angle_FRAC
        ADC     angle_step_frac
        STA     tether_angle_FRAC
        LDA     angle_ship_to_pod
        ADC     angle_step_int
        AND     #ANGLE_MASK
        STA     angle_ship_to_pod

        DEC     search_inner_count
        BNE     L2086                           ; test next candidate

        LDA     prev_tether_vel_LO
        STA     tether_angle_FRAC
        LDA     temp_angle_ship_to_pod
        STA     angle_ship_to_pod

        CLC
        ROR     angle_step_int                  ; step >> 1 (Q8.8)
        ROR     angle_step_frac

; ---------------------------------------------------------------------------
; Prepare for next pass.
; Rewind angle by half a step so the new search window is centered.
; ---------------------------------------------------------------------------

        DEC     search_iterations
        BEQ     L20F6                           ; after 7 passes, done

        SEC
        LDA     tether_angle_FRAC
        SBC     angle_step_frac
        STA     tether_angle_FRAC
        LDA     angle_ship_to_pod
        SBC     angle_step_int
        AND     #ANGLE_MASK
        STA     angle_ship_to_pod
        JMP     L207E
; ---------------------------------------------------------------------------
; Atan2 calculation is now finished.
; ---------------------------------------------------------------------------

; ===========================================================================
; 
; Final phase: derive angular velocity / torque terms based on final angle
; ===========================================================================

.L20F6
        LDA     force_vectorx_INT
        STA     multiply_operand_a
        LDA     force_vectorx_FRAC
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a              ; project X force onto tether frame
        LDA     attach_pod_delta_y_scaled
        JSR     multiply_signed_8x8             ; (force_x << 4) * delta_y_scaled

        LDA     multiply_result_lo
        STA     cross_product_term_lo
        LDA     multiply_result_hi
        STA     cross_product_term_hi
        LDA     force_vectory_INT
        STA     multiply_operand_a
        LDA     force_vectory_FRAC
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a
        ROL     A
        ROL     multiply_operand_a              ; project Y force similarly
        LDA     delta_x_scaled
        JSR     multiply_signed_8x8             ; (force_y << 4) * delta_x_scaled

; Compute net angular impulse (difference of projections)

        SEC
        LDA     multiply_result_lo
        SBC     cross_product_term_lo
        STA     tether_angular_vel_FRAC
        LDA     multiply_result_hi
        SBC     cross_product_term_hi
        PHA
        ROL     A
        PLA
        ROR     A
        ROR     tether_angular_vel_FRAC
        PHA
        ROL     A
        PLA
        ROR     A
        ROR     tether_angular_vel_FRAC
        STA     tether_angular_vel_INT          ; final angular velocity term
        
        JSR     collect_pod_fuel_sound          ; audio feedback on attachment

        RTS
}
\ ******************************************************************************
\ * Function: generate_stars_to_start
\ * Description: Draw ship sprite and animate star particles until counter wraps to zero
\ ******************************************************************************

.generate_stars_to_start
{
        LDA     #$08
        STA     plot_ship_sprite_number
        LDA     #$A0
        STA     plot_ship_at_ptr
        LDA     #$56
        STA     plot_ship_at_ptr+1
        LDA     #$00
        STA     window_xpos_INT
        STA     window_ypos_EXT
        STA     plot_ship_pixel_column
IF _FAST_SPRITES
        SET_RAM_BANK	SPRITE_BANK
ENDIF
        JSR     plot_ship_or_shield
IF _FAST_SPRITES
        SET_RAM_BANK    SWRAM_BANK
ENDIF

    .loop
        JSR     particles_update_and_draw

        INC     level_tick_counter
        LDY     #$03
        JSR     wait_time_out_Y

        INC     window_xpos_INT
        BNE     loop

        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * This code is not called directly - these bytes are used to write over existing code
\ ******************************************************************************
\ ******************************************************************************

.ship_fn_SKIP_pixel_mask_CODE
        JMP     plot_pod_loop

\ ******************************************************************************
\ * Function: plot_pod_sprite
\ * Params: plot_pod_xpos_FRAC = ?,plot_pod_xpos_INT = ?,
\ * plot_pod_ypos_INT = ?
\ * Description: Calculate screen address from pod position and plot pod sprite
\ ******************************************************************************

.plot_pod_sprite
\\ {
        JSR     set_plot_pod_sprite_mask_addr

        LDA     plot_pod_xpos_FRAC
        ROL     A
        ROL     A
        ROL     A
        AND     #PIXEL_COLUMN_MASK
        STA     pod_pixel_column
        LDA     #$00
        STA     plot_pod_sprite_at_ptr
        STA     pod_temp
        LDA     plot_pod_ypos_INT
        CLC
        AND     #$F8
        ROR     A
        ROR     A
        STA     plot_pod_sprite_at_ptr+1
        ROR     A
        ROR     A
        ROR     plot_pod_sprite_at_ptr
        ROR     A
        ROR     plot_pod_sprite_at_ptr
        ADC     #SCREEN_ADDR_HI_OFFSET
        ADC     plot_pod_sprite_at_ptr+1
        STA     plot_pod_sprite_at_ptr+1
        LDY     plot_pod_xpos_INT
        LDA     mult_by_8_LO,Y
        ADC     plot_pod_sprite_at_ptr
        STA     plot_pod_sprite_at_ptr
        LDA     mult_by_8_HI,Y
        ADC     plot_pod_sprite_at_ptr+1
        STA     plot_pod_sprite_at_ptr+1
        STA     pod_screen_addr_HI
        LDA     plot_pod_ypos_INT
        AND     #$07
        ADC     plot_pod_sprite_at_ptr
        STA     plot_pod_sprite_at_ptr
        STA     pod_screen_addr_LO

    .L21B6
        JSR     set_plot_pod_sprite_mask_addr

        LDA     pod_sprite_ptr_LO
        STA     pod_sprite_load_addr_1_LO                    ; **MODIFIES CODE**
        STA     pod_sprite_load_addr_2_LO                    ; **MODIFIES CODE**
        STA     pod_sprite_load_addr_3_LO                    ; **MODIFIES CODE**
        LDA     pod_sprite_ptr_HI
        STA     pod_sprite_load_addr_1_HI                    ; **MODIFIES CODE**
        STA     pod_sprite_load_addr_2_HI                    ; **MODIFIES CODE**
        STA     pod_sprite_load_addr_3_HI                    ; **MODIFIES CODE**
        LDX     #$00
        JMP     L21D7

.plot_pod_loop
        LDX     pod_sprite_data_index
        INX

    .L21D7
        STX     pod_sprite_data_index

    .L21D9
        LDA     LFFFF,X                    ; **SELF-MODIFIED CODE**
        pod_sprite_load_addr_1_LO   = L21D9+1
        pod_sprite_load_addr_1_HI   = L21D9+2
        BMI     L2202

    .L21DE
        CLC
        ADC     pod_pixel_column
        STA     pod_temp
        AND     #$3C
        ROL     A
        STA     plot_pod_sprite_y_offset
        LDA     pod_temp
        AND     #PIXEL_COLUMN_MASK
        TAX

.plot_pod_sprite_load_pixel_mask
        LDA     pixel_masks_1,X            ; **SELF-MODIFIED CODE**
        plot_pod_sprite_mask_addr_LO   = plot_pod_sprite_load_pixel_mask+1
        plot_pod_sprite_mask_addr_HI   = plot_pod_sprite_load_pixel_mask+2

        LDY     plot_pod_sprite_y_offset
        EOR     (plot_pod_sprite_at_ptr),Y
        STA     (plot_pod_sprite_at_ptr),Y

.plot_pod_sprite_test_pixel_mask
        AND     pixel_masks_1,X            ; **SELF-MODIFIED CODE**
        BEQ     plot_pod_loop

        LDA     #$FF
        
    .L21FD
        STA     plot_pod_collision_detected            ; **SELF-MODIFIED CODE**
        plot_pod_sprite_addr_zp   = L21FD+1
        JMP     plot_pod_loop

    .L2202
        CMP     #$FF
        BEQ     plot_pod_sprite_return

        LDA     plot_pod_sprite_at_ptr
        AND     #$07
        CMP     #$07
        BEQ     L221A

        INC     plot_pod_sprite_at_ptr

    .L2210
        LDA     LFFFF,X                    ; **SELF-MODIFIED CODE**
        pod_sprite_load_addr_2_LO   = L2210+1
        pod_sprite_load_addr_2_HI   = L2210+2
        CMP     #$80
        BNE     L21DE

        JMP     plot_pod_loop

    .L221A
        CLC
        LDA     plot_pod_sprite_at_ptr
        ADC     #$39
        STA     plot_pod_sprite_at_ptr
        LDA     plot_pod_sprite_at_ptr+1
        ADC     #$02                            ; character row = $240 bytes -> $239 = $240 - 7
        STA     plot_pod_sprite_at_ptr+1

    .L2227
        LDA     LFFFF,X                            ; **SELF-MODIFIED CODE**
        pod_sprite_load_addr_3_LO   = L2227+1
        pod_sprite_load_addr_3_HI   = L2227+2
        CMP     #$80
        BNE     L21DE

        JMP     plot_pod_loop

    .plot_pod_sprite_return
        RTS
\\ }

\ ******************************************************************************
\ * Function: set_plot_pod_sprite_mask_addr
\ * Description: Set pod sprite pixel mask address from lookup table based on X index
\ ******************************************************************************

.set_plot_pod_sprite_mask_addr
{
        LDA     pixel_mask_ptrs_LO-1,X    ; presume X>0
        STA     plot_pod_sprite_mask_addr_LO                    ; **MODIFIES CODE**
        LDA     pixel_mask_ptrs_HI-1,X
        STA     plot_pod_sprite_mask_addr_HI                    ; **MODIFIES CODE**
        RTS
}

.pixel_mask_ptrs_LO
        EQUB    LO(pixel_masks_3)
        EQUB    LO(pixel_masks_2)
        EQUB    LO(pixel_masks_1)

.pixel_mask_ptrs_HI
        EQUB    HI(pixel_masks_3)
        EQUB    HI(pixel_masks_2)
        EQUB    HI(pixel_masks_1)

\ ******************************************************************************
\ * Function: draw_pod_and_collision_test
\ * Description: Erase old pod sprite, redraw at new position, detect ship-pod collision
\ ******************************************************************************

.draw_pod_and_collision_test
{
        LDA     #plot_pod_collision_detected                                ; yes, this is immediate!
        STA     plot_pod_sprite_addr_zp
        LDA     #$00
        STA     plot_pod_collision_detected
        LDX     #$02
        
    .copy_loop1
        LDA     ship_AND_pixel_mask_CODE,X
        STA     plot_pod_sprite_test_pixel_mask,X                    ; **MODIFIES CODE**
        DEX
        BPL     copy_loop1

        LDA     #LO(pod_sprite_data)
        STA     pod_sprite_ptr_LO
        LDA     #HI(pod_sprite_data)
        STA     pod_sprite_ptr_HI
        LDA     pod_sprite_plotted_flag
        BEQ     L227A

        LDA     #$00
        STA     pod_sprite_plotted_flag
        LDA     old_plot_pod_sprite_at_ptr
        STA     plot_pod_sprite_at_ptr
        LDA     old_plot_pod_sprite_at_ptr+1
        STA     plot_pod_sprite_at_ptr+1
        LDA     old_pod_pixel_column
        STA     pod_pixel_column
        LDX     #$03
        JSR     L21B6

    .L227A
        LDA     pod_lifted_flag
        BNE     L2282

        JMP     return

    .L2282
        LDX     #$02
        
    .copy_loop2
        LDA     ship_fn_SKIP_pixel_mask_CODE,X
        STA     plot_pod_sprite_test_pixel_mask,X                            ; **MODIFIES CODE**
        DEX
        BPL     copy_loop2

        SEC
        LDA     midpoint_ypos_FRAC
        SBC     midpoint_deltay_FRAC
        STA     pod_temp
        LDA     player_ydist_in_window_INT
        SBC     midpoint_deltay_INT
        ROL     pod_temp
        ROL     A
        STA     plot_pod_ypos_INT
        STA     pod_window_ypos_INT
        SEC
        LDA     midpoint_xpos_FRAC_LO
        SBC     midpoint_deltax_FRAC_LO
        LDA     midpoint_xpos_FRAC
        SBC     midpoint_deltax_FRAC
        STA     plot_pod_xpos_FRAC
        STA     pod_window_xpos_FRAC
        LDA     player_xdist_in_window_INT
        SBC     midpoint_deltax_INT
        STA     plot_pod_xpos_INT
        STA     pod_window_xpos_INT
        LDX     #$03
        LDA     pod_tethered_flag
        BNE     L22BF

        LDA     #$00
        STA     plot_pod_collision_detected
        RTS

    .L22BF
        LDA     #$01
        STA     pod_sprite_plotted_flag
        JSR     plot_pod_sprite

        LDA     pod_screen_addr_LO
        STA     old_plot_pod_sprite_at_ptr
        LDA     pod_screen_addr_HI
        STA     old_plot_pod_sprite_at_ptr+1
        LDA     pod_pixel_column
        STA     old_pod_pixel_column

    .return
        RTS
}

\ ******************************************************************************
\ * Unreachable code?
\ ******************************************************************************

        RTS

\ ******************************************************************************
\ ******************************************************************************
\ * IRQ handler
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: irq1_handler
\ * Description: IRQ handler for vsync and Timer1; sets up video timing and palette
\ ******************************************************************************

.irq1_handler
{
        PHP
        PHA
        LDA     #$02
        BIT     SHEILA_System_VIA_Interrupt_Flag
        BNE     irq1_vsync

        LDA     #$40
        BIT     SHEILA_User_VIA_Interrupt_Flag
        BNE     irq1_timer1

        PLA
        PLP
        JMP     (old_irq1v)

    .irq1_timer1
        LDA     SHEILA_User_VIA_Timer1_Low_Order
        LDA     #$01
        STA     irq1_timer1_signal
        PLA
        PLP
        LDA     IRQ1_RETURN_A
        RTI

    .irq1_vsync
        TXA
        PHA
        TYA
        PHA
        LDA     SHEILA_System_VIA_Register_A
        LDA     #$80
        STA     SHEILA_User_VIA_Aux_Ctrl_Reg
        LDA     #$C0
        STA     SHEILA_User_VIA_Interrupt_Enable
        LDA     #$00
        STA     SHEILA_User_VIA_Timer1_Low_Order
        LDA     #$38
        STA     SHEILA_User_VIA_Timer1_High_Order
        LDA     #$D8
        STA     SHEILA_Video_ULA
        LDA     #$00
        STA     irq1_timer1_signal
        INC     vsync_count
        LDX     planet_explode_anim
        BEQ     irq1_return

        LDA     background_colour_table,X
        LDY     #$00
        JSR     palette_set_colour_Y_to_A

        LDA     #$00
        LDY     #$02
        JSR     palette_set_colour_Y_to_A

        LDA     vsync_count
        AND     #$01
        BEQ     irq1_return

        DEC     planet_explode_anim

    .irq1_return
        PLA
        TAY
        PLA
        TAX
        PLA
        PLP
        LDA     IRQ1_RETURN_A
        RTI
}

\ ******************************************************************************
\ * Colour table used when planet explodes
\ ******************************************************************************

.background_colour_table
{
        EQUB    $00,$00,$04,$01,$05,$02,$06,$03
        EQUB    $07,$07,$03,$06,$02,$05,$01,$04
}

\ ******************************************************************************
\ ******************************************************************************
\ * Ship routines
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: ship_input_rotate
\ * Description: Read capslock/ctrl keys to rotate ship angle left or right
\ ******************************************************************************

.ship_input_rotate
{
        LDA     level_tick_counter
        AND     #$03
        BEQ     return

        LDX     #KEY_ROTATE_left
        JSR     test_inkey
        BNE     rotate_left_not_pressed

        DEC     ship_angle
        
    .rotate_left_not_pressed
        LDX     #KEY_ROTATE_right
        JSR     test_inkey
        BNE     rotate_right_not_pressed

        INC     ship_angle

    .rotate_right_not_pressed
        LDA     ship_angle
        AND     #ANGLE_MASK
        STA     ship_angle

    .return
        RTS
}

\ ******************************************************************************
\ * Function: midpoint_add_force_vector
\ * Description: Add force vector to midpoint position and update tether swing angle
\ ******************************************************************************

.midpoint_add_force_vector
{
        CLC
        LDA     midpoint_xpos_FRAC_LO
        ADC     force_vectorx_FRAC_LO
        STA     midpoint_xpos_FRAC_LO
        LDA     midpoint_xpos_FRAC
        ADC     force_vectorx_FRAC
        STA     midpoint_xpos_FRAC
        LDA     midpoint_xpos_INT
        ADC     force_vectorx_INT
        STA     midpoint_xpos_INT

        CLC
        LDA     midpoint_ypos_FRAC
        ADC     force_vectory_FRAC
        STA     midpoint_ypos_FRAC
        LDA     force_vectory_INT
        BMI     ship_force_negative

        ADC     midpoint_ypos_INT
        STA     midpoint_ypos_INT
        BCC     ship_ypos_no_ext

        INC     midpoint_ypos_INT_HI
        JMP     ship_ypos_no_ext

    .ship_force_negative
        ADC     midpoint_ypos_INT
        STA     midpoint_ypos_INT
        BCS     ship_ypos_no_ext

        DEC     midpoint_ypos_INT_HI
        
    .ship_ypos_no_ext
        LDA     pod_destroying_player_timer
        BPL     L23A7

        LDA     pod_tethered_flag
        BEQ     return

    .L23A7
        CLC
        LDA     tether_angular_vel_LO
        ADC     tether_angle_LO
        STA     tether_angle_LO
        LDA     tether_angular_vel_FRAC
        ADC     tether_angle_FRAC
        STA     tether_angle_FRAC
        LDA     tether_angular_vel_INT
        ADC     angle_ship_to_pod
        AND     #ANGLE_MASK
        STA     angle_ship_to_pod

    .return
        RTS
}

\ ******************************************************************************
\ * Function: calculate_player_position_from_midpoint
\ * Description: Derive ship and pod positions from midpoint plus/minus delta vector
\ ******************************************************************************

.calculate_player_position_from_midpoint
{
        CLC
        LDA     midpoint_xpos_FRAC_LO
        STA     temp_midpoint_xpos_FRAC_LO

        LDA     midpoint_xpos_FRAC
        ADC     midpoint_deltax_FRAC
        STA     new_ship_xpos_FRAC
        LDA     midpoint_xpos_INT
        ADC     midpoint_deltax_INT
        STA     new_ship_xpos_INT

        CLC
        LDA     midpoint_ypos_FRAC
        ADC     midpoint_deltay_FRAC
        STA     new_ship_ypos_FRAC
        LDA     midpoint_ypos_INT
        ADC     midpoint_deltay_INT
        STA     new_ship_ypos_INT
        PHP
        LDA     midpoint_deltay_INT
        BMI     L23E5

        LDA     #$00
        JMP     L23E7

    .L23E5
        LDA     #$FF
        
    .L23E7
        PLP
        ADC     midpoint_ypos_INT_HI
        STA     new_ship_ypos_INT_HI

        SEC
        LDA     temp_midpoint_xpos_FRAC_LO
        SBC     old_midpoint_xpos_FRAC_LO
        STA     diff_midpoint_xpos_FRAC_LO
        
        LDA     new_ship_xpos_FRAC
        SBC     player_xpos_FRAC
        STA     player_velocityx_FRAC
        LDA     new_ship_xpos_INT
        SBC     player_xpos_INT
        STA     player_velocityx_INT

        SEC
        LDA     new_ship_ypos_FRAC
        SBC     player_ypos_FRAC
        STA     player_velocityy_FRAC
        LDA     new_ship_ypos_INT
        SBC     player_ypos_INT
        STA     player_velocityy_INT
        LDA     new_ship_ypos_INT_HI
        SBC     player_ypos_INT_HI
        STA     player_velocityy_INT_HI

        LDA     player_xpos_FRAC
        STA     old_player_xpos_FRAC
        LDA     player_xpos_INT
        STA     old_player_xpos_INT
        LDA     player_ypos_INT
        STA     old_player_ypos_INT
        LDA     player_ypos_INT_HI
        STA     old_player_ypos_INT_HI

        LDA     temp_midpoint_xpos_FRAC_LO
        STA     old_midpoint_xpos_FRAC_LO

        LDA     new_ship_xpos_FRAC
        STA     player_xpos_FRAC
        LDA     new_ship_xpos_INT
        STA     player_xpos_INT
        LDA     new_ship_ypos_FRAC
        STA     player_ypos_FRAC
        LDA     new_ship_ypos_INT
        STA     player_ypos_INT
        LDA     new_ship_ypos_INT_HI
        STA     player_ypos_INT_HI
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Particle system
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: create_explosion
\ * Description: Create explosion particles at given position with sound effect
\ ******************************************************************************

.create_explosion
{
        JSR     explosion_sound

        LDX     #$08
        LDA     explosion_particle_type
        CMP     #PARTICLE_type_random_debris                        ; random debris
        BNE     loop

        LDX     #$03
        LDA     level_tick_counter
        AND     #$01
        STA     explosion_particle_type
        INC     explosion_particle_type
        JSR     rnd

        AND     #ANGLE_MASK
        STA     explosion_angle
        
    .loop
        STX     explosion_particle_count
        JSR     particle_return_free_slot_in_Y

        LDA     explosion_xpos_FRAC
        STA     particles_xpos_FRAC,Y
        LDA     explosion_xpos_INT
        STA     particles_xpos_INT,Y
        LDA     explosion_ypos_INT
        STA     particles_ypos_INT,Y
        LDA     explosion_ypos_INT_HI
        STA     particles_ypos_INT_HI,Y
        LDX     explosion_particle_count
        JSR     rnd

        AND     #$03
        CLC
        ADC     explosion_angle
        AND     #ANGLE_MASK
        TAX
        LDA     angle_to_x_FRAC,X
        STA     explosion_dx_FRAC
        LDA     angle_to_x_INT,X
        STA     explosion_dx_INT
        LDA     angle_to_y_FRAC,X
        STA     explosion_dy_FRAC
        LDA     angle_to_y_INT,X
        STA     explosion_dy_INT
        LDA     explosion_dx_INT
        ROL     A
        PHP
        PHP
        PHP
        PHP
        LDX     #$04
        
    .L249A
        PLP
        ROR     explosion_dx_INT
        ROR     explosion_dx_FRAC
        DEX
        BNE     L249A

        LDA     explosion_dy_INT
        ROL     A
        PHP
        PHP
        PHP
        PHP
        LDX     #$04
        
    .L24AB
        PLP
        ROR     explosion_dy_INT
        ROR     explosion_dy_FRAC
        DEX
        BNE     L24AB

        LDA     #$00
        STA     particles_dx_FRAC,Y
        STA     particles_dx_INT,Y
        STA     particles_dy_FRAC,Y
        STA     particles_dy_INT,Y
        LDA     rnd_B
        AND     #$03
        TAX
        INX
        INX
        PHA
        
    .L24C9
        CLC
        LDA     explosion_dx_FRAC
        ADC     particles_dx_FRAC,Y
        STA     particles_dx_FRAC,Y
        LDA     explosion_dx_INT
        ADC     particles_dx_INT,Y
        STA     particles_dx_INT,Y
        CLC
        LDA     explosion_dy_FRAC
        ADC     particles_dy_FRAC,Y
        STA     particles_dy_FRAC,Y
        LDA     explosion_dy_INT
        ADC     particles_dy_INT,Y
        STA     particles_dy_INT,Y
        DEX
        BNE     L24C9

        PLA
        ROL     A
        ROL     A
        ROL     A
        EOR     #ANGLE_MASK
        STA     explosion_dx_FRAC
        LDA     particles_lifetime,Y
        ROL     A
        LDA     rnd_A
        AND     #$0F
        ROR     A
        ADC     explosion_dx_FRAC
        ADC     #$08
        STA     particles_lifetime,Y
        LDA     explosion_particle_type
        STA     particles_type,Y
        CLC
        LDA     explosion_angle
        ADC     #$04
        AND     #ANGLE_MASK
        STA     explosion_angle
        TYA
        TAX

        JSR     particle_move_index_X
        JSR     particle_move_index_X

        LDX     explosion_particle_count
        DEX
        BEQ     return

        JMP     loop

    .return
        RTS
}

\ ******************************************************************************
\ * Function: particle_return_free_slot_in_Y
\ * Params: none
\ * Returns: Y = next free slot in particle table
\ * Description: Find and return index of first free slot in the particle table
\ ******************************************************************************

.particle_return_free_slot_in_Y
{
        LDY     #PARTICLE_table_max

    .L2527
        LDA     particles_lifetime,Y
        AND     #($FF EOR PARTICLE_flag)
        BEQ     return

        DEY
        BNE     L2527

        LDY     #PARTICLE_table_max
        
    .L2533
        LDA     particles_lifetime,Y
        AND     #($FF EOR PARTICLE_flag)
        CMP     #PARTICLE_lifetime_generator
        BCC     return

        DEY
        BNE     L2533

    .L253F
        BEQ     return
        BNE     L253F

        JSR     rnd
        AND     #$0F
        ADC     #$04
        TAY

    .return
        RTS
}

IF _SWRAM_BUILD==FALSE
INCLUDE "thrust1/level_data.asm"
ENDIF

\ ******************************************************************************
\ * level_obj_flags: per-object state bits (one byte per object slot, 20 slots).
\ * Indexed by current_object (0-19). Initialised to OBJ_flag_alive for all
\ * slots at level load (see initialise_level_pointers at
\ * initialise_sprite_table_A). Flag bit constants live near the OBJECT_*
\ * block at the top of the file.
\ *
\ *   bit 0  OBJ_flag_drawn ($01) "sprite drawn"
\ *                    Set by plot_static_sprite after XORing pixels to screen.
\ *                    Tested each frame by the update loop (ROR into carry):
\ *                    when set, the object's previous pixels must be erased
\ *                    before it can be redrawn at a new position.
\ *                    Cleared after re-plotting in the same location, and
\ *                    cleared for all slots on screen wipe / level reset.
\ *
\ *   bit 1  OBJ_flag_alive ($02) "active / alive"
\ *                    Cleared on destroy (bullet hit), when fuel has been
\ *                    fully tractor-collected, when the pod attaches to its
\ *                    pod_stand, and while the generator is in its exploding
\ *                    countdown. Re-asserted each frame for pod_stand (while
\ *                    empty) and generator (while recharging). The per-type
\ *                    update branches short-circuit when this bit is clear.
\ *
\ *   bits 2-7         unused.
\ *
\ * Special case: update_pod_tractor_beam reads level_obj_flags (no ,X -
\ * hardcoded index 0) and tests that both OBJ_flag_drawn and OBJ_flag_alive
\ * are set. This is the "pod must be object index 0" coupling noted in
\ * docs/ideas.md.
\ ******************************************************************************

.level_obj_flags                                        ; initialised to OBJ_flag_alive at start of level
{
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
IF _SWRAM_BUILD
        \ extend to LEVEL_MAX_OBJECTS+1 entries; the init and screen-wipe
        \ loops count X from LEVEL_MAX_OBJECTS down, so the array must be
        \ at least that long to avoid corrupting adjacent tables
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
ENDIF
}

.level_obj_plot_at_ptr_LO
{
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
IF _SWRAM_BUILD
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
ENDIF
}

.level_obj_plot_at_ptr_HI
{
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
IF _SWRAM_BUILD
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00
ENDIF
}

\ ******************************************************************************
\ * Function: particles_update_and_draw
\ * Description: Erase, move, and redraw all active particles each frame
\ ******************************************************************************

.particles_update_and_draw
{
        JSR     particles_generate_stars

        LDA     #$00
        STA     particle_temp_clear_77
        LDA     #$00
        STA     particle_temp_clear_79

        LDX     #PARTICLE_table_max
        
    .particle_update_loop_X
        LDA     #$00
        STA     particle_collision_flag
        LDA     particles_lifetime,X
        BPL     L28D3

        AND     #($FF EOR PARTICLE_flag)
        STA     particles_lifetime,X
        LDA     particles_scraddr_LO,X
        STA     particle_write_ptr
        LDA     particles_scraddr_HI,X
        STA     particle_write_ptr+1
        LDY     #$00
        LDA     particles_pixels_byte,X
        PHA
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        PLA
        INY
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        
    .L28D3
        LDY     particles_lifetime,X
        BEQ     particle_update_next_X

        DEY
        TYA
        STA     particles_lifetime,X
        JSR     test_particle_X_close_to_player

        JSR     particle_move_index_X

        LDY     particles_type,X
        LDA     lookup_particle_type_to_pixel_byte,Y
        STA     particle_pixel_byte
        JMP     L28F5

    .particle_update_next_X
        DEX
        BMI     return

        JMP     particle_update_loop_X

    .return
        RTS

    .L28F5
        SEC
        LDA     particles_ypos_INT,X
        SBC     window_ypos_INT
        STA     particle_screen_y
        LDA     particles_ypos_INT_HI,X
        SBC     window_ypos_EXT
        BNE     L2938

        LDA     particle_screen_y
        CLC
        ADC     terrain_window_y_index
        TAY
        LDA     particles_xpos_INT,X
        CMP     terrain_left_wall,Y                ; bullet vs terrain collision detection?
        BCC     L2938

        CMP     terrain_right_wall,Y                ; bullet vs terrain collision detection?
        BCS     L2938

        LDA     particles_xpos_INT,X
        SEC
        SBC     window_xpos_INT
        BCC     next_X1

        CMP     #SCREEN_WIDTH_CHARS
        BCS     next_X1

        STA     particle_screen_x
        SEC
        LDA     particle_screen_y
        SBC     #SCREEN_ADDR_HI_OFFSET
        STA     particle_screen_y
        CMP     #$11
        BCC     next_X1

        CMP     #$7F
        BCC     L2940

    .next_X1
        JMP     particle_update_next_X

    .L2938
        LDA     #$00
        STA     particles_lifetime,X
        JMP     particle_update_next_X

    .L2940
        LDA     particles_lifetime,X
        ORA     #$80
        STA     particles_lifetime,X
        LDA     particle_screen_y
        ROL     A
        STA     particle_screen_y
        LDY     #$00
        STY     particle_write_ptr
        AND     #$F8
        ROR     A
        ROR     A
        STA     particle_write_ptr+1
        ROR     A
        ROR     A
        ROR     particle_write_ptr
        ROR     A
        ROR     particle_write_ptr
        ADC     #SCREEN_ADDR_HI_OFFSET
        ADC     particle_write_ptr+1
        STA     particle_write_ptr+1
        LDY     particle_screen_x
        LDA     mult_by_8_LO,Y
        ADC     particle_write_ptr
        STA     particle_write_ptr
        LDA     mult_by_8_HI,Y
        ADC     particle_write_ptr+1
        STA     particle_write_ptr+1
        STA     particles_scraddr_HI,X
        LDA     particle_screen_y
        AND     #$07
        CMP     #$07
        BNE     L2981

        LDA     #$06
        
    .L2981
        CLC
        ADC     particle_write_ptr
        STA     particle_write_ptr
        STA     particles_scraddr_LO,X
        LDA     particles_xpos_FRAC,X
        ROL     A
        ROL     A
        ROL     A
        AND     #PIXEL_COLUMN_MASK
        TAY
        LDA     particles_xpos_byte_mask,Y
        STA     particle_byte_mask
        AND     particle_pixel_byte
        STA     particle_masked_pixels
        PHA
        STA     particles_pixels_byte,X
        LDY     #$00
        STY     particle_collision_flag
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        AND     particle_byte_mask
        CMP     particle_masked_pixels
        BEQ     L29B1

        LDA     #$FF
        STA     particle_collision_flag
        
    .L29B1
        INY
        PLA
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        AND     particle_byte_mask
        CMP     particle_masked_pixels
        BEQ     L29C1

        LDA     #$FF
        STA     particle_collision_flag
        
    .L29C1
        LDA     particle_collision_flag
        BEQ     next_X2

        LDA     particles_type,X
        CMP     #PARTICLE_type_hostile_bullet
        BNE     L29D1

        LDA     #$81
        STA     particles_lifetime,X

    .L29D1
        LDA     particles_type,X
        CMP     #PARTICLE_type_debris
        BEQ     L29E0

        CMP     #$02
        BEQ     L29E0

        LDA     shield_tractor_pressed
        BEQ     next_X2

    .L29E0
        LDA     particles_pixels_byte,X
        PHA
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        PLA
        DEY
        EOR     (particle_write_ptr),Y
        STA     (particle_write_ptr),Y
        LDA     particles_lifetime,X
        AND     #$7F
        STA     particles_lifetime,X
        LDA     particles_type,X
        CMP     #PARTICLE_type_hostile_bullet
        BCC     next_X2

        LDA     #$00
        STA     particles_lifetime,X

    .next_X2
        JMP     particle_update_next_X
}

\ ******************************************************************************
\ * Function: test_particle_X_close_to_player
\ * Params: X = index into particle table
\ * Returns: plot_ship_collision_detected
\ * Description: Test if a hostile bullet particle is close enough to hit the player
\ ******************************************************************************

.test_particle_X_close_to_player
{
        LDA     particles_type,X
        CMP     #PARTICLE_type_hostile_bullet
        BNE     return

        LDA     particles_xpos_INT,X
        SBC     player_xpos_INT
        CMP     #$03
        BCC     return

        CMP     #$06
        BCS     return

        SEC
        LDA     particles_ypos_INT,X
        SBC     player_ypos_INT
        STA     player_to_particle_deltay_INT
        LDA     particles_ypos_INT_HI,X
        SBC     player_ypos_INT_HI
        BNE     return

        LDA     player_to_particle_deltay_INT
        CMP     #$02
        BCC     return

        CMP     #$07
        BCS     return

        LDA     ship_sprite_plotted_flag
        BEQ     return

        LDA     particles_lifetime,X
        AND     #$80
        STA     particles_lifetime,X
        LDA     shield_tractor_pressed
        BNE     return

        LDA     #$FF
        STA     plot_ship_collision_detected

    .return
        RTS
}

\ ******************************************************************************
\ * Particle look up tables
\ ******************************************************************************

.particles_xpos_byte_mask
        EQUB    $CC,$66,$66,$33

.lookup_particle_type_to_pixel_byte
        EQUB    $FF,$FF,$0F

.hostile_bullet_pixel_byte
        EQUB    $F0

\ ******************************************************************************
\ * Function: particle_move_index_X
\ * Params: X = index into particle table
\ * Returns: none
\ * Description: Move a particle by adding its velocity to its position
\ ******************************************************************************

.particle_move_index_X
{
        CLC
        LDA     particles_xpos_FRAC,X
        ADC     particles_dx_FRAC,X
        STA     particles_xpos_FRAC,X
        LDA     particles_xpos_INT,X
        ADC     particles_dx_INT,X
        STA     particles_xpos_INT,X
        CLC
        LDA     particles_ypos_FRAC,X
        ADC     particles_dy_FRAC,X
        STA     particles_ypos_FRAC,X
        LDA     particles_ypos_INT,X
        ADC     particles_dy_INT,X
        STA     particles_ypos_INT,X
        PHP
        LDA     particles_dy_INT,X
        BMI     L2A80

        LDA     #$00
        JMP     L2A82

    .L2A80
        LDA     #$FF
        
    .L2A82
        PLP
        ADC     particles_ypos_INT_HI,X
        STA     particles_ypos_INT_HI,X
}
\\ Fall through!

.particles_return        ; used by above & below functions
{
        RTS
}

\ ******************************************************************************
\ * Function: particles_generate_stars
\ * Description: Spawn random stationary star particles near top of screen
\ ******************************************************************************

.particles_generate_stars
{
        LDA     window_ypos_EXT
        CMP     #$02
        BCS     particles_return

        LDA     level_tick_counter
        AND     #$01
        BNE     particles_return

        JSR     particle_return_free_slot_in_Y

        JSR     rnd

        ADC     #$64
        STA     particles_ypos_INT,Y
        LDA     #$00
        ADC     #$00
        STA     particles_ypos_INT_HI,Y
        LDA     #$00
        STA     particles_dx_FRAC,Y
        STA     particles_dx_INT,Y
        STA     particles_dy_FRAC,Y
        STA     particles_dy_INT,Y
        LDA     rnd_B
        AND     #$3F
        ADC     window_xpos_INT
        ADC     #$05
        STA     particles_xpos_INT,Y

        LDA     particles_lifetime,Y
        AND     #PARTICLE_flag
        ORA     #PARTICLE_lifetime_star
        STA     particles_lifetime,Y
        LDA     rnd_B
        AND     #$01
        CLC
        ADC     #$01
        STA     particles_type,Y        ; stars / debris
        RTS
}

\ ******************************************************************************
\ * Function: level_reset
\ * Description: this happens at level retry
\ ******************************************************************************

.level_reset
{
        JSR     clear_screen_and_init

IF _TIMED_LASER
\\ Screen is now blank, but level_obj_flags bit 2 (OBJ_flag_laser_beam_drawn)
\\ may still be set on lasers that were on-screen at the moment of death.
\\ Clear it here, otherwise update_one_laser_beam's Phase 1 XOR-erase will
\\ paint the cached beam back onto the freshly cleared screen.
        LDX     #LEVEL_MAX_OBJECTS
    .level_reset_clear_laser_drawn
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_laser_beam_drawn)
        STA     level_obj_flags,X
        DEX
        BPL     level_reset_clear_laser_drawn
ENDIF

        LDY     #$1B
        JSR     wait_time_out_Y

\\ Store important ZP vars termporarily

        LDA     midpoint_ypos_INT_HI
        PHA
        LDA     midpoint_ypos_INT
        PHA
        LDA     rnd_B
        PHA
        LDA     rnd_A
        PHA
        LDY     demo_mode_flag

\\ Blank all ZP variables from $9A to $01

        LDX     #$9A
    .clear_zp_game_vars
        LDA     #$00
        STA     zp_base,X                        ; 
        DEX
        BNE     clear_zp_game_vars

\\ Restore important ZP vars

        STY     demo_mode_flag
        PLA
        STA     rnd_A
        PLA
        STA     rnd_B
        PLA
        STA     midpoint_ypos_INT
        PLA
        STA     midpoint_ypos_INT_HI
        
\\ Set various flags & state variables to initialise:

        LDA     #$FF
        STA     level_tick_state
        
        LDX     #$FF
        STX     player_ship_destroyed_flag
        STX     pod_destroying_player_timer
        STX     player_pressed_fire
        STX     planet_countdown_timer
        INX
        STX     pod_lifted_flag
        LDX     #$0F
        STX     generator_recharge_counter

\\ Lookup correct pointers to reset tables for level:
        
        LDX     level_number
        LDA     level_reset_ptr_table_LO,X
        STA     level_reset_ptr
        LDA     level_reset_ptr_table_HI,X
        STA     level_reset_ptr+1
        LDA     level_reset_ptr2_table_LO,X
        STA     level_reset_ptr2
        LDA     level_reset_ptr2_table_HI,X
        STA     level_reset_ptr2+1
        LDA     level_reset_data_sizes,X
        STA     level_reset_size

\\ Think this code is matching current ship (x,y) position against respawn positions & screen offset:

        LDY     #$00

IF _LAST_USED_CHECKPOINT
        \\ Active-checkpoint model: respawn at the index tracked across deaths
        \\ by update_active_checkpoint (per-frame advance scan, teleporter
        \\ writes, pod-pickup snap). The historical height-based scan and the
        \\ pod-flag direction flip below it are bypassed entirely — the
        \\ direction-of-travel logic now lives in the per-frame scan.
        LDY     active_checkpoint_index
        JMP     active_checkpoint_loaded
ENDIF

    .level_reset_loop
        LDA     (level_reset_ptr2),Y
        SBC     midpoint_ypos_INT
        LDA     (level_reset_ptr),Y
        SBC     midpoint_ypos_INT_HI
        BCS     L2B4B

        INY
        CPY     level_reset_size
        BNE     level_reset_loop

        LDA     #$00
        STA     level_reset_with_pod_flag

    .L2B4B
        CPY     #$00
        BEQ     L2B55

        LDA     level_reset_with_pod_flag
        BNE     L2B55

        DEY

    .L2B55
        INY
        CPY     level_reset_size
        BNE     L2B5F

        LDA     #$00
        STA     level_reset_with_pod_flag

    .L2B5F
        DEY
    .active_checkpoint_loaded

IF _LAST_USED_CHECKPOINT
        \\ Pod-respawn rule: with pod attached, push respawn one checkpoint
        \\ deeper than the player-tracked active index — but never deeper
        \\ than the deepest checkpoint they've reached on foot in the current
        \\ segment (deepest_checkpoint_visited). Teleporters reset both
        \\ trackers to the destination, so this can never reference a
        \\ checkpoint the player hasn't actually been to.
        \\
        \\   target = min(active + 1, deepest_visited)
        \\   if target == deepest_visited: drop the pod
        \\
        \\ The "drop on deepest" clause means the player loses the pod when
        \\ the bump-or-clamp lands them at their high-watermark — there's
        \\ nowhere "further down" they could be respawned, so the pod gets
        \\ stranded at its original spawn instead of teleporting with the
        \\ ship. Mirrors the original game's "fell off the bottom" / "matched
        \\ cp[size-1] with pod" pod-drop semantics.
        LDA     level_reset_with_pod_flag
        BEQ     active_cp_pod_done

        \\ Phase 1 — maybe bump Y. The bump (active+1, clamped to deepest)
        \\ only fires when cp[active] is *above* the death Y, i.e. respawn
        \\ at cp[active] would let the player progress upward by dying.
        \\ When cp[active] is at or below death, no bump — respawn there.
        \\ midpoint_ypos at this point is the death Y (restored from the
        \\ stack at the start of level_reset).
        LDA     (level_reset_ptr),Y                     ; cp[active].y_HI
        CMP     midpoint_ypos_INT_HI
        BCC     active_cp_pod_bump                      ; cp_HI < death_HI -> cp above, bump
        BNE     active_cp_pod_check_drop                ; cp_HI > death_HI -> cp below, no bump
        \\ HI bytes equal: compare LO. PHA preserves carry across the LO
        \\ lookup; PLA / TAY both leave C alone.
        TYA
        PHA
        CLC
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y                     ; cp[active].y_LO
        CMP     midpoint_ypos_INT
        PLA
        TAY                                              ; restore Y = active
        BCS     active_cp_pod_check_drop                ; cp_LO >= death_LO -> cp at or below, no bump

    .active_cp_pod_bump
        \\ cp[active] above death — bump to min(active+1, deepest).
        INY
        CPY     deepest_checkpoint_visited
        BCC     active_cp_pod_check_drop                ; active+1 < deepest -> Y = active+1
        LDY     deepest_checkpoint_visited              ; clamp

    .active_cp_pod_check_drop
        \\ Phase 2 — drop the pod whenever the final respawn target equals
        \\ the deepest checkpoint visited, regardless of how Y got there.
        \\ Mirrors the original game's "respawn at the bottom drops the pod"
        \\ rule, applied to the segment-local watermark instead of cp[size-1].
        CPY     deepest_checkpoint_visited
        BNE     active_cp_pod_done
        LDA     #$00
        STA     level_reset_with_pod_flag
    .active_cp_pod_done
ENDIF

        CLC

\\ Matched nearest respawn position so set new ship (x,y) coordinates

        LDA     (level_reset_ptr),Y
        STA     midpoint_ypos_INT_HI
        TYA
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y
        STA     midpoint_ypos_INT
        TYA
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y
        STA     window_xpos_INT
        TYA
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y
        STA     window_ypos_EXT
        TYA
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y
        STA     window_ypos_INT
        TYA
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y
        STA     midpoint_xpos_INT

        LDA     #$0E
        STA     top_nibble_index

IF _Y_BANDS
        \\ The player may have died inside a reverse-gravity band, leaving
        \\ gravity_SIGN at $FF -- but the respawn position might also sit
        \\ inside a (possibly different) band. Recompute gravity from the
        \\ spawn Y by preloading player_ypos from the just-loaded
        \\ midpoint_ypos and re-running the band scan, so the orientation
        \\ tests below see the correct local sign for the spawn point.
        LDA     midpoint_ypos_INT
        STA     player_ypos_INT
        LDA     midpoint_ypos_INT_HI
        STA     player_ypos_INT_HI
        JSR     update_active_band
ENDIF
        LDA     level_reset_with_pod_flag
        BEQ     dont_set_angle_to_pod

        LDX     #$FF
        STX     pod_lifted_flag
        STX     pod_tethered_flag

        LDX     #$01                        ; angle $01 - straight up (+1)
        LDA     gravity_SIGN
        BPL     L2BA5                        ; normal gravity

        LDX     #$11                        ; angle $11 - straight down (+1)

    .L2BA5
        STX     angle_ship_to_pod
        
    .dont_set_angle_to_pod
        LDA     gravity_SIGN
        BPL     L2BAF

        LDA     #ANGLE_DOWN                        ; angle $10 - straight down for reverse gravity
        STA     ship_angle

    .L2BAF
        LDX     level_number
        LDA     level_landscape_colour,X
        LDY     #$02
        JSR     palette_set_colour_Y_to_A    ; set default landscape colour

        LDA     level_object_colour,X
        LDY     #$03
        JSR     palette_set_colour_Y_to_A    ; set default object colour

IF _Y_BANDS
        \\ The level-default palette writes above clobbered any band-correct
        \\ colour that update_active_band applied earlier in this routine.
        \\ Invalidate the cache and re-run the scan so the post-respawn
        \\ teleport-appear animation renders in the band's colours instead
        \\ of flashing level defaults until the first per-frame band scan.
        LDA     #$FF
        STA     band_current_active_index
        JSR     update_active_band
ENDIF
        RTS
}

\ ******************************************************************************
\ * Misc level variables / flags
\ ******************************************************************************

.level_number                        ; level 0 - 5, distinct from mission_number
        EQUB    $00

.reverse_gravity_flag                ; inverted every 6 levels
        EQUB    $00

.level_reset_with_pod_flag
        EQUB    $00

\ ******************************************************************************
\ * Function: initialise_level_pointers
\ * Description: Set terrain, gravity, and rendering vars from level number
\ ******************************************************************************

.initialise_level_pointers
{
        LDA     #$00
        STA     level_reset_with_pod_flag
IF _LAST_USED_CHECKPOINT
        \\ Reset checkpoint trackers to top spawn at every level start. The
        \\ editor exports checkpoints sorted by ascending Y, so index 0 is
        \\ always the topmost spawn point. Both bytes sit outside the ZP-clear
        \\ range so they persist across death-respawn cycles.
        STA     active_checkpoint_index
        STA     deepest_checkpoint_visited
ENDIF
        LDA     #$32
        STA     generator_recharge_increase
        
        LDX     level_number
        LDA     level_gravity_FRAC_table,X
        STA     gravity_FRAC
IF _Y_BANDS
        STA     level_base_gravity_FRAC               ; remember unmodified base for per-frame band overrides
ENDIF
IF _NO_WRAP_UNDERGROUND
        LDA     level_no_wrap_y_table_LO,X
        STA     no_wrap_y_INT
        LDA     level_no_wrap_y_table_HI,X
        STA     no_wrap_y_INT_HI
ENDIF

        LDA     terrain_left_wall_counter_ptrs_LO,X
        STA     terrain_left_wall_counter_LO
        LDA     terrain_left_wall_increment_ptrs_LO,X
        STA     terrain_left_wall_increment_LO
        LDA     terrain_left_wall_counter_ptrs_HI,X
        STA     terrain_left_wall_counter_HI
        LDA     terrain_left_wall_increment_ptrs_HI,X
        STA     terrain_left_wall_increment_HI
        LDA     terrain_right_wall_counter_ptrs_LO,X
        STA     terrain_right_wall_counter_LO
        LDA     terrain_right_wall_increment_ptrs_LO,X
        STA     terrain_right_wall_increment_LO
        LDA     terrain_right_wall_counter_ptrs_HI,X
        STA     terrain_right_wall_counter_HI
        LDA     terrain_right_wall_increment_ptrs_HI,X
        STA     terrain_right_wall_increment_HI

        LDY     #$00
IF _SWRAM_BUILD
        \\ Sign-extend gravity_FRAC bit 7 into Y so per-level gravity values
        \\ in $80..$FF are interpreted as small negative (upward) gravity.
        \\ Mirrors the per-band sign-extension in update_active_band.
        LDA     gravity_FRAC
        BPL     gravity_sign_done
        DEY                                             ; Y = $FF for negative FRAC
    .gravity_sign_done
ENDIF
        LDA     reverse_gravity_flag
        BEQ     normal_gravity

        LDA     gravity_FRAC
        EOR     #$FF
        STA     gravity_FRAC

IF _SWRAM_BUILD
        \\ Flip Y too so the sign byte tracks the EOR'd FRAC (e.g. $07/$00 ->
        \\ $F8/$FF, and $F8/$FF -> $07/$00). Equivalent to EORing the whole
        \\ 16-bit value with $FFFF.
        TYA
        EOR     #$FF
        TAY
ELSE
        LDY     #$FF
ENDIF

    .normal_gravity
        STY     gravity_SIGN
        LDA     #LANDSCAPE_COLOUR_BYTE
        ORA     invisible_landscape_flag
        STA     level_line_pixels_byte
        STA     hostile_bullet_pixel_byte

        CLC
        TXA
        ROL     A
        TAX                                        ; level_number *= 2

\\ Modify code to read from address containing current level object data
        
        LDA     level_obj_pos_X_lookup_LO,X
        STA     level_obj_pos_X_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     level_obj_pos_X_addr_HI                    ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_lookup_LO,X
        STA     level_obj_pos_Y_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     level_obj_pos_Y_addr_HI                    ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     level_obj_pos_Y_EXT_addr_LO                ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     level_obj_pos_Y_EXT_addr_HI                ; **MODIFIES CODE**

        LDA     level_obj_type_lookup_LO,X
        STA     level_obj_type_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_HI,X
        STA     level_obj_type_addr_HI                    ; **MODIFIES CODE**
IF _TIMED_LASER
        LDA     level_obj_type_lookup_LO,X
        STA     laser_load_object_type_addr_LO            ; **MODIFIES CODE** (mirror for update_all_laser_beams)
        LDA     level_obj_type_lookup_HI,X
        STA     laser_load_object_type_addr_HI            ; **MODIFIES CODE**
ENDIF

        LDA     level_obj_data_0_lookup_LO,X
        STA     level_gun_aim_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_data_0_lookup_HI,X
        STA     level_gun_aim_addr_HI                    ; **MODIFIES CODE**
IF _TIMED_LASER
        LDA     level_obj_data_0_lookup_LO,X
        STA     laser_load_gun_aim_addr_LO                ; **MODIFIES CODE** (mirror for update_one_laser_beam)
        LDA     level_obj_data_0_lookup_HI,X
        STA     laser_load_gun_aim_addr_HI                ; **MODIFIES CODE**

        LDA     level_obj_data_1_lookup_LO,X
        STA     laser_load_dx_addr_LO                     ; **MODIFIES CODE** (slot 1 = laser dx)
        LDA     level_obj_data_1_lookup_HI,X
        STA     laser_load_dx_addr_HI                     ; **MODIFIES CODE**

        LDA     level_obj_data_2_lookup_LO,X
        STA     laser_load_dy_addr_LO                     ; **MODIFIES CODE** (slot 2 = laser dy)
        LDA     level_obj_data_2_lookup_HI,X
        STA     laser_load_dy_addr_HI                     ; **MODIFIES CODE**
ENDIF
IF _GRAVITY_WELL
        LDA     level_obj_type_lookup_LO,X
        STA     well_load_obj_type_addr_LO                ; **MODIFIES CODE** (mirror for apply_gravity_wells_to_force)
        LDA     level_obj_type_lookup_HI,X
        STA     well_load_obj_type_addr_HI                ; **MODIFIES CODE**

        LDA     level_obj_pos_X_lookup_LO,X
        STA     well_load_obj_pos_x_addr_LO               ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     well_load_obj_pos_x_addr_HI               ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_lookup_LO,X
        STA     well_load_obj_pos_y_addr_LO               ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     well_load_obj_pos_y_addr_HI               ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     well_load_obj_pos_y_ext_addr_LO           ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     well_load_obj_pos_y_ext_addr_HI           ; **MODIFIES CODE**

        LDA     level_obj_data_1_lookup_LO,X
        STA     well_load_radius_addr_LO                  ; **MODIFIES CODE** (slot 1 = well radius)
        LDA     level_obj_data_1_lookup_HI,X
        STA     well_load_radius_addr_HI                  ; **MODIFIES CODE**

        LDA     level_obj_data_2_lookup_LO,X
        STA     well_load_strength_addr_LO                ; **MODIFIES CODE** (slot 2 = well strength)
        LDA     level_obj_data_2_lookup_HI,X
        STA     well_load_strength_addr_HI                ; **MODIFIES CODE**
ENDIF
IF _Y_BANDS
        LDA     level_band_y_HI_lookup_LO,X
        STA     band_load_y_hi_addr_LO                    ; **MODIFIES CODE**
        LDA     level_band_y_HI_lookup_HI,X
        STA     band_load_y_hi_addr_HI                    ; **MODIFIES CODE**

        LDA     level_band_y_LO_lookup_LO,X
        STA     band_load_y_lo_addr_LO                    ; **MODIFIES CODE**
        LDA     level_band_y_LO_lookup_HI,X
        STA     band_load_y_lo_addr_HI                    ; **MODIFIES CODE**

        LDA     level_band_gravity_lookup_LO,X
        STA     band_load_gravity_addr_LO                 ; **MODIFIES CODE**
        LDA     level_band_gravity_lookup_HI,X
        STA     band_load_gravity_addr_HI                 ; **MODIFIES CODE**

        LDA     level_band_landscape_colour_lookup_LO,X
        STA     band_load_landscape_addr_LO               ; **MODIFIES CODE**
        LDA     level_band_landscape_colour_lookup_HI,X
        STA     band_load_landscape_addr_HI               ; **MODIFIES CODE**

        LDA     level_band_object_colour_lookup_LO,X
        STA     band_load_object_addr_LO                  ; **MODIFIES CODE**
        LDA     level_band_object_colour_lookup_HI,X
        STA     band_load_object_addr_HI                  ; **MODIFIES CODE**

        \\ Force a colour-transition on the next update_active_band scan.
        LDA     #$FF
        STA     band_current_active_index
ENDIF
IF _BOBBING_MINES
        \\ Reset every per-mine local tick to 0 so re-entry into the level
        \\ (or first play) starts each mine at the position the designer
        \\ authored via the phase slot. 32 slots = LEVEL_MAX_OBJECTS + 1.
        \\ Cheap enough to unroll for a tight loop's cost rather than a
        \\ JSR; 32 zeroes is the worst case per level start.
        LDA     #$00
        LDY     #$1F
.init_bm_local_tick_loop
        STA     bobbing_mine_local_tick,Y
        DEY
        BPL     init_bm_local_tick_loop

        LDA     level_obj_data_0_lookup_LO,X
        STA     bm_phase_addr_LO                          ; **MODIFIES CODE** (slot 0 = phase)
        LDA     level_obj_data_0_lookup_HI,X
        STA     bm_phase_addr_HI                          ; **MODIFIES CODE**

        LDA     level_obj_data_1_lookup_LO,X
        STA     bm_amp_addr_LO                            ; **MODIFIES CODE** (slot 1 = amp)
        LDA     level_obj_data_1_lookup_HI,X
        STA     bm_amp_addr_HI                            ; **MODIFIES CODE**

        LDA     level_obj_data_2_lookup_LO,X
        STA     bm_prev_addr_LO                           ; **MODIFIES CODE** (slot 2 = prev offset)
        LDA     level_obj_data_2_lookup_HI,X
        STA     bm_prev_addr_HI                           ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_LO,X
        STA     bm_prev_store_addr_LO                     ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_HI,X
        STA     bm_prev_store_addr_HI                     ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_lookup_LO,X
        STA     bm_pos_y_load_addr_LO                     ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     bm_pos_y_load_addr_HI                     ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_LO,X
        STA     bm_pos_y_store_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     bm_pos_y_store_addr_HI                    ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     bm_pos_y_ext_load_addr_LO                 ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     bm_pos_y_ext_load_addr_HI                 ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     bm_pos_y_ext_store_addr_LO                ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     bm_pos_y_ext_store_addr_HI                ; **MODIFIES CODE**

        \\ Horizontal mine: same slot mapping, X-axis position writes.
        LDA     level_obj_data_0_lookup_LO,X
        STA     bm_h_phase_addr_LO                        ; **MODIFIES CODE**
        LDA     level_obj_data_0_lookup_HI,X
        STA     bm_h_phase_addr_HI                        ; **MODIFIES CODE**

        LDA     level_obj_data_1_lookup_LO,X
        STA     bm_h_amp_addr_LO                          ; **MODIFIES CODE**
        LDA     level_obj_data_1_lookup_HI,X
        STA     bm_h_amp_addr_HI                          ; **MODIFIES CODE**

        LDA     level_obj_data_2_lookup_LO,X
        STA     bm_h_prev_addr_LO                         ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_HI,X
        STA     bm_h_prev_addr_HI                         ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_LO,X
        STA     bm_h_prev_store_addr_LO                   ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_HI,X
        STA     bm_h_prev_store_addr_HI                   ; **MODIFIES CODE**

        LDA     level_obj_pos_X_lookup_LO,X
        STA     bm_h_pos_x_load_addr_LO                   ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     bm_h_pos_x_load_addr_HI                   ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_LO,X
        STA     bm_h_pos_x_store_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     bm_h_pos_x_store_addr_HI                  ; **MODIFIES CODE**
ENDIF
IF _TELEPORTER
        LDA     level_obj_pos_X_lookup_LO,X
        STA     tp_pos_x_addr_LO                          ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     tp_pos_x_addr_HI                          ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_lookup_LO,X
        STA     tp_pos_y_addr_LO                          ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     tp_pos_y_addr_HI                          ; **MODIFIES CODE**

        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     tp_pos_y_ext_addr_LO                      ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     tp_pos_y_ext_addr_HI                      ; **MODIFIES CODE**

        LDA     level_obj_data_0_lookup_LO,X
        STA     tp_dest_addr_LO                           ; **MODIFIES CODE** (slot 0 = dest checkpoint index)
        LDA     level_obj_data_0_lookup_HI,X
        STA     tp_dest_addr_HI                           ; **MODIFIES CODE**

        \\ Clear any stale pending warp / overlap state from a previous life.
        LDA     #$00
        STA     teleporter_pending_index
        STA     teleporter_just_warped
        STA     teleporter_overlap_this_frame
ENDIF
IF _SWITCHES
        \\ Clear per-switch refractory state at level start. 8 slots.
        LDA     #$00
        STA     level_switch_state+0
        STA     level_switch_state+1
        STA     level_switch_state+2
        STA     level_switch_state+3
        STA     level_switch_state+4
        STA     level_switch_state+5
        STA     level_switch_state+6
        STA     level_switch_state+7

        \\ Clear per-door runtime state (cursor, phase, hold/close phases,
        \\ close rate). 32 slots × 5 arrays — unroll the inner so the loop
        \\ is one DEY+BPL per object.
        LDY     #$1F
.init_door_state_loop
        STA     door_cursor,Y
        STA     door_phase,Y
        STA     door_hold_phase,Y
        STA     door_close_phase,Y
        STA     door_close_rate,Y
        DEY
        BPL     init_door_state_loop

        \\ SMC patches: dispatcher reads per-level switch wiring tables.
        LDA     level_switch_obj_indices_lookup_LO,X
        STA     switch_indices_addr_LO                   ; **MODIFIES CODE**
        LDA     level_switch_obj_indices_lookup_HI,X
        STA     switch_indices_addr_HI                   ; **MODIFIES CODE**
        LDA     level_switch_target_lookup_LO,X
        STA     switch_target_addr_LO                    ; **MODIFIES CODE**
        LDA     level_switch_target_lookup_HI,X
        STA     switch_target_addr_HI                    ; **MODIFIES CODE**
        LDA     level_switch_action_lookup_LO,X
        STA     switch_action_addr_LO                    ; **MODIFIES CODE**
        LDA     level_switch_action_lookup_HI,X
        STA     switch_action_addr_HI                    ; **MODIFIES CODE**
        LDA     level_switch_arg_a_lookup_LO,X
        STA     switch_arg_a_addr_LO                     ; **MODIFIES CODE**
        LDA     level_switch_arg_a_lookup_HI,X
        STA     switch_arg_a_addr_HI                     ; **MODIFIES CODE**
        LDA     level_switch_arg_b_lookup_LO,X
        STA     switch_arg_b_addr_LO                     ; **MODIFIES CODE**
        LDA     level_switch_arg_b_lookup_HI,X
        STA     switch_arg_b_addr_HI                     ; **MODIFIES CODE**

        \\ SMC patches: param actions write into target's obj_data slots.
        \\ set_param uses 3 STA sites (slot 0/1/2). xor_param needs 3 LDA
        \\ sites and 3 STA sites at different code locations. All six STAs
        \\ + three LDAs share the same per-level base address per slot.
        LDA     level_obj_data_0_lookup_LO,X
        STA     act_set_store_0_addr_LO                  ; **MODIFIES CODE**
        STA     act_xor_load_0_addr_LO                   ; **MODIFIES CODE**
        STA     act_xor_store_0_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_data_0_lookup_HI,X
        STA     act_set_store_0_addr_HI                  ; **MODIFIES CODE**
        STA     act_xor_load_0_addr_HI                   ; **MODIFIES CODE**
        STA     act_xor_store_0_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_data_1_lookup_LO,X
        STA     act_set_store_1_addr_LO                  ; **MODIFIES CODE**
        STA     act_xor_load_1_addr_LO                   ; **MODIFIES CODE**
        STA     act_xor_store_1_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_data_1_lookup_HI,X
        STA     act_set_store_1_addr_HI                  ; **MODIFIES CODE**
        STA     act_xor_load_1_addr_HI                   ; **MODIFIES CODE**
        STA     act_xor_store_1_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_LO,X
        STA     act_set_store_2_addr_LO                  ; **MODIFIES CODE**
        STA     act_xor_load_2_addr_LO                   ; **MODIFIES CODE**
        STA     act_xor_store_2_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_HI,X
        STA     act_set_store_2_addr_HI                  ; **MODIFIES CODE**
        STA     act_xor_load_2_addr_HI                   ; **MODIFIES CODE**
        STA     act_xor_store_2_addr_HI                  ; **MODIFIES CODE**

        \\ SMC patches: destroy action reads target's pos and type from
        \\ the existing per-level object tables.
        LDA     level_obj_pos_X_lookup_LO,X
        STA     act_dest_pos_x_addr_LO                   ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     act_dest_pos_x_addr_HI                   ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_LO,X
        STA     act_dest_pos_y_addr_LO                   ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     act_dest_pos_y_addr_HI                   ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     act_dest_pos_y_ext_addr_LO               ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     act_dest_pos_y_ext_addr_HI               ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_LO,X
        STA     act_dest_type_addr_LO                    ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_HI,X
        STA     act_dest_type_addr_HI                    ; **MODIFIES CODE**

        \\ SMC patches: door_update_one reads door's pos and shape data.
        LDA     level_obj_pos_X_lookup_LO,X
        STA     door_load_pos_x_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_pos_X_lookup_HI,X
        STA     door_load_pos_x_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_LO,X
        STA     door_load_pos_y_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_lookup_HI,X
        STA     door_load_pos_y_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_LO,X
        STA     door_load_pos_y_ext_addr_LO              ; **MODIFIES CODE**
        LDA     level_obj_pos_Y_EXT_lookup_HI,X
        STA     door_load_pos_y_ext_addr_HI              ; **MODIFIES CODE**
        LDA     level_obj_data_0_lookup_LO,X
        STA     door_load_shape_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_data_0_lookup_HI,X
        STA     door_load_shape_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_data_1_lookup_LO,X
        STA     door_load_width_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_data_1_lookup_HI,X
        STA     door_load_width_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_LO,X
        STA     door_load_max_carve_addr_LO              ; **MODIFIES CODE**
        LDA     level_obj_data_2_lookup_HI,X
        STA     door_load_max_carve_addr_HI              ; **MODIFIES CODE**

        LDA     level_obj_type_lookup_LO,X
        STA     tick_doors_type_addr_LO                  ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_HI,X
        STA     tick_doors_type_addr_HI                  ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_LO,X
        STA     init_door_type_addr_LO                   ; **MODIFIES CODE**
        LDA     level_obj_type_lookup_HI,X
        STA     init_door_type_addr_HI                   ; **MODIFIES CODE**
ENDIF

        TXA
        ROR     A                                        ; level_number /= 2
        TAX

        LDX     #LEVEL_MAX_OBJECTS                                    ; max objects per level

    .initialise_sprite_table_A
        LDA     #OBJ_flag_alive
        STA     level_obj_flags,X
        DEX
        BPL     initialise_sprite_table_A
IF _SWITCHES
        \\ Door objects re-purpose OBJ_flag_alive as "currently animating".
        \\ The blanket init above set every slot alive — that would put each
        \\ door in mid-cycle with cursor=0 and hold_phase=0, causing it to
        \\ flicker open/closed and ignore the first pulse. Clear alive on
        \\ every door slot so doors start idle.
        LDX     #LEVEL_MAX_OBJECTS
    .init_door_clear_alive_loop
.init_door_load_type
        LDA     level_0_obj_type,X                       ; **SELF-MODIFIED CODE**
        init_door_type_addr_LO = init_door_load_type+1
        init_door_type_addr_HI = init_door_load_type+2
        CMP     #OBJECT_door
        BNE     init_door_skip
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X
    .init_door_skip
        DEX
        BPL     init_door_clear_alive_loop
ENDIF

        LDX     #$0B
        
    .initialise_obj_tractor_counter
        LDA     #$00
        STA     obj_tractor_counter,X
        DEX
        BPL     initialise_obj_tractor_counter

        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Level reset data - start position of window & player (I think)
\ ******************************************************************************
\ ******************************************************************************

IF _SWRAM_BUILD=FALSE
.level_reset_data_sizes
        EQUB    $01,$01,$03,$03,$04,$05            ; this is size of tables below (6 bytes per entry)
        
.level_0_reset_data
        EQUB    $01,$91,$56,$01,$24,$6C

.level_1_reset_data
        EQUB    $01,$91,$56,$01,$24,$6C

.level_2_reset_data
        EQUB    $01,$02,$02
        EQUB    $91,$2D,$96
        EQUB    $56,$6F,$32
        EQUB    $01,$01,$02
        EQUB    $24,$AA,$23
        EQUB    $6C,$86,$48

.level_3_reset_data
        EQUB    $01,$01,$02
        EQUB    $91,$E6,$4A
        EQUB    $56,$57,$76
        EQUB    $01,$01,$01
        EQUB    $24,$60,$D8
        EQUB    $6C,$7B,$A1

.level_4_reset_data
        EQUB    $01,$02,$02,$03
        EQUB    $91,$68,$DC,$15
        EQUB    $56,$58,$43,$64
        EQUB    $01,$01,$02,$02
        EQUB    $24,$EE,$66,$9F
        EQUB    $6C,$7B,$6B,$81

.level_5_reset_data
        EQUB    $01,$02,$02,$03,$03
        EQUB    $91,$4B,$D4,$2A,$98
        EQUB    $56,$8C,$82,$6E,$87
        EQUB    $01,$01,$02,$02,$03
        EQUB    $24,$D8,$5A,$B4,$1B
        EQUB    $6C,$A2,$9A,$87,$AE

\ ******************************************************************************
\ * Pointers to level reset data
\ ******************************************************************************

.level_reset_ptr_table_LO                                            
        EQUB    LO(level_0_reset_data)
        EQUB    LO(level_1_reset_data)
        EQUB    LO(level_2_reset_data)
        EQUB    LO(level_3_reset_data)
        EQUB    LO(level_4_reset_data)
        EQUB    LO(level_5_reset_data)
.level_reset_ptr_table_HI                                            
        EQUB    HI(level_0_reset_data)
        EQUB    HI(level_1_reset_data)
        EQUB    HI(level_2_reset_data)
        EQUB    HI(level_3_reset_data)
        EQUB    HI(level_4_reset_data)
        EQUB    HI(level_5_reset_data)

.level_reset_ptr2_table_LO                                            
        EQUB    LO(level_0_reset_data + 1)
        EQUB    LO(level_1_reset_data + 1)
        EQUB    LO(level_2_reset_data + 3)
        EQUB    LO(level_3_reset_data + 3)
        EQUB    LO(level_4_reset_data + 4)
        EQUB    LO(level_5_reset_data + 5)
.level_reset_ptr2_table_HI                                            
        EQUB    HI(level_0_reset_data + 1)
        EQUB    HI(level_1_reset_data + 1)
        EQUB    HI(level_2_reset_data + 3)
        EQUB    HI(level_3_reset_data + 3)
        EQUB    HI(level_4_reset_data + 4)
        EQUB    HI(level_5_reset_data + 5)

\ ******************************************************************************
\ ******************************************************************************
\ * Gravity values per level
\ ******************************************************************************
\ ******************************************************************************

.level_gravity_FRAC_table
        EQUB    $05,$07,$09,$0B,$0C,$0D            ; initialises gravity_FRAC per level
ENDIF

\ ******************************************************************************
\ ******************************************************************************
\ * Pointers to level terrain data tables
\ ******************************************************************************
\ ******************************************************************************

.terrain_left_wall_counter_ptrs_LO                            ; initialises terrain_left_wall_counter_LO per level
        EQUB    LO(terrain_left_wall_count_0)
        EQUB    LO(terrain_left_wall_count_1)
        EQUB    LO(terrain_left_wall_count_2)
        EQUB    LO(terrain_left_wall_count_3)
        EQUB    LO(terrain_left_wall_count_4)
        EQUB    LO(terrain_left_wall_count_5)
.terrain_left_wall_counter_ptrs_HI                            ; initialises terrain_left_wall_counter_HI per level
        EQUB    HI(terrain_left_wall_count_0)
        EQUB    HI(terrain_left_wall_count_1)
        EQUB    HI(terrain_left_wall_count_2)
        EQUB    HI(terrain_left_wall_count_3)
        EQUB    HI(terrain_left_wall_count_4)
        EQUB    HI(terrain_left_wall_count_5)

.terrain_left_wall_increment_ptrs_LO                        ; initialises terrain_left_wall_increment_LO per level
        EQUB    LO(terrain_left_wall_inc_0)
        EQUB    LO(terrain_left_wall_inc_1)
        EQUB    LO(terrain_left_wall_inc_2)
        EQUB    LO(terrain_left_wall_inc_3)
        EQUB    LO(terrain_left_wall_inc_4)
        EQUB    LO(terrain_left_wall_inc_5)
.terrain_left_wall_increment_ptrs_HI                        ; initialises terrain_left_wall_increment_HI per level
        EQUB    HI(terrain_left_wall_inc_0)
        EQUB    HI(terrain_left_wall_inc_1)
        EQUB    HI(terrain_left_wall_inc_2)
        EQUB    HI(terrain_left_wall_inc_3)
        EQUB    HI(terrain_left_wall_inc_4)
        EQUB    HI(terrain_left_wall_inc_5)

.terrain_right_wall_counter_ptrs_LO                            ; initialises terrain_right_wall_counter_LO per level
        EQUB    LO(terrain_right_wall_count_0)
        EQUB    LO(terrain_right_wall_count_1)
        EQUB    LO(terrain_right_wall_count_2)
        EQUB    LO(terrain_right_wall_count_3)
        EQUB    LO(terrain_right_wall_count_4)
        EQUB    LO(terrain_right_wall_count_5)
.terrain_right_wall_counter_ptrs_HI                            ; initialises terrain_right_wall_counter_HI per level
        EQUB    HI(terrain_right_wall_count_0)
        EQUB    HI(terrain_right_wall_count_1)
        EQUB    HI(terrain_right_wall_count_2)
        EQUB    HI(terrain_right_wall_count_3)
        EQUB    HI(terrain_right_wall_count_4)
        EQUB    HI(terrain_right_wall_count_5)

.terrain_right_wall_increment_ptrs_LO                        ; initialises terrain_right_wall_increment_LO per level
        EQUB    LO(terrain_right_wall_inc_0)
        EQUB    LO(terrain_right_wall_inc_1)
        EQUB    LO(terrain_right_wall_inc_2)
        EQUB    LO(terrain_right_wall_inc_3)
        EQUB    LO(terrain_right_wall_inc_4)
        EQUB    LO(terrain_right_wall_inc_5)
.terrain_right_wall_increment_ptrs_HI                        ; initialises terrain_right_wall_increment_HI per level
        EQUB    HI(terrain_right_wall_inc_0)
        EQUB    HI(terrain_right_wall_inc_1)
        EQUB    HI(terrain_right_wall_inc_2)
        EQUB    HI(terrain_right_wall_inc_3)
        EQUB    HI(terrain_right_wall_inc_4)
        EQUB    HI(terrain_right_wall_inc_5)

\ ******************************************************************************
\ ******************************************************************************
\ * Palette data for each level
\ *
\ * Colour 0 is always black
\ * Colour 1 is always yellow (ship)
\ * Colour 2 is landscape
\ * Colour 3 is objects (guns, pod, bullets etc.)    
\ ******************************************************************************
\ ******************************************************************************

IF _SWRAM_BUILD=FALSE
.level_landscape_colour                            ; colour 2
        EQUB    $01,$02,$06,$02,$01,$05

.level_object_colour                            ; colour 3
        EQUB    $02,$01,$02,$05,$05,$06
ENDIF

\ ******************************************************************************
\ * Function: palette_set_colour_Y_to_A
\ * Params: Y = actual colour, A = logical colour
\ * Returns: none
\ * Description: Set a logical colour to a physical colour via palette register
\ ******************************************************************************

.palette_set_colour_Y_to_A
{
        ORA     palette_base_mask,Y
        EOR     #$07
        STA     SHEILA_PaletteReg
        ORA     #$10
        STA     SHEILA_PaletteReg
        ORA     #$40
        STA     SHEILA_PaletteReg
        EOR     #$10
        STA     SHEILA_PaletteReg
        RTS
}

.palette_base_mask
        EQUB    $00,$20,$80,$A0

\ ******************************************************************************
\ ******************************************************************************
\ * Level data pointers
\ ******************************************************************************
\ ******************************************************************************

.level_obj_pos_X_lookup_LO
        EQUB    LO(level_0_obj_pos_X)
.level_obj_pos_X_lookup_HI
        EQUB    HI(level_0_obj_pos_X)
        EQUB    LO(level_1_obj_pos_X), HI(level_1_obj_pos_X)
        EQUB    LO(level_2_obj_pos_X), HI(level_2_obj_pos_X)
        EQUB    LO(level_3_obj_pos_X), HI(level_3_obj_pos_X)
        EQUB    LO(level_4_obj_pos_X), HI(level_4_obj_pos_X)
        EQUB    LO(level_5_obj_pos_X), HI(level_5_obj_pos_X)

.level_obj_pos_Y_lookup_LO
        EQUB    LO(level_0_obj_pos_Y)
.level_obj_pos_Y_lookup_HI
        EQUB    HI(level_0_obj_pos_Y)
        EQUB    LO(level_1_obj_pos_Y), HI(level_1_obj_pos_Y)
        EQUB    LO(level_2_obj_pos_Y), HI(level_2_obj_pos_Y)
        EQUB    LO(level_3_obj_pos_Y), HI(level_3_obj_pos_Y)
        EQUB    LO(level_4_obj_pos_Y), HI(level_4_obj_pos_Y)
        EQUB    LO(level_5_obj_pos_Y), HI(level_5_obj_pos_Y)

.level_obj_pos_Y_EXT_lookup_LO
        EQUB    LO(level_0_obj_pos_Y_EXT)
.level_obj_pos_Y_EXT_lookup_HI
        EQUB    HI(level_0_obj_pos_Y_EXT)
        EQUB    LO(level_1_obj_pos_Y_EXT), HI(level_1_obj_pos_Y_EXT)
        EQUB    LO(level_2_obj_pos_Y_EXT), HI(level_2_obj_pos_Y_EXT)
        EQUB    LO(level_3_obj_pos_Y_EXT), HI(level_3_obj_pos_Y_EXT)
        EQUB    LO(level_4_obj_pos_Y_EXT), HI(level_4_obj_pos_Y_EXT)
        EQUB    LO(level_5_obj_pos_Y_EXT), HI(level_5_obj_pos_Y_EXT)

.level_obj_type_lookup_LO
        EQUB    LO(level_0_obj_type)
.level_obj_type_lookup_HI
        EQUB    HI(level_0_obj_type)
        EQUB    LO(level_1_obj_type), HI(level_1_obj_type)
        EQUB    LO(level_2_obj_type), HI(level_2_obj_type)
        EQUB    LO(level_3_obj_type), HI(level_3_obj_type)
        EQUB    LO(level_4_obj_type), HI(level_4_obj_type)
        EQUB    LO(level_5_obj_type), HI(level_5_obj_type)

\\ Per-level pointers to the generic obj_data slot arrays. Slot 0 is the
\\ "primary config" byte (gun_aim for guns/lasers; unused for other types).
\\ Slots 1 and 2 are interpreted per object type (laser dx/dy, well
\\ radius/strength, future per-type fields). Each new object type that
\\ needs config bytes claims slot offsets without growing the schema.
.level_obj_data_0_lookup_LO
        EQUB    LO(level_0_obj_data_0)
.level_obj_data_0_lookup_HI
        EQUB    HI(level_0_obj_data_0)
        EQUB    LO(level_1_obj_data_0), HI(level_1_obj_data_0)
        EQUB    LO(level_2_obj_data_0), HI(level_2_obj_data_0)
        EQUB    LO(level_3_obj_data_0), HI(level_3_obj_data_0)
        EQUB    LO(level_4_obj_data_0), HI(level_4_obj_data_0)
        EQUB    LO(level_5_obj_data_0), HI(level_5_obj_data_0)

\\ level_obj_data_1_lookup_* / level_obj_data_2_lookup_* are defined in
\\ SWRAM alongside the IF _TIMED_LASER / _GRAVITY_WELL blocks (native RAM
\\ here is too tight in the SWRAM build); see update_all_laser_beams and
\\ apply_gravity_wells_to_force.

\ ******************************************************************************
\ ******************************************************************************
\ * Ship shooting & bullet routines
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: ship_input_fire
\ * Description: Handle fire input; block firing while shield/tractor is active
\ ******************************************************************************

.ship_input_fire
{
        LDA     pod_destroying_player_timer
        BPL     return

        LDA     shield_tractor_pressed
        BEQ     test_fire_key

        LDA     #$FF
        STA     player_pressed_fire

    .return
        RTS
}

\ ******************************************************************************
\ * Function: test_fire_key
\ * Description: Read fire key and create a new bullet on first press
\ ******************************************************************************

.test_fire_key
{
        LDX     #KEY_FIRE
        JSR     test_inkey

        CPX     #$FF
        BEQ     fire_pressed

        LDA     #$00
        STA     player_pressed_fire
        RTS

    .fire_pressed
        LDA     player_pressed_fire
        BEQ     player_shoot_bullet                
        RTS

    .player_shoot_bullet
        LDX     bullet_index                    
        LDA     particles_type,X                
        CMP     #$00
        BNE     create_new_player_bullet        

        LDA     particles_lifetime,X            
        BEQ     create_new_player_bullet        

        RTS
}

\ ******************************************************************************
\ * Function: angle_to_bullet_dx_dy
\ * Description: Copy angle-based X/Y velocity from lookup tables to particle
\ ******************************************************************************

.angle_to_bullet_dx_dy
{
        LDA     angle_to_x_FRAC,Y
        STA     particles_dx_FRAC,X
        LDA     angle_to_x_INT,Y
        STA     particles_dx_INT,X
        LDA     angle_to_y_FRAC,Y
        STA     particles_dy_FRAC,X
        LDA     angle_to_y_INT,Y
        STA     particles_dy_INT,X
        RTS
}

\ ******************************************************************************
\ * Function: create_new_player_bullet
\ * Description: Spawn a player bullet at ship centre with ship-angle velocity
\ ******************************************************************************

.create_new_player_bullet
{
        LDA     #$FF
        STA     player_pressed_fire

        LDA     player_xpos_FRAC
        STA     particles_xpos_FRAC,X
        LDA     player_xpos_INT
        CLC
        ADC     #PLAYER_CENTRE_X_OFFSET                    ; player x position offset by $4 - start bullet in centre?
        STA     particles_xpos_INT,X
        LDA     player_ypos_FRAC
        STA     particles_ypos_FRAC,X
        CLC
        LDA     player_ypos_INT
        ADC     #PLAYER_CENTRE_Y_OFFSET                    ; player y position offset by $5 - start bullet in centre?
        STA     particles_ypos_INT,X
        LDA     player_ypos_INT_HI
        ADC     #$00
        STA     particles_ypos_INT_HI,X
        
        LDY     ship_angle
        JSR     angle_to_bullet_dx_dy

        LDY     #$02
        
    .move_bullet_initial
        CLC
        LDA     particles_xpos_FRAC,X
        ADC     particles_dx_FRAC,X
        STA     particles_xpos_FRAC,X
        LDA     particles_xpos_INT,X
        ADC     particles_dx_INT,X
        STA     particles_xpos_INT,X
        CLC
        LDA     particles_ypos_FRAC,X
        ADC     particles_dy_FRAC,X
        STA     particles_ypos_FRAC,X
        LDA     particles_ypos_INT,X
        ADC     particles_dy_INT,X
        STA     particles_ypos_INT,X
        PHP
        LDA     particles_dy_INT,X
        BMI     bullet_dy_negative

        LDA     #$00
        JMP     bullet_dy_positive

    .bullet_dy_negative
        LDA     #$FF
        
    .bullet_dy_positive
        PLP
        ADC     particles_ypos_INT_HI,X
        STA     particles_ypos_INT_HI,X
        DEY
        BNE     move_bullet_initial

        CLC
        LDA     particles_dx_FRAC,X
        ADC     player_velocityx_FRAC
        STA     particles_dx_FRAC,X
        LDA     particles_dx_INT,X
        ADC     player_velocityx_INT
        STA     particles_dx_INT,X
        CLC
        LDA     particles_dy_FRAC,X
        ADC     player_velocityy_FRAC
        STA     particles_dy_FRAC,X
        LDA     particles_dy_INT,X
        ADC     player_velocityy_INT
        STA     particles_dy_INT,X

        LDA     particles_lifetime,X
        AND     #PARTICLE_flag
        ORA     #PARTICLE_lifetime_bullet
        STA     particles_lifetime,X

        LDA     #PARTICLE_type_player_bullet
        STA     particles_type,X

        INX
        TXA
        AND     #$03                    ; can only have 4 active bullets
        TAX
        STX     bullet_index
        JSR     own_gun_sound

        RTS
}

\ ******************************************************************************
\ * Appears to be unreachable code? - Maybe particle test code?
\ ******************************************************************************
{        
        LDA     #$28
        STA     particles_xpos_FRAC,X
        STA     particles_xpos_INT,X
        LDA     #$02
        STA     particles_ypos_FRAC,X
        STA     particles_ypos_INT,X
        STA     particles_ypos_INT_HI,X
        LDA     #$01
        STA     particles_dx_FRAC,X
        STA     particles_dx_INT,X
        STA     particles_dy_FRAC,X
        STA     particles_dy_INT,X
        LDA     #$28
        STA     particles_lifetime,X
        LDA     #$00
        STA     particles_type,X
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Random number generator - returns a random byte in A with workspace $3A, 3B
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: rnd
\ * Params: none
\ * Returns: A = random number 0 - 255
\ * Description: Generate an 8-bit pseudo-random number using shift and add
\ ******************************************************************************

.rnd
{
        PHP
        LDA     rnd_A
        PHA
        LDA     rnd_B
        PHA
        LDA     rnd_A
        PHA
        CLC
        ROL     A
        ROL     rnd_B
        ROL     A
        ROL     rnd_B
        ORA     #$01
        STA     rnd_A
        CLC
        PLA
        ADC     rnd_A
        STA     rnd_A
        PLA
        ADC     rnd_B
        STA     rnd_B
        PLA
        CLC
        ADC     rnd_B
        STA     rnd_B
        EOR     rnd_A
        PLP
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Tractor beam / pod code?
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: get_distance_ship_to_pod_tractor, get_distance_ship_to_pod_tractor_ext
\ * Returns: A = distance from ship to pod during tractor beam
\ * Description: Calculate approximate Manhattan distance from ship to pod
\ ******************************************************************************

.get_distance_ship_to_pod_tractor
\\ {
        SEC
        LDA     ship_window_ypos_INT
        SBC     pod_window_ypos_INT
        BCS     L2EE7

        EOR     #$FF
        CLC
        ADC     #$01
        
    .L2EE7
        STA     multiply_result_lo
        LDA     ship_window_xpos_FRAC
        SEC
        SBC     pod_window_xpos_FRAC
        STA     ship_to_pod_dx_FRAC
        LDA     ship_window_xpos_INT
        SBC     pod_window_xpos_INT
        BVS     return_max_distance

        TAY
        AND     #$E0
        BEQ     L2EFF

        CMP     #$E0
        BNE     return_max_distance

    .L2EFF
        TYA
        ROL     ship_to_pod_dx_FRAC
        ROL     A
        ROL     ship_to_pod_dx_FRAC
        ROL     A
        BPL     L2F0D

        EOR     #$FF
        CLC
        ADC     #$01
        
    .L2F0D
        STA     multiply_operand_a

.get_distance_ship_to_pod_tractor_ext
        LDA     multiply_operand_a
        CMP     multiply_result_lo
        BCS     L2F1B

        LDY     multiply_result_lo
        STA     multiply_result_lo
        STY     multiply_operand_a
    .L2F1B
        LDA     multiply_result_lo
        CLC
        ADC     multiply_operand_a
        BCS     return_max_distance

        ADC     multiply_operand_a
        BCS     return_max_distance

        ADC     multiply_operand_a
        BCS     return_max_distance

        BCC     return_distance

    .return_max_distance
        LDA     #$FF
        
    .return_distance
        RTS
\\ }

\ ******************************************************************************
\ * Storage for previous address of jump routine
\ ******************************************************************************

.old_jmp_fn_LO
        EQUB    $00
.old_jmp_fn_HI
        EQUB    $00

\ ******************************************************************************
\ * Function: draw_line
\ * Params: L008A, L008B, L0088, L0089
\ * Returns: none
\ * Description: Draw a line between two screen coordinates using Bresenham
\ ******************************************************************************

.draw_line
{
        SEC
        LDA     draw_line_end_x
        SBC     draw_line_start_x
        BCS     L2F52

        \\ This swaps L0088 & L008A and L0089 & L008B
        \\ to ensure they are the right way around
        
        EOR     #$FF
        ADC     #$01
        PHA
        LDA     draw_line_start_x
        PHA
        LDA     draw_line_end_x
        STA     draw_line_start_x
        PLA
        STA     draw_line_end_x
        LDA     draw_line_start_y
        PHA
        LDA     draw_line_end_y
        STA     draw_line_start_y
        PLA
        STA     draw_line_end_y
        PLA
        
    .L2F52
        STA     pixel_colour_mask
        STA     draw_line_delta_major
        LDA     #LO(pixels_ptr_increment)
        STA     old_jmp_fn_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_increment)
        STA     old_jmp_fn_HI                        ; **MODIFIES CODE**
        LDA     draw_line_end_y
        CMP     draw_line_start_y
        BCS     L2F70

        LDA     #LO(pixels_ptr_decrement)
        STA     old_jmp_fn_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_decrement)
        STA     old_jmp_fn_HI                        ; **MODIFIES CODE**
        
    .L2F70
        JSR     calculate_pixels_ptr

        LDA     #LO(pixels_ptr_add_7)
        STA     plot_line_bresenham_1_addr_LO            ; **MODIFIES CODE**
        STA     plot_line_bresenham_2_addr_LO            ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_add_7)
        STA     plot_line_bresenham_1_addr_HI            ; **MODIFIES CODE**
        STA     plot_line_bresenham_2_addr_HI            ; **MODIFIES CODE**
        SEC
        LDA     draw_line_end_y
        SBC     draw_line_start_y
        BCS     L2F8E

        EOR     #$FF
        ADC     #$01
        
    .L2F8E
        STA     draw_line_delta_y_unused
        STA     draw_line_delta_minor
        CMP     draw_line_delta_major
        BCC     L2FAD

        PHA
        LDA     draw_line_delta_major
        STA     draw_line_delta_minor
        PLA
        STA     draw_line_delta_major
        LDA     old_jmp_fn_LO
        STA     plot_line_bresenham_1_addr_LO            ; **MODIFIES CODE**
        LDA     old_jmp_fn_HI
        STA     plot_line_bresenham_1_addr_HI            ; **MODIFIES CODE**
        JMP     L2FB9

    .L2FAD
        LDA     old_jmp_fn_LO
        STA     plot_line_bresenham_2_addr_LO            ; **MODIFIES CODE**
        LDA     old_jmp_fn_HI
        STA     plot_line_bresenham_2_addr_HI            ; **MODIFIES CODE**
    
    .L2FB9
        LDA     draw_line_delta_major
        CLC
        ROR     A
        STA     bresenham_error
        LDX     draw_line_delta_major
        INX
        
        JMP     plot_line_pixels
}

\ ******************************************************************************
\ * Functions: plot_line_bresenham_1, plot_line_pixels
\ * Description: X = ?
\ ******************************************************************************

.plot_line_bresenham_1
\\ {
        JSR     pixels_ptr_add_7                        ; **SELF-MODIFIED CODE**
        plot_line_bresenham_1_addr_LO   = plot_line_bresenham_1+1
        plot_line_bresenham_1_addr_HI   = plot_line_bresenham_1+2

        LDA     bresenham_error
        CLC
        ADC     draw_line_delta_minor
        BCS     plot_line_bresenham_2

        CMP     draw_line_delta_major
        BCS     plot_line_bresenham_2

        STA     bresenham_error
\\ }
\\ Fall through!

.plot_line_pixels
{
        LDY     pixel_column_index
        LDA     pixel_masks_1,Y
        AND     plot_line_pixels_byte
        LDY     #$00
        EOR     (plot_pixels_ptr),Y
        STA     (plot_pixels_ptr),Y
        DEX
        BNE     plot_line_bresenham_1

        RTS
}

\ ******************************************************************************
\ * Functions: plot_line_bresenham_2
\ * Description: Steps Bresenham error and advances draw address for line plotting
\ ******************************************************************************

.plot_line_bresenham_2
{
        SBC     draw_line_delta_major
        STA     bresenham_error
}
\\ Fall through!!
        
.plot_line_bresenham_2_JSR_label
\\ {
        JSR     landscape_increment_draw_addr            ; **SELF-MODIFIED CODE**
        plot_line_bresenham_2_addr_LO   = plot_line_bresenham_2_JSR_label+1
        plot_line_bresenham_2_addr_HI   = plot_line_bresenham_2_JSR_label+2
        JMP     plot_line_pixels
\\ }

\ ******************************************************************************
\ * Function: calculate_pixels_ptr
\ * Inputs: draw_line_start_x, draw_line_start_x
\ * Description: Converts X,Y coordinates to a screen memory address and pixel column
\ ******************************************************************************

.calculate_pixels_ptr
{
        LDA     #$00
        STA     plot_pixels_ptr
        STA     screen_addr_hi_temp
        LDA     draw_line_start_y
        CLC
        AND     #$F8
        ROR     A
        ROR     A
        STA     plot_pixels_ptr+1
        ROR     A
        ROR     A
        ROR     plot_pixels_ptr
        ROR     A
        ROR     plot_pixels_ptr
        ADC     #SCREEN_ADDR_HI_OFFSET
        ADC     plot_pixels_ptr+1
        STA     plot_pixels_ptr+1
        LDA     draw_line_start_x
        AND     #$FC
        ROL     A
        ROL     screen_addr_hi_temp
        ADC     plot_pixels_ptr
        STA     plot_pixels_ptr
        LDA     screen_addr_hi_temp
        ADC     plot_pixels_ptr+1
        STA     plot_pixels_ptr+1
        LDA     draw_line_start_y
        AND     #$07
        ADC     plot_pixels_ptr
        STA     plot_pixels_ptr
        LDA     draw_line_start_x
        AND     #PIXEL_COLUMN_MASK
        STA     pixel_column_index
        RTS
}

\ ******************************************************************************
\ * Function: plot_teleport_effect_step_horizontal
\ * Description: Self-modified jump for horizontal pixel pointer movement
\ ******************************************************************************

.plot_teleport_effect_step_horizontal
        JMP     pixels_ptr_add_7                            ; **SELF-MODIFIED CODE**
        jump_fn_1_addr_LO   = plot_teleport_effect_step_horizontal+1
        jump_fn_1_addr_HI   = plot_teleport_effect_step_horizontal+2

\ ******************************************************************************
\ * Function: plot_teleport_effect_step_vertical
\ * Description: Self-modified jump for vertical pixel pointer movement
\ ******************************************************************************

.plot_teleport_effect_step_vertical
        JMP     pixels_ptr_increment                        ; **SELF-MODIFIED CODE**
        jump_fn_2_addr_LO   = plot_teleport_effect_step_vertical+1
        jump_fn_2_addr_HI   = plot_teleport_effect_step_vertical+2

\ ******************************************************************************
\ * Function: plot_teleport_effect_3
\ * Description: Draws a rectangular ring of teleport effect pixels
\ ******************************************************************************

.plot_teleport_effect_3
{
        LDA     plot_pixels_ptr
        PHA
        LDA     plot_pixels_ptr+1
        PHA
        LDA     pixel_column_index
        PHA
        LDX     teleport_ring_count
        
    .L303D
        JSR     plot_teleport_effect_step_horizontal

        DEX
        BNE     L303D

        LDA     teleport_ring_count
        STA     teleport_row_count
        
    .L3047
        LDA     plot_pixels_ptr
        PHA
        LDA     plot_pixels_ptr+1
        PHA
        LDX     #$08
        
    .L304F
        JSR     plot_teleport_pixels

        JSR     plot_teleport_effect_step_vertical

        DEX
        BNE     L304F

        PLA
        STA     plot_pixels_ptr+1
        PLA
        STA     plot_pixels_ptr
        LDX     #$08
        
    .L3060
        JSR     plot_teleport_effect_step_horizontal

        DEX
        BNE     L3060

        DEC     teleport_row_count
        BNE     L3047

        PLA
        STA     pixel_column_index
        PLA
        STA     plot_pixels_ptr+1
        PLA
        STA     plot_pixels_ptr
        RTS
}

\ ******************************************************************************
\ * Function: plot_teleport_pixels
\ * Description: EORs a pixel at the current screen address using a colour mask
\ ******************************************************************************

.plot_teleport_pixels
{
        LDY     pixel_column_index
        LDA     pixel_masks_1,Y
        AND     pixel_colour_mask
        LDY     #$00
        EOR     (plot_pixels_ptr),Y
        STA     (plot_pixels_ptr),Y
        RTS
}

\ ******************************************************************************
\ * Function: plot_teleport_effect_1
\ * Description: Erases old teleport effect then draws new one at current position
\ ******************************************************************************

.plot_teleport_effect_1
{
        LDA     #$0F
        STA     pixel_colour_mask
        LDA     old_plot_pixels_ptr
        STA     plot_pixels_ptr
        LDA     old_plot_pixels_ptr+1
        STA     plot_pixels_ptr+1
        LDA     old_pixel_column_index
        STA     pixel_column_index
        JSR     plot_teleport_effect_2

        LDA     #$FF
        STA     pixel_colour_mask
        LDA     teleport_screen_addr_LO
        STA     plot_pixels_ptr
        LDA     teleport_screen_addr_HI
        STA     plot_pixels_ptr+1
        BEQ     return

        LDA     current_obj_visible_flag
        STA     pixel_column_index
        JSR     plot_teleport_effect_2

    .return
        RTS
}

\ ******************************************************************************
\ * Function: plot_teleport_effect_2
\ * Description: Draws all four sides of a teleport ring using self-modifying code
\ ******************************************************************************

.plot_teleport_effect_2
{
        LDA     #LO(pixels_ptr_add_7)
        STA     jump_fn_1_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_add_7)
        STA     jump_fn_1_addr_HI                        ; **MODIFIES CODE**
        LDA     #LO(pixels_ptr_increment)
        STA     jump_fn_2_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_increment)
        STA     jump_fn_2_addr_HI                        ; **MODIFIES CODE**
        JSR     plot_teleport_effect_3

        LDA     #LO(pixels_ptr_sbc_8)
        STA     jump_fn_1_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_sbc_8)
        STA     jump_fn_1_addr_HI                        ; **MODIFIES CODE**
        LDX     #$09
        
    .loop_1
        JSR     pixels_ptr_sbc_8

        DEX
        BNE     loop_1

        JSR     plot_teleport_effect_3

        LDA     #LO(pixels_ptr_decrement)
        STA     jump_fn_1_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_decrement)
        STA     jump_fn_1_addr_HI                        ; **MODIFIES CODE**
        LDA     #LO(pixels_ptr_add_7)
        STA     jump_fn_2_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_add_7)
        STA     jump_fn_2_addr_HI                        ; **MODIFIES CODE**
        JSR     pixels_ptr_add_7

        JSR     pixels_ptr_decrement

        JSR     plot_teleport_effect_3

        LDA     #LO(pixels_ptr_increment)
        STA     jump_fn_1_addr_LO                        ; **MODIFIES CODE**
        LDA     #HI(pixels_ptr_increment)
        STA     jump_fn_1_addr_HI                        ; **MODIFIES CODE**
        LDX     #$09
        
    .loop_2
        JSR     pixels_ptr_increment

        DEX
        BNE     loop_2

        JSR     plot_teleport_effect_3
        RTS
}

\ ******************************************************************************
\ * Function: pixels_ptr_add_7
\ * Description: Advances pixel pointer right by one pixel, adding 7 on column wrap
\ ******************************************************************************

.pixels_ptr_add_7
{
        LDY     pixel_column_index
        INY
        CPY     #$04
        BNE     return

        LDY     #$00
        LDA     plot_pixels_ptr
        ADC     #$07
        STA     plot_pixels_ptr
        BCC     return

        INC     plot_pixels_ptr+1

    .return
        STY     pixel_column_index
        RTS
}

\ ******************************************************************************
\ * Function: pixels_ptr_sbc_8
\ * Description: Moves pixel pointer left by one pixel, subtracting 8 on column wrap
\ ******************************************************************************

.pixels_ptr_sbc_8
{
        DEC     pixel_column_index
        BMI     L3125
        RTS

    .L3125
        LDY     #$03
        STY     pixel_column_index
        SEC
        LDA     plot_pixels_ptr
        SBC     #$08
        STA     plot_pixels_ptr
        BCS     return

        DEC     plot_pixels_ptr+1
        
    .return
        RTS
}

\ ******************************************************************************
\ * Function: pixels_ptr_increment
\ * Description: Moves pixel pointer down one scanline with character row wrapping
\ ******************************************************************************

.pixels_ptr_increment
{
        INC     plot_pixels_ptr
        LDA     plot_pixels_ptr
        AND     #$07
        BEQ     L313E
        RTS

    .L313E
        DEC     plot_pixels_ptr
        CLC
        LDA     plot_pixels_ptr
        ADC     #$39
        STA     plot_pixels_ptr
        LDA     plot_pixels_ptr+1
        ADC     #$02
        STA     plot_pixels_ptr+1
        RTS
}

\ ******************************************************************************
\ * Function: pixels_ptr_decrement
\ * Description: Moves pixel pointer up one scanline with character row wrapping
\ ******************************************************************************

.pixels_ptr_decrement
{
        DEC     plot_pixels_ptr
        LDA     plot_pixels_ptr
        AND     #$07
        CMP     #$07
        BEQ     L3159
        RTS

    .L3159
        INC     plot_pixels_ptr
        LDA     plot_pixels_ptr
        SBC     #$39
        STA     plot_pixels_ptr
        LDA     plot_pixels_ptr+1
        SBC     #$02
        STA     plot_pixels_ptr+1
        RTS
}

\ ******************************************************************************
\ * Function: draw_new_line
\ * Description: Draws the tractor beam line between ship and pod if attached
\ ******************************************************************************

.draw_new_line
{
        LDA     pod_destroying_player_timer
        BPL     L3170

        LDA     pod_tethered_flag
        BNE     L3175

    .L3170
        LDA     pod_line_exists_flag
        BNE     L3175
        RTS

    .L3175
        LDA     #$FF
        STA     line_drawn_flag
        JSR     calculate_line_coordinates

        LDA     level_line_pixels_byte
        STA     plot_line_pixels_byte
        JMP     draw_line
}

\ ******************************************************************************
\ * Function: calculate_line_coordinates
\ * Description: Calculates line start/end coords from ship and pod screen positions
\ ******************************************************************************

.calculate_line_coordinates
{
        CLC
        LDA     ship_window_ypos_INT
        ADC     #$0A
        STA     draw_line_start_y
        STA     old_draw_line_start_y
        LDA     pod_window_ypos_INT
        ADC     #$0A
        STA     draw_line_end_y
        STA     old_draw_line_end_y
        LDA     ship_window_xpos_INT
        ADC     #PLAYER_CENTRE_X_OFFSET
        ROL     ship_window_xpos_FRAC
        ROL     A
        ROL     ship_window_xpos_FRAC
        ROL     A
        STA     draw_line_start_x
        STA     old_draw_line_start_x
        LDA     pod_window_xpos_INT
        ADC     #PLAYER_CENTRE_X_OFFSET
        ROL     pod_window_xpos_FRAC
        ROL     A
        ROL     pod_window_xpos_FRAC
        ROL     A
        STA     draw_line_end_x
        STA     old_draw_line_end_x
        RTS
}

\ ******************************************************************************
\ * Function: erase_old_line
\ * Params: none
\ * Returns: none
\ * Description: Erases previously drawn tractor beam line by redrawing it with XOR
\ ******************************************************************************

.erase_old_line
{
        LDA     line_drawn_flag
        BNE     draw_old_line

        RTS

    .draw_old_line
        LDA     #$00
        STA     line_drawn_flag

        LDA     old_draw_line_start_x
        STA     draw_line_start_x
        LDA     old_draw_line_end_x
        STA     draw_line_end_x
        LDA     old_draw_line_start_y
        STA     draw_line_start_y
        LDA     old_draw_line_end_y
        STA     draw_line_end_y
        LDA     level_line_pixels_byte
        STA     plot_line_pixels_byte
        JSR     draw_line

        RTS
}

.level_line_pixels_byte
        EQUB    $FF

\ ******************************************************************************
\ * Function: tick_fuel_pickup_draw_beams
\ * Description: Handles fuel collection: adds fuel, draws/erases refuelling beams
\ ******************************************************************************

.tick_fuel_pickup_draw_beams
{
        LDA     fuel_beam_position_flag
        BEQ     L31E6

        LDX     fuel_beam_start_x
        LDY     fuel_beam_start_y
        JSR     draw_beams

        LDA     #$00
        STA     fuel_beam_position_flag
        
    .L31E6
        LDA     collecting_fuel_flag
        BNE     L31EB

    .return
        RTS

    .L31EB
        JSR     add_fuel

        LDA     level_tick_counter
        ROR     A
        BCC     return

        LDA     ship_window_ypos_INT
        CLC
        ADC     #$14
        STA     fuel_beam_start_y
        TAY
        LDA     ship_window_xpos_INT
        ROL     ship_window_xpos_FRAC
        ROL     A
        ROL     ship_window_xpos_FRAC
        ROL     A
        STA     fuel_beam_start_x
        TAX
        LDA     #$01
        STA     fuel_beam_position_flag
        JMP     draw_beams

    .draw_beams
        TXA
        STA     draw_line_start_x
        CLC
        ADC     #$0A
        STA     draw_line_end_x
        TYA
        STA     draw_line_end_y
        ADC     #$1E
        STA     draw_line_start_y
        LDA     #$0F
        STA     plot_line_pixels_byte
        JSR     draw_line

        CLC
        LDA     draw_line_end_x
        ADC     #$0C
        STA     draw_line_end_x
        ADC     #$08
        STA     draw_line_start_x
        JMP     draw_line
}

.fuel_beam_start_x
        EQUB    $00
.fuel_beam_start_y
        EQUB    $00

\ ******************************************************************************
\ * Function: do_teleport_animation
\ * Description: Animates expanding then contracting teleport rings around the ship
\ ******************************************************************************

.do_teleport_animation
{
        LDA     #$00
        STA     teleport_ring_count
        
    .L3239
        INC     teleport_ring_count
        JSR     plot_teleport_effect_1

        JSR     L325B

        LDA     teleport_ring_count
        CMP     #$06
        BNE     L3239

    .L3247
        JSR     L3255
        JSR     L3255

        JSR     plot_teleport_effect_1

        DEC     teleport_ring_count
        BNE     L3247
        RTS

    .L3255
        LDA     teleport_appear_or_disappear
        BEQ     L3261
        BNE     go_to_draw

    .L325B
        LDA     teleport_appear_or_disappear
        BNE     L3261
        BEQ     go_to_draw

    .L3261
        LDA     teleport_ring_count
        CMP     #$03
        BCS     go_to_draw

        LDX     #$00
        STX     plot_ship_collision_detected
        STX     pod_line_exists_flag
        STX     pod_tethered_flag

    .go_to_draw
        JMP     draw_player_timed_to_vsync
}

\ ******************************************************************************
\ * Functions: player_teleport_appear, player_entered_orbit, player_teleport
\ * Description: Handles teleport appear/disappear and orbit entry with animation
\ ******************************************************************************

.player_teleport_appear
{
        LDA     #$00
        STA     teleport_appear_or_disappear
        BEQ     player_teleport
}
\\ Unreachable!
        
.player_entered_orbit
{
        JSR     enter_orbit_sound

        LDA     #$FF
        STA     teleport_appear_or_disappear
}
\\ Fall through!

.player_teleport
{
        LDA     pod_line_exists_flag
        PHA
        LDA     plot_ship_collision_detected
        PHA
        LDA     pod_tethered_flag
        PHA
        LDX     #$FF
        STX     plot_ship_collision_detected
        INX
        STX     pod_line_exists_flag
        STX     pod_tethered_flag
        JSR     draw_player_timed_to_vsync

        JSR     calculate_line_coordinates
        JSR     calculate_pixels_ptr
        JSR     pixels_ptr_offset_diagonal_by_4

        LDA     plot_pixels_ptr
        STA     old_plot_pixels_ptr
        LDA     plot_pixels_ptr+1
        STA     old_plot_pixels_ptr+1
        LDA     pixel_column_index
        STA     old_pixel_column_index
        LDA     draw_line_end_x
        STA     draw_line_start_x
        LDA     draw_line_end_y
        STA     draw_line_start_y
        JSR     calculate_pixels_ptr

        JSR     pixels_ptr_offset_diagonal_by_4

        LDA     plot_pixels_ptr
        STA     teleport_screen_addr_LO
        LDA     plot_pixels_ptr+1
        STA     teleport_screen_addr_HI
        LDA     pixel_column_index
        STA     current_obj_visible_flag
        PLA
        PHA
        BNE     L32CB

        LDA     #$00
        STA     teleport_screen_addr_HI
        
    .L32CB
        JSR     do_teleport_animation

        PLA
        STA     pod_tethered_flag
        PLA
        STA     plot_ship_collision_detected
        PLA
        STA     pod_line_exists_flag
        RTS
}

\ ******************************************************************************
\ * Function: pixels_ptr_offset_diagonal_by_4
\ * Description: Offsets pixel pointer diagonally by 4 pixels (right and up)
\ ******************************************************************************

.pixels_ptr_offset_diagonal_by_4
{
        LDX     #$04
        
    .loop
        JSR     pixels_ptr_add_7
        JSR     pixels_ptr_decrement

        DEX
        BNE     loop

        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Sound routines
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: explosion_sound
\ * Description: Plays two explosion sound effects and sets sound timer to 31
\ ******************************************************************************

.explosion_sound
{
        LDA     #$1F
        STA     sound_timer

        LDX     #LO(sound_params_explosion_1)
        JSR     make_sound

        LDX     #LO(sound_params_explosion_2)
        JMP     make_sound
}

\ ******************************************************************************
\ * Function: run_engine
\ * Description: Plays engine thrust sound if shield not active and no sound queued
\ ******************************************************************************

.run_engine
\\ {
        LDA     shield_tractor_pressed
        BNE     run_engine_return

        LDA     #$05
        STA     sound_param_engine_pitch

.run_engine_ext
        LDA     sound_timer
        BNE     run_engine_return

        LDX     #LO(sound_params_engine)
        JSR     make_sound

    .run_engine_return
        LDA     #$02
        STA     sound_param_engine_pitch
        RTS
\\ }

\ ******************************************************************************
\ * Function: own_gun_sound
\ * Description: Plays the player gun firing sound effect
\ ******************************************************************************

.own_gun_sound
{
        LDX     #LO(sound_params_own_gun)
        JMP     make_sound
}

\ ******************************************************************************
\ * Function: hostile_gun_sound
\ * Description: Plays the enemy gun firing sound effect
\ ******************************************************************************

.hostile_gun_sound
{
        LDX     #LO(sound_params_hostile_gun)
        JMP     make_sound
}

\ ******************************************************************************
\ * Function: collect_pod_fuel_sound
\ * Description: Plays a three-part pod/fuel collection sound effect
\ ******************************************************************************

.collect_pod_fuel_sound
{
        LDX     #LO(sound_params_collect_1)
        JSR     make_sound

        LDX     #LO(sound_params_collect_2)
        JSR     make_sound

        LDX     #LO(sound_params_collect_1)
        JMP     make_sound
}

\ ******************************************************************************
\ * Functions: make_sound, make_sound_ext
\ * Params: X = address of sound params LO byte, Y = address of sound params HI byte
\ * Returns: none
\ * Description: Calls OSWORD 7 to play a sound unless muted or in demo mode
\ ******************************************************************************

.make_sound
\\ {
        LDY     #HI(sound_params_page)

.make_sound_ext
        LDA     mute_sound_flag
        BNE     sound_return

        LDA     demo_mode_flag
        BNE     sound_return

        LDA     #$07
        JMP     OSWORD
\\ }

\ ******************************************************************************
\ * Function: countdown_sound
\ * Description: Plays the countdown warning sound using two sound parameters
\ ******************************************************************************

.countdown_sound
{
        LDX     #LO(sound_params_collect_2)
        JSR     make_sound

        LDX     #LO(sound_params_countdown)
        JMP     make_sound
}

\ ******************************************************************************
\ * Function: enter_orbit_sound
\ * Description: Plays the enter-orbit sound effect
\ ******************************************************************************

.enter_orbit_sound
{
        LDX     #LO(sound_params_enter_orbit)
        LDY     #HI(sound_params_enter_orbit)
        JMP     make_sound_ext
}

\ ******************************************************************************
\ * Function: update_sound_timer
\ * Description: Decrements the sound timer if it is non-zero
\ ******************************************************************************

.update_sound_timer
{
        LDA     sound_timer
        BEQ     sound_return
        DEC     sound_timer
}
\\ Fall through!
        
.sound_return
{
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Sprite data
\ *
\ * In SWRAM builds this block is replaced by tools/output/object_sprites.asm,
\ * which is owned by tools/sprite_editor.py. Keep inline copy in sync if
\ * non-SWRAM builds are ever revived.
\ ******************************************************************************
\ ******************************************************************************

IF _SWRAM_BUILD=FALSE
INCLUDE "thrust1/obj_sprite_data.asm"
ENDIF ; _SWRAM_BUILD=FALSE

\ ******************************************************************************
\ ******************************************************************************
\ * Function: game_start
\ * Description: Entry point that jumps to start_new_game
\ ******************************************************************************
\ ******************************************************************************

.game_start
{
        JMP        start_new_game
}

\ ******************************************************************************
\ * Generic game variables
\ ******************************************************************************

.level_hostile_gun_probability
        EQUB    $00                        ; init to 1, incremented at start of levels 3-6 (not 1&2), capped at $23 (35)

.planet_destroyed_hostile_gun_modifier
        EQUB    $00                        ; init to 0, set to 8 when planet destroyed

.reverse_gravity_msg_shown
        EQUB    $00

.invisible_landscape_msg_shown
        EQUB    $00

.high_score_time_out
        EQUB    $00

.extra_string_ptrs
        EQUB    LO(string_i_love_space), LO(string_physics_is_fun),LO(string_support_hotol)

\ ******************************************************************************
\ ******************************************************************************
\ * Main game loop
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: player_new_high_score
\ * Description: Clears escape condition then prompts player to enter high score name
\ ******************************************************************************

.player_new_high_score
{
        LDA        #$7E
        JSR        OSBYTE                    ; clear escape + effects
        JSR        enter_new_high_score_name
}
\\ Fall through!

\ ******************************************************************************
\ * Function: high_score_start
\ * Description: Shows high score table, runs attract loop, starts game or demo
\ ******************************************************************************

.high_score_start
{
        LDA     #$7E
        JSR     OSBYTE                    ; clear escape + effects

        LDA     #$00
        STA     total_levels_played
        STA     invisible_landscape_flag
        STA     level_number
        STA     reverse_gravity_flag
        LDA     #$8C
        STA     high_score_time_out
        LDA     #$02
        STA     hostile_gun_shoot_probability

        JSR     initialise_level_pointers
        JSR     level_reset
        JSR     initialise_landscape
        JSR     update_window_and_terrain_tables
        JSR     landscape_draw
        JSR     draw_pod_and_collision_test
        JSR     update_and_draw_all_objects
        JSR     plot_high_score_table
        JSR     write_top_8_thrusters
        JSR     write_press_spacebar

        LDX     #$00
        STX     demo_keypress_bit_mask
        STX     demo_keypress_timer
        STX     demo_keypress_index

    .high_score_tick_loop
        INC     level_tick_counter
        JSR     update_and_draw_all_objects
        JSR     particles_update_and_draw

        LDA     #$0F
        LDX     #$00
        JSR     OSBYTE                        ; *FX 15,0 - flush all buffers

        LDA     #$81
        LDX     #$03
        LDY     #$00
        JSR     OSBYTE                        ; *FX $81 - read key with time limit

        LDA     #$00
        STA     demo_mode_flag
        
        LDX     #INKEY_spacebar
        JSR     test_inkey

        BEQ     start_new_game

        LDA     #$FF
        STA     demo_mode_flag
        
        LDA     level_tick_counter
        AND     #$01
        BEQ     high_score_tick_loop

        DEC     high_score_time_out
        BNE     high_score_tick_loop

        JSR     clear_screen_and_init

        LDY     #$0A
        JSR     wait_time_out_Y

        JMP     level_start_demo_entry
}

\ ******************************************************************************
\ * Function: start_new_game
\ * Description: Initialises all game state, score, lives and fuel for a new game
\ ******************************************************************************

.start_new_game
{
        LDX     #$01
        STX     level_hostile_gun_probability           ; set level_hostile_gun_probability to 1
        DEX
        STX     planet_destroyed_hostile_gun_modifier   ; set planet_destroyed_hostile_gun_modifier to 0
        STX     reverse_gravity_msg_shown               ; set reverse_gravity_msg_shown to 0
        STX     invisible_landscape_msg_shown           ; set invisible_landscape_msg_shown to 0
        STX     extra_string_index                      ; set extra_string_index to 0
        STX     extra_string_counter                    ; set extra_string_counter to 0

        LDX     #$03
        
    .zero_fuel_and_score
        LDA     #$00
        STA     fuel_A,X                                ; set fuel_A to zero
        STA     score_A,X                               ; set score_A to zero
        DEX
        BPL     zero_fuel_and_score

        LDX     #$0D
        
    .store_32_loop
        LDA     #$20
        STA     score_C,X                               ; store $20 (32) at L0183 for 13 bytes
        DEX
        BNE     store_32_loop

        LDA     #$00                                    ; set initial score_A
        JSR     add_A_to_score

        LDA     #INITIAL_LIVES                          ; set initial number of lives
        STA     lives
        JSR     lose_a_life

        LDA     #INITIAL_FUEL
        STA     fuel_B                                  ; set initial fuel value (1000)
        
        LDA     #$FF
        STA     total_levels_played                     ; set total_levels_played to 255 (-1)
        
        LDA     #LO(INITIAL_LEVEL-2)
        STA     level_number                            ; set level_number to 255 (-1)

        LDA     #$00
        STA     mission_number                          ; zero mission number
        STA     level_modifier_flag                     ; zero level modifier flag (reverse gravity etc.)
        STA     invisible_landscape_flag                ; set invisible_landscape_flag to 0
        STA     reverse_gravity_flag                    ; set reverse_gravity_flag to 0
        STA     fuel_empty_flag                         ; zero fuel flag
        JSR     plot_fuel_value
}
\\ Fall through!

\ ******************************************************************************
\ * Function: start_new_level
\ * Description: Advances to next level, toggles gravity/invisible modifiers, shows messages
\ ******************************************************************************

.start_new_level
{
        LDA     #$00
        STA     midpoint_ypos_INT
        STA     midpoint_ypos_INT_HI
        INC     total_levels_played
        INC     level_number
        LDA     level_number
        CMP     #$06                                    ; number of levels
        BNE     setup_next_mission

        LDA     #$00
        STA     level_number                            ; reset level number to 0

        LDA     reverse_gravity_flag
        EOR     #$FF
        STA     reverse_gravity_flag                    ; invert flag
        BNE     setup_reverse_gravity

        LDA     invisible_landscape_flag
        EOR     #$0F
        STA     invisible_landscape_flag                ; invert lower 4 bits of flag

    .setup_reverse_gravity
        LDA     reverse_gravity_flag
        BEQ     setup_invisible_landscape

        LDA     reverse_gravity_msg_shown
        BNE     setup_invisible_landscape

        JSR     clear_screen_and_init
        JSR     write_reverse_gravity

        LDY     #$96                                    
        STY     reverse_gravity_msg_shown
        JSR     wait_time_out_Y

        JMP     setup_clear_screen

    .setup_invisible_landscape
        LDA     invisible_landscape_flag
        BEQ     setup_clear_screen

        LDA     invisible_landscape_msg_shown
        BNE     setup_clear_screen

        JSR     clear_screen_and_init
        JSR     write_invisible_landscape

        LDY     #$96                                    ; why $96?  Just timeout value recycled as flag!
        STY     invisible_landscape_msg_shown
        JSR     wait_time_out_Y

    .setup_clear_screen
        INC     extra_string_counter
        LDA     extra_string_counter                    ; number of attempts at level?
        AND     #$03
        BNE     setup_next_mission

        JSR     clear_screen_and_init

        LDX     extra_string_index
        CPX     #$02
        BEQ     skip_inc_extra_string_index

        INC     extra_string_index
        
    .skip_inc_extra_string_index
        LDA     #HI(end_of_level_messages)
        STA     plot_string_ptr+1
        LDA     extra_string_ptrs,X
        TAX
        JSR     write_message

        JSR     generate_stars_to_start                    ; generate star field and scroll window

        LDY     #$50
        JSR     wait_time_out_Y

    .setup_next_mission
        SED                                                ; set decimal mode
        CLC
        LDA     mission_number
        ADC     #$01
        STA     mission_number                            ; increment mission_number by 1
        CLD                                                ; clear decimal mode

        LDA     #$01
        LDX     mission_number
        CPX     #$03            
        BCC     setup_level                                ; mission_number less than 3

        INC     level_hostile_gun_probability            ; increment level_hostile_gun_probability
        LDA     level_hostile_gun_probability
        CMP     #$23
        BCC     setup_level

        LDA     #$23
        STA     level_hostile_gun_probability            ; cap level_hostile_gun_probability to $23 (35)
        
    .setup_level
        CLC
        ADC     planet_destroyed_hostile_gun_modifier    ; level_hostile_gun_probability + planet_destroyed_hostile_gun_modifier
        STA     hostile_gun_shoot_probability            ; store at hostile_gun_shoot_probability

        LDA     #$00
        STA     planet_destroyed_hostile_gun_modifier    ; reset planet_destroyed_hostile_gun_modifier to zero

        JSR     initialise_level_pointers
}
\\ Fall through!

\ ******************************************************************************
\ * Function: level_retry
\ * Description: Resets the current level state for a retry after death
\ ******************************************************************************

.level_retry
{
        JSR     level_reset
}
\\ Fall through!

\ ******************************************************************************
\ * Function: level_start_demo_entry
\ * Description: Sets up randomised demo mode timers, inits level and teleports player in
\ ******************************************************************************

.level_start_demo_entry
{
        JSR     rnd
        AND     #$03
        ADC     #$08
        STA     demo_keypress_timer_rnd_A        ; tweak keypress timers for demo mode

        JSR     rnd
        AND     #$03
        ADC     #$04
        STA     demo_keypress_timer_rnd_B        ; tweak keypress timers for demo mode
        
        LDA     #$7F
        STA     demo_keypress_timer_rnd_C        ; tweak keypress timers for demo mode

        JSR     rnd
        AND     #$03
        BNE     demo_no_big_spin
        LDA     #$23
        STA     demo_keypress_timer_rnd_C        ; is either $7F (75%) or $23 (25%) - big spin 1 in 4 times? :)

    .demo_no_big_spin
        LDA     #$0F
        LDX     #$00
        JSR     OSBYTE                            ; *FX 15,0 - flush all buffers

        LDA     #$00
        STA     level_tick_counter                ; set level_tick_counter to 0

        JSR     initialise_landscape
        JSR     update_window_and_terrain_tables
        JSR     calculate_player_position_from_midpoint
        JSR     landscape_draw
        JSR     update_and_draw_all_objects

        LDY     #$08
        JSR     wait_time_out_Y

        JSR     player_teleport_appear

        LDA     #$00
        STA     level_tick_state

        JSR     reset_system_clock
}
\\ Fall through!

\ ******************************************************************************
\ * Function: tick_loop
\ * Description: Main game tick loop: runs input, physics, drawing and end-of-level logic
\ ******************************************************************************

.tick_loop
{
\\ This is the main tick loop that performs all game logic and rendering:

        JSR     demo_mode_tick

SET_BG_COL PAL_yellow
        JSR     hide_landscape
        JSR     ship_input_rotate
        JSR     midpoint_add_force_vector
        JSR     update_window_and_terrain_tables
SET_BG_COL PAL_black
        JSR     draw_player_timed_to_vsync
        JSR     update_player_and_pod_states
SET_BG_COL PAL_blue
        JSR     update_and_draw_all_objects
SET_BG_COL PAL_magenta
        JSR     landscape_draw
SET_BG_COL PAL_black

        JSR     tick_fuel_pickup_draw_beams
        JSR     ship_input_fire
SET_BG_COL PAL_cyan
        JSR     particles_update_and_draw
SET_BG_COL PAL_green
        JSR     test_for_pause
        JSR     calculate_player_position_from_midpoint
        JSR     plot_fuel_value
        IF _DEBUG_FRAME_TIME
        JSR     plot_debug_frame_time
        ENDIF
        JSR     update_sound_timer
IF _Y_BANDS
        JSR     update_active_band
ENDIF
IF _LAST_USED_CHECKPOINT
        JSR     update_active_checkpoint
ENDIF
        JSR     ship_input_thrust_calculate_force
SET_BG_COL PAL_black
        
        JSR     test_player_escaped_to_orbit
        BCS     test_level_ended_else_tick_loop

        LDA     pod_destroying_player_timer
        BPL     test_level_ended_else_tick_loop

\\ At this point the level has ended in some way!
        
        LDY     #$03
        JSR     wait_time_out_Y

        JSR     player_entered_orbit

        LDY     #$14
        JSR     wait_time_out_Y

        JSR     show_landscape

        LDA     demo_mode_flag
        BNE     go_to_high_score

        LDA     fuel_empty_flag
        BNE     player_out_of_fuel

        LDA     pod_tethered_flag
        BNE     player_completed_mission

        LDA     planet_countdown_timer
        BMI     player_died_collision

    .player_died_countdown
        JSR     clear_screen_and_init
        JSR     show_landscape

        LDA     #$08
        STA     planet_destroyed_hostile_gun_modifier

        JSR     write_planet_destroyed
        JSR     write_mission

        LDA     #$20
        JSR     plot_char_A

        LDA     mission_number
        JSR     write_decimal_A

        LDA     #$20
        JSR     plot_char_A
        JSR     plot_char_A

        JSR     write_failed
        JSR     write_no_bonus

        LDY     #$78
        JSR     wait_time_out_Y
        JMP     start_new_level

    .player_out_of_fuel
        JMP     game_over

    .go_to_high_score
        JMP     high_score_start

    .player_died_collision
        JSR     clear_screen_and_init

        JSR     write_mission
        JSR     write_in
        JSR     write_complete

        LDY     #$3C
        JSR     wait_time_out_Y

        JMP     level_retry

    .player_completed_mission
        JSR     mission_complete
        JMP     start_new_level

    .jump_tick_loop
        JMP     tick_loop

    .test_level_ended_else_tick_loop
        LDX     #INKEY_escape
        JSR     test_inkey

        BEQ     key_was_pressed

        LDA     demo_mode_flag
        BEQ     skip_test_for_keypress

        LDA     #$81
        LDX     #$00
        LDY     #$00
        JSR     OSBYTE                    ; *FX $81 - read key with time limit

        CPY     #$FF
        BNE     key_was_pressed            ; key was pressed

    .skip_test_for_keypress
        INC     level_tick_counter

        LDA     level_ended_flag
        BEQ     jump_tick_loop

        LDA     demo_mode_flag
        BNE     go_to_high_score

        LDA     fuel_empty_flag
        BNE     game_over

        JSR     lose_a_life

        CPX     #$FF
        BEQ     game_over

        LDA     planet_countdown_timer
        BMI     jump_to_retry_level

        JMP     player_died_countdown

    .jump_to_retry_level
        JMP     level_retry

    .game_over
        JSR     clear_screen_and_init
        JSR     show_landscape

        LDA     fuel_empty_flag
        BEQ     show_game_over_message

        JSR     write_out_of_fuel

    .show_game_over_message
        JSR     write_game_over

        LDY     #$5A
        JSR     wait_time_out_Y

        JMP     player_new_high_score
}
\\ Fall through!

.key_was_pressed
{
        JMP     high_score_start
}

\ ******************************************************************************
\ * Function: update_player_and_pod_states
\ * Description: Updates player/pod state each tick, handles collisions and explosions
\ ******************************************************************************

.update_player_and_pod_states
{
        LDA     #$00
        STA     level_ended_flag

        LDA     pod_tethered_flag
        BNE     L38BE

        LDA     ship_sprite_plotted_flag
        BNE     L38BE

        STA     pod_line_exists_flag
        
    .L38BE
        LDA     pod_destroying_player_timer
        BMI     L38F0

        LDA     planet_countdown_timer
        BEQ     planet_countdown_at_zero

\\ Set standard colour for landscape

        LDY     level_number
        LDA     level_landscape_colour,Y
        LDY     #$02
        JSR     palette_set_colour_Y_to_A

    .planet_countdown_at_zero
        DEC     pod_destroying_player_timer
        BEQ     set_level_ended

        LDA     pod_destroying_player_timer
        CMP     #$28
        BNE     L38E2

        LDA     #$00
        LDY     #$00
        JSR     palette_set_colour_Y_to_A

    .L38E2
        DEC     top_nibble_index
        DEC     top_nibble_index
        BPL     L38F0

        LDA     player_ship_destroyed_flag
        BMI     destroy_player_ship

        LDA     pod_tethered_flag
        BNE     destroy_attached_pod

    .L38F0
        LDA     player_ship_destroyed_flag
        BPL     L38FF

        LDA     pod_tethered_flag
        BEQ     L38FF

        LDA     #$01
        STA     pod_line_exists_flag
        JMP     L3907

    .L38FF
        LDA     pod_destroying_player_timer
        BPL     L3907

        LDA     #$00
        STA     pod_line_exists_flag
        
    .L3907
        LDA     plot_pod_collision_detected
        BNE     destroy_attached_pod

        LDA     plot_ship_collision_detected
        BNE     destroy_player_ship

        JSR     calculate_pod_pos

        RTS
}

\ ******************************************************************************
\ * Function: set_level_ended
\ * Description: Sets level_ended_flag to signal the current level has ended
\ ******************************************************************************

.set_level_ended
{
        LDA     #$FF
        STA     level_ended_flag
        RTS
}

\ ******************************************************************************
\ * Function: destroy_player_ship
\ * Description: Triggers player ship explosion with debris particles at ship position
\ ******************************************************************************

.destroy_player_ship
{
        LDX     #$01
        STX     level_tick_state
        LDA     player_ship_destroyed_flag
        BPL     return

        LDA     #POD_DESTROY_TIMER_INIT
        STA     pod_destroying_player_timer
        LDA     #$00
        STA     plot_ship_collision_detected
        LDA     #$01
        STA     player_ship_destroyed_flag
        LDA     old_player_xpos_FRAC
        STA     explosion_xpos_FRAC
        CLC
        LDA     old_player_xpos_INT
        ADC     #PLAYER_CENTRE_X_OFFSET            ; to centre of player object?
        STA     explosion_xpos_INT
        CLC
        LDA     old_player_ypos_INT
        ADC     #PLAYER_CENTRE_Y_OFFSET            ; to centre of player object?
        STA     explosion_ypos_INT
        LDA     old_player_ypos_INT_HI
        ADC     #$00
        STA     explosion_ypos_INT_HI
        LDA     #PARTICLE_type_debris
        STA     explosion_angle
        STA     explosion_particle_type
        JSR     create_explosion

    .return
        RTS
}

\ ******************************************************************************
\ * Function: destroy_attached_pod
\ * Description: Detaches and explodes the pod with debris particles at pod position
\ ******************************************************************************

.destroy_attached_pod
{
        LDX     #$01
        STX     level_tick_state
        DEX
        STX     pod_tethered_flag
        STX     plot_pod_collision_detected
        LDA     #POD_DESTROY_TIMER_INIT
        STA     pod_destroying_player_timer
        LDA     pod_xpos_FRAC
        STA     explosion_xpos_FRAC
        LDA     pod_xpos_INT
        STA     explosion_xpos_INT
        LDA     pod_ypos_FRAC
        STA     explosion_ypos_INT
        LDA     pod_ypos_INT_HI
        STA     explosion_ypos_INT_HI
        LDA     #PARTICLE_type_debris
        STA     explosion_angle
        STA     explosion_particle_type
        JSR     create_explosion

        RTS
}

\ ******************************************************************************
\ * Function: calculate_pod_pos
\ * Description: Calculates pod screen position relative to the midpoint/player
\ ******************************************************************************

.calculate_pod_pos
{
        SEC
        LDA     midpoint_xpos_FRAC
        SBC     midpoint_deltax_FRAC
        STA     pod_xpos_FRAC
        LDA     midpoint_xpos_INT
        SBC     midpoint_deltax_INT
        CLC
        ADC     #$04
        STA     pod_xpos_INT
        SEC
        LDA     midpoint_ypos_INT
        SBC     midpoint_deltay_INT
        STA     pod_ypos_FRAC
        LDA     midpoint_ypos_INT_HI
        SBC     #$00
        STA     pod_ypos_INT_HI
        LDA     midpoint_deltay_INT
        BPL     L3998

        INC     pod_ypos_INT_HI
        
    .L3998
        CLC
        LDA     pod_ypos_FRAC
        ADC     #$05
        STA     pod_ypos_FRAC
        LDA     pod_ypos_INT_HI
        ADC     #$00
        STA     pod_ypos_INT_HI
        RTS
}

\ ******************************************************************************
\ * Function: hide_landscape
\ * Description: Hides landscape by setting its palette colour to black
\ ******************************************************************************

.hide_landscape
{
        LDA     planet_countdown_timer
        BEQ     set_landscape_colour_to_black

        LDA     pod_destroying_player_timer
        BPL     return

        LDA     invisible_landscape_flag
        BEQ     return

        LDA     shield_tractor_pressed
        BEQ     set_landscape_colour_to_black

        JMP     show_landscape

    .set_landscape_colour_to_black
        LDA     #$00
        LDY     #$02
        JMP     palette_set_colour_Y_to_A

    .return
        RTS
}

\ ******************************************************************************
\ * Function: show_landscape
\ * Description: Restores the landscape palette colour for the current level
\ ******************************************************************************

.show_landscape
{
        LDY     level_number
        LDA     level_landscape_colour,Y
        LDY     #$02
        JMP     palette_set_colour_Y_to_A
}

\ ******************************************************************************
\ * Function: test_player_escaped_to_orbit
\ * Returns: carry clear if player high enough to escape to orbit else carry set
\ * Description: Tests if player Y position is high enough to escape to orbit
\ ******************************************************************************

.test_player_escaped_to_orbit
{
        LDA     midpoint_ypos_INT_HI
        CMP     #$01
        BNE     L39D8

        LDA     midpoint_ypos_INT
        CMP     #$20
        BCC     L39DA

    .L39D8
        SEC
        RTS

    .L39DA
        CLC
        RTS
}

\ ******************************************************************************
\ * Function: escape_pressed
\ * Description: Handles escape key by jumping to the high score screen
\ ******************************************************************************

.escape_pressed
{
        JMP     key_was_pressed
}

\ ******************************************************************************
\ * Function: wait_time_out_Y
\ * Params: Y = length of timeout in centiseconds
\ * Description: Waits Y centiseconds polling for keypress, handles escape to abort
\ ******************************************************************************

.wait_time_out_Y
{
        STY     time_out_vsync_count
        
    .wait_loop
        CMP     vsync_count
        BEQ     wait_loop

        LDA     #$81
        LDX     #$00
        LDY     #$00
        JSR     OSBYTE                    ; *FX $81,0 - read key with time limit

        CPY     #ASCII_escape
        BEQ     escape_pressed            ; escape pressed

        LDA     vsync_count
        DEC     time_out_vsync_count
        BNE     wait_loop

        JMP     reset_system_clock
}

\ ******************************************************************************
\ * Function: clear_screen_and_init
\ * Description: Clears screen memory, resets terrain tables, objects and particles
\ ******************************************************************************

.clear_screen_and_init
{
        LDA     #$00
        LDY     #$00
        JSR     palette_set_colour_Y_to_A

        LDA     #$20
        JSR     write_countdown_timer

        LDX     #$11
        
    .L3A09
        LDA     #$00
        STA     terrain_draw_table_1,X
        LDA     #SCREEN_WIDTH_CHARS                    ; $48 = 72 = num chars
        STA     terrain_draw_table_3,X
        INX
        BPL     L3A09

        LDX     #LEVEL_MAX_OBJECTS                    ; max number of objects
        
    .L3A18
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_drawn)
        STA     level_obj_flags,X
        DEX
        BPL     L3A18

        LDX     #$20
        
    .L3A25
        LDA     #$00
        STA     particles_lifetime,X
        DEX
        BPL     L3A25

        LDA     #LO(SCREEN_START_ADDR)
        STA     clear_screen_ptr
        LDA     #HI(SCREEN_START_ADDR)
        STA     clear_screen_ptr+1
        LDY     #$00
        LDA     #$00
        
    .clear_screen_loop
        STA     (clear_screen_ptr),Y
        INY
        BNE     clear_screen_loop

        INC     clear_screen_ptr+1
        BPL     clear_screen_loop

        RTS
}

\ ******************************************************************************
\ * Function: draw_player_timed_to_vsync
\ * Description: Syncs ship drawing to vsync, waits for system clock timing window
\ ******************************************************************************

.draw_player_timed_to_vsync
{
        LDA     #$00
        STA     player_sprite_drawn_flag

    .loop
        LDA     irq1_timer1_signal
        BEQ     wait_for_system_clock     ; timer 1 not fired yet

        LDA     player_sprite_drawn_flag
        BNE     wait_for_system_clock     ; player already drawn

SET_BG_COL PAL_red
        JSR     draw_ship_line_and_pod    ; draw player sprite immediately
SET_BG_COL PAL_black

        LDA     #$FF
        STA     player_sprite_drawn_flag  ; Flag player drawn

    .wait_for_system_clock
        LDY     #HI(system_clock_value)
        LDX     #LO(system_clock_value)
        LDA     #$01
        JSR     OSWORD                    ; read system clock

        LDA     system_clock_value
        CMP     #$03
        BCC     loop                      ; wait minimum 0.03s

        IF _SWRAM_BUILD
        STA     debug_frame_time_cs
        ENDIF

        LDA     #$00
        STA     system_clock_value        ; reset system clock.
        
        LDY     #HI(system_clock_value)
        LDX     #LO(system_clock_value)
        LDA     #$02
        JSR     OSWORD                    ; write system clock

        LDA     player_sprite_drawn_flag
        BNE     return

SET_BG_COL PAL_red
        JSR     draw_ship_line_and_pod    ; draw player if not done already
SET_BG_COL PAL_black

    .return
        RTS
}

\ ******************************************************************************
\ * Function: reset_system_clock
\ * Description: Resets the system clock to zero via OSWORD
\ ******************************************************************************

.reset_system_clock
{
        LDA     #$00
        STA     system_clock_value
        
        LDY     #HI(system_clock_value)
        LDX     #LO(system_clock_value)
        LDA     #$02
        JMP     OSWORD                    ; write system clock
}

\ ******************************************************************************
\ * Function: draw_ship_line_and_pod
\ * Description: Erases old tractor line, redraws ship/pod/shield, draws new line
\ ******************************************************************************

.draw_ship_line_and_pod
{
        JSR     erase_old_line
        JSR     update_shield_tractor_draw_ship_and_pod
        JMP     draw_new_line
}

\ ******************************************************************************
\ * System clock variables
\ ******************************************************************************

.system_clock_value
        EQUB    $00,$00,$00,$00,$00        ; LSB to MSB (5 bytes)

.player_sprite_drawn_flag
        EQUB    $00
        EQUB    $00                        ; unused?

\ ******************************************************************************
\ ******************************************************************************
\ * Keyboard handler
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: test_inkey
\ * Params: X = INKEY value of key to test
\ * Returns: A = 0 if pressed, <> 0 if not pressed
\ * Description: Tests a key via hardware port or delegates to demo fake keypress
\ ******************************************************************************

.test_inkey
{
        PHP
        CPX     #$8F
        BEQ     L3AA7

        LDA     demo_mode_flag
        BNE     demo_fake_keypress

    .L3AA7
        TXA
        EOR     #$FF
        LDX     #$03
        LDY     #$0B
        SEI
        STX     SHEILA_System_VIA_Register_B
        LDX     #$7F
        STX     SHEILA_System_VIA_Data_Dir
        STA     SHEILA_System_VIA_Register_A_NH
        LDA     SHEILA_System_VIA_Register_A_NH
        STY     SHEILA_System_VIA_Register_B
        PLP
        LDX     #$00
        ROL     A
        BCC     L3AC8

        LDX     #$FF
        
    .L3AC8
        CPX     #$FF
        RTS
}

\ ******************************************************************************
\ ******************************************************************************
\ * Demo / attract mode routines
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: demo_fake_keypress
\ * Params: X = <>
\ * Returns: A = 0 if pressed, <> 0 if not pressed
\ * Description: Simulates a keypress for demo mode using bitmask lookup tables
\ ******************************************************************************

.demo_fake_keypress
{
        PLP
        TXA
        LDX     #$04
        
    .L3ACF
        CMP     demo_inkey_table,X
        BEQ     L3ADA

        DEX
        BPL     L3ACF

        INX
        BEQ     demo_return_keypress_match

    .L3ADA
        LDA     lookup_index_to_bit,X
        LDX     #$00
        AND     demo_keypress_bit_mask
        BEQ     demo_return_keypress_match

        DEX
        
    .demo_return_keypress_match
        CPX     #$FF
        RTS
}

\ ******************************************************************************
\ * Demo lookup tables & variables
\ ******************************************************************************

.demo_inkey_table                                    ; 5x possible keypresses
        EQUB    KEY_ROTATE_left
        EQUB    KEY_ROTATE_right
        EQUB    KEY_FIRE
        EQUB    KEY_THRUST
        EQUB    KEY_SHIELD

.lookup_index_to_bit
        EQUB    $01,$02,$04,$08,$10                    ; 5x possible keypresses - make enums

.demo_keypress_bit_mask
        EQUB    $00

.demo_keypress_timer
        EQUB    $00

.demo_keypress_index
        EQUB    $00

\ ******************************************************************************
\ * Function: demo_mode_tick
\ * Description: Decrements demo keypress timer, advances to next keypress when expired
\ ******************************************************************************

.demo_mode_tick
{
        LDA     demo_mode_flag
        BEQ     return

        DEC     demo_keypress_timer
        BMI     demo_mode_next_keypress

    .return
        RTS
}

\ ******************************************************************************
\ * Function: demo_mode_next_keypress
\ * Description: Loads next demo keypress bitmask and timer from data tables
\ ******************************************************************************

.demo_mode_next_keypress
{
        LDX     demo_keypress_index
        LDA     demo_keypress_bit_mask_table,X
        STA     demo_keypress_bit_mask
        LDA     demo_keypress_timer_table,X
        STA     demo_keypress_timer
        INC     demo_keypress_index
        RTS
}

\ ******************************************************************************
\ * Demo data for fake keypresses etc.
\ ******************************************************************************

.demo_keypress_bit_mask_table                        ; these correspond to 5x bits above $01 to $10
        EQUB    $00,$02,$00,$04,$01,$10,$18,$00        ; those in turn match the 5x keypress INKEY values
        EQUB    $01,$00,$18,$08,$0A,$08,$0A,$08        ; can make these enums eventually when cleaning up
        EQUB    $0A,$08

.demo_keypress_timer_table
        EQUB    $18,$0F,$05,$05,$08,$14,$17,$0F

.demo_keypress_timer_rnd_A                            ; add some randomness to the demo mode
        EQUB    $08,$0D,$26,$0D

.demo_keypress_timer_rnd_B                            ; by tweaking length of keypress slightly
        EQUB    $06

.demo_keypress_timer_rnd_C                            ; only for specific keys so level always completes
        EQUB    $7F,$14,$0A,$0F,$7F

\ ******************************************************************************
\ * pod_lifted_flag: non-zero once the pod has been lifted off its stand this
\ * level (sticky until next level load). Set by attach_pod_to_ship, by the
\ * planet-countdown-zero handler, and on level respawn-with-pod. Controls:
\ *   - pod_stand loses its OBJ_flag_alive once set (update loop phase 2a)
\ *   - the shield-tractor beam is disabled once set (update_pod_tractor_beam)
\ *   - the pod is drawn by pod physics rather than as part of the stand
\ * Unlike pod_tethered_flag, this is NOT cleared when the pod is destroyed —
\ * only on a fresh level load.
\ ******************************************************************************

.pod_lifted_flag
        EQUB    $00

\ ******************************************************************************
\ ******************************************************************************
\ * High score routine
\ ******************************************************************************
\ ******************************************************************************

\ ******************************************************************************
\ * Function: enter_new_high_score_name
\ * Description: Checks if player beat a high score, inserts and prompts for name entry
\ ******************************************************************************

.enter_new_high_score_name
{
        LDA     #$09
        STA     high_score_counter
        LDA     #$01
        STA     high_score_ptr_A+1
        STA     high_score_ptr_B+1
        LDA     #$80
        STA     high_score_ptr_A
        LDA     #$70
        STA     high_score_ptr_B
        
    .L3B49
        LDY     #$02
        
    .L3B4B
        LDA     (high_score_ptr_A),Y
        CMP     (high_score_ptr_B),Y
        BCC     L3B56

        BNE     L3B5D

        DEY
        BPL     L3B4B

    .L3B56
        LDA     high_score_ptr_A
        CMP     #$80
        BNE     L3B7A

        RTS

    .L3B5D
        DEC     high_score_counter
        LDY     #$00
        
    .L3B61
        LDA     (high_score_ptr_A),Y
        PHA
        LDA     (high_score_ptr_B),Y
        STA     (high_score_ptr_A),Y
        PLA
        STA     (high_score_ptr_B),Y
        INY
        CPY     #$10
        BNE     L3B61

        LDA     high_score_ptr_B
        STA     high_score_ptr_A
        SBC     #$10
        STA     high_score_ptr_B
        BCS     L3B49

    .L3B7A
        CLC
        LDA     high_score_ptr_A
        ADC     #$06
        STA     read_line_parameter_block
        STA     high_score_ptr_C
        LDA     high_score_ptr_A+1
        STA     read_line_parameter_block+1
        STA     high_score_ptr_C+1

        JSR     clear_screen_and_init
        JSR     plot_high_score_table
        JSR     write_congratulations
        JSR     write_enter_name

        LDX     #$30
        LDY     #$4B
        JSR     plot_char_set_scr_addr_XY

        LDY     high_score_counter
        
    .L3BA0
        LDX     #$48
        
    .L3BA2
        JSR     char_write_ptr_next_column

        DEX
        BNE     L3BA2

        DEY
        BNE     L3BA0

        LDA     #$FF
        STA     char_flag_cursor
        LDA     #$00
        JSR     plot_char_A

        LDA     #$0F
        LDX     #$00
        LDY     #$00
        JSR     OSBYTE                    ; *FX 15 - flush all buffers

        LDA     #$F0
        STA     font_byte_mask

        LDA     #$00
        LDX     #LO(read_line_parameter_block)
        LDY     #HI(read_line_parameter_block)
        JSR     OSWORD                    ; read line from input stream

        BCC     L3BD5

        LDA     #$7E
        JSR     OSBYTE

        LDY     #$00
        
    .L3BD5
        LDA     #$20
        STA     (high_score_ptr_C),Y
        INY
        CPY     #$0A
        BNE     L3BD5

        LDA     #$0F
        STA     font_byte_mask
        LDA     #$00
        STA     char_flag_cursor
        RTS
}

\ ******************************************************************************
\ * Parameters for OSWORD 0
\ ******************************************************************************

.read_line_parameter_block                ; for OSWORD 0
        EQUB    $00                        ; buffer address for input LSB
        EQUB    $00                        ; buffer address for input MSB
        EQUB    $09                        ; maximum line length
        EQUB    $20                        ; min acceptable character value
        EQUB    $FF                        ; max acceptable character value

\ ******************************************************************************
\ * Functions: main_wrchv, jmp_wrchv
\ * Description: WRCHV intercept that redirects character output to plot_char_A
\ ******************************************************************************

.main_wrchv
{
        JMP        plot_char_A
        RTS
}
        
.jmp_wrchv
        JMP     LFFFF                    ; address gets written into code in main_entry
        old_wrchv   = jmp_wrchv+1

\ ******************************************************************************
\ * Functions: write_decimal_A
\ * Params: A = BCD value to plot to screen
\ * Description: Plots a BCD value as a one or two digit decimal number on screen
\ ******************************************************************************

.write_decimal_A
{
        PHA
        ROR     A
        ROR     A
        ROR     A
        ROR     A
        AND     #$0F
        BEQ     L3C04

        CLC
        ADC     #$30
        JSR     plot_char_A

    .L3C04
        PLA
        AND     #$0F
        CLC
        ADC     #$30
        JMP     plot_char_A
}

\ ******************************************************************************
\ * Function: mission_complete
\ * Description: Shows mission complete screen, calculates and awards bonus score
\ ******************************************************************************

.mission_complete
{
        LDA     #$00
        STA     level_modifier_flag
        JSR     clear_screen_and_init

        JSR     write_mission

        LDX     #$50
        LDY     #$56
        JSR     plot_char_set_scr_addr_XY

        LDA     mission_number
        JSR     write_decimal_A

        LDA     #$20
        JSR     plot_char_A

        JSR     write_complete

        SED
        CLC
        CLD
        LDA     #$00
        STA     bonus_score
        LDA     level_number
        CLC
        ADC     #$05
        LDY     planet_countdown_timer
        BMI     L3C47

        PHA
        JSR     write_planet_destroyed

        PLA
        CLC
        ADC     #$05
        
    .L3C47
        TAY
        
    .L3C48
        TYA
        PHA
        LDA     #$40
        JSR     add_A_to_score

        LDA     bonus_score
        SED
        ADC     #$04
        STA     bonus_score
        CLD
        PLA
        TAY
        DEY
        BNE     L3C48

        JSR     write_bonus

        LDA     bonus_score
        JSR     write_decimal_A

        LDA     #$30
        JSR     plot_char_A

        JSR     plot_char_A

        LDY     #$64
        JMP     wait_time_out_Y
}

\ ******************************************************************************
\ * Misc mission / level variables
\ ******************************************************************************

.bonus_score
        EQUB    $00

.mission_number
        EQUB    $00                        ; BCD starting at 1

.level_modifier_flag
        EQUB    $00

\ ******************************************************************************
\ ******************************************************************************
\ * Appears to be unreachable?
\ ******************************************************************************
\ ******************************************************************************

.L3C77
        EQUB    $1E,$A5,$7E,$C9,$02,$90,$18,$C9,$07

\ ******************************************************************************
\ ******************************************************************************
\ *
\ * This code cannot be higher than $3C80 (SCREEN_BASE_ADDR)
\ *
\ ******************************************************************************
\ ******************************************************************************

IF P%>SCREEN_BASE_ADDR
ERROR "Base code overruns available space!"
ELSE
PRINT "~~~~~~~~~~~~~~~~~~~"
PRINT "MAIN CODE RAM FREE=", ~(SCREEN_BASE_ADDR-P%), "bytes (", HI(SCREEN_BASE_ADDR-P%+&FF), "pages )"
PRINT "~~~~~~~~~~~~~~~~~~~"
ENDIF

\ ******************************************************************************
\ ******************************************************************************
\ * App init. Relocates code and data to lower RAM. Calls game_start.
\ ******************************************************************************
\ ******************************************************************************

INCLUDE "app_init.asm"

\ ******************************************************************************
\ ******************************************************************************
\ * End of original code
\ ******************************************************************************
\ ******************************************************************************

IF _SWRAM_BUILD
SWRAM_BANK      = 4
SPRITE_BANK     = 5
SWRAM_ADDR      = &8000

.copy_up_swram
{
        SET_RAM_BANK    SWRAM_BANK

\ Relocate new data & code block to SWRAM.

        LDA     #LO(SWRAM_RELOC_START+OFFSET)
        STA     boot_read_ptr
        LDA     #HI(SWRAM_RELOC_START+OFFSET)
        STA     boot_read_ptr+1
        LDA     #LO(SWRAM_ADDR)
        STA     boot_write_ptr
        LDA     #HI(SWRAM_ADDR)
        STA     boot_write_ptr+1
        LDX     #SWRAM_PAGES
        
    .relocate
        LDY     #$00
        
    .relocate_loop
        LDA     (boot_read_ptr),Y
        STA     (boot_write_ptr),Y
        DEY
        BNE     relocate_loop

        INC     boot_read_ptr+1
        INC     boot_write_ptr+1
        DEX
        BNE     relocate

        JMP     main_entry                ; jump to entry
}
ENDIF

.NATIVE_END

\ ******************************************************************************
\ ******************************************************************************
\ * SWRAM new data and code.
\ ******************************************************************************
\ ******************************************************************************

IF _SWRAM_BUILD
PRINT "~~~~~~~~~~~~"
PRINT "SWRAM BUILD!"
PRINT "~~~~~~~~~~~~"

.SWRAM_RELOC_START

; TODO: Just load SWRAM banks as part of the loader.
ORG SWRAM_ADDR
GUARD SWRAM_ADDR+&8000-(NATIVE_END+OFFSET)

; Avoid the first 16 lines below screen buffer
; as sprites are deliberately drawn into ROM
; address space to avoid culling...
skip &480

