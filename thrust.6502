        EQUB    $20,$4F,$F0
        EQUS    "Planet Destroyed"
        EQUB    $FF
    .string_reverse_gravity
        EQUB    $A0,$53,$0F
        EQUS    "Reverse Gravity"
        EQUB    $FF
    .string_invisible_landscape
        EQUB    $80,$53,$0F
        EQUS    "Invisible Landscape"
        EQUB    $FF
