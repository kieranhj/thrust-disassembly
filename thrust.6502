\ ******************************************************************************

IF _DEBUG_RASTERS
.raster_set_bg
{
        STA &FE21
        eor #&10:STA &FE21
        eor #&50:STA &FE21
        eor #&10:STA &FE21
        RTS
}
ENDIF

\ ******************************************************************************
\ ******************************************************************************

IF _THRUST_PARTICLES
.create_thrust_particle
{
        ; Only create particles every N frames?
        ;LDA     level_tick_counter
        ;AND     #$03
        ;BNE     return

        JSR     particle_return_free_slot_in_Y
        TYA:TAX

        ; Copy player position.
        LDA     player_xpos_FRAC
        STA     particles_xpos_FRAC,X
        LDA     player_xpos_INT
        CLC
        ADC     #PLAYER_CENTRE_X_OFFSET                    ; player x position offset by $4 - start bullet in centre?
        STA     particles_xpos_INT,X
        LDA     player_ypos_FRAC
        STA     particles_ypos_FRAC,X
        CLC
        LDA     player_ypos_INT
        ADC     #PLAYER_CENTRE_Y_OFFSET                    ; player y position offset by $5 - start bullet in centre?
        STA     particles_ypos_INT,X
        LDA     player_ypos_INT_HI
        ADC     #$00
        STA     particles_ypos_INT_HI,X
        
        ; Particle angle opposite to ship's direction.

        JSR     rnd
        AND     #&03
        CLC
        ADC     ship_angle
        ADC     #15                                        ; away from ship
        AND     #ANGLE_MASK
        TAY

        LDA     angle_to_x_FRAC,Y
        STA     particles_dx_FRAC,X
        LDA     angle_to_x_INT,Y
        STA     particles_dx_INT,X
        ROL     A       ; sign into C
        ROR     particles_dx_INT,X
        ROR     particles_dx_FRAC,X

        LDA     angle_to_y_FRAC,Y
        STA     particles_dy_FRAC,X
        LDA     angle_to_y_INT,Y
        STA     particles_dy_INT,X
        ROL     A       ; sign into C
        ROR     particles_dy_INT,X
        ROR     particles_dy_FRAC

        ; Particle params.
        LDA     particles_lifetime,X
        AND     #PARTICLE_flag
        ORA     #PARTICLE_lifetime_thrust
        STA     particles_lifetime,X

        LDA     #PARTICLE_type_debris
        STA     particles_type,X
    .return
        RTS
}
ENDIF

IF _TIMED_LASER
\ ******************************************************************************
\ * Per-instance beam direction. dx/dy come from the per-level
\ * level_N_laser_dx_pixels / level_N_laser_dy_rows arrays via laser_load_dx
\ * and laser_load_dy in update_one_laser_beam. The scratch slots below feed
\ * draw_laser_beam_at_obj_screen below.
\ ******************************************************************************

\ Scratch for draw_laser_beam_at_obj_screen.
.laser_dx_temp          EQUB $00            ; per-instance dx (signed pixels), loaded by laser_load_dx
.laser_dy_temp          EQUB $00            ; per-instance dy (signed rows), loaded by laser_load_dy
.laser_clip_t_x_max     EQUB $00            ; doubles as duty stash in update_one_laser_beam timer gate
.laser_abs_dx           EQUB $00            ; |dx|
.laser_abs_dy           EQUB $00            ; |dy|
.laser_range_x          EQUB $00            ; pixels to screen edge in dx direction
.laser_range_y          EQUB $00            ; rows to screen edge in dy direction
.laser_t_q              EQUB $00            ; clipped t in Q7 (0..127), 127 ~= full beam
.laser_divisor          EQUB $00            ; divide_q7 input
.laser_quotient         EQUB $00            ; divide_q7 accumulator
.laser_save_start_x     EQUB $00            ; saved start_x (zp draw_line_start_x at $88 aliases multiply_operand_a)
.laser_save_start_y     EQUB $00            ; saved start_y (zp draw_line_start_y at $89 aliases multiply_result_lo)
.laser_save_end_x       EQUB $00            ; saved end_x (zp draw_line_end_x at $8A aliases multiply_result_hi)
.laser_save_end_y       EQUB $00            ; saved end_y (zp draw_line_end_y at $8B aliases multiply_operand_b)

\ Per-level lookup tables for obj_data slots 1 and 2. Lives in SWRAM (native
\ RAM is too tight in the SWRAM build to hold these alongside the existing
\ level_*_lookup_LO/HI tables). Slot 1 carries laser_dx_pixels for laser
\ types and well_radius for gravity-well types; slot 2 carries laser_dy_rows
\ or well_strength. The two consumers are mutually exclusive on any single
\ object slot, so the same lookup is used by both code paths via separate
\ self-modifying-code sites.
.level_obj_data_1_lookup_LO
        EQUB    LO(level_0_obj_data_1)
.level_obj_data_1_lookup_HI
        EQUB    HI(level_0_obj_data_1)
        EQUB    LO(level_1_obj_data_1), HI(level_1_obj_data_1)
        EQUB    LO(level_2_obj_data_1), HI(level_2_obj_data_1)
        EQUB    LO(level_3_obj_data_1), HI(level_3_obj_data_1)
        EQUB    LO(level_4_obj_data_1), HI(level_4_obj_data_1)
        EQUB    LO(level_5_obj_data_1), HI(level_5_obj_data_1)

.level_obj_data_2_lookup_LO
        EQUB    LO(level_0_obj_data_2)
.level_obj_data_2_lookup_HI
        EQUB    HI(level_0_obj_data_2)
        EQUB    LO(level_1_obj_data_2), HI(level_1_obj_data_2)
        EQUB    LO(level_2_obj_data_2), HI(level_2_obj_data_2)
        EQUB    LO(level_3_obj_data_2), HI(level_3_obj_data_2)
        EQUB    LO(level_4_obj_data_2), HI(level_4_obj_data_2)
        EQUB    LO(level_5_obj_data_2), HI(level_5_obj_data_2)

IF _Y_BANDS
\\ Per-level Y-band parameter overrides. Three parallel arrays per level
\\ (band Y high byte, band Y low byte, gravity_FRAC override). Bands sorted
\\ ascending by Y. Sentinel: $FF in band_y_HI terminates the list. A level
\\ with no bands is just a single $FF byte in band_y_HI; the y_LO and
\\ gravity arrays still need a placeholder byte at that index.
.level_band_y_HI_lookup_LO
        EQUB    LO(level_0_band_y_HI)
.level_band_y_HI_lookup_HI
        EQUB    HI(level_0_band_y_HI)
        EQUB    LO(level_1_band_y_HI), HI(level_1_band_y_HI)
        EQUB    LO(level_2_band_y_HI), HI(level_2_band_y_HI)
        EQUB    LO(level_3_band_y_HI), HI(level_3_band_y_HI)
        EQUB    LO(level_4_band_y_HI), HI(level_4_band_y_HI)
        EQUB    LO(level_5_band_y_HI), HI(level_5_band_y_HI)

.level_band_y_LO_lookup_LO
        EQUB    LO(level_0_band_y_LO)
.level_band_y_LO_lookup_HI
        EQUB    HI(level_0_band_y_LO)
        EQUB    LO(level_1_band_y_LO), HI(level_1_band_y_LO)
        EQUB    LO(level_2_band_y_LO), HI(level_2_band_y_LO)
        EQUB    LO(level_3_band_y_LO), HI(level_3_band_y_LO)
        EQUB    LO(level_4_band_y_LO), HI(level_4_band_y_LO)
        EQUB    LO(level_5_band_y_LO), HI(level_5_band_y_LO)

.level_band_gravity_lookup_LO
        EQUB    LO(level_0_band_gravity)
.level_band_gravity_lookup_HI
        EQUB    HI(level_0_band_gravity)
        EQUB    LO(level_1_band_gravity), HI(level_1_band_gravity)
        EQUB    LO(level_2_band_gravity), HI(level_2_band_gravity)
        EQUB    LO(level_3_band_gravity), HI(level_3_band_gravity)
        EQUB    LO(level_4_band_gravity), HI(level_4_band_gravity)
        EQUB    LO(level_5_band_gravity), HI(level_5_band_gravity)

.level_band_landscape_colour_lookup_LO
        EQUB    LO(level_0_band_landscape_colour)
.level_band_landscape_colour_lookup_HI
        EQUB    HI(level_0_band_landscape_colour)
        EQUB    LO(level_1_band_landscape_colour), HI(level_1_band_landscape_colour)
        EQUB    LO(level_2_band_landscape_colour), HI(level_2_band_landscape_colour)
        EQUB    LO(level_3_band_landscape_colour), HI(level_3_band_landscape_colour)
        EQUB    LO(level_4_band_landscape_colour), HI(level_4_band_landscape_colour)
        EQUB    LO(level_5_band_landscape_colour), HI(level_5_band_landscape_colour)

.level_band_object_colour_lookup_LO
        EQUB    LO(level_0_band_object_colour)
.level_band_object_colour_lookup_HI
        EQUB    HI(level_0_band_object_colour)
        EQUB    LO(level_1_band_object_colour), HI(level_1_band_object_colour)
        EQUB    LO(level_2_band_object_colour), HI(level_2_band_object_colour)
        EQUB    LO(level_3_band_object_colour), HI(level_3_band_object_colour)
        EQUB    LO(level_4_band_object_colour), HI(level_4_band_object_colour)
        EQUB    LO(level_5_band_object_colour), HI(level_5_band_object_colour)
ENDIF

IF _SWITCHES
\\ Per-level switch wiring tables. Three parallel arrays per level,
\\ indexed by switch slot (0..7):
\\   level_N_switch_obj_indices: object index of each switch ($FF terminator)
\\   level_N_switch_target:      target object index ($FF = no target / disabled)
\\   level_N_switch_action:      action code (see action jump table)
.level_switch_obj_indices_lookup_LO
        EQUB    LO(level_0_switch_obj_indices)
.level_switch_obj_indices_lookup_HI
        EQUB    HI(level_0_switch_obj_indices)
        EQUB    LO(level_1_switch_obj_indices), HI(level_1_switch_obj_indices)
        EQUB    LO(level_2_switch_obj_indices), HI(level_2_switch_obj_indices)
        EQUB    LO(level_3_switch_obj_indices), HI(level_3_switch_obj_indices)
        EQUB    LO(level_4_switch_obj_indices), HI(level_4_switch_obj_indices)
        EQUB    LO(level_5_switch_obj_indices), HI(level_5_switch_obj_indices)

.level_switch_target_lookup_LO
        EQUB    LO(level_0_switch_target)
.level_switch_target_lookup_HI
        EQUB    HI(level_0_switch_target)
        EQUB    LO(level_1_switch_target), HI(level_1_switch_target)
        EQUB    LO(level_2_switch_target), HI(level_2_switch_target)
        EQUB    LO(level_3_switch_target), HI(level_3_switch_target)
        EQUB    LO(level_4_switch_target), HI(level_4_switch_target)
        EQUB    LO(level_5_switch_target), HI(level_5_switch_target)

.level_switch_action_lookup_LO
        EQUB    LO(level_0_switch_action)
.level_switch_action_lookup_HI
        EQUB    HI(level_0_switch_action)
        EQUB    LO(level_1_switch_action), HI(level_1_switch_action)
        EQUB    LO(level_2_switch_action), HI(level_2_switch_action)
        EQUB    LO(level_3_switch_action), HI(level_3_switch_action)
        EQUB    LO(level_4_switch_action), HI(level_4_switch_action)
        EQUB    LO(level_5_switch_action), HI(level_5_switch_action)

.level_switch_arg_a_lookup_LO
        EQUB    LO(level_0_switch_arg_a)
.level_switch_arg_a_lookup_HI
        EQUB    HI(level_0_switch_arg_a)
        EQUB    LO(level_1_switch_arg_a), HI(level_1_switch_arg_a)
        EQUB    LO(level_2_switch_arg_a), HI(level_2_switch_arg_a)
        EQUB    LO(level_3_switch_arg_a), HI(level_3_switch_arg_a)
        EQUB    LO(level_4_switch_arg_a), HI(level_4_switch_arg_a)
        EQUB    LO(level_5_switch_arg_a), HI(level_5_switch_arg_a)

.level_switch_arg_b_lookup_LO
        EQUB    LO(level_0_switch_arg_b)
.level_switch_arg_b_lookup_HI
        EQUB    HI(level_0_switch_arg_b)
        EQUB    LO(level_1_switch_arg_b), HI(level_1_switch_arg_b)
        EQUB    LO(level_2_switch_arg_b), HI(level_2_switch_arg_b)
        EQUB    LO(level_3_switch_arg_b), HI(level_3_switch_arg_b)
        EQUB    LO(level_4_switch_arg_b), HI(level_4_switch_arg_b)
        EQUB    LO(level_5_switch_arg_b), HI(level_5_switch_arg_b)
ENDIF

\ Per-object cached screen coords for the laser beam: when
\ OBJ_flag_laser_beam_drawn is set in level_obj_flags[X], these hold the
\ obj_screen_x/obj_screen_y from the frame the beam was XOR-drawn so
\ update_all_laser_beams can XOR-erase at exactly those pixels next time
\ around. Sized to the SWRAM-extended LEVEL_MAX_OBJECTS+1.
.obj_laser_prev_screen_x
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
.obj_laser_prev_screen_y
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00

\ Per-laser cached dx / dy from the frame the beam was XOR-drawn. Needed
\ so set_param / xor_param can change a laser's dx/dy mid-game and the
\ subsequent erase pass uses the OLD direction (matching the pixels still
\ on screen) rather than the new direction (which would XOR a different
\ line and leave the old pixels intact).
.obj_laser_prev_dx
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
.obj_laser_prev_dy
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00

IF _SWITCHES
\\ Per-switch refractory state, parallel-indexed to level_N_switch_obj_indices.
\\ $00 = idle (switch is shootable). Non-zero = refractory countdown.
\\ Decremented each frame by tick_switch_logic; cleared on level start in
\\ initialise_level_pointers. 8 slots — same cap as the wiring entries.
.level_switch_state
        EQUB    $00,$00,$00,$00,$00,$00,$00,$00
ENDIF

\ ******************************************************************************
\ * Function: update_all_laser_beams
\ * Description: Per-frame state machine for every laser turret in the level.
\ *   Walks the object type array (terminated by $FF) and for each object whose
\ *   type is in $09..$0C runs update_one_laser_beam. Called from
\ *   end_of_objects_function once the main object loop has finished.
\ ******************************************************************************

.update_all_laser_beams
\\ {
        LDX     #$00
    .laser_pass_loop
        STX     current_object
    .laser_load_object_type
        LDA     level_0_obj_type,X                  ; **SELF-MODIFIED CODE** (mirror of load_object_type)
        laser_load_object_type_addr_LO = laser_load_object_type+1
        laser_load_object_type_addr_HI = laser_load_object_type+2
        CMP     #$FF
        BEQ     laser_pass_done
        STA     object_type
        CMP     #OBJECT_laser_turret_up_right       ; $09
        BCC     laser_pass_next
        CMP     #(OBJECT_laser_turret_down_left+1)  ; $0D
        BCS     laser_pass_next

        JSR     update_one_laser_beam

    .laser_pass_next
        LDX     current_object
        INX
        JMP     laser_pass_loop
    .laser_pass_done
        RTS
\\ }

\ ******************************************************************************
\ * Function: update_one_laser_beam
\ * Params: X = current_object, object_type already loaded
\ * Returns: none
\ * Description: Erases this laser's previous beam (if any), then decides whether
\ *   the beam should be on this frame and re-draws if so. Period stays
\ *   hardcoded at 128 frames; the gun_aim byte encodes per-instance phase
\ *   (low nibble × 8 frames offset) and duty (high nibble × 4 + 4 frames).
\ *   The "drawn last frame" state lives in bit 2 of level_obj_flags
\ *   (OBJ_flag_laser_beam_drawn) and the screen coords used at draw time
\ *   are cached in obj_laser_prev_screen_x/y, so window scrolling and
\ *   destruction cleanly retire the old pixels via XOR.
\ ******************************************************************************

.update_one_laser_beam
\\ {
        \\ Disabled lasers route through the off-phase erase path so any
        \\ currently-drawn beam gets XOR-erased cleanly and no redraw fires
        \\ this frame. Sprite plot is unaffected — turret stays visible.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BEQ     laser_not_disabled
        JMP     laser_should_be_off
    .laser_not_disabled

        \\ Load per-instance beam direction (dx, dy) into scratch. Needed for
        \\ any erase or draw call into draw_laser_beam_at_obj_screen. (Wasted
        \\ ~8 cycles on the fast path that returns without drawing — cheap
        \\ relative to the full erase+redraw it replaces.)
    .laser_load_dx
        LDA     level_0_obj_data_1,X                ; **SELF-MODIFIED CODE** (slot 1 = laser dx)
        laser_load_dx_addr_LO = laser_load_dx+1
        laser_load_dx_addr_HI = laser_load_dx+2
        STA     laser_dx_temp
    .laser_load_dy
        LDA     level_0_obj_data_2,X                ; **SELF-MODIFIED CODE** (slot 2 = laser dy)
        laser_load_dy_addr_LO = laser_load_dy+1
        laser_load_dy_addr_HI = laser_load_dy+2
        STA     laser_dy_temp

        \\ Decode timer first so the fast-path test below knows whether the
        \\ beam should be on this frame. Period stays hardcoded at 128 frames;
        \\ gun_aim encodes phase (low nibble × 8) and duty (high nibble × 4 + 4).
        \\ Beam is ON while ((tick + phase_offset) AND $7F) < duty. Reuses
        \\ laser_clip_t_x_max as scratch (not read until draw_laser_beam_at_obj_screen).
    .laser_load_gun_aim
        LDA     level_0_obj_data_0,X                ; **SELF-MODIFIED CODE** (slot 0 = gun_aim)
        laser_load_gun_aim_addr_LO = laser_load_gun_aim+1
        laser_load_gun_aim_addr_HI = laser_load_gun_aim+2
        TAY                                         ; Y = gun_aim (saved)
        AND     #$F0                                ; duty_idx << 4
        LSR     A
        LSR     A                                   ; duty_idx * 4
        CLC
        ADC     #4                                  ; duty = duty_idx * 4 + 4 (range 4..64)
        STA     laser_clip_t_x_max                  ; scratch: stash duty
        TYA
        AND     #$0F                                ; phase_idx
        ASL     A
        ASL     A
        ASL     A                                   ; phase_offset = phase_idx * 8 (range 0..120)
        CLC
        ADC     level_tick_counter
        AND     #$7F                                ; modulo period 128
        CMP     laser_clip_t_x_max                  ; A = phase_in_cycle, mem = duty
        BCC     laser_in_phase                      ; phase < duty: on-phase
        JMP     laser_should_be_off                 ; phase >= duty: erase if drawn
.laser_in_phase

        \\ -------- SHOULD BE ON --------
        \\ Fast path: XOR-drawn pixels stay valid through other sprites/particles
        \\ passing over them (XOR-cancel). The beam only needs an erase+redraw
        \\ when something invalidates the cached screen position — i.e. window
        \\ scroll (software scroll redraws the world relative to the laser),
        \\ a phase transition, or destruction. So if (was_drawn AND alive AND
        \\ no scroll this frame), nothing to do — pixels are already correct.
        LDA     window_scroll_x
        ORA     window_scroll_y
        BNE     laser_must_redraw
        LDA     level_obj_flags,X
        AND     #(OBJ_flag_alive OR OBJ_flag_laser_beam_drawn OR OBJ_flag_laser_redraw_pending)
        CMP     #(OBJ_flag_alive OR OBJ_flag_laser_beam_drawn)
        BNE     laser_must_redraw                   ; not the fast-path bit pattern → slow path
        JMP     laser_one_done                      ; FAST PATH (alive+drawn AND no redraw_pending)

    .laser_must_redraw
        \\ Geometry-change flag is consumed here regardless of which branch
        \\ runs below — slot 1/2 writes always force the slow path once.
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_laser_redraw_pending)
        STA     level_obj_flags,X
        \\ Erase previous beam (if drawn last frame) using cached coords.
        AND     #OBJ_flag_laser_beam_drawn
        BEQ     laser_skip_erase

        LDA     obj_laser_prev_screen_x,X
        STA     obj_screen_x
        LDA     obj_laser_prev_screen_y,X
        STA     obj_screen_y
        \\ Swap in cached prev dx/dy so the erase XORs the same pixels that
        \\ were drawn last frame (matters when set_param/xor_param has just
        \\ rewritten the live dx/dy; the live values are what the redraw
        \\ below will use, so stash them on the stack first).
        LDA     laser_dx_temp
        PHA
        LDA     laser_dy_temp
        PHA
        LDA     obj_laser_prev_dx,X
        STA     laser_dx_temp
        LDA     obj_laser_prev_dy,X
        STA     laser_dy_temp
        JSR     draw_laser_beam_at_obj_screen       ; XOR-erases at OLD direction
        PLA
        STA     laser_dy_temp
        PLA
        STA     laser_dx_temp

        LDX     current_object                      ; draw_line clobbers X
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_laser_beam_drawn)
        STA     level_obj_flags,X

    .laser_skip_erase
        \\ Only redraw for alive, on-screen lasers. The reliable cull indicator
        \\ is obj_plot_sprite_at_ptr+1, which calculate_object_plot_addr only
        \\ writes when X-cull and Y-cull both pass; current_obj_visible_flag
        \\ stays set to $01 even for Y-culled objects on the same world page.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BEQ     laser_one_done

        LDA     #$00
        STA     obj_plot_sprite_at_ptr+1
        JSR     object_visibility_test
        LDA     obj_plot_sprite_at_ptr+1
        BEQ     laser_one_done                      ; off-screen → leave erased

        LDX     current_object

        \\ Cache the freshly computed screen coords AND dx/dy. The cached
        \\ dx/dy let a later set_param / xor_param mid-frame mutation work
        \\ correctly: next frame's erase uses the OLD direction (matching
        \\ the pixels still on screen), then the redraw uses the NEW one.
        LDA     obj_screen_x
        STA     obj_laser_prev_screen_x,X
        LDA     obj_screen_y
        STA     obj_laser_prev_screen_y,X
        LDA     laser_dx_temp
        STA     obj_laser_prev_dx,X
        LDA     laser_dy_temp
        STA     obj_laser_prev_dy,X

        JSR     draw_laser_beam_at_obj_screen
        BCS     laser_one_done                      ; barrel off-screen → skip flag set

        LDX     current_object
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_laser_beam_drawn
        STA     level_obj_flags,X
        JMP     laser_one_done

    .laser_should_be_off
        \\ Off-phase: erase if drawn last frame, then return. Also clear
        \\ redraw-pending — geometry change while in off-phase need only
        \\ ensure this single erase happens at the cached old direction.
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_laser_redraw_pending)
        STA     level_obj_flags,X
        AND     #OBJ_flag_laser_beam_drawn
        BEQ     laser_one_done

        LDA     obj_laser_prev_screen_x,X
        STA     obj_screen_x
        LDA     obj_laser_prev_screen_y,X
        STA     obj_screen_y
        \\ Use cached prev dx/dy so a mid-cycle dx/dy change still erases
        \\ the line that was actually drawn (laser_dx/dy_temp may have
        \\ been overwritten by a set_param/xor_param hit since then).
        LDA     obj_laser_prev_dx,X
        STA     laser_dx_temp
        LDA     obj_laser_prev_dy,X
        STA     laser_dy_temp
        JSR     draw_laser_beam_at_obj_screen

        LDX     current_object
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_laser_beam_drawn)
        STA     level_obj_flags,X

    .laser_one_done
        RTS
\\ }

\ ******************************************************************************
\ * Function: draw_laser_beam_at_obj_screen
\ * Params: obj_screen_x, obj_screen_y (sprite cell), object_type (orientation)
\ * Returns: none (XOR-plots in hostile bullet colour; clobbers A/X/Y)
\ * Description: Builds Bresenham start/end coordinates from the sprite centre
\ *   and the per-orientation (dx, dy) table, then tail-calls draw_line. Called
\ *   for both draw and erase — draw_line's deterministic endpoint swap means
\ *   passing the same inputs twice XORs the same pixels.
\ *
\ * TODO: a straight-line plotter would beat the generic Bresenham for
\ *   axis-aligned beams once profiling justifies it.
\ ******************************************************************************

.draw_laser_beam_at_obj_screen
\\ {
        \\ Per-instance dx, dy come from laser_dx_temp / laser_dy_temp (loaded
        \\ at the top of update_one_laser_beam). Slope is no longer fixed at
        \\ 2:1 so we parameterise by t in Q7 (0..127). t = 127 ~= "full beam",
        \\ smaller values mean the beam has been clipped at a screen edge.
        \\ End coords are start + (d_signed * t_q) >> 7 via signed multiply.
        LDY     object_type
        LDA     obj_screen_x                                          ; barrel X (chars): reuse gun bullet offsets
        CLC                                                           ; (+4 chars right side / +1 left side)
        ADC     gun_bullet_x_offset-OBJECT_laser_turret_up_right,Y
        ASL     A
        BCS     laser_barrel_x_off                                    ; obj cull window allows up to 67 chars; >=64 → off-screen right
        ASL     A
        BCS     laser_barrel_x_off
        STA     draw_line_start_x
        JMP     laser_barrel_x_ok
    .laser_barrel_x_off
        JMP     laser_barrel_off_screen
    .laser_barrel_x_ok

        LDA     gun_bullet_y_offset-OBJECT_laser_turret_up_right,Y    ; offset in world Y units
        ASL     A                                                     ; (+0 top / +16 bottom in pixel rows)
        CLC                                                           ; obj_screen_y was ROL'd to pixel rows
        ADC     obj_screen_y                                          ; in calculate_object_plot_addr
        BCC     laser_barrel_y_ok                                     ; in range → continue
        JMP     laser_barrel_off_screen                               ; obj scrolled off bottom: barrel past row 255
    .laser_barrel_y_ok
        STA     draw_line_start_y

        \\ Compute |dx|, range_x (pixels remaining toward the dx direction).
        LDA     laser_dx_temp
        BMI     laser_range_x_left
        STA     laser_abs_dx
        LDA     #$FF
        SEC
        SBC     draw_line_start_x                                     ; range_x = 255 - start_x
        STA     laser_range_x
        JMP     laser_compute_abs_dy
    .laser_range_x_left
        EOR     #$FF
        CLC
        ADC     #1                                                    ; A = |dx|
        STA     laser_abs_dx
        LDA     draw_line_start_x                                     ; range_x = start_x
        STA     laser_range_x

    .laser_compute_abs_dy
        LDA     laser_dy_temp
        BMI     laser_range_y_up
        STA     laser_abs_dy
        LDA     #$FF
        SEC
        SBC     draw_line_start_y                                     ; range_y = 255 - start_y
        STA     laser_range_y
        JMP     laser_test_clip
    .laser_range_y_up
        EOR     #$FF
        CLC
        ADC     #1
        STA     laser_abs_dy
        LDA     draw_line_start_y                                     ; range_y = start_y
        STA     laser_range_y

    .laser_test_clip
        \\ Clip path triggers when |dx| > range_x OR |dy| > range_y.
        LDA     laser_abs_dx
        CMP     laser_range_x
        BEQ     laser_test_clip_y
        BCS     laser_clip_path
    .laser_test_clip_y
        LDA     laser_abs_dy
        CMP     laser_range_y
        BEQ     laser_no_clip_far
        BCC     laser_no_clip_far
        JMP     laser_clip_path
    .laser_no_clip_far
        JMP     laser_no_clip

    .laser_clip_path
        \\ Compute t_q = min(127, t_x, t_y). Each axis: if |d_axis| > range_axis
        \\ then candidate = (range_axis << 7) / |d_axis| (always < 128).
        LDA     #$7F
        STA     laser_t_q

        LDA     laser_abs_dx
        CMP     laser_range_x
        BEQ     laser_skip_x_div
        BCC     laser_skip_x_div                                      ; |dx| <= range_x → no x-clip on this axis
        STA     laser_divisor                                         ; A = |dx|
        LDA     laser_range_x
        JSR     laser_divide_q7
        CMP     laser_t_q
        BCS     laser_skip_x_div
        STA     laser_t_q
    .laser_skip_x_div

        LDA     laser_abs_dy
        CMP     laser_range_y
        BEQ     laser_skip_y_div
        BCC     laser_skip_y_div
        STA     laser_divisor
        LDA     laser_range_y
        JSR     laser_divide_q7
        CMP     laser_t_q
        BCS     laser_skip_y_div
        STA     laser_t_q
    .laser_skip_y_div

        \\ Save start coords because the upcoming multiplies will clobber zp $88-$8B
        \\ (draw_line_start_x/y/end_x/y alias multiply_operand_a/result_lo/result_hi/
        \\ operand_b respectively). We compute end coords into scratch too because
        \\ the second multiply would overwrite the first's stored end value.
        LDA     draw_line_start_x
        STA     laser_save_start_x
        LDA     draw_line_start_y
        STA     laser_save_start_y

        \\ end_axis = start_axis + ((d_signed * t_q) >> 7). With t_q in [0, 127]
        \\ the high bit stays clear so multiply_signed_8x8's sign handling
        \\ leaves the result correctly signed; ASL/ROL gives the >>7.
        LDA     laser_t_q
        STA     multiply_operand_a
        LDA     laser_dx_temp
        JSR     multiply_signed_8x8
        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     laser_save_start_x
        CLC
        ADC     multiply_result_hi
        STA     laser_save_end_x

        LDA     laser_t_q
        STA     multiply_operand_a
        LDA     laser_dy_temp
        JSR     multiply_signed_8x8
        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     laser_save_start_y
        CLC
        ADC     multiply_result_hi
        STA     laser_save_end_y

        \\ Copy all four coords from scratch to zp draw_line slots.
        LDA     laser_save_start_x
        STA     draw_line_start_x
        LDA     laser_save_start_y
        STA     draw_line_start_y
        LDA     laser_save_end_x
        STA     draw_line_end_x
        LDA     laser_save_end_y
        STA     draw_line_end_y
        JMP     laser_do_draw

    .laser_no_clip
        \\ Both axes fit within the screen; just signed-add d to start.
        LDA     draw_line_start_x
        CLC
        ADC     laser_dx_temp
        STA     draw_line_end_x

        LDA     draw_line_start_y
        CLC
        ADC     laser_dy_temp
        STA     draw_line_end_y

    .laser_do_draw
        \\ Beam draws in the level's object colour (logical 3) so it visually
        \\ reads as part of the turret/level palette rather than as a stream
        \\ of enemy bullets. The hostile-bullet collision path still picks the
        \\ beam up via existing ship-vs-pixel detection — colour is independent
        \\ of which collision branches fire.
        LDA     #OBJECT_COLOUR_BYTE
        STA     plot_line_pixels_byte
        JSR     draw_line
        CLC                                                           ; signal: beam was drawn
        RTS

    .laser_barrel_off_screen
        SEC                                                           ; signal: barrel off-screen, no draw
        RTS
\\ }

\ ******************************************************************************
\ * Function: laser_divide_q7
\ * Params: A = numerator (must be < laser_divisor); laser_divisor = divisor.
\ * Returns: A = (numerator * 128) / divisor in [0, 127].
\ * Corrupts: A, X, laser_quotient.
\ * Description: Standard shift-and-subtract; 7 iterations develop 7 quotient
\ *   bits since the dividend has 7 fractional zeros appended (the << 7).
\ *   Caller must ensure numerator < divisor so the quotient fits in 7 bits.
\ ******************************************************************************

.laser_divide_q7
\\ {
        \\ A on entry = numerator (used as running remainder). Y is used to
        \\ zero laser_quotient without disturbing A; X is the iteration count.
        LDY     #$00
        STY     laser_quotient
        LDX     #$07
    .laser_div_loop
        ASL     A                                                     ; remainder *= 2 (no carry: remainder < divisor < 128)
        CMP     laser_divisor
        BCC     laser_div_no_sub
        SBC     laser_divisor                                         ; remainder -= divisor; carry stays 1 → ROL shifts in 1
    .laser_div_no_sub
        ROL     laser_quotient                                        ; quotient bit (carry: 1 if subtracted, 0 otherwise)
        DEX
        BNE     laser_div_loop
        LDA     laser_quotient
        RTS
\\ }
ENDIF

IF _GRAVITY_WELL
\ Per-level gravity-well config bytes live in obj_data slots 1 (radius) and
\ 2 (strength) of the shared level_N_obj_data_* arrays — laser turrets
\ reuse the same slots for dx/dy, the two object types are mutually
\ exclusive on any single slot. The lookup tables for slots 1 and 2 are
\ defined above next to the laser code; the well code's SMC sites are
\ patched from those same tables.

\ Scratch for apply_gravity_wells_to_force.
.well_radius_save     EQUB $00          ; current well's radius (1..127)
.well_strength_save   EQUB $00          ; current well's signed strength
.well_dx_signed       EQUB $00          ; signed dx = obj_x - midpoint_x (8-bit, X wraps)
.well_dy_signed       EQUB $00          ; signed dy_lo from 16-bit subtract; reused as pull_signed scratch
.well_abs_dx          EQUB $00
.well_abs_dy          EQUB $00
.well_pull            EQUB $00          ; reused: r → delta_r → signed pull magnitude

\ Saved well world position (so the debris emitter can spawn relative to it
\ even after the pull math has consumed obj_pos into well_dx/dy_signed).
.well_obj_x_save      EQUB $00
.well_obj_y_lo_save   EQUB $00
.well_obj_y_hi_save   EQUB $00

\ Scratch for well_emit_debris_particle.
.well_emit_dir        EQUB $00
.well_emit_offset_x   EQUB $00          ; signed perimeter X offset (world units, ~ -radius..+radius)
.well_emit_offset_y   EQUB $00          ; signed perimeter Y offset
.well_emit_slot       EQUB $00          ; saved particle slot index (X is clobbered by multiply_signed_8x8)

\ Direction lookup for the 8-way Manhattan-diamond perimeter. Each entry is
\ a Q0.7 signed factor. World X has twice the pixel resolution of world Y
\ (1 world X = 4 BBC px wide, 1 world Y = 2 px rows), so the X factors are
\ half the Y factors — that gives a diamond that's pixel-square rather than
\ "stretched horizontally". Pairs with the 2*|dx|+|dy| radius test below.
\ dir 0 = right vertex, increasing CCW around the diamond.
.well_dir_dx_factor                              ; dir 0..7
        EQUB    $3F, $1F, $00, $E1, $C1, $E1, $00, $1F
.well_dir_dy_factor
        EQUB    $00, $3F, $7F, $3F, $00, $C1, $81, $C1

\ Constants. Lifetime is a power of 2 to make the velocity computation a shift.
\ With lifetime 16 and offset = ±radius, peak speed = ±radius/16 world units/frame.
WELL_DEBRIS_LIFETIME      = $10
WELL_DEBRIS_SPAWN_MASK    = $01          ; emit one particle every 8 ticks per well

\ ******************************************************************************
\ * Function: apply_gravity_wells_to_force
\ * Description: Per-frame walk over the level's object list. For every
\ *   OBJECT_gravity_well within Manhattan radius of the ship midpoint, adds a
\ *   linear-ramp pull toward the well centre to (force_vectorx, force_vectory).
\ *   Called from ship_input_thrust_calculate_force after the constant-gravity
\ *   add, on the same tick gating as gravity itself.
\ * Params: none (uses midpoint_*pos_INT/INT_HI for ship reference)
\ * Returns: none. Clobbers A, X, Y, multiply_* zp ($88..$8B + multiply_sign_ext).
\ ******************************************************************************
.apply_gravity_wells_to_force
\\ {
        LDX     #$00
    .well_loop
        STX     current_object
    .well_load_obj_type
        LDA     level_0_obj_type,X                        ; **SELF-MODIFIED CODE** (mirror of level_obj_type_addr)
        well_load_obj_type_addr_LO = well_load_obj_type+1
        well_load_obj_type_addr_HI = well_load_obj_type+2
        CMP     #$FF
        BNE     well_check_type
        JMP     well_loop_done
    .well_check_type
        CMP     #OBJECT_gravity_well
        BEQ     well_is_well
        JMP     well_loop_next
    .well_is_well
        \\ OBJ_flag_disabled suspends the well's pull AND debris emission.
        \\ Sprite path (debris ring as visual cue) is what would normally
        \\ draw the well — turning it off makes the field look genuinely
        \\ inert in-game.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BEQ     well_not_disabled
        JMP     well_loop_next
    .well_not_disabled

        \\ Radius == 0 means well is disabled (default for non-well slots too).
    .well_load_radius
        LDA     level_0_obj_data_1,X                      ; **SELF-MODIFIED CODE** (slot 1 = well radius)
        well_load_radius_addr_LO = well_load_radius+1
        well_load_radius_addr_HI = well_load_radius+2
        BNE     well_radius_nonzero
        JMP     well_loop_next
    .well_radius_nonzero
        STA     well_radius_save

        \\ Save the well's absolute world position (X, Y_lo, Y_hi) and strength
        \\ before the pull math consumes them. The debris emitter (always-on,
        \\ even when the ship is outside the radius) needs absolute world
        \\ coords; the pull math below works from the saved values too.
    .well_load_obj_pos_x
        LDA     level_0_obj_pos_X,X                       ; **SELF-MODIFIED CODE**
        well_load_obj_pos_x_addr_LO = well_load_obj_pos_x+1
        well_load_obj_pos_x_addr_HI = well_load_obj_pos_x+2
        STA     well_obj_x_save
    .well_load_obj_pos_y
        LDA     level_0_obj_pos_Y,X                       ; **SELF-MODIFIED CODE**
        well_load_obj_pos_y_addr_LO = well_load_obj_pos_y+1
        well_load_obj_pos_y_addr_HI = well_load_obj_pos_y+2
        STA     well_obj_y_lo_save
    .well_load_obj_pos_y_ext
        LDA     level_0_obj_pos_Y_EXT,X                   ; **SELF-MODIFIED CODE**
        well_load_obj_pos_y_ext_addr_LO = well_load_obj_pos_y_ext+1
        well_load_obj_pos_y_ext_addr_HI = well_load_obj_pos_y_ext+2
        STA     well_obj_y_hi_save
    .well_load_strength
        LDA     level_0_obj_data_2,X                      ; **SELF-MODIFIED CODE** (slot 2 = well strength)
        well_load_strength_addr_LO = well_load_strength+1
        well_load_strength_addr_HI = well_load_strength+2
        STA     well_strength_save

        \\ Emit gate. apply_gravity_wells_to_force is itself only called on
        \\ gravity ticks (level_tick_counter & $0F ∈ {0,3,5,8,B,D} — 6 of 16
        \\ frames), which already rate-limits per-well emits. The earlier
        \\ AND #$07 gate combined poorly with that restricted tick set: tick&7
        \\ is only ever 0/3/5, so wells whose slot&7 wasn't 0/3/5 never emitted.
        \\ Stagger by parity instead — adjacent slots fire on opposite gravity
        \\ ticks. Runs whether the ship is in range or not (position marker).
        LDA     level_tick_counter
        EOR     current_object
        AND     #$01
        BNE     well_emit_skip
        JSR     well_emit_debris_particle
    .well_emit_skip

        \\ Compute dy = (Y_hi:Y_lo) - midpoint_ypos as 16-bit signed; reject
        \\ if outside -128..+127. midpoint_* is the centre of mass of the
        \\ ship+pod system when tethered (and falls back to a ship-relative
        \\ point otherwise), so pulling that point keeps tethered physics
        \\ consistent. The visual offset between the particles (at obj_pos)
        \\ and the ship's resting position is a consequence of this — the
        \\ debris marks the well's actual world position, which is what
        \\ matters for "where is the well?".
        SEC
        LDA     well_obj_y_lo_save
        SBC     midpoint_ypos_INT
        STA     well_dy_signed                            ; tentative dy_lo
        LDA     well_obj_y_hi_save
        SBC     midpoint_ypos_INT_HI
        BEQ     well_dy_hi_zero
        CMP     #$FF
        BEQ     well_dy_hi_neg
        JMP     well_loop_next                            ; |dy| >= 256 → out of range
    .well_dy_hi_neg
        \\ dy_hi == $FF: dy_lo must be >= $80 for the value to be in -128..-1
        LDA     well_dy_signed
        BMI     well_dy_in_range
        JMP     well_loop_next                            ; dy_lo < $80 → actual dy < -128
    .well_dy_hi_zero
        \\ dy_hi == 0: dy_lo must be < $80 for the value to be in 0..127
        LDA     well_dy_signed
        BPL     well_dy_in_range
        JMP     well_loop_next                            ; dy_lo >= $80 → actual dy > 127
    .well_dy_in_range

        \\ Compute dx = obj_x - midpoint_xpos_INT (8-bit signed; X wraps).
        SEC
        LDA     well_obj_x_save
        SBC     midpoint_xpos_INT
        STA     well_dx_signed

        \\ |dx|, |dy| (preserve signed values in well_d{x,y}_signed for direction).
        BPL     well_dx_was_pos
        EOR     #$FF
        CLC
        ADC     #$01
    .well_dx_was_pos
        STA     well_abs_dx

        LDA     well_dy_signed
        BPL     well_dy_was_pos
        EOR     #$FF
        CLC
        ADC     #$01
    .well_dy_was_pos
        STA     well_abs_dy

        \\ r = 2*|dx| + |dy|; if r >= radius, no force. The 2× on |dx|
        \\ compensates for world X being twice the pixel scale of world Y,
        \\ so the pull region is a pixel-square diamond rather than stretched
        \\ horizontally. Matches the 0.5× X factor in well_dir_dx_factor.
        LDA     well_abs_dx
        ASL     A
        BCC     well_dx_doubled
        JMP     well_loop_next                            ; 2*|dx| overflowed → out of range
    .well_dx_doubled
        ADC     well_abs_dy                               ; C=0 from ASL not branching
        BCC     well_sum_ok
        JMP     well_loop_next                            ; sum overflowed 8-bit → out of range
    .well_sum_ok
        CMP     well_radius_save
        BCC     well_in_radius
        JMP     well_loop_next                            ; r >= radius → outside / on boundary
    .well_in_radius
        \\ delta_r = radius - r (unsigned, 1..127).
        STA     well_pull                                 ; reuse: stash r briefly
        LDA     well_radius_save
        SEC
        SBC     well_pull
        STA     well_pull                                 ; well_pull = delta_r

        \\ Signed pull magnitude = high byte of (strength * delta_r).
        LDA     well_strength_save
        STA     multiply_operand_a
        LDA     well_pull
        JSR     multiply_signed_8x8                       ; result_hi:result_lo = strength * delta_r
        LDA     multiply_result_hi
        BNE     well_pull_nonzero
        JMP     well_loop_next                            ; pull rounded to zero in high byte → no contribution
    .well_pull_nonzero
        STA     well_pull

        \\ Y axis: pull_y = sign(dy) * pull. Add to (force_vectory_INT, force_vectory_FRAC).
        LDA     well_dy_signed
        BPL     well_apply_y_pos
        LDA     well_pull
        EOR     #$FF
        CLC
        ADC     #$01
        JMP     well_apply_y_add
    .well_apply_y_pos
        LDA     well_pull
    .well_apply_y_add
        STA     well_dy_signed                            ; reuse: stash signed pull_y
        CLC
        ADC     force_vectory_FRAC
        STA     force_vectory_FRAC
        LDA     well_dy_signed
        BPL     well_y_sign_pos
        LDA     #$FF
        JMP     well_y_sign_done
    .well_y_sign_pos
        LDA     #$00
    .well_y_sign_done
        ADC     force_vectory_INT
        STA     force_vectory_INT

        \\ X axis: pull_x = sign(dx) * pull. Add to (force_vectorx_INT, force_vectorx_FRAC).
        LDA     well_dx_signed
        BPL     well_apply_x_pos
        LDA     well_pull
        EOR     #$FF
        CLC
        ADC     #$01
        JMP     well_apply_x_add
    .well_apply_x_pos
        LDA     well_pull
    .well_apply_x_add
        STA     well_dx_signed                            ; reuse: stash signed pull_x
        CLC
        ADC     force_vectorx_FRAC
        STA     force_vectorx_FRAC
        LDA     well_dx_signed
        BPL     well_x_sign_pos
        LDA     #$FF
        JMP     well_x_sign_done
    .well_x_sign_pos
        LDA     #$00
    .well_x_sign_done
        ADC     force_vectorx_INT
        STA     force_vectorx_INT

    .well_loop_next
        LDX     current_object
        INX
        JMP     well_loop
    .well_loop_done
        RTS
\\ }

\ ******************************************************************************
\ * Function: well_emit_debris_particle
\ * Description: Spawn one PARTICLE_type_debris (non-lethal) at a random point
\ *   on the well's Manhattan-radius perimeter, with velocity toward the centre
\ *   sized so the particle reaches the centre as it expires. For repulsors
\ *   (strength < 0) the velocity sign is flipped so debris flies outward from
\ *   the perimeter instead.
\ * Params: X = current_object, well_radius_save / well_strength_save /
\ *         well_obj_{x,y_lo,y_hi}_save populated by the caller.
\ * Returns: none. X is restored to current_object.
\ * Clobbers: A, Y, multiply_* zp.
\ ******************************************************************************
.well_emit_debris_particle
\\ {
        \\ Random direction 0..7 around the diamond.
        JSR     rnd
        AND     #$07
        STA     well_emit_dir
        TAY

        \\ offset_x = (factor_x[dir] * radius) >> 7. Treat factor as Q0.7 signed
        \\ and radius as Q7.0 unsigned; the 16-bit product is Q7.7. Shift left 1
        \\ then take the high byte to get the integer Q7.0 offset (signed).
        LDA     well_dir_dx_factor,Y
        STA     multiply_operand_a
        LDA     well_radius_save
        JSR     multiply_signed_8x8
        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     multiply_result_hi
        STA     well_emit_offset_x

        LDY     well_emit_dir
        LDA     well_dir_dy_factor,Y
        STA     multiply_operand_a
        LDA     well_radius_save
        JSR     multiply_signed_8x8
        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     multiply_result_hi
        STA     well_emit_offset_y

        \\ Get a free particle slot. Y on return = slot. Save it because the
        \\ velocity multiplies below clobber X (multiply_signed_8x8 uses LDX #$08).
        JSR     particle_return_free_slot_in_Y
        STY     well_emit_slot
        TYA
        TAX                                               ; X = particle slot

        \\ Spawn position. Pull (strength >= 0): perimeter = obj + offset, so
        \\ debris flies inward to the centre. Push (strength < 0): spawn at the
        \\ centre itself, so debris flies outward to the perimeter — matches the
        \\ "matter being repelled" feel and stops repulsor particles from looking
        \\ like they originate at the radius edge.
        LDA     well_strength_save
        BMI     well_emit_spawn_centre

        \\ Pull: spawn position X = obj_x + offset_x (8-bit, X wraps mod 256).
        LDA     well_obj_x_save
        CLC
        ADC     well_emit_offset_x
        STA     particles_xpos_INT,X

        \\ Pull: spawn position Y = (obj_y_hi:obj_y_lo) + sign_extended(offset_y).
        CLC
        LDA     well_obj_y_lo_save
        ADC     well_emit_offset_y
        STA     particles_ypos_INT,X
        LDA     well_emit_offset_y
        BMI     well_emit_y_signext_neg
        LDA     #$00
        JMP     well_emit_y_signext_done
    .well_emit_y_signext_neg
        LDA     #$FF
    .well_emit_y_signext_done
        ADC     well_obj_y_hi_save
        STA     particles_ypos_INT_HI,X
        JMP     well_emit_spawn_done

    .well_emit_spawn_centre
        LDA     well_obj_x_save
        STA     particles_xpos_INT,X
        LDA     well_obj_y_lo_save
        STA     particles_ypos_INT,X
        LDA     well_obj_y_hi_save
        STA     particles_ypos_INT_HI,X

    .well_emit_spawn_done
        LDA     #$00
        STA     particles_xpos_FRAC,X
        STA     particles_ypos_FRAC,X

        \\ Velocity: pull → -offset/16 (toward centre); push (strength < 0) →
        \\ +offset/16 (outward from perimeter). Compute as multiply by ±16 to
        \\ get a 16-bit signed Q8.8 directly into (vel_INT:vel_FRAC).
        \\ multiply_signed_8x8 clobbers X, so reload from well_emit_slot before
        \\ each store.
        LDA     well_strength_save
        BMI     well_emit_repulsor_x

        \\ Pull: vel_x = -offset_x * 16.
        LDA     well_emit_offset_x
        EOR     #$FF
        CLC
        ADC     #$01
        JMP     well_emit_vel_x_mul
    .well_emit_repulsor_x
        \\ Push: vel_x = +offset_x * 16.
        LDA     well_emit_offset_x
    .well_emit_vel_x_mul
        STA     multiply_operand_a
        LDA     #$10
        JSR     multiply_signed_8x8
        LDX     well_emit_slot
        LDA     multiply_result_lo
        STA     particles_dx_FRAC,X
        LDA     multiply_result_hi
        STA     particles_dx_INT,X

        LDA     well_strength_save
        BMI     well_emit_repulsor_y
        LDA     well_emit_offset_y
        EOR     #$FF
        CLC
        ADC     #$01
        JMP     well_emit_vel_y_mul
    .well_emit_repulsor_y
        LDA     well_emit_offset_y
    .well_emit_vel_y_mul
        STA     multiply_operand_a
        LDA     #$10
        JSR     multiply_signed_8x8
        LDX     well_emit_slot
        LDA     multiply_result_lo
        STA     particles_dy_FRAC,X
        LDA     multiply_result_hi
        STA     particles_dy_INT,X

        \\ Type and lifetime. Preserve PARTICLE_flag bit per existing convention.
        LDA     #PARTICLE_type_debris
        STA     particles_type,X
        LDA     particles_lifetime,X
        AND     #PARTICLE_flag
        ORA     #WELL_DEBRIS_LIFETIME
        STA     particles_lifetime,X

        \\ Restore X = current_object so the caller's loop indexing still works.
        LDX     current_object
        RTS
\\ }
ENDIF

IF _TELEPORTER
\ ******************************************************************************
\ * Teleporter debris emitter
\ *
\ * Reuses well_emit_debris_particle in repulsor mode (negative strength) to
\ * fountain debris outward from each teleporter pad once every few ticks. The
\ * pad supplies the well centre (its world XY) and a fixed radius / negative
\ * strength via the same well_*_save scratch slots the gravity-well code uses.
\ *
\ * Position is read via per-level SMC patches so the emit can run before
\ * object_visibility_test has populated current_obj_*pos_*. Patched in
\ * initialise_level_pointers alongside the bobbing-mine SMC sites.
\ *
\ * Requires _GRAVITY_WELL = TRUE (well_emit_debris_particle lives in that block).
\ ******************************************************************************

TELEPORTER_DEBRIS_RADIUS    = $08          ; world units; 8 char-widths feels active without flooding
TELEPORTER_DEBRIS_STRENGTH  = $80          ; any negative -> repulsor mode (spawn at centre, fly outward)
TELEPORTER_DEBRIS_SPAWN_MASK = $03         ; emit one particle every 4 ticks per pad

\ Shift between the pad's stored top-left position and the AABB / debris
\ centre. Tuned so the trigger sits over the visible ship (whose sprite
\ origin is offset from player_xpos / player_ypos), and the debris
\ fountain is anchored on the same point.
TELEPORTER_CENTRE_X_OFFSET  = $02          ; chars
TELEPORTER_CENTRE_Y_OFFSET  = $04          ; pixel rows

\ Pending warp request: 0 = idle, 1+ = pending (destination = pending - 1).
\ Set by the AABB trigger; consumed by teleporter_dispatch_pending at end of frame.
.teleporter_pending_index   EQUB $00

\ "Ship was inside a pad's AABB last frame." Suppresses repeated triggers while
\ the player sits on a pad. Carried forward each frame from
\ teleporter_overlap_this_frame; cleared automatically once the ship leaves.
.teleporter_just_warped     EQUB $00

\ Set by the AABB whenever the ship is inside a pad's box, regardless of guard.
\ Drives the just_warped transition at end of frame, then resets to 0.
.teleporter_overlap_this_frame  EQUB $00

\ Scratch holding the destination checkpoint index while the warp routine runs.
.teleporter_dest_save           EQUB $00

.teleporter_emit_debris
\\ {
        \\ Always load the pad's world position into well_obj_*_save (also
        \\ used by the ship-contact AABB), then gate the actual particle emit
        \\ on the per-pad cadence. Per-pad jitter via EOR current_object so
        \\ two pads don't spawn on the same frame.
        LDX     current_object

        \\ Pad world position is the TOP-LEFT of the sprite; ship's
        \\ player_xpos / player_ypos point at the sprite's plot origin
        \\ (~2 chars + 5 rows offset from the visible ship centre). Shift
        \\ the saved pad position right + down so the AABB lines up with
        \\ where the ship visually is, and the debris fountain centres on
        \\ the same point (both read from these slots).

.tp_load_pos_x
        LDA     level_0_obj_pos_X,X                  ; **SELF-MODIFIED CODE**
        tp_pos_x_addr_LO = tp_load_pos_x+1
        tp_pos_x_addr_HI = tp_load_pos_x+2
        CLC
        ADC     #TELEPORTER_CENTRE_X_OFFSET
        STA     well_obj_x_save

.tp_load_pos_y
        LDA     level_0_obj_pos_Y,X                  ; **SELF-MODIFIED CODE**
        tp_pos_y_addr_LO = tp_load_pos_y+1
        tp_pos_y_addr_HI = tp_load_pos_y+2
        CLC
        ADC     #TELEPORTER_CENTRE_Y_OFFSET
        STA     well_obj_y_lo_save

.tp_load_pos_y_ext
        LDA     level_0_obj_pos_Y_EXT,X              ; **SELF-MODIFIED CODE**
        tp_pos_y_ext_addr_LO = tp_load_pos_y_ext+1
        tp_pos_y_ext_addr_HI = tp_load_pos_y_ext+2
        ADC     #$00                                  ; carry-extend the +Y offset above
        STA     well_obj_y_hi_save

        LDA     level_tick_counter
        EOR     current_object
        AND     #TELEPORTER_DEBRIS_SPAWN_MASK
        BEQ     do_emit
        RTS
.do_emit
        LDA     #TELEPORTER_DEBRIS_RADIUS
        STA     well_radius_save
        LDA     #TELEPORTER_DEBRIS_STRENGTH
        STA     well_strength_save

        JMP     well_emit_debris_particle            ; tail-call (restores X = current_object)
\\ }

\ ******************************************************************************
\ * Function: teleporter_check_ship_contact
\ * Description: AABB ship-vs-pad test. Same shape as the bobbing-mine ship
\ *              test (X in chars, Y in pixels). On overlap, latch
\ *              teleporter_pending_index = (slot 0 + 1). Pads refuse to fire
\ *              while the pod is tethered or being carried (v1 simplification).
\ *              Skipped if a warp is already pending so the player sitting on
\ *              the pad doesn't keep re-arming it each frame.
\ * Params: X = current_object (preserved on RTS).
\ ******************************************************************************
.teleporter_check_ship_contact
{
        \\ Disabled pads don't trigger the warp. Sprite path (debris ring)
        \\ still ran above; we just suppress the latch here so the player
        \\ can stand on a dormant pad without warping.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BNE     no_contact
        LDA     pod_tethered_flag
        BNE     no_contact
        LDA     pod_lifted_flag
        BNE     no_contact

        \\ 16-bit dy = pad_y - player_y. Pad position lives in well_obj_*_save
        \\ (populated by teleporter_emit_debris just above this call site).
        \\ Pad is 8 px tall; ship ~10 px. Threshold $08 keeps the trigger
        \\ zone close to the pad's visual footprint instead of a wide AABB.
        SEC
        LDA     well_obj_y_lo_save
        SBC     player_ypos_INT
        TAY
        LDA     well_obj_y_hi_save
        SBC     player_ypos_INT_HI
        BMI     tp_dy_neg
        BNE     no_contact
        CPY     #$08
        BCS     no_contact
        JMP     tp_test_dx
    .tp_dy_neg
        CMP     #$FF
        BNE     no_contact
        TYA
        EOR     #$FF
        CLC
        ADC     #$01
        CMP     #$08
        BCS     no_contact

    .tp_test_dx
        SEC                                          ; 8-bit dx = pad_x - player_x (chars)
        LDA     well_obj_x_save
        SBC     player_xpos_INT
        BPL     tp_dx_pos
        EOR     #$FF
        CLC
        ADC     #$01
    .tp_dx_pos
        CMP     #$05                                 ; |dx| < 5 chars
        BCS     no_contact

        \\ Geometric overlap. Mark the frame; latch a pending warp only if the
        \\ ship wasn't already on a pad last frame and one isn't already pending.
        LDA     #$FF
        STA     teleporter_overlap_this_frame
        LDA     teleporter_just_warped
        BNE     no_contact
        LDA     teleporter_pending_index
        BNE     no_contact

        LDX     current_object
        JSR     teleporter_load_dest_index
        CLC
        ADC     #$01
        STA     teleporter_pending_index
    .no_contact
        LDX     current_object                       ; restore X for caller's loop
        RTS
}

\ ******************************************************************************
\ * Function: teleporter_load_dest_index
\ * Description: Read the selected pad's slot-0 byte (destination checkpoint
\ *              index) via SMC. X must = current_object on entry.
\ * Returns: A = dest index.
\ ******************************************************************************
.teleporter_load_dest_index
.tp_load_dest
        LDA     level_0_obj_data_0,X                 ; **SELF-MODIFIED CODE**
        tp_dest_addr_LO = tp_load_dest+1
        tp_dest_addr_HI = tp_load_dest+2
        RTS

\ ******************************************************************************
\ * Function: teleporter_dispatch_pending
\ * Description: End-of-frame hook. If the AABB trigger flagged a pending warp,
\ *              fire its visual / audio confirmation and clear the pending flag.
\ *              v1 stub: plays a collect sound. The actual position write +
\ *              teleport-out/in animations land in the next step.
\ ******************************************************************************
.teleporter_dispatch_pending
{
        LDA     teleporter_pending_index
        BEQ     no_pending
        SEC
        SBC     #$01                                 ; back to 0-based dest index
        JSR     teleporter_perform_warp
        LDA     #$00
        STA     teleporter_pending_index
    .no_pending
        \\ Carry "ship overlapped a pad this frame" forward to next frame's
        \\ guard, so the ship sitting on the pad won't keep re-arming pending.
        \\ When no overlap fires, just_warped clears automatically.
        LDA     teleporter_overlap_this_frame
        STA     teleporter_just_warped
        LDA     #$00
        STA     teleporter_overlap_this_frame
        RTS
}

\ ******************************************************************************
\ * Function: teleporter_perform_warp
\ * Description: One-way warp to the level's checkpoint at index A. Plays the
\ *              teleport-out animation at the source, writes the destination
\ *              position into ship/window state, redraws the screen for the
\ *              new window, then plays the teleport-in animation at the
\ *              destination. Mirrors the position-write block in
\ *              level_reset_loop and the screen-rebuild sequence used by
\ *              level_start_demo_entry.
\ * Params: A = destination checkpoint index (0..N-1).
\ ******************************************************************************
.teleporter_perform_warp
{
        \\ Reuse the level-retry flow (it wipes ZP, rebuilds landscape, plays
        \\ the teleport-in animation). With the active-checkpoint model we
        \\ write the destination directly into active_checkpoint_index;
        \\ level_reset reads it as Y and the position-load block does the rest.
        \\ No midpoint nudge / pod-flag dance needed any more.
        STA     teleporter_dest_save
        \\ Clear pending state up front: JMP level_retry never returns, so
        \\ anything after the JMP in our caller (dispatch_pending) won't run.
        \\ Without clearing here, the AABB-latched pending flag would stay set
        \\ across the warp and loop us right back into the warp next frame.
        LDA     #$00
        STA     teleporter_pending_index
        LDA     #$FF
        STA     teleporter_just_warped                 ; suppress immediate re-trigger if dest pad sits us in another box
        LDA     #$00
        STA     teleporter_overlap_this_frame

        LDX     level_number
        LDA     level_reset_data_sizes,X
        STA     level_reset_size
        BNE     tp_have_checkpoints
        RTS                                            ; no checkpoints
    .tp_have_checkpoints

        \\ Clamp dest to range, then commit. Reset deepest watermark to the
        \\ destination — the player has only just arrived, so respawn-with-pod
        \\ must not bump beyond this index until they've crossed further cps
        \\ on foot.
        LDA     teleporter_dest_save
        CMP     level_reset_size
        BCC     tp_dest_in_range
        LDA     #$00
    .tp_dest_in_range
        STA     active_checkpoint_index
        STA     deepest_checkpoint_visited

        \\ Force the with-pod flag clear so the post-match block in
        \\ level_reset doesn't re-attach a pod (the AABB already gated this
        \\ case out anyway).
        LDA     #$00
        STA     level_reset_with_pod_flag

        \\ Teleport-out animation at the source pad. player_teleport saves
        \\ and restores the relevant flags itself, and XOR-erases the ship
        \\ via draw_player_timed_to_vsync before playing the rings — the
        \\ subsequent level_retry's clear_screen_and_init wipes whatever's
        \\ left, so the disappear animation is purely cosmetic at this point.
        \\ Same ping that plays on entering orbit, since the rising-pitch
        \\ effect reads naturally as "going somewhere".
        JSR     enter_orbit_sound
        LDA     #$FF
        STA     teleport_appear_or_disappear
        JSR     player_teleport

        \\ Reset stack pointer: we're nested several JSRs deep inside
        \\ update_and_draw_all_objects → end_of_objects_function → dispatch.
        \\ JMP level_retry restarts tick_loop and never returns up the chain,
        \\ so without this the orphaned return addresses leak each warp.
        LDX     #$FF
        TXS

        JMP     level_retry
}
ENDIF

IF _Y_BANDS
\ ******************************************************************************
\ * Y-banded per-level parameter overrides
\ *
\ * Each frame, scans the active level's band list and overwrites gravity_FRAC
\ * with the override value of the deepest band whose Y threshold is at or
\ * above the player. Bands sorted ascending; sentinel $FF in band_y_HI ends
\ * the list. Reverse-gravity flag is honoured by EOR'ing the result, mirroring
\ * the level-init logic in initialise_level_pointers.
\ ******************************************************************************

.level_base_gravity_FRAC EQUB $00       ; raw level gravity (pre reverse-flag), set in initialise_level_pointers

\\ Cached state for band-driven palette transitions. Holds the index of the
\\ deepest band active on the previous frame ($FF = no band active). The
\\ palette is only re-applied when this changes, so the existing
\\ hide_landscape / show_landscape paths can still drive the palette in
\\ between transitions without being fought every frame.
.band_current_active_index EQUB $FF
.band_target_landscape_colour EQUB $00
.band_target_object_colour    EQUB $00
.band_active_index_this_frame EQUB $FF

.update_active_band
        \\ Start each frame from the level's base gravity. gravity is a
        \\ 16-bit signed value (gravity_SIGN:gravity_FRAC); base byte's bit 7
        \\ sign-extends into gravity_SIGN so $80..$FF read as upward gravity.
        \\ Then apply reverse_gravity_flag (the every-6-levels inversion) by
        \\ EORing the whole 16-bit value with $FFFF.
        LDY     #$00
        LDA     level_base_gravity_FRAC
        BPL     update_band_base_sign_done
        DEY                                             ; Y = $FF for negative base
.update_band_base_sign_done
        LDX     reverse_gravity_flag
        BEQ     update_band_base_done
        EOR     #$FF                                    ; flip FRAC
        TYA
        EOR     #$FF                                    ; flip SIGN
        TAY
.update_band_base_done
        STA     gravity_FRAC
        STY     gravity_SIGN

        \\ Pre-fill colour targets with level defaults; band overrides
        \\ stomp these as they activate during the scan. $FF in a band's
        \\ colour byte means "inherit", so the level default sticks.
        LDX     level_number
        LDA     level_landscape_colour,X
        STA     band_target_landscape_colour
        LDA     level_object_colour,X
        STA     band_target_object_colour
        LDA     #$FF
        STA     band_active_index_this_frame

        LDX     #$00
.update_band_scan_loop
.band_load_y_hi
        LDA     level_0_band_y_HI,X                    ; **SELF-MODIFIED CODE**
        band_load_y_hi_addr_LO = band_load_y_hi+1
        band_load_y_hi_addr_HI = band_load_y_hi+2
        CMP     #$FF
        BEQ     update_band_done
        CMP     player_ypos_INT_HI
        BCC     update_band_active                      ; band_HI < player_HI -> band active
        BNE     update_band_done                        ; band_HI > player_HI -> not yet, list sorted
.band_load_y_lo
        LDA     level_0_band_y_LO,X                    ; **SELF-MODIFIED CODE**
        band_load_y_lo_addr_LO = band_load_y_lo+1
        band_load_y_lo_addr_HI = band_load_y_lo+2
        CMP     player_ypos_INT
        BEQ     update_band_active                      ; equal counts as active
        BCS     update_band_done                        ; band_LO > player_LO -> not yet
.update_band_active
        STX     band_active_index_this_frame
        \\ Band byte is a signed Q-format gravity value: bit 7 sign-extends
        \\ into gravity_SIGN so $80..$FF give upward (negative) gravity.
        \\ Band override is absolute -- reverse_gravity_flag has already been
        \\ applied to the base above, but bands themselves bypass it so
        \\ "this band is hollow-earth reverse" reads literally.
.band_load_gravity
        LDA     level_0_band_gravity,X                 ; **SELF-MODIFIED CODE**
        band_load_gravity_addr_LO = band_load_gravity+1
        band_load_gravity_addr_HI = band_load_gravity+2
        STA     gravity_FRAC
        LDY     #$00
        ASL     A                                       ; bit 7 of band byte -> C
        BCC     update_band_sign_pos
        DEY                                             ; Y = $FF when bit 7 set
.update_band_sign_pos
        STY     gravity_SIGN

        \\ Per-band colour override. $FF = inherit (leave target alone).
.band_load_landscape
        LDA     level_0_band_landscape_colour,X        ; **SELF-MODIFIED CODE**
        band_load_landscape_addr_LO = band_load_landscape+1
        band_load_landscape_addr_HI = band_load_landscape+2
        CMP     #$FF
        BEQ     band_skip_landscape
        STA     band_target_landscape_colour
.band_skip_landscape
.band_load_object
        LDA     level_0_band_object_colour,X           ; **SELF-MODIFIED CODE**
        band_load_object_addr_LO = band_load_object+1
        band_load_object_addr_HI = band_load_object+2
        CMP     #$FF
        BEQ     band_skip_object
        STA     band_target_object_colour
.band_skip_object
        INX
        BNE     update_band_scan_loop
.update_band_done
        \\ Apply colour targets only when the active band actually changed,
        \\ so we don't fight hide_landscape / show_landscape on intervening
        \\ frames.
        LDA     band_active_index_this_frame
        CMP     band_current_active_index
        BEQ     update_band_colours_done
        STA     band_current_active_index
        LDA     band_target_landscape_colour
        LDY     #$02
        JSR     palette_set_colour_Y_to_A
        LDA     band_target_object_colour
        LDY     #$03
        JSR     palette_set_colour_Y_to_A
.update_band_colours_done
        RTS
ENDIF

IF _SWITCHES
\ ******************************************************************************
\ * Switches & triggers — wiring dispatcher and per-frame refractory tick.
\ *
\ * On a switch bullet-hit, handle_door_switch calls try_dispatch_switch_action.
\ * If the switch's object index appears in the per-level switch_obj_indices
\ * list, the dispatcher fires the wired action (set/clear/toggle alive, or
\ * destroy) against the target object and returns carry CLEAR — the caller
\ * suppresses the legacy door_switch_counter_A latch. Switches not in the
\ * list return carry SET, falling through to the original counter path so
\ * levels 3/4/5 doors keep working unchanged.
\ *
\ * Refractory: each switch has one byte in level_switch_state. Set to 8
\ * frames on dispatch; tick_switch_logic decrements each frame. Subsequent
\ * hits while non-zero are consumed (carry CLEAR) without re-firing.
\ ******************************************************************************

.action_target_idx EQUB $00
.action_arg_a      EQUB $00            ; pre-loaded by dispatcher; param actions read this
.action_arg_b      EQUB $00            ; pre-loaded by dispatcher; param actions read this
.tdsa_match_found  EQUB $00            ; multi-trigger: 0 = no match yet, 1 = found at least one matching wiring entry
.tdsa_save_y       EQUB $00            ; multi-trigger: switch slot iterator, saved across each action JSR (action_destroy clobbers Y)

.tick_switch_logic
        LDX     #$07
.tick_switch_loop
        LDA     level_switch_state,X
        BEQ     tick_switch_skip
        DEC     level_switch_state,X
.tick_switch_skip
        DEX
        BPL     tick_switch_loop
        RTS

.try_dispatch_switch_action
\\ {
        \\ Multi-trigger: a switch can have any number of wiring entries (up
        \\ to the 8-slot table cap). Walk the indices list; for each slot
        \\ matching current_object, fire its action. Refractory is checked
        \\ ONCE on the first match — if active, skip the whole batch (so
        \\ rapid double-shots can't half-fire some entries while others sit
        \\ behind the cool-down). Otherwise fire all matches in slot order
        \\ and set refractory on each as we go.
        TXA
        PHA                                              ; preserve bullet index
        LDA     #$00
        STA     tdsa_match_found

        LDY     #$00
.tdsa_search
.tdsa_load_idx
        LDA     level_0_switch_obj_indices,Y             ; **SELF-MODIFIED CODE**
        switch_indices_addr_LO = tdsa_load_idx+1
        switch_indices_addr_HI = tdsa_load_idx+2
        CMP     #$FF
        BEQ     tdsa_done
        CMP     current_object
        BNE     tdsa_next_slot

        \\ Slot Y matches our switch. First match drives refractory.
        LDA     tdsa_match_found
        BNE     tdsa_fire_entry                          ; not first match: just fire
        INC     tdsa_match_found
        LDA     level_switch_state,Y
        BNE     tdsa_done                                ; first match in refractory: skip whole batch

.tdsa_fire_entry
        \\ Set refractory on this slot before dispatch.
        \\ ~20 frames (~0.6s @ 33Hz, the centisecond-gated main-loop rate).
        STY     tdsa_save_y
        LDA     #$14
        STA     level_switch_state,Y

.tdsa_load_target
        LDA     level_0_switch_target,Y                  ; **SELF-MODIFIED CODE**
        switch_target_addr_LO = tdsa_load_target+1
        switch_target_addr_HI = tdsa_load_target+2
        CMP     #$FF
        BEQ     tdsa_skip_entry                          ; no target: skip this entry, continue search
        STA     action_target_idx

.tdsa_load_action
        LDA     level_0_switch_action,Y                  ; **SELF-MODIFIED CODE**
        switch_action_addr_LO = tdsa_load_action+1
        switch_action_addr_HI = tdsa_load_action+2
        BEQ     tdsa_skip_entry                          ; action $00 = none: skip
        PHA                                              ; stash action across arg loads

        \\ Pre-load arg_a / arg_b so param actions can read them without
        \\ needing to recover the switch slot Y after dispatch.
.tdsa_load_arg_a
        LDA     level_0_switch_arg_a,Y                   ; **SELF-MODIFIED CODE**
        switch_arg_a_addr_LO = tdsa_load_arg_a+1
        switch_arg_a_addr_HI = tdsa_load_arg_a+2
        STA     action_arg_a
.tdsa_load_arg_b
        LDA     level_0_switch_arg_b,Y                   ; **SELF-MODIFIED CODE**
        switch_arg_b_addr_LO = tdsa_load_arg_b+1
        switch_arg_b_addr_HI = tdsa_load_arg_b+2
        STA     action_arg_b

        \\ Vector through action_jump_table. action × 2 = byte offset.
        \\ This clobbers Y (used as table index); save_y holds the slot for us.
        PLA                                              ; recover action code
        ASL     A
        TAY
        LDA     action_jump_table,Y
        STA     tdsa_dispatch_jsr+1
        LDA     action_jump_table+1,Y
        STA     tdsa_dispatch_jsr+2
        LDX     action_target_idx                        ; X = target_obj_index
.tdsa_dispatch_jsr
        JSR     $FFFF                                    ; **SELF-MODIFIED CODE**

.tdsa_skip_entry
        LDY     tdsa_save_y                              ; restore loop index
.tdsa_next_slot
        INY
        CPY     #$08
        BNE     tdsa_search

.tdsa_done
        PLA
        TAX                                              ; restore bullet index
        LDA     tdsa_match_found
        BEQ     tdsa_no_match
        CLC                                              ; matched at least one entry: consumed
        RTS
.tdsa_no_match
        SEC                                              ; not wired: fall through to legacy
        RTS
\\ }

\\ Action jump table: interleaved (LO, HI) pairs indexed by action_code × 2.
\\ Slots $05, $0B..$0F reserved for follow-up actions (pulse_door / cycle_param);
\\ they currently point at action_none so future builds can drop them in by
\\ replacing entries without touching the dispatcher.
.action_jump_table
        EQUB    LO(action_none),            HI(action_none)             ; $00 none
        EQUB    LO(action_set_alive),       HI(action_set_alive)        ; $01
        EQUB    LO(action_clear_alive),     HI(action_clear_alive)      ; $02
        EQUB    LO(action_toggle_alive),    HI(action_toggle_alive)     ; $03
        EQUB    LO(action_destroy),         HI(action_destroy)          ; $04
        EQUB    LO(action_pulse_door),      HI(action_pulse_door)       ; $05
        EQUB    LO(action_set_param),       HI(action_set_param)        ; $06
        EQUB    LO(action_xor_param),       HI(action_xor_param)        ; $07
        EQUB    LO(action_set_disabled),    HI(action_set_disabled)     ; $08
        EQUB    LO(action_clear_disabled),  HI(action_clear_disabled)   ; $09
        EQUB    LO(action_toggle_disabled), HI(action_toggle_disabled)  ; $0A
        EQUB    LO(action_none),            HI(action_none)             ; $0B reserved
        EQUB    LO(action_none),            HI(action_none)             ; $0C reserved
        EQUB    LO(action_none),            HI(action_none)             ; $0D reserved
        EQUB    LO(action_none),            HI(action_none)             ; $0E reserved
        EQUB    LO(action_none),            HI(action_none)             ; $0F reserved

.action_none
        RTS

.action_set_alive
        \\ X = target_obj_index
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_alive
        STA     level_obj_flags,X
        RTS

.action_clear_alive
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X
        RTS

.action_toggle_alive
        LDA     level_obj_flags,X
        EOR     #OBJ_flag_alive
        STA     level_obj_flags,X
        RTS

.action_set_disabled
        \\ X = target_obj_index. Suspends per-type behaviour (gun fire,
        \\ laser beam, mine motion+contact, well force, teleporter warp)
        \\ while leaving the sprite plot path untouched.
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_disabled
        STA     level_obj_flags,X
        RTS

.action_clear_disabled
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_disabled)
        STA     level_obj_flags,X
        RTS

.action_toggle_disabled
        LDA     level_obj_flags,X
        EOR     #OBJ_flag_disabled
        STA     level_obj_flags,X
        RTS

.action_destroy
        \\ X = target_obj_index. Mirrors destroy_object's effects without
        \\ clobbering current_object / current_obj_*pos (which the bullet
        \\ loop still needs after we return). Reads target's pos and type
        \\ via dedicated SMC slots patched in initialise_level_pointers.
        \\
        \\ Bail if target's alive bit is already clear — re-firing would
        \\ spawn a phantom explosion at the destroyed object's last position
        \\ and double-award the score.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BEQ     act_dest_already_dead
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X

.act_dest_load_x
        LDA     level_0_obj_pos_X,X                      ; **SELF-MODIFIED CODE**
        act_dest_pos_x_addr_LO = act_dest_load_x+1
        act_dest_pos_x_addr_HI = act_dest_load_x+2
        CLC
        ADC     #$02
        STA     explosion_xpos_INT

.act_dest_load_y
        LDA     level_0_obj_pos_Y,X                      ; **SELF-MODIFIED CODE**
        act_dest_pos_y_addr_LO = act_dest_load_y+1
        act_dest_pos_y_addr_HI = act_dest_load_y+2
        CLC
        ADC     #$04
        STA     explosion_ypos_INT

.act_dest_load_y_ext
        LDA     level_0_obj_pos_Y_EXT,X                  ; **SELF-MODIFIED CODE**
        act_dest_pos_y_ext_addr_LO = act_dest_load_y_ext+1
        act_dest_pos_y_ext_addr_HI = act_dest_load_y_ext+2
        ADC     #$00
        STA     explosion_ypos_INT_HI

.act_dest_load_type
        LDA     level_0_obj_type,X                       ; **SELF-MODIFIED CODE**
        act_dest_type_addr_LO = act_dest_load_type+1
        act_dest_type_addr_HI = act_dest_load_type+2
        TAY
        LDA     obj_type_score_value,Y
        JSR     accumulate_score_A
        LDA     obj_type_explosion_particle,Y
        STA     explosion_particle_type
        JSR     create_explosion
.act_dest_already_dead
        RTS

\ ******************************************************************************
\ * Param-write actions: set_param and xor_param.
\ *
\ * Each writes into target's obj_data_<slot>[X] where slot = action_arg_a (0..2).
\ * set_param writes action_arg_b verbatim; xor_param EORs action_arg_b in place.
\ * Slot >= 3 is silently ignored — the editor blocks it on export validation
\ * but a runtime guard keeps a malformed level from corrupting other arrays.
\ ******************************************************************************

.action_set_param
        \\ X = target_obj_index, action_arg_a = slot, action_arg_b = value.
        \\ Set redraw-pending flag so update_one_laser_beam takes the slow
        \\ path next frame and re-erases the cached beam at the OLD endpoint
        \\ before redrawing at the new dx/dy. Inert on non-laser targets
        \\ since only update_one_laser_beam reads this bit (and it only runs
        \\ for type $09..$0C objects).
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_laser_redraw_pending
        STA     level_obj_flags,X
        LDA     action_arg_a
        BNE     act_set_not_slot0
        LDA     action_arg_b
.act_set_store_0
        STA     level_0_obj_data_0,X                     ; **SELF-MODIFIED CODE**
        act_set_store_0_addr_LO = act_set_store_0+1
        act_set_store_0_addr_HI = act_set_store_0+2
        RTS
.act_set_not_slot0
        CMP     #$01
        BNE     act_set_not_slot1
        LDA     action_arg_b
.act_set_store_1
        STA     level_0_obj_data_1,X                     ; **SELF-MODIFIED CODE**
        act_set_store_1_addr_LO = act_set_store_1+1
        act_set_store_1_addr_HI = act_set_store_1+2
        RTS
.act_set_not_slot1
        CMP     #$02
        BNE     act_set_oor                              ; out-of-range slot: ignore
        LDA     action_arg_b
.act_set_store_2
        STA     level_0_obj_data_2,X                     ; **SELF-MODIFIED CODE**
        act_set_store_2_addr_LO = act_set_store_2+1
        act_set_store_2_addr_HI = act_set_store_2+2
.act_set_oor
        RTS

.action_xor_param
        \\ X = target_obj_index, action_arg_a = slot, action_arg_b = mask.
        \\ Same redraw-pending flag as set_param — see comment there.
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_laser_redraw_pending
        STA     level_obj_flags,X
        LDA     action_arg_a
        BNE     act_xor_not_slot0
.act_xor_load_0
        LDA     level_0_obj_data_0,X                     ; **SELF-MODIFIED CODE**
        act_xor_load_0_addr_LO = act_xor_load_0+1
        act_xor_load_0_addr_HI = act_xor_load_0+2
        EOR     action_arg_b
.act_xor_store_0
        STA     level_0_obj_data_0,X                     ; **SELF-MODIFIED CODE**
        act_xor_store_0_addr_LO = act_xor_store_0+1
        act_xor_store_0_addr_HI = act_xor_store_0+2
        RTS
.act_xor_not_slot0
        CMP     #$01
        BNE     act_xor_not_slot1
.act_xor_load_1
        LDA     level_0_obj_data_1,X                     ; **SELF-MODIFIED CODE**
        act_xor_load_1_addr_LO = act_xor_load_1+1
        act_xor_load_1_addr_HI = act_xor_load_1+2
        EOR     action_arg_b
.act_xor_store_1
        STA     level_0_obj_data_1,X                     ; **SELF-MODIFIED CODE**
        act_xor_store_1_addr_LO = act_xor_store_1+1
        act_xor_store_1_addr_HI = act_xor_store_1+2
        RTS
.act_xor_not_slot1
        CMP     #$02
        BNE     act_xor_oor
.act_xor_load_2
        LDA     level_0_obj_data_2,X                     ; **SELF-MODIFIED CODE**
        act_xor_load_2_addr_LO = act_xor_load_2+1
        act_xor_load_2_addr_HI = act_xor_load_2+2
        EOR     action_arg_b
.act_xor_store_2
        STA     level_0_obj_data_2,X                     ; **SELF-MODIFIED CODE**
        act_xor_store_2_addr_LO = act_xor_store_2+1
        act_xor_store_2_addr_HI = act_xor_store_2+2
.act_xor_oor
        RTS

\ ******************************************************************************
\ * pulse_door action ($05)
\ *
\ * X = target_obj_index (a door). If the door is already alive (mid-
\ * animation), the hold timer is re-seeded — matching the original
\ * game's counter_A=$FF latch on every switch hit. If the door is
\ * currently closing, it flips back to opening from its current cursor
\ * position. arg_a = hold frames, arg_b = close rate.
\ ******************************************************************************
.action_pulse_door
        \\ Always re-seed timing args from the wiring entry.
        LDA     action_arg_a
        STA     door_hold_phase,X
        LDA     action_arg_b
        STA     door_close_rate,X

        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BNE     pulse_door_already_alive

        \\ Door was idle: kick off a fresh open / hold / close cycle.
        LDA     level_obj_flags,X
        ORA     #OBJ_flag_alive
        STA     level_obj_flags,X
        LDA     #$00
        STA     door_cursor,X
        STA     door_close_phase,X
        STA     door_phase,X                             ; phase = opening
        RTS

.pulse_door_already_alive
        \\ Already animating. If in the closing phase, flip back to opening
        \\ (cursor will INC from wherever the close left it). Otherwise the
        \\ re-seeded hold_phase above is the only effect: a re-pulse during
        \\ opening / holding extends the open window.
        LDA     door_phase,X
        CMP     #$02
        BNE     pulse_door_done
        LDA     #$00
        STA     door_phase,X
        STA     door_close_phase,X
.pulse_door_done
        RTS

\ ******************************************************************************
\ * door_update_one
\ *
\ * Called from update_objects_loop with X = current_object and object_type
\ * already confirmed = OBJECT_door. Two phases:
\ *
\ *   1. Advance the animation state machine if alive: opening (cursor++)
\ *      → holding (hold_phase--) → closing (cursor--, paced by close_rate)
\ *      → close-finish (clear alive bit).
\ *   2. Render the carved wall into terrain_left/right_wall for the visible
\ *      rows. Runs every frame regardless of alive, so a closed door
\ *      continuously imposes its anchor_x on the affected rows — matching
\ *      the original level_3_door_logic's "always-owns-the-wall" model.
\ *
\ * Shape codes (low 7 bits of obj_data_0):
\ *   0 = slot          (every row carves to the same depth — implemented)
\ *   1 = notch_v       (D2)
\ *   2 = flat_window   (D3)
\ *
\ * Side: obj_data_0 bit 7. 0 = left wall, 1 = right wall.
\ ******************************************************************************
.door_update_one
\\ {
        STX     door_save_x

        \\ Phase 1: state-machine tick.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_alive
        BEQ     render_door
        JSR     door_advance_anim
        LDX     door_save_x

.render_door
        \\ Phase 2: paint the wall. Need on-screen Y first.
.door_load_pos_y
        LDA     level_0_obj_pos_Y,X                      ; **SELF-MODIFIED CODE**
        door_load_pos_y_addr_LO = door_load_pos_y+1
        door_load_pos_y_addr_HI = door_load_pos_y+2
        SEC
        SBC     window_ypos_INT
        STA     door_screen_y_temp
.door_load_pos_y_ext
        LDA     level_0_obj_pos_Y_EXT,X                  ; **SELF-MODIFIED CODE**
        door_load_pos_y_ext_addr_LO = door_load_pos_y_ext+1
        door_load_pos_y_ext_addr_HI = door_load_pos_y_ext+2
        SBC     window_ypos_EXT
        BEQ     door_y_same_page                         ; different page: off-window
        JMP     door_off_screen
.door_y_same_page
        LDA     door_screen_y_temp
        CMP     #$F1                                     ; same threshold as level_3 routine
        BCC     door_y_on_screen
        JMP     door_off_screen
.door_y_on_screen

        \\ On-screen. Wall array index = screen_y + terrain_window_y_index.
        CLC
        ADC     terrain_window_y_index
        STA     door_row_temp

        \\ Read shape descriptor (bit 7 = side, low bits = shape code).
.door_load_shape
        LDA     level_0_obj_data_0,X                     ; **SELF-MODIFIED CODE**
        door_load_shape_addr_LO = door_load_shape+1
        door_load_shape_addr_HI = door_load_shape+2
        STA     door_shape_temp

        \\ Anchor X — wall position when closed (cursor = 0).
.door_load_anchor_x
        LDA     level_0_obj_pos_X,X                      ; **SELF-MODIFIED CODE**
        door_load_pos_x_addr_LO = door_load_anchor_x+1
        door_load_pos_x_addr_HI = door_load_anchor_x+2
        STA     door_anchor_x_temp

.door_load_width
        LDA     level_0_obj_data_1,X                     ; **SELF-MODIFIED CODE**
        door_load_width_addr_LO = door_load_width+1
        door_load_width_addr_HI = door_load_width+2
        STA     door_width_temp

        \\ Pre-compute carve_x = anchor_x - cursor (for left wall) or
        \\ anchor_x + cursor (for right wall). Slot uses this directly;
        \\ notch_v offsets it per row.
        LDA     door_shape_temp
        BMI     door_carve_right

        LDA     door_anchor_x_temp
        SEC
        SBC     door_cursor,X
        STA     door_carve_x_temp
        JMP     door_carve_done
.door_carve_right
        LDA     door_anchor_x_temp
        CLC
        ADC     door_cursor,X
        STA     door_carve_x_temp
.door_carve_done

        \\ Dispatch on shape code (low 7 bits of door_shape_temp).
        \\ Side bit (bit 7) is handled inside each shape's renderer.
        LDA     door_shape_temp
        AND     #$7F
        BEQ     render_slot
        CMP     #$01
        BEQ     render_notch_v
        JMP     door_off_screen                          ; unknown shape: no render

\ --- Slot ------------------------------------------------------------
\ Every row carves to the same depth. Pulled-back X = carve_x_temp.
.render_slot
        LDY     door_row_temp
        LDX     door_width_temp
        LDA     door_carve_x_temp
        BIT     door_shape_temp
        BMI     render_slot_right
.render_slot_left_loop
        STA     terrain_left_wall,Y
        INY
        DEX
        BNE     render_slot_left_loop
        JMP     door_off_screen
.render_slot_right
.render_slot_right_loop
        STA     terrain_right_wall,Y
        INY
        DEX
        BNE     render_slot_right_loop
        JMP     door_off_screen

\ --- Notch_v (triangular) --------------------------------------------
\ Per-row anchor: base + min(row, width-1-row). Splits the run into a
\ rising half (rise_count = width / 2 iters, +1 per row) then a
\ descending half (descend_count = width - rise_count iters, peak then
\ -1 per row). For left wall, base means smaller X is "pulled back"
\ so the peak protrudes INTO the cavern with +rise_count from carve_x.
\ Right wall mirrors: base + cursor, peak protrudes via -rise_count.
.render_notch_v
        LDA     door_width_temp
        LSR     A                                        ; rise_count = width / 2
        STA     door_rise_count_temp
        LDA     door_width_temp
        SEC
        SBC     door_rise_count_temp
        STA     door_descend_count_temp

        BIT     door_shape_temp
        BMI     render_notch_v_right

\ Left wall: rise loop ADC, descend loop SBC. carve_x is edge value.
        LDY     door_row_temp
        LDA     door_carve_x_temp
        LDX     door_rise_count_temp
        BEQ     nvl_skip_rise
.nvl_rise_loop
        STA     terrain_left_wall,Y
        CLC
        ADC     #$01
        INY
        DEX
        BNE     nvl_rise_loop
.nvl_skip_rise
        LDX     door_descend_count_temp
        BEQ     door_off_screen
.nvl_descend_loop
        STA     terrain_left_wall,Y
        SEC
        SBC     #$01
        INY
        DEX
        BNE     nvl_descend_loop
        JMP     door_off_screen

\ Right wall: rise loop SBC (peak protrudes into cavern = smaller X),
\ descend loop ADC.
.render_notch_v_right
        LDY     door_row_temp
        LDA     door_carve_x_temp
        LDX     door_rise_count_temp
        BEQ     nvr_skip_rise
.nvr_rise_loop
        STA     terrain_right_wall,Y
        SEC
        SBC     #$01
        INY
        DEX
        BNE     nvr_rise_loop
.nvr_skip_rise
        LDX     door_descend_count_temp
        BEQ     door_off_screen
.nvr_descend_loop
        STA     terrain_right_wall,Y
        CLC
        ADC     #$01
        INY
        DEX
        BNE     nvr_descend_loop

.door_off_screen
        LDX     door_save_x
        RTS
\\ }

\ ******************************************************************************
\ * door_advance_anim
\ *
\ * X = current_object. alive bit confirmed set. Drives the open/hold/close
\ * state machine via the per-door auxiliary arrays. Cursor reaches 0 at
\ * close-end → clear alive bit (door goes idle until next pulse_door).
\ ******************************************************************************
.door_advance_anim
\\ {
        \\ Branch on phase. Each phase decides whether to tick its counter
        \\ or transition to the next phase. Transitions consume the frame
        \\ (no double-step) so the open/hold/close edge is one frame wide.
        LDA     door_phase,X
        BEQ     phase_opening
        CMP     #$01
        BEQ     phase_holding
        JMP     phase_closing

    .phase_opening
.door_load_max_carve
        LDA     level_0_obj_data_2,X                     ; **SELF-MODIFIED CODE**
        door_load_max_carve_addr_LO = door_load_max_carve+1
        door_load_max_carve_addr_HI = door_load_max_carve+2
        CMP     door_cursor,X
        BNE     open_inc
        \\ Cursor at max — start holding next frame.
        LDA     #$01
        STA     door_phase,X
        RTS
    .open_inc
        INC     door_cursor,X
        RTS

    .phase_holding
        LDA     door_hold_phase,X
        BEQ     hold_done
        DEC     door_hold_phase,X
        RTS
    .hold_done
        \\ Hold expired — start closing next frame.
        LDA     #$02
        STA     door_phase,X
        RTS

    .phase_closing
        LDA     door_close_phase,X
        BEQ     do_close_step
        DEC     door_close_phase,X
        RTS
    .do_close_step
        LDA     door_close_rate,X
        STA     door_close_phase,X
        LDA     door_cursor,X
        BEQ     close_finished                           ; safety: already 0
        DEC     door_cursor,X
        BNE     close_running

    .close_finished
        \\ Cursor just hit 0: door is fully shut. Clear alive — next pulse
        \\ resets the state machine via action_pulse_door.
        LDA     level_obj_flags,X
        AND     #($FF EOR OBJ_flag_alive)
        STA     level_obj_flags,X
    .close_running
        RTS
\\ }

\ ******************************************************************************
\ * tick_doors
\ *
\ * Per-frame walker over all level objects looking for OBJECT_door.
\ * Replaces tick_door_logic's legacy per-level dispatch under _SWITCHES —
\ * each door object now drives its own animation. Hardcoded routines
\ * (level_3/4/5_door_logic) stay assembled but go unreachable.
\ ******************************************************************************
.tick_doors
        LDX     #$00
.tick_doors_loop
        STX     current_object
.tick_doors_load_type
        LDA     level_0_obj_type,X                       ; **SELF-MODIFIED CODE** (mirror of laser pass)
        tick_doors_type_addr_LO = tick_doors_load_type+1
        tick_doors_type_addr_HI = tick_doors_load_type+2
        CMP     #$FF
        BEQ     tick_doors_done
        CMP     #OBJECT_door
        BNE     tick_doors_next
        STA     object_type                              ; door_update_one doesn't read this but be safe
        JSR     door_update_one
.tick_doors_next
        LDX     current_object
        INX
        JMP     tick_doors_loop
.tick_doors_done
        RTS
ENDIF

IF _LAST_USED_CHECKPOINT
\ ******************************************************************************
\ * Per-frame active-checkpoint advance scan
\ *
\ * Bidirectional tracking. Direction-agnostic during play; pod handling lives
\ * entirely in level_reset's respawn path (using deepest_checkpoint_visited
\ * as a safety cap).
\ *
\ *   Retreat: while player_y < cp[active-1].y. Player has gone above prev cp.
\ *   Advance: while player_y > cp[active+1].y. Player has gone below next cp.
\ *
\ * Each advance also bumps deepest_checkpoint_visited if it grows past it,
\ * so the respawn-with-pod path never references a checkpoint the player
\ * hasn't reached on foot in the current segment (teleporters reset both
\ * active and deepest to the destination index).
\ *
\ * Equality on the boundary doesn't move active — "higher than" / "lower
\ * than" are interpreted strictly.
\ ******************************************************************************

.update_active_checkpoint
{
        LDX     level_number
        LDA     level_reset_data_sizes,X
        STA     level_reset_size
        BNE     uac_have_cps
        RTS                                            ; level has no checkpoints (shouldn't happen)
    .uac_have_cps
        LDA     level_reset_ptr_table_LO,X
        STA     level_reset_ptr
        LDA     level_reset_ptr_table_HI,X
        STA     level_reset_ptr+1

\\ ----- Retreat: player_y < cp[active-1].y (player above prev cp). -----
    .uac_retreat_loop
        LDA     active_checkpoint_index
        BEQ     uac_advance_loop                       ; already at index 0
        SEC
        SBC     #$01
        TAY                                             ; Y = active-1
        LDA     (level_reset_ptr),Y                    ; cp[Y].y_HI
        CMP     midpoint_ypos_INT_HI
        BCC     uac_advance_loop                       ; cp_HI < player_HI -> cp above player, no retreat
        BNE     uac_do_retreat                         ; cp_HI > player_HI -> cp below player, retreat
        \\ HI bytes equal: compare LO.
        TYA
        CLC
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y                    ; cp[Y].y_LO
        CMP     midpoint_ypos_INT
        BCC     uac_advance_loop                       ; cp_LO < player_LO -> cp above (HI eq), no retreat
        BEQ     uac_advance_loop                       ; equal -> not strictly higher, no retreat
    .uac_do_retreat
        DEC     active_checkpoint_index
        JMP     uac_retreat_loop

\\ ----- Advance: player_y > cp[active+1].y (player below next cp). -----
    .uac_advance_loop
        LDA     active_checkpoint_index
        CLC
        ADC     #$01
        CMP     level_reset_size
        BCS     uac_done                               ; already at last index
        TAY                                             ; Y = active+1
        LDA     (level_reset_ptr),Y                    ; cp[Y].y_HI
        CMP     midpoint_ypos_INT_HI
        BCC     uac_do_advance                         ; cp_HI < player_HI -> cp above player, advance
        BNE     uac_done                               ; cp_HI > player_HI -> cp below player, done
        \\ HI bytes equal: compare LO.
        TYA
        CLC
        ADC     level_reset_size
        TAY
        LDA     (level_reset_ptr),Y                    ; cp[Y].y_LO
        CMP     midpoint_ypos_INT
        BCS     uac_done                               ; cp_LO >= player_LO -> cp at or below, done
    .uac_do_advance
        INC     active_checkpoint_index
        \\ Update deepest watermark when active grows past the previous max.
        LDA     active_checkpoint_index
        CMP     deepest_checkpoint_visited
        BCC     uac_advance_loop                       ; active < deepest -> no update
        STA     deepest_checkpoint_visited
        JMP     uac_advance_loop
    .uac_done
        RTS
}
ENDIF

IF _BOBBING_MINES
\ ******************************************************************************
\ * Bobbing mines
\ *
\ * Mine Y position bobs along a sine curve with per-instance phase and
\ * amplitude. obj_data slots:
\ *   slot 0 = phase byte (added to vsync_count, masked to ANGLE_MASK)
\ *   slot 1 = signed amplitude byte (peak-to-peak ≈ 2*amp pixels)
\ *   slot 2 = previous frame's signed offset (state; starts at 0)
\ *
\ * level_obj_pos_Y / _EXT track the live displayed Y. Each frame the routine
\ * computes new_offset = (sin(phase + vsync_count) * amp) >> 7, applies
\ * (new_offset - prev_offset) as a 16-bit signed delta to the live Y, and
\ * writes new_offset back to slot 2.
\ ******************************************************************************

.bobbing_mine_sin_table
        \\ signed Q.7 sin(2*pi*angle/256) for angle 0..255. -128 ($80) is
        \\ clamped to -127 ($81) at the trough so multiply_signed_8x8 stays
        \\ well-defined (its negate path can't represent +128).
        EQUB $00,$03,$06,$09,$0C,$10,$13,$16
        EQUB $19,$1C,$1F,$22,$25,$28,$2B,$2E
        EQUB $31,$33,$36,$39,$3C,$3F,$41,$44
        EQUB $47,$49,$4C,$4E,$51,$53,$55,$58
        EQUB $5A,$5C,$5E,$60,$62,$64,$66,$68
        EQUB $6A,$6B,$6D,$6F,$70,$71,$73,$74
        EQUB $75,$76,$78,$79,$7A,$7A,$7B,$7C
        EQUB $7D,$7D,$7E,$7E,$7E,$7F,$7F,$7F
        EQUB $7F,$7F,$7F,$7F,$7E,$7E,$7E,$7D
        EQUB $7D,$7C,$7B,$7A,$7A,$79,$78,$76
        EQUB $75,$74,$73,$71,$70,$6F,$6D,$6B
        EQUB $6A,$68,$66,$64,$62,$60,$5E,$5C
        EQUB $5A,$58,$55,$53,$51,$4E,$4C,$49
        EQUB $47,$44,$41,$3F,$3C,$39,$36,$33
        EQUB $31,$2E,$2B,$28,$25,$22,$1F,$1C
        EQUB $19,$16,$13,$10,$0C,$09,$06,$03
        EQUB $00,$FD,$FA,$F7,$F4,$F0,$ED,$EA
        EQUB $E7,$E4,$E1,$DE,$DB,$D8,$D5,$D2
        EQUB $CF,$CD,$CA,$C7,$C4,$C1,$BF,$BC
        EQUB $B9,$B7,$B4,$B2,$AF,$AD,$AB,$A8
        EQUB $A6,$A4,$A2,$A0,$9E,$9C,$9A,$98
        EQUB $96,$95,$93,$91,$90,$8F,$8D,$8C
        EQUB $8B,$8A,$88,$87,$86,$86,$85,$84
        EQUB $83,$83,$82,$82,$82,$81,$81,$81
        EQUB $81,$81,$81,$81,$82,$82,$82,$83
        EQUB $83,$84,$85,$86,$86,$87,$88,$8A
        EQUB $8B,$8C,$8D,$8F,$90,$91,$93,$95
        EQUB $96,$98,$9A,$9C,$9E,$A0,$A2,$A4
        EQUB $A6,$A8,$AB,$AD,$AF,$B2,$B4,$B7
        EQUB $B9,$BC,$BF,$C1,$C4,$C7,$CA,$CD
        EQUB $CF,$D2,$D5,$D8,$DB,$DE,$E1,$E4
        EQUB $E7,$EA,$ED,$F0,$F4,$F7,$FA,$FD

.bobbing_mine_save_x        EQUB $00
.bobbing_mine_new_offset    EQUB $00
.bobbing_mine_delta_hi      EQUB $00

\ Per-mine local tick counter, indexed by current_object. Advanced once
\ per call to update_bobbing_mine[_horizontal]. Driving the sin lookup
\ from this (instead of the global level_tick_counter) means a mine that
\ stops updating — e.g. while OBJ_flag_disabled is set — has its phase
\ frozen, so toggling disabled back off resumes the bob at the position
\ it left, not where it "would have been" had it kept running.
.bobbing_mine_local_tick
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00

\ Per-door animation state, indexed by current_object. Only meaningful
\ for OBJECT_door slots; harmless on other types (tick_doors ignores
\ non-door objects). All zero at level start = closed and idle.
\   door_cursor:      current carve depth (0..max_carve_depth)
\   door_hold_phase:  frames remaining at full open
\   door_close_phase: frames-until-next-close-step countdown
\   door_close_rate:  constant from pulse_door's arg_b; reloads close_phase
IF _SWITCHES
.door_cursor
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
.door_hold_phase
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
.door_close_phase
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
.door_close_rate
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00

\ Explicit phase byte for the door's open/hold/close state machine.
\ 0 = opening (cursor advancing toward max_carve)
\ 1 = holding (hold_phase counting down)
\ 2 = closing (cursor retreating toward 0)
\ Without this the state was ambiguous mid-close (cursor < max_carve) and
\ door_advance_anim would treat it as "still opening" — bouncing the
\ cursor right back up.
.door_phase
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00
        EQUB $00,$00,$00,$00,$00,$00,$00,$00

\ Scratch used by door_update_one each frame. Single-instance — the
\ update runs serially per object, so reusing these is safe.
.door_save_x             EQUB $00
.door_screen_y_temp      EQUB $00
.door_row_temp           EQUB $00
.door_shape_temp         EQUB $00
.door_anchor_x_temp      EQUB $00
.door_width_temp         EQUB $00
.door_carve_x_temp       EQUB $00
.door_rise_count_temp    EQUB $00
.door_descend_count_temp EQUB $00
ENDIF

.update_bobbing_mine
\\ {
        \\ Disabled: freeze at current position. Skip the motion update.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BEQ     bm_not_disabled
        RTS
.bm_not_disabled
        STX     bobbing_mine_save_x

        \\ amp byte (slot 1) -> multiply_operand_a (signed)
.bm_load_amp
        LDA     level_0_obj_data_1,X                    ; **SELF-MODIFIED CODE** (slot 1 = amp)
        bm_amp_addr_LO = bm_load_amp+1
        bm_amp_addr_HI = bm_load_amp+2
        STA     multiply_operand_a

        \\ angle index = (phase + local_tick) AND $FF. The 256-entry
        \\ sin table gives smooth motion with one cycle every 256 frames
        \\ and full 256-step phase resolution. bobbing_mine_local_tick is
        \\ per-mine and only advances when this routine runs — so a mine
        \\ that's been frozen via OBJ_flag_disabled resumes from where it
        \\ left off, rather than jumping to the global-tick position.
.bm_load_phase
        LDA     level_0_obj_data_0,X                    ; **SELF-MODIFIED CODE** (slot 0 = phase)
        bm_phase_addr_LO = bm_load_phase+1
        bm_phase_addr_HI = bm_load_phase+2
        CLC
        ADC     bobbing_mine_local_tick,X
        TAY
        LDA     bobbing_mine_sin_table,Y                ; A = signed Q.7 sin
        JSR     multiply_signed_8x8

        \\ Double the 16-bit product, then take high byte ≈ amp * sin
        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     multiply_result_hi                      ; A = signed pixel offset
        STA     bobbing_mine_new_offset

        LDX     bobbing_mine_save_x

        \\ delta = new_offset - prev_offset (slot 2)
        SEC
.bm_load_prev
        SBC     level_0_obj_data_2,X                    ; **SELF-MODIFIED CODE** (slot 2 = prev offset)
        bm_prev_addr_LO = bm_load_prev+1
        bm_prev_addr_HI = bm_load_prev+2
        TAY                                             ; Y = signed delta_lo

        \\ Sign-extend Y to delta_hi
        LDA     #$00
        CPY     #$80
        BCC     bm_delta_sign_done
        LDA     #$FF
.bm_delta_sign_done
        STA     bobbing_mine_delta_hi

        \\ level_obj_pos_Y / _EXT += delta (16-bit signed add)
        TYA
        CLC
.bm_pos_y_load
        ADC     level_0_obj_pos_Y,X                     ; **SELF-MODIFIED CODE**
        bm_pos_y_load_addr_LO = bm_pos_y_load+1
        bm_pos_y_load_addr_HI = bm_pos_y_load+2
.bm_pos_y_store
        STA     level_0_obj_pos_Y,X                     ; **SELF-MODIFIED CODE**
        bm_pos_y_store_addr_LO = bm_pos_y_store+1
        bm_pos_y_store_addr_HI = bm_pos_y_store+2

        LDA     bobbing_mine_delta_hi
.bm_pos_y_ext_load
        ADC     level_0_obj_pos_Y_EXT,X                 ; **SELF-MODIFIED CODE**
        bm_pos_y_ext_load_addr_LO = bm_pos_y_ext_load+1
        bm_pos_y_ext_load_addr_HI = bm_pos_y_ext_load+2
.bm_pos_y_ext_store
        STA     level_0_obj_pos_Y_EXT,X                 ; **SELF-MODIFIED CODE**
        bm_pos_y_ext_store_addr_LO = bm_pos_y_ext_store+1
        bm_pos_y_ext_store_addr_HI = bm_pos_y_ext_store+2

        \\ slot 2 := new_offset
        LDA     bobbing_mine_new_offset
.bm_prev_store
        STA     level_0_obj_data_2,X                    ; **SELF-MODIFIED CODE**
        bm_prev_store_addr_LO = bm_prev_store+1
        bm_prev_store_addr_HI = bm_prev_store+2

        INC     bobbing_mine_local_tick,X
        RTS
\\ }

\ ******************************************************************************
\ * Function: update_bobbing_mine_horizontal
\ * Description: Same as update_bobbing_mine but the bob axis is X. World X
\ *   is 8-bit (single byte, wraps), so the position update is one 8-bit
\ *   add/wrap. Slot conventions are identical to the vertical variant.
\ ******************************************************************************
.update_bobbing_mine_horizontal
\\ {
        \\ Disabled: freeze at current position. Skip the motion update.
        LDA     level_obj_flags,X
        AND     #OBJ_flag_disabled
        BEQ     bm_h_not_disabled
        RTS
.bm_h_not_disabled
        STX     bobbing_mine_save_x

        \\ amp byte (slot 1) -> multiply_operand_a (signed)
.bm_h_load_amp
        LDA     level_0_obj_data_1,X                    ; **SELF-MODIFIED CODE** (slot 1 = amp)
        bm_h_amp_addr_LO = bm_h_load_amp+1
        bm_h_amp_addr_HI = bm_h_load_amp+2
        STA     multiply_operand_a

        \\ angle = (phase + local_tick) AND $FF -- per-mine counter, see
        \\ comment in update_bobbing_mine.
.bm_h_load_phase
        LDA     level_0_obj_data_0,X                    ; **SELF-MODIFIED CODE** (slot 0 = phase)
        bm_h_phase_addr_LO = bm_h_load_phase+1
        bm_h_phase_addr_HI = bm_h_load_phase+2
        CLC
        ADC     bobbing_mine_local_tick,X
        TAY
        LDA     bobbing_mine_sin_table,Y
        JSR     multiply_signed_8x8

        ASL     multiply_result_lo
        ROL     multiply_result_hi
        LDA     multiply_result_hi
        STA     bobbing_mine_new_offset

        LDX     bobbing_mine_save_x

        \\ delta = new_offset - prev_offset (slot 2)
        SEC
.bm_h_load_prev
        SBC     level_0_obj_data_2,X                    ; **SELF-MODIFIED CODE** (slot 2 = prev offset)
        bm_h_prev_addr_LO = bm_h_load_prev+1
        bm_h_prev_addr_HI = bm_h_load_prev+2

        \\ Apply 8-bit signed delta to level_obj_pos_X (X axis is one byte
        \\ in this engine; wraps naturally on overflow).
        CLC
.bm_h_pos_x_load
        ADC     level_0_obj_pos_X,X                     ; **SELF-MODIFIED CODE**
        bm_h_pos_x_load_addr_LO = bm_h_pos_x_load+1
        bm_h_pos_x_load_addr_HI = bm_h_pos_x_load+2
.bm_h_pos_x_store
        STA     level_0_obj_pos_X,X                     ; **SELF-MODIFIED CODE**
        bm_h_pos_x_store_addr_LO = bm_h_pos_x_store+1
        bm_h_pos_x_store_addr_HI = bm_h_pos_x_store+2

        \\ slot 2 := new_offset
        LDA     bobbing_mine_new_offset
.bm_h_prev_store
        STA     level_0_obj_data_2,X                    ; **SELF-MODIFIED CODE**
        bm_h_prev_store_addr_LO = bm_h_prev_store+1
        bm_h_prev_store_addr_HI = bm_h_prev_store+2

        INC     bobbing_mine_local_tick,X
        RTS
\\ }
ENDIF

IF PARTICLE_table_max<>$1F
.particles_xpos_FRAC    SKIP PARTICLE_table_max+1 ; 32 entries, fractional X position
.particles_xpos_INT     SKIP PARTICLE_table_max+1 ; 32 entries, integer X position
.particles_ypos_FRAC    SKIP PARTICLE_table_max+1 ; 32 entries, fractional Y position
.particles_ypos_INT     SKIP PARTICLE_table_max+1 ; 32 entries, integer Y position
.particles_ypos_INT_HI  SKIP PARTICLE_table_max+1 ; 32 entries, Y position high byte
.particles_dx_FRAC      SKIP PARTICLE_table_max+1 ; 32 entries, fractional X velocity
.particles_dx_INT       SKIP PARTICLE_table_max+1 ; 32 entries, integer X velocity
.particles_dy_FRAC      SKIP PARTICLE_table_max+1 ; 32 entries, fractional Y velocity
.particles_dy_INT       SKIP PARTICLE_table_max+1 ; 32 entries, integer Y velocity
.particles_lifetime     SKIP PARTICLE_table_max+1 ; 32 entries, remaining lifetime
.particles_scraddr_LO   SKIP PARTICLE_table_max+1 ; 32 entries, screen address low byte
.particles_scraddr_HI   SKIP PARTICLE_table_max+1 ; 32 entries, screen address high byte
.particles_pixels_byte  SKIP PARTICLE_table_max+1 ; 32 entries, pixel pattern for plotting
.particles_type         SKIP PARTICLE_table_max+1 ; 32 entries, particle type
ENDIF

\ ******************************************************************************
\ * Function: draw_terrain
\ * Params: Y = start column, X = width to draw in columns
\ * Returns: none
\ * Description: Draws a horizontal terrain line across columns using EOR plotting 
\ ******************************************************************************

IF _UNROLL_TERRAIN
.draw_terrain
{
        LDA     mult_by_8_LO,Y                  ; 4c
        STA     terrain_draw_ptr                ; 3c

        LDA     mult_by_8_HI,Y                  ; 4c
        ADC     terrain_draw_addr_HI            ; 3c
        STA     terrain_draw_ptr+1              ; 3c
        
        LDY     terrain_draw_addr_LO            ; 3c
        LDA     #LANDSCAPE_COLOUR_BYTE          ; 2c          ; solid line colour 2
        EOR     (terrain_draw_ptr),Y            ; 6c
        STA     (terrain_draw_ptr),Y            ; 6c
        DEX                                     ; 2c
        BEQ     draw_terrain_return             ; 2c
        ; 38c

        CPX     #9                              ; not worth doing it for <9 columns
        BCS     draw_terrain_unrolled

    .draw_terrain_loop
        TYA                                     ; 2c
        ADC     #$08                            ; 2c          ; next column
        TAY                                     ; 2c
        BCC     inc_terrain_draw_ptr_no_carry   ; 2/3c

        CLC                                     ; 2c
        INC     terrain_draw_ptr+1              ; 5c
        
    .inc_terrain_draw_ptr_no_carry
        LDA     #LANDSCAPE_COLOUR_BYTE          ; 2c          ; solid line colour 2
        EOR     (terrain_draw_ptr),Y            ; 6c
        STA     (terrain_draw_ptr),Y            ; 6c
        DEX                                     ; 2c
        BNE     draw_terrain_loop               ; 3c
        ; 27c per col

    .draw_terrain_return
        RTS                                     ; 6c

    .draw_terrain_unrolled
        ; Reset base ptr to next column.
        CLC                                     ; 2c
        TYA                                     ; 2c
        LDY     #0                              ; 2c
        ADC     #8                              ; 2c
        BCC     next_col                        ; 3c
        INC     terrain_draw_ptr+1              ; 5c
        CLC                                     ; 2c
        .next_col
        ADC     terrain_draw_ptr                ; 3c
        STA     terrain_draw_ptr                ; 3c
        BCC     no_carry                        ; 3c

        .next_page
        INC     terrain_draw_ptr+1              ; 5c
        CLC                                     ; 2c
        .no_carry

        ; X=remaining columns
        LDA     width_to_plot_LO, X             ; 4c
        STA     jump_to+1                       ; 4c
        LDA     width_to_plot_HI, X             ; 4c
        STA     jump_to+2                       ; 4c

        ; Plot up to 32 columns in one go.
        .jump_to
        JMP     terrain_unrolled_plot_one_page  ; 3c
        ; 66c setup + 40c per loop + 19c per col.
        .^draw_terrain_unrolled_return

        ; Check how many are left.
        SEC                                     ; 2c
        TXA                                     ; 2c
        SBC     #32                             ; 2c          ; we just did 32 cols max
        TAX                                     ; 2c
        BCS     next_page                       ; 3c          ; or we finished
        RTS
}

.width_to_plot_LO
FOR width,0,72,1
IF width>31
        w=0             ; plots 32
ELSE
        w=32-width      ; plots N (jump to N from the end)
ENDIF
EQUB LO(terrain_unrolled_plot_one_page+w*UNROLLED_PLOT_SIZE)
NEXT

.width_to_plot_HI
FOR width,0,72,1
IF width>31
        w=0             ; plots 32
ELSE
        w=32-width      ; plots N (jump to N from the end)
ENDIF
EQUB HI(terrain_unrolled_plot_one_page+w*UNROLLED_PLOT_SIZE)
NEXT

.terrain_unrolled_plot_one_page
{
        FOR col, 0, 31, 1
                LDA     #LANDSCAPE_COLOUR_BYTE          ; 2c          ; solid line colour 2
                EOR     (terrain_draw_ptr),Y            ; 5c
                STA     (terrain_draw_ptr),Y            ; 6c
                TYA                                     ; 2c
                ADC     #$08                            ; 2c          ; next column
                TAY                                     ; 2c
                ; 20c per col.
        NEXT
        JMP     draw_terrain_unrolled_return            ; 3c
}

UNROLLED_PLOT_SIZE=10
ENDIF

\ ******************************************************************************
\ ******************************************************************************
\ * Copy down the SWRAM block to lower RAM for the executable.
\ ******************************************************************************
\ ******************************************************************************

SWRAM_SIZE      = P%-SWRAM_ADDR
SWRAM_PAGES     = HI(SWRAM_SIZE+&FF)

PRINT "~~~~~~~~~~"
PRINT "SWRAM BANK"
PRINT "~~~~~~~~~~"
PRINT "TOTAL SIZE=", ~SWRAM_SIZE, "bytes (", ~SWRAM_PAGES, " pages)"
PRINT "COPYBLOCK FROM=", ~SWRAM_ADDR, " TO=", ~SWRAM_RELOC_START, " SIZE=", ~SWRAM_SIZE, " bytes (", ~SWRAM_PAGES, " pages)"
COPYBLOCK SWRAM_ADDR, P%, SWRAM_RELOC_START
PRINT "SWRAM BANK RAM BYTES FREE=", ~(&4000-SWRAM_SIZE)
PRINT "~~~~~~~~~~"

ELSE
SWRAM_SIZE      = 0
ENDIF

\ ******************************************************************************
\ ******************************************************************************
\ * Save code to disk image with correct execution address to relocate function
\ ******************************************************************************
\ ******************************************************************************

SAVE "Thrust", NATIVE_START, NATIVE_END+SWRAM_SIZE, RELOC_START+OFFSET, LOAD_ADDR

\ ******************************************************************************
\ ******************************************************************************
\ * EOF
\ ******************************************************************************
\ ******************************************************************************

IF _FAST_SPRITES

PRINT "~~~~~~~~~~~~~~~~~~~"
PRINT "FAST SPRITES BUILD!"
PRINT "~~~~~~~~~~~~~~~~~~~"

CLEAR &8000, &C000
ORG &8000
GUARD &C000

\ ******************************************************************************
\ * Pre-baked two-stream ship sprite data and plotter (_FAST_SPRITES)
\ ******************************************************************************

INCLUDE "tools/output/ship_twostream_data.asm"

\ ******************************************************************************
\ * Collision test code templates (3 bytes each, copied into self-modifying site)
\ * AND mode: test for collision during erase pass
\ * SKIP mode: jump past collision test during draw pass
\ ******************************************************************************

.ship_ts_AND_CODE
        AND     ship_ts_mask_temp                   ; $2D lo hi (3 bytes, absolute)
.ship_ts_SKIP_CODE
        JMP     plot_ship_ts_loop                   ; $4C lo hi (3 bytes)

\ ******************************************************************************
\ * Function: plot_ship_or_shield
\ * Params: plot_ship_at_ptr = screen address, plot_ship_pixel_column = 0-3,
\ *         plot_ship_sprite_number = angle (0-31) or $FF for shield
\ * Description: Two-stream ship sprite plotter setup. Looks up pre-baked
\ *              stream data for the given angle and pixel column, patches
\ *              self-modifying code, and runs the two-stream plot loop.
\ ******************************************************************************

.plot_ship_or_shield
{
        LDA     plot_ship_sprite_number
        BPL     ship_not_shield

        ; Shield sprite: colour 3 = both bitplanes (no reduction)
        LDA     #$FF
        STA     ship_ts_colour_operand              ; AND #$FF = no-op
        LDY     plot_ship_pixel_column
        LDA     shield_ts_ptr_A_LO,Y
        STA     ship_ts_stream_A_addr_LO            ; **MODIFIES CODE**
        LDA     shield_ts_ptr_A_HI,Y
        STA     ship_ts_stream_A_addr_HI            ; **MODIFIES CODE**
        LDA     shield_ts_ptr_B_LO,Y
        STA     ship_ts_stream_B_addr_LO            ; **MODIFIES CODE**
        LDA     shield_ts_ptr_B_HI,Y
        STA     ship_ts_stream_B_addr_HI            ; **MODIFIES CODE**
        JMP     plot_ship_ts_setup_done

    .ship_not_shield
        ; Ship sprite: colour 1 = low bitplane only
        LDA     #$0F
        STA     ship_ts_colour_operand              ; AND #$0F = keep low bitplane
        LDA     plot_ship_sprite_number
        ASL     A                                   ; angle * 2
        ASL     A                                   ; angle * 4
        ORA     plot_ship_pixel_column              ; + pixel_column (0-3)
        TAY
        LDA     ship_ts_ptr_A_LO,Y
        STA     ship_ts_stream_A_addr_LO            ; **MODIFIES CODE**
        LDA     ship_ts_ptr_A_HI,Y
        STA     ship_ts_stream_A_addr_HI            ; **MODIFIES CODE**
        LDA     ship_ts_ptr_B_LO,Y
        STA     ship_ts_stream_B_addr_LO            ; **MODIFIES CODE**
        LDA     ship_ts_ptr_B_HI,Y
        STA     ship_ts_stream_B_addr_HI            ; **MODIFIES CODE**

    .plot_ship_ts_setup_done
        ; Initialise row counter: rows remaining before char row boundary
        LDA     plot_ship_at_ptr
        AND     #$07
        EOR     #$07
        STA     plot_ship_row_counter
        LDX     #$00
        JMP     plot_ship_ts_entry
}

\ ******************************************************************************
\ * Function: plot_ship_ts_loop / plot_ship_ts_entry
\ * Description: Two-stream ship sprite plot loop. Stream A provides screen
\ *              byte offsets (bit 7 = row advance, $FF = end). Stream B
\ *              provides pre-computed pixel mask bytes for XOR plotting.
\ *              Collision detection via self-modified AND/JMP at test site.
\ ******************************************************************************

.plot_ship_ts_loop
        INX

.plot_ship_ts_entry
    .ship_ts_stream_A_load
        LDY     $FFFF,X                             ; **SELF-MODIFIED CODE**
        ship_ts_stream_A_addr_LO = ship_ts_stream_A_load+1
        ship_ts_stream_A_addr_HI = ship_ts_stream_A_load+2
        BPL     plot_ship_ts_pixel

        ; Row advance or end of sprite
        CPY     #$FF
        BEQ     plot_ship_ts_done

        ; Advance to next pixel row
        DEC     plot_ship_row_counter
        BMI     plot_ship_ts_char_crossing

        INC     plot_ship_at_ptr
        TYA
        AND     #$7F
        TAY
        JMP     plot_ship_ts_pixel

    .plot_ship_ts_char_crossing
        LDA     #$07
        STA     plot_ship_row_counter
        CLC
        LDA     plot_ship_at_ptr
        ADC     #$39
        STA     plot_ship_at_ptr
        LDA     plot_ship_at_ptr+1
        ADC     #$02
        STA     plot_ship_at_ptr+1
        TYA
        AND     #$7F
        TAY

.plot_ship_ts_pixel
    .ship_ts_stream_B_load
        LDA     $FFFF,X                             ; **SELF-MODIFIED CODE**
        ship_ts_stream_B_addr_LO = ship_ts_stream_B_load+1
        ship_ts_stream_B_addr_HI = ship_ts_stream_B_load+2
        STA     ship_ts_mask_temp                   ; save full mask for collision test
    .ship_ts_colour_reduce
        AND     #$0F                                ; **SELF-MODIFIED CODE** ship=0F shield=FF
        ship_ts_colour_operand = ship_ts_colour_reduce+1
        EOR     (plot_ship_at_ptr),Y
        STA     (plot_ship_at_ptr),Y

    .ship_ts_collision_test                          ; **SELF-MODIFIED CODE**
        AND     ship_ts_mask_temp                   ; erase mode: test collision
        BEQ     plot_ship_ts_loop                   ; no collision: next pixel

        LDA     #$FF
        STA     plot_ship_collision_detected
        JMP     plot_ship_ts_loop

.plot_ship_ts_done
        RTS

SPRITES_SIZE    = P%-&8000
SPRITES_PAGES   = HI(SPRITES_SIZE+&FF)

PRINT "~~~~~~~~~~~~~~~~~"
PRINT "FAST SPRITES BANK"
PRINT "~~~~~~~~~~~~~~~~~"
PRINT "TOTAL SIZE=", ~SPRITES_SIZE, "bytes (", ~SPRITES_PAGES, " pages)"
PRINT "SPRITE BANK RAM BYTES FREE=", ~(&4000-SPRITES_SIZE)
PRINT "~~~~~~~~~~~~~~~~~"
SAVE "Sprites", &8000, P%, &8000, &8000
PRINT "~~~~~~~~~~~~~~~~~"

ENDIF ; _FAST_SPRITES
