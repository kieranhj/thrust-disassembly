\ * Modified level data. Potentially larger than original so requires SWRAM.
\ ******************************************************************************

INCLUDE "tools/output/thrust_levels_export2.asm"

\ ******************************************************************************
\ * Modified object sprite data. Potentially larger than original so requires SWRAM.
\ ******************************************************************************

INCLUDE "tools/output/object_sprites.asm"

