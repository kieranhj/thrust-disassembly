\ ******************************************************************************
\ ******************************************************************************

NATIVE_ADDR        = &A60        ; address at which code will run
LOAD_ADDR          = &1A00       ; address at which code will load
OFFSET             = LOAD_ADDR - NATIVE_ADDR  ; difference between load and run addresses

ORG     NATIVE_ADDR

.NATIVE_START

