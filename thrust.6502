force_vectory_INT                   = $0016     ; set to gravity_SIGN in ship_input_thrust_calculate_force
pod_sprite_plotted_flag             = $0017     ; set to 1 as plot_pod_sprite is called
ship_sprite_plotted_flag            = $0018     ; set to 1 when ship sprite has been plotted
level_tick_counter                  = $0019     ; increments every tick loop
vsync_count                         = $001A     ; increments every vsync event
tether_angle_LO                     = $001B     ; tether angle, extra precision low byte
tether_angle_FRAC                   = $001C     ; tether angle, fractional part (sub-angle for interpolation)
angle_ship_to_pod                   = $001D     ; tether angle, integer part (0-31 index into trig tables)
tether_angular_vel_LO               = $001E     ; tether angular velocity, extra precision low byte
